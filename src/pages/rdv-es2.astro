---
import GAConsentMode from '../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light only">
    <title>Réserve ton appel offert — Sonny Court</title>
    <meta name="description" content="Ton appel offert avec un coach après la masterclass : choisis simplement ton moment.">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"></noscript>

    <!-- Sélecteur d'indicatif téléphonique : même modèle que l'opt-in /masterclass -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@18.5.3/build/css/intlTelInput.css">
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.5.3/build/js/intlTelInput.min.js" defer></script>

    <style is:global>
        :root { color-scheme: light only; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f8fafc;
            color: #0f172a;
            line-height: 1.55;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }
        .rv-wrap { max-width: 560px; margin: 0 auto; padding: 28px 18px 140px; }
        .rv-brand { font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: .12em; color: #2563eb; margin-bottom: 18px; }
        .rv-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 18px; padding: 24px 22px; box-shadow: 0 2px 12px rgba(15,23,42,.05); }
        h1 { font-size: clamp(1.35rem, 5vw, 1.7rem); font-weight: 900; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 10px; }
        .rv-sub { font-size: 15px; color: #475569; }
        .rv-sub b { color: #0f172a; }

        .rv-spinner { width: 34px; height: 34px; border: 3px solid #e2e8f0; border-top-color: #2563eb; border-radius: 50%; margin: 60px auto; animation: rvspin .8s linear infinite; }
        @keyframes rvspin { to { transform: rotate(360deg); } }

        /* Bandeau coachs (photos ou initiales en attendant) */
        .rv-coachs { display: flex; align-items: center; gap: 14px; background: linear-gradient(135deg, #eff6ff, #f5f3ff); border: 1px solid #dbeafe; border-radius: 14px; padding: 14px 16px; margin-top: 16px; }
        .rv-coachs-avs { display: flex; flex: 0 0 auto; }
        .rv-av { position: relative; width: 54px; height: 54px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 21px; border: 3px solid #fff; box-shadow: 0 3px 10px rgba(15,23,42,.18); overflow: hidden; }
        .rv-av::before { content: attr(data-init); }
        .rv-av img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
        .rv-av + .rv-av { margin-left: -14px; }
        .rv-coachs-t b { display: block; font-size: 14.5px; color: #0f172a; }
        .rv-coachs-t small { font-size: 12.5px; color: #64748b; }

        .rv-current { display: flex; gap: 10px; align-items: flex-start; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 12px; padding: 12px 14px; margin: 16px 0 4px; font-size: 14px; color: #1e40af; }
        .rv-current b { color: #1d4ed8; }
        .rv-notice { background: #fffbeb; border: 1px solid #fde68a; border-radius: 12px; padding: 12px 14px; margin: 16px 0 4px; font-size: 14px; color: #92400e; }

        .rv-tz { font-size: 12.5px; color: #94a3b8; margin-top: 12px; }

        .rv-day { margin-top: 22px; }
        .rv-day-t { font-size: 13px; font-weight: 800; color: #0f172a; margin-bottom: 10px; }
        .rv-day-t::first-letter { text-transform: uppercase; }
        .rv-slots { display: grid; grid-template-columns: repeat(auto-fill, minmax(96px, 1fr)); gap: 8px; }
        .rv-slot { border: 1.5px solid #e2e8f0; background: #fff; border-radius: 10px; padding: 10px 4px; font: inherit; font-size: 14px; font-weight: 700; color: #334155; cursor: pointer; text-align: center; transition: border-color .1s ease, background .1s ease; }
        .rv-slot:hover { border-color: #93c5fd; }
        .rv-slot.sel { background: #2563eb; border-color: #2563eb; color: #fff; }

        .rv-confirm { position: fixed; left: 0; right: 0; bottom: 0; padding: 14px 18px calc(14px + env(safe-area-inset-bottom)); background: rgba(248,250,252,.92); backdrop-filter: blur(8px); border-top: 1px solid #e2e8f0; transform: translateY(110%); transition: transform .18s ease; }
        .rv-confirm.on { transform: translateY(0); }
        .rv-confirm-in { max-width: 560px; margin: 0 auto; }
        .rv-confirm-btn { width: 100%; border: 0; border-radius: 12px; background: #16a34a; color: #fff; font: inherit; font-size: 16px; font-weight: 800; padding: 15px 18px; cursor: pointer; }
        .rv-confirm-btn:hover { background: #15803d; }
        .rv-confirm-btn:disabled { opacity: .6; cursor: default; }

        .rv-msg { font-size: 14px; font-weight: 700; color: #dc2626; margin-top: 12px; min-height: 18px; }

        .rv-form { display: flex; flex-direction: column; gap: 10px; margin-top: 18px; }
        .rv-input { border: 1.5px solid #cbd5e1; border-radius: 12px; padding: 13px 14px; font: inherit; font-size: 16px; color: #0f172a; background: #fff; width: 100%; }
        .rv-input:focus { outline: none; border-color: #60a5fa; box-shadow: 0 0 0 3px rgba(59,130,246,.12); }
        .rv-tel-why { font-size: 12.5px; font-weight: 700; color: #475569; margin-bottom: 6px; }
        .rv-err { display: none; background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: 10px 12px; font-size: 13.5px; font-weight: 700; color: #dc2626; }
        .rv-err.on { display: block; }
        .rv-book-btn { border: 0; border-radius: 12px; background: #16a34a; color: #fff; font: inherit; font-size: 15px; font-weight: 800; padding: 14px 18px; cursor: pointer; }
        .rv-book-btn:hover { background: #15803d; }
        .rv-book-btn:disabled { opacity: .6; cursor: default; }
        .rv-note { font-size: 12px; color: #94a3b8; text-align: center; margin-top: 8px; }
        .rv-form .iti { width: 100%; }
        .rv-form .iti__selected-flag { background: #f1f5f9; border-right: 1.5px solid #cbd5e1; border-radius: 11px 0 0 11px; padding: 0 10px; }
        .rv-form .iti--separate-dial-code .iti__selected-dial-code { font-weight: 700; color: #0f172a; margin-left: 6px; }
        .iti--container, .iti__country-list { z-index: 10000001 !important; }

        /* Étape budget */
        .rv-budget-q { font-size: 16.5px; font-weight: 800; color: #0f172a; margin-top: 16px; }
        .rv-budget-opts { display: flex; flex-direction: column; gap: 10px; margin-top: 14px; }
        .rv-budget-opt { border: 1.5px solid #e2e8f0; background: #fff; border-radius: 14px; padding: 16px; font: inherit; font-size: 16px; font-weight: 800; color: #0f172a; cursor: pointer; text-align: left; display: flex; align-items: center; gap: 12px; transition: border-color .1s ease, background .1s ease; }
        .rv-budget-opt:hover { border-color: #93c5fd; background: #f8fafc; }
        .rv-budget-opt .ic { font-size: 20px; }
        .rv-budget-opt:disabled { opacity: .55; cursor: wait; }
        .rv-redirect { display: none; background: #f5f3ff; border: 1px solid #ddd6fe; border-radius: 12px; padding: 14px 16px; margin-top: 16px; font-size: 14.5px; font-weight: 700; color: #5b21b6; }
        .rv-redirect.on { display: block; }

        /* Étape replay */
        .rv-replay-btn { display: inline-flex; align-items: center; gap: 9px; margin-top: 18px; background: #dc2626; color: #fff; text-decoration: none; font-weight: 800; font-size: 15px; border-radius: 12px; padding: 14px 20px; }
        .rv-replay-btn:hover { background: #b91c1c; }

        .rv-done-ic { width: 58px; height: 58px; border-radius: 50%; background: #dcfce7; color: #16a34a; display: flex; align-items: center; justify-content: center; font-size: 28px; margin-bottom: 14px; }
        .rv-done-when { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 14px 16px; margin: 16px 0; font-size: 16px; font-weight: 800; color: #15803d; }
        .rv-done-when::first-letter { text-transform: uppercase; }
        .rv-done-note { font-size: 13.5px; color: #64748b; margin-top: 14px; }
        .rv-done-row { display: flex; align-items: center; gap: 13px; }
        .rv-done-row .rv-av { width: 58px; height: 58px; flex: 0 0 auto; }
        .rv-wa { display: inline-flex; align-items: center; gap: 7px; margin-top: 8px; background: #25d366; color: #fff; text-decoration: none; font-weight: 800; font-size: 14px; border-radius: 11px; padding: 10px 15px; }
        .rv-wa:hover { background: #1fb958; }

        .rv-info-ic { font-size: 34px; margin-bottom: 10px; }
        [hidden] { display: none !important; }
    </style>
</head>
<body>
    <div class="rv-wrap">
        <div class="rv-brand">Sonny Court</div>

        <div id="rv-loading"><div class="rv-spinner" aria-label="Chargement"></div></div>

        <!-- Étape 0 : identification (token masterclass auto, sinon email/téléphone) -->
        <div id="rv-ident" class="rv-card" hidden>
            <h1>Ton appel offert avec un coach</h1>
            <p class="rv-sub">Chaque participant à la masterclass bénéficie d'un <b>suivi offert</b> : 20 minutes en tête-à-tête avec un coach de l'équipe pour faire le point et repartir au clair.</p>
            <div class="rv-coachs">
                <div class="rv-coachs-avs">
                    <span class="rv-av" data-init="R"><img src="/media/coachs/romain.webp" alt="Romain" onerror="this.remove()"></span>
                    <span class="rv-av" data-init="V"><img src="/media/coachs/valentin.webp" alt="Valentin" onerror="this.remove()"></span>
                </div>
                <div class="rv-coachs-t">
                    <b>Romain &amp; Valentin, tes coachs</b>
                    <small>Ils t'aident à y voir clair, sans jargon et sans pression.</small>
                </div>
            </div>
            <form class="rv-form" id="rv-ident-form">
                <input class="rv-input" id="rv-f-email" type="email" inputmode="email" autocapitalize="none" spellcheck="false" placeholder="Ton email (celui de la masterclass)" autocomplete="email" required>
                <div id="rv-tel-row" hidden>
                    <p class="rv-tel-why" id="rv-tel-why"></p>
                    <input class="rv-input" id="rv-f-tel" type="tel" inputmode="tel" placeholder="Ton numéro de téléphone" autocomplete="tel" maxlength="30">
                </div>
                <p class="rv-err" id="rv-ident-err" role="alert"></p>
                <button type="submit" class="rv-book-btn" id="rv-ident-btn">Accéder au calendrier</button>
                <p class="rv-note">On retrouve automatiquement tes infos d'inscription.</p>
            </form>
        </div>

        <!-- Filtre 1 : replay pas (assez) vu -->
        <div id="rv-replay" class="rv-card" hidden>
            <div class="rv-info-ic">🎬</div>
            <h1 id="rv-replay-title">Regarde d'abord le replay</h1>
            <p class="rv-sub">Pour accéder à ton <b>coaching offert</b>, tu dois d'abord regarder le replay de la masterclass : ton coach s'appuie sur ce que tu y auras découvert.</p>
            <a class="rv-replay-btn" id="rv-replay-link" href="/masterclass/replay">▶&nbsp; Regarder le replay</a>
            <p class="rv-done-note">Une fois le replay vu, reviens sur cette page pour réserver ton appel.</p>
        </div>

        <!-- Filtre 2 : capacité d'investissement -->
        <div id="rv-budget" class="rv-card" hidden>
            <h1 id="rv-budget-title">Dernière étape avant le calendrier</h1>
            <p class="rv-budget-q">Quelle est ta capacité à investir dans ta transformation ?</p>
            <p class="rv-sub" style="margin-top:6px;">Sois franc(he) — ça nous permet de te proposer l'accompagnement adapté.</p>
            <div class="rv-budget-opts">
                <button type="button" class="rv-budget-opt" data-budget="500+"><span class="ic">🚀</span> Plus de 500 € par mois</button>
                <button type="button" class="rv-budget-opt" data-budget="200-500"><span class="ic">💪</span> 200 à 500 € par mois</button>
                <button type="button" class="rv-budget-opt" data-budget="&lt;200"><span class="ic">🌱</span> Moins de 200 € par mois</button>
            </div>
            <div class="rv-redirect" id="rv-redirect">Merci pour ta franchise 🙏 L'appel n'est pas adapté pour le moment — on t'emmène vers une offre qui peut te correspondre…</div>
            <p class="rv-err" id="rv-budget-err" role="alert"></p>
        </div>

        <div id="rv-info" class="rv-card" hidden>
            <div class="rv-info-ic" id="rv-info-ic">📞</div>
            <h1 id="rv-info-title"></h1>
            <p class="rv-sub" id="rv-info-sub"></p>
        </div>

        <div id="rv-book" hidden>
            <div class="rv-card">
                <h1 id="rv-title"></h1>
                <p class="rv-sub" id="rv-intro"></p>
                <div class="rv-coachs" id="rv-coachs">
                    <div class="rv-coachs-avs">
                        <span class="rv-av" data-init="R"><img src="/media/coachs/romain.webp" alt="Romain" onerror="this.remove()"></span>
                        <span class="rv-av" data-init="V"><img src="/media/coachs/valentin.webp" alt="Valentin" onerror="this.remove()"></span>
                    </div>
                    <div class="rv-coachs-t">
                        <b>Romain &amp; Valentin, tes coachs</b>
                        <small>Ils t'aident à y voir clair, sans jargon et sans pression.</small>
                    </div>
                </div>
                <div class="rv-current" id="rv-current" hidden></div>
                <div class="rv-notice" id="rv-notice" hidden></div>
                <div class="rv-form" id="rv-book-telrow" hidden style="margin-top:14px;">
                    <p class="rv-tel-why">Le numéro sur lequel ton coach t'appellera :</p>
                    <input class="rv-input" id="rv-book-tel" type="tel" inputmode="tel" placeholder="Ton numéro de téléphone" autocomplete="tel" maxlength="30">
                </div>
                <div id="rv-days"></div>
                <p class="rv-tz" id="rv-tz" hidden></p>
                <p class="rv-msg" id="rv-msg"></p>
            </div>
        </div>

        <div id="rv-done" class="rv-card" hidden>
            <div class="rv-done-ic">✓</div>
            <h1 id="rv-done-title">C'est noté !</h1>
            <div class="rv-done-when" id="rv-done-when"></div>
            <div class="rv-done-row">
                <span id="rv-done-av" hidden></span>
                <p class="rv-sub" id="rv-done-sub"></p>
            </div>
            <p class="rv-done-note" id="rv-done-note">Un empêchement ? Reviens sur cette page pour déplacer ton rendez-vous.</p>
        </div>
    </div>

    <div class="rv-confirm" id="rv-confirm">
        <div class="rv-confirm-in">
            <button type="button" class="rv-confirm-btn" id="rv-confirm-btn"></button>
        </div>
    </div>

    <script is:inline>
    (function () {
        var EP = '/.netlify/functions/rdv-es2';
        var qs = new URLSearchParams(location.search);

        var fmtDay = new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
        var fmtTime = new Intl.DateTimeFormat('fr-FR', { hour: '2-digit', minute: '2-digit' });
        var fmtFull = new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' });

        var SLOTS = {};
        var SELECTED = null;
        var LAST = null;   // dernière réponse identify (contexte calendrier)
        var IDENT = null;  // { t } ou { email, telephone } : identité validée côté serveur

        function el(id) { return document.getElementById(id); }
        function esc(s) { return (s == null ? '' : String(s)).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }
        function show(id) {
            ['rv-loading', 'rv-ident', 'rv-replay', 'rv-budget', 'rv-info', 'rv-book', 'rv-done'].forEach(function (v) { el(v).hidden = v !== id; });
            if (id !== 'rv-book') setConfirm(false);
        }
        function setConfirm(on, label) {
            var bar = el('rv-confirm');
            if (on) { el('rv-confirm-btn').textContent = label; bar.classList.add('on'); }
            else bar.classList.remove('on');
        }
        function info(icon, title, sub) {
            el('rv-info-ic').textContent = icon;
            el('rv-info-title').textContent = title;
            el('rv-info-sub').innerHTML = sub;
            show('rv-info');
        }
        function errBox(id, msg) {
            var e = el(id);
            if (msg) { e.textContent = msg; e.classList.add('on'); }
            else { e.textContent = ''; e.classList.remove('on'); }
        }
        var COACH_WHATSAPP = { romain: '+33 6 00 00 00 00', valentin: '+33 6 00 00 00 00' };
        function coachSlug(name) {
            return (name || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]/g, '');
        }
        function coachAv(name) {
            var init = esc((name || '?').charAt(0).toUpperCase());
            var slug = coachSlug(name);
            return '<span class="rv-av" data-init="' + init + '">' + (slug ? '<img src="/media/coachs/' + slug + '.webp" alt="' + esc(name) + '" onerror="this.remove()">' : '') + '</span>';
        }

        // Téléphone avec indicatifs (même modèle que l'opt-in /masterclass)
        function makeTelInput(inputEl) {
            if (typeof intlTelInput === 'undefined') return null;
            return intlTelInput(inputEl, {
                initialCountry: 'auto',
                geoIpLookup: function (callback) {
                    fetch('https://ipapi.co/json/')
                        .then(function (res) { return res.json(); })
                        .then(function (data) { callback((data.country_code || 'fr').toLowerCase()); })
                        .catch(function () { callback('fr'); });
                },
                preferredCountries: ['fr', 'be', 'ch', 'ca', 'ma', 'sn'],
                separateDialCode: true,
                dropdownContainer: document.body,
                utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@18.5.3/build/js/utils.js',
            });
        }
        var itiIdent = null, itiBook = null;
        function telValue(iti, inputEl) {
            var v = inputEl.value.trim();
            if (iti) { try { v = iti.getNumber() || v; } catch (e) {} }
            return v;
        }

        function identityPayload() {
            var p = {};
            if (IDENT && IDENT.t) p.t = IDENT.t;
            if (IDENT && IDENT.email) p.email = IDENT.email;
            if (IDENT && IDENT.telephone) p.telephone = IDENT.telephone;
            return p;
        }
        async function api(action, extra) {
            var payload = Object.assign({ action: action }, identityPayload(), extra || {});
            var r = await fetch(EP, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });
            var d = await r.json().catch(function () { return {}; });
            return { r: r, d: d };
        }

        function renderSlots(slots) {
            SLOTS = {}; SELECTED = null;
            var groups = [], byKey = {};
            (slots || []).forEach(function (s) {
                var key = s.start;
                SLOTS[key] = s;
                var day = fmtDay.format(new Date(s.start));
                if (!byKey[day]) { byKey[day] = []; groups.push(day); }
                byKey[day].push({ key: key, start: s.start });
            });
            el('rv-days').innerHTML = groups.map(function (day) {
                return '<div class="rv-day"><div class="rv-day-t">' + esc(day) + '</div><div class="rv-slots">' +
                    byKey[day].map(function (s) {
                        return '<button type="button" class="rv-slot" data-key="' + esc(s.key) + '">' + esc(fmtTime.format(new Date(s.start))) + '</button>';
                    }).join('') + '</div></div>';
            }).join('');

            var tz = '';
            try { tz = Intl.DateTimeFormat().resolvedOptions().timeZone || ''; } catch (e) {}
            var tzEl = el('rv-tz');
            if (tz && tz !== 'Europe/Paris') { tzEl.textContent = 'Heures affichées dans ton fuseau horaire (' + tz + ').'; tzEl.hidden = false; }
            else tzEl.hidden = true;
        }

        function showCalendar(d) {
            LAST = d;
            if (!Array.isArray(d.slots) || !d.slots.length) {
                info('📞', 'Merci' + (d.prenom ? ' ' + esc(d.prenom) : '') + ' !', 'Il n\'y a plus de créneau en ligne pour le moment.' + (d.closer ? ' Ton coach <b>' + esc(d.closer) + '</b> te contactera directement par téléphone.' : ' On te contactera directement par téléphone.'));
                return;
            }
            if (d.assigned && d.closer) {
                el('rv-coachs').innerHTML = '<div class="rv-coachs-avs">' + coachAv(d.closer) + '</div>' +
                    '<div class="rv-coachs-t"><b>' + esc(d.closer) + ', ton coach</b><small>Il t\'aide à y voir clair, sans jargon et sans pression.</small></div>';
                el('rv-title').textContent = 'Réserve ton appel avec ' + d.closer;
                el('rv-intro').innerHTML = 'Choisis le créneau qui t\'arrange : <b>' + esc(d.closer) + '</b> t\'appellera sur ' + (d.phone_hint ? 'ton numéro finissant par <b>&bull;&bull;' + esc(d.phone_hint) + '</b>' : 'ton numéro') + '. L\'appel dure environ 20 minutes.';
            } else {
                el('rv-title').textContent = (d.prenom ? esc(d.prenom) + ', c' : 'C') + 'hoisis ton moment';
                el('rv-intro').innerHTML = 'Un coach de l\'équipe t\'appellera sur ' + (d.phone_hint ? 'ton numéro finissant par <b>&bull;&bull;' + esc(d.phone_hint) + '</b>' : 'ton numéro') + '. L\'appel dure environ 20 minutes. <b>Choisis simplement ton moment.</b>';
            }
            var cur = el('rv-current');
            if (d.current) {
                cur.innerHTML = '<span>📅</span><span>Ton RDV actuel : <b>' + esc(fmtFull.format(new Date(d.current))) + '</b>.<br>Choisis un autre créneau ci-dessous pour le déplacer.</span>';
                cur.hidden = false;
            } else cur.hidden = true;

            // Numéro manquant en base : on le demande une bonne fois ici.
            var needTel = !LAST.phone_known && !(IDENT && IDENT.telephone);
            el('rv-book-telrow').hidden = !needTel;
            if (needTel && !itiBook) itiBook = makeTelInput(el('rv-book-tel'));

            el('rv-notice').hidden = true;
            renderSlots(d.slots);
            el('rv-msg').textContent = '';
            show('rv-book');
        }

        // Après identification réussie : budget d'abord si pas encore déclaré assez haut.
        function afterIdentify(d) {
            LAST = d;
            if (d.need_budget) {
                el('rv-budget-title').textContent = (d.prenom ? esc(d.prenom) + ', d' : 'D') + 'ernière étape avant le calendrier';
                show('rv-budget');
            } else {
                showCalendar(d);
            }
        }

        function routeMode(d) {
            if (d.mode === 'purchased') {
                info('🎉', 'Tu fais déjà partie du programme' + (d.prenom ? ', ' + esc(d.prenom) : '') + ' !', 'Pas besoin de rendez-vous : ton accès t\'attend dans tes emails. À tout de suite à l\'intérieur.');
                return true;
            }
            if (d.mode === 'replay') {
                el('rv-replay-title').textContent = (d.prenom ? esc(d.prenom) + ', r' : 'R') + 'egarde d\'abord le replay';
                if (d.replay_url) el('rv-replay-link').setAttribute('href', d.replay_url);
                show('rv-replay');
                return true;
            }
            return false;
        }

        // ---- Identification ----
        async function identify(payloadIdent, opts) {
            try {
                var res = await fetch(EP, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.assign({ action: 'identify' }, payloadIdent)),
                });
                var d = await res.json().catch(function () { return {}; });
                if (res.ok && (d.mode === 'ok' || d.mode === 'purchased' || d.mode === 'replay')) {
                    IDENT = payloadIdent;
                    try { if (d.token) localStorage.setItem('masterclass_es2_token', d.token); } catch (e) {}
                    if (!routeMode(d)) afterIdentify(d);
                    return true;
                }
                if (opts && opts.silent) return false;
                if (res.status === 404) {
                    errBox('rv-ident-err', (d && d.error) || "On ne trouve pas ton inscription. Utilise l'email avec lequel tu t'es inscrit(e) à la masterclass.");
                    el('rv-tel-row').hidden = false;
                    el('rv-tel-why').textContent = "Ou identifie-toi avec le numéro donné à l'inscription :";
                    if (!itiIdent) itiIdent = makeTelInput(el('rv-f-tel'));
                } else {
                    errBox('rv-ident-err', (d && d.error) || 'Erreur, réessaie.');
                }
                return false;
            } catch (e) {
                if (!(opts && opts.silent)) errBox('rv-ident-err', 'Erreur réseau. Vérifie ta connexion et réessaie.');
                return false;
            }
        }

        el('rv-ident-form').addEventListener('submit', async function (e) {
            e.preventDefault();
            errBox('rv-ident-err', '');
            var email = el('rv-f-email').value.trim().toLowerCase();
            var tel = el('rv-tel-row').hidden ? '' : telValue(itiIdent, el('rv-f-tel'));
            if (!email && !tel) { errBox('rv-ident-err', 'Entre ton email.'); return; }
            var btn = el('rv-ident-btn');
            btn.disabled = true; btn.textContent = 'Vérification…';
            var payload = {};
            if (email) payload.email = email;
            if (tel) payload.telephone = tel;
            await identify(payload);
            btn.disabled = false; btn.textContent = 'Accéder au calendrier';
        });

        // ---- Budget ----
        el('rv-budget').addEventListener('click', async function (e) {
            var b = e.target.closest('.rv-budget-opt');
            if (!b) return;
            var budget = b.getAttribute('data-budget');
            errBox('rv-budget-err', '');
            document.querySelectorAll('.rv-budget-opt').forEach(function (x) { x.disabled = true; });
            try {
                var res = await api('budget', { budget: budget });
                if (res.r.ok && res.d.ok) {
                    if (res.d.redirect) {
                        el('rv-redirect').classList.add('on');
                        setTimeout(function () { location.href = res.d.redirect; }, 2800);
                        return;
                    }
                    showCalendar(LAST);
                    return;
                }
                errBox('rv-budget-err', (res.d && res.d.error) || 'Erreur, réessaie.');
            } catch (err) {
                errBox('rv-budget-err', 'Erreur réseau. Vérifie ta connexion et réessaie.');
            }
            document.querySelectorAll('.rv-budget-opt').forEach(function (x) { x.disabled = false; });
        });

        // ---- Calendrier + réservation ----
        el('rv-days').addEventListener('click', function (e) {
            var b = e.target.closest('.rv-slot');
            if (!b) return;
            SELECTED = b.getAttribute('data-key');
            document.querySelectorAll('.rv-slot.sel').forEach(function (x) { x.classList.remove('sel'); });
            b.classList.add('sel');
            setConfirm(true, 'Confirmer · ' + fmtFull.format(new Date(SLOTS[SELECTED].start)));
        });

        function showDone(d) {
            el('rv-done-when').textContent = fmtFull.format(new Date(d.at));
            el('rv-done-title').textContent = 'C\'est noté' + (d.prenom ? ' ' + esc(d.prenom) : '') + ' !';
            var closer = d.closer || '';
            var hint = d.phone_hint || '';
            var av = el('rv-done-av');
            if (closer) { av.innerHTML = coachAv(closer); av.hidden = false; } else { av.hidden = true; }
            el('rv-done-sub').innerHTML = (closer ? 'Ton coach <b>' + esc(closer) + '</b>' : 'Ton coach') + ' t\'appellera sur ' + (hint ? 'ton numéro finissant par <b>&bull;&bull;' + esc(hint) + '</b>' : 'le numéro que tu as donné') + '. Garde ton téléphone à portée de main.';
            var wa = d.closer_phone || COACH_WHATSAPP[coachSlug(closer)];
            el('rv-done-note').innerHTML = wa
                ? 'Un empêchement ou une question ? Écris directement à ' + esc(closer) + ' :<br><a class="rv-wa" href="https://wa.me/' + wa.replace(/\D/g, '') + '" target="_blank" rel="noopener noreferrer">&#128172; WhatsApp ' + esc(closer) + ' &middot; ' + esc(wa) + '</a>'
                : 'Un empêchement ? Reviens sur cette page pour déplacer ton rendez-vous.';
            show('rv-done');
        }

        el('rv-confirm-btn').addEventListener('click', async function () {
            var s = SLOTS[SELECTED];
            if (!s) return;
            var extra = { start: s.start };
            if (!el('rv-book-telrow').hidden) {
                var tel = telValue(itiBook, el('rv-book-tel'));
                if (!tel) { el('rv-msg').textContent = 'Entre ton numéro pour être appelé(e).'; return; }
                if (itiBook && typeof itiBook.isValidNumber === 'function' && !itiBook.isValidNumber()) {
                    el('rv-msg').textContent = 'Ce numéro de téléphone ne semble pas valide. Vérifie le format et réessaie.';
                    return;
                }
                extra.telephone = tel;
            }
            var btn = this;
            btn.disabled = true; btn.textContent = 'Réservation…';
            el('rv-msg').textContent = '';
            try {
                var res = await api('book', extra);
                var d = res.d || {};
                if (res.r.ok && d.ok) { showDone(d); }
                else if (routeMode(d)) { /* purchased / replay */ }
                else if (res.r.status === 409) {
                    var n = el('rv-notice');
                    n.innerHTML = esc(d.error || 'Ce créneau n\'est plus disponible. Choisis-en un autre ci-dessous.');
                    n.hidden = false;
                    renderSlots(Array.isArray(d.slots) ? d.slots : []);
                    setConfirm(false);
                    if (!(d.slots || []).length) info('📞', 'Merci !', 'Il n\'y a plus de créneau en ligne pour le moment. On te contactera directement par téléphone.');
                } else if (res.r.status === 400 && d.code === 'phone_required') {
                    el('rv-book-telrow').hidden = false;
                    if (!itiBook) itiBook = makeTelInput(el('rv-book-tel'));
                    el('rv-msg').textContent = d.error || 'Entre ton numéro pour être appelé(e).';
                } else if (res.r.status === 400 && d.code === 'budget_required') {
                    show('rv-budget');
                } else {
                    el('rv-msg').textContent = d.error || 'Erreur, réessaie.';
                }
            } catch (err) {
                el('rv-msg').textContent = 'Erreur réseau. Vérifie ta connexion et réessaie.';
            }
            btn.disabled = false;
            if (SELECTED && SLOTS[SELECTED]) btn.textContent = 'Confirmer · ' + fmtFull.format(new Date(SLOTS[SELECTED].start));
        });

        // ---- Boot : token URL, sinon token masterclass en localStorage, sinon formulaire ----
        (async function boot() {
            show('rv-loading');
            var t = (qs.get('t') || qs.get('token') || '').trim();
            var stored = '';
            try { stored = (localStorage.getItem('masterclass_es2_token') || '').trim(); } catch (e) {}
            if (t && (await identify({ t: t }, { silent: true }))) return;
            if (stored && (await identify({ t: stored }, { silent: true }))) return;
            show('rv-ident');
        })();
    })();
    </script>
</body>
</html>
