    <script is:inline>
        (function () {
            var SESSION = '/.netlify/functions/admin-es2-session';
            var LOGIN = '/.netlify/functions/admin-es2-login';
            var LOGOUT = '/.netlify/functions/admin-es2-logout';
            var API = '/.netlify/functions/closer-admin';

            var boot = document.getElementById('boot');
            var loginView = document.getElementById('login-view');
            var adminView = document.getElementById('admin-view');

            var dtf = new Intl.DateTimeFormat('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
            function fmtDate(iso) {
                if (!iso) return '—';
                try { return dtf.format(new Date(iso)); } catch (e) { return '—'; }
            }
            function esc(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
                });
            }

            function showView(which) {
                boot.hidden = which !== 'boot';
                loginView.hidden = which !== 'login';
                adminView.hidden = which !== 'admin';
            }

            // --- Copie presse-papier ---
            function copyText(text, btnEl) {
                function ok() {
                    if (!btnEl) return;
                    btnEl.classList.add('copied');
                    setTimeout(function () { btnEl.classList.remove('copied'); }, 1400);
                }
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(ok).catch(function () { fallback(text); ok(); });
                } else { fallback(text); ok(); }
            }
            function fallback(text) {
                var ta = document.createElement('textarea');
                ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
                document.body.appendChild(ta); ta.select();
                try { document.execCommand('copy'); } catch (e) { /* noop */ }
                document.body.removeChild(ta);
            }

            // --- Rendu de la liste ---
            var codesAll = [];
            var STATS = {};
            var GLOBAL = null;
            var RECREDIT = [];
            var SESSION_DATE = '2026-07-02';
            var SESSIONS = [];

            var dfDay = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
            function frDate(d) { try { return dfDay.format(new Date(d + 'T12:00:00')); } catch (e) { return d; } }
            function pct(n, d) { return d > 0 ? Math.round((n / d) * 100) + '%' : '—'; }

            async function loadSessions() {
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'sessions' }),
                    });
                    var d = r.ok ? await r.json() : {};
                    SESSIONS = (d.sessions && d.sessions.length) ? d.sessions : [{ date: SESSION_DATE, count: 0 }];
                } catch (e) { SESSIONS = [{ date: SESSION_DATE, count: 0 }]; }
                if (!SESSION_DATE || !SESSIONS.some(function (s) { return s.date === SESSION_DATE; })) {
                    SESSION_DATE = SESSIONS[0].date;
                }
                var sel = document.getElementById('session-select');
                sel.innerHTML = SESSIONS.map(function (s) {
                    return '<option value="' + s.date + '"' + (s.date === SESSION_DATE ? ' selected' : '') +
                        '>' + frDate(s.date) + ' · ' + s.count + ' inscrits</option>';
                }).join('');
                updateSessionMeta();
                loadStats();
            }

            function updateSessionMeta() {
                var s = SESSIONS.find(function (x) { return x.date === SESSION_DATE; });
                document.getElementById('session-meta').textContent = s ? (s.count + ' inscrits pays riches') : '';
                var lab = document.getElementById('assign-session-label');
                if (lab) lab.textContent = frDate(SESSION_DATE);
            }

            function renderGlobalKpis() {
                var host = document.getElementById('kpi-global');
                if (!host) return;
                var g = GLOBAL || { leads: 0, calls: 0, contacted: 0, a_traiter: 0, rappels: 0, oui: 0, ventes: 0 };
                function kpi(v, l, cls) {
                    return '<div class="kpi ' + (cls || '') + '"><div class="kpi-v">' + v + '</div><div class="kpi-l">' + l + '</div></div>';
                }
                host.innerHTML =
                    kpi(g.leads, 'Leads assignés', '') +
                    kpi(g.contacted + ' / ' + g.a_traiter, 'Contactés / à traiter', 'kpi-blue') +
                    kpi(g.rappels, 'À rappeler', 'kpi-amber') +
                    kpi(g.oui, 'Dits oui', '') +
                    kpi(g.ventes, 'Ventes créditées', 'kpi-green') +
                    kpi(pct(g.ventes, g.leads), 'Taux de transfo', 'kpi-green');
            }

            function renderRecredit() {
                var box = document.getElementById('recredit-box');
                if (!box) return;
                var list = RECREDIT || [];
                var seuls = GLOBAL ? (GLOBAL.achats_seuls || 0) : 0;
                if (!list.length && !seuls) { box.hidden = true; box.innerHTML = ''; return; }
                box.hidden = false;
                var rows = list.map(function (x) {
                    return '<div class="recredit-row"><b>' + esc(x.prenom) + '</b>' +
                        '<span class="rc-closer">' + esc(closerName(x.closer_id)) + '</span>' +
                        '<span>acheté ' + fmtDate(x.purchased_at) + '</span>' +
                        '<span>appel ' + fmtDate(x.last_contact_at) + '</span></div>';
                }).join('');
                box.innerHTML =
                    '<div class="recredit-h">&#128176; ' + list.length + ' vente(s) à vérifier / recréditer dans Spiffy' +
                        (seuls ? ' <span class="rc-seuls">· ' + seuls + ' achat(s) spontané(s) non crédité(s)</span>' : '') + '</div>' +
                    '<div class="recredit-sub">Le closer a parlé au prospect AVANT l\'achat (achat via la page invitation). Vérifie et recrédite dans Spiffy si ce n\'est pas déjà passé par son lien perso.</div>' +
                    (list.length ? '<div class="recredit-list">' + rows + '</div>' : '');
            }

            async function loadStats() {
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'stats', session_date: SESSION_DATE }),
                    });
                    if (!r.ok) return;
                    var d = await r.json();
                    STATS = d.stats || {};
                    GLOBAL = d.global || null;
                    RECREDIT = d.recredit || [];
                    renderGlobalKpis();
                    renderRecredit();
                    splitRender();
                } catch (e) { /* noop */ }
            }

            // Un closer = ligne AVEC email ; un code de recrutement = ligne SANS email.
            function splitRender() {
                renderList(
                    codesAll.filter(function (c) { return !c.email; }),
                    { host: 'codes', empty: 'codes-empty', mode: 'recruit',
                      sumTotal: 'sum-total', sumCame: 'sum-came', sumNot: 'sum-not' }
                );
                renderList(
                    orderClosers(codesAll.filter(function (c) { return c.email; })),
                    { host: 'closers', empty: 'closers-empty', mode: 'closer',
                      sumTotal: 'sum-cl-total', sumCame: 'sum-cl-conn', sumNot: 'sum-cl-not' }
                );
            }

            // --- Ordre personnalisé des cartes closers (localStorage, jamais en base) ---
            function orderClosers(list) {
                var saved = [];
                try { saved = JSON.parse(localStorage.getItem('closer_card_order') || '[]'); } catch (e) {}
                if (!saved.length) return list;
                var pos = {};
                saved.forEach(function (id, i) { pos[String(id)] = i; });
                return list.slice().sort(function (a, b) {
                    var pa = pos[String(a.id)], pb = pos[String(b.id)];
                    if (pa == null && pb == null) return 0;
                    if (pa == null) return 1;   // nouveaux closers : à la fin
                    if (pb == null) return -1;
                    return pa - pb;
                });
            }
            function saveCardOrder(host) {
                var ids = Array.prototype.map.call(host.querySelectorAll('.code-card'), function (el) {
                    return el.getAttribute('data-id');
                });
                try { localStorage.setItem('closer_card_order', JSON.stringify(ids)); } catch (e) {}
            }
            function bindCardDrag(host) {
                host.querySelectorAll('.js-drag').forEach(function (g) {
                    g.addEventListener('dragstart', function (e) {
                        var card = g.closest('.code-card');
                        host.__dragged = card;
                        card.classList.add('is-dragging');
                        try { e.dataTransfer.setData('text/plain', ''); e.dataTransfer.effectAllowed = 'move'; } catch (_) {}
                    });
                    g.addEventListener('dragend', function () {
                        if (host.__dragged) {
                            host.__dragged.classList.remove('is-dragging');
                            host.__dragged = null;
                            saveCardOrder(host);
                        }
                    });
                });
                if (host.__dndBound) return; // listeners du conteneur : une seule fois
                host.__dndBound = true;
                host.addEventListener('dragover', function (e) {
                    var dragged = host.__dragged;
                    if (!dragged) return;
                    e.preventDefault();
                    var over = e.target.closest('.code-card');
                    if (!over || over === dragged) return;
                    var r = over.getBoundingClientRect();
                    var before = e.clientY < r.top + r.height / 2;
                    host.insertBefore(dragged, before ? over : over.nextSibling);
                });
                host.addEventListener('drop', function (e) { e.preventDefault(); });
            }

            function cardHtml(c, mode) {
                var visited = (c.visit_count > 0) || !!c.first_visit_at;
                var revoked = c.active === false;
                var st = STATS[c.id] || {};
                var badge = revoked
                    ? '<span class="badge badge-revoked">Révoqué</span>'
                    : (mode === 'closer'
                        ? (visited ? '<span class="badge badge-came">Connecté</span>' : '<span class="badge badge-not">Jamais connecté</span>')
                        : (visited ? '<span class="badge badge-came">Venu</span>' : '<span class="badge badge-not">Pas venu</span>'));
                var action = revoked
                    ? '<button class="btn btn-ghost btn-sm js-toggle" data-id="' + c.id + '" data-active="true">Réactiver</button>'
                    : '<button class="btn btn-ghost btn-sm js-toggle" data-id="' + c.id + '" data-active="false">Révoquer</button>';
                // Pastille code : seulement pour les codes de recrutement
                var chip = mode === 'closer' ? '' :
                    '<span class="code-chip">' + esc(c.code) +
                        '<button class="copy-btn js-copy" data-code="' + esc(c.code) + '" title="Copier" aria-label="Copier">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>' +
                        '</button>' +
                    '</span>';
                // Métadonnées : closer (email/connexions) vs recrutement (visites)
                var meta = mode === 'closer'
                    ? '<span class="meta-item"><span class="meta-k">Email :</span> <b>' + esc(c.email || '—') + '</b></span>' +
                      '<span class="meta-item"><span class="meta-k">1ʳᵉ connexion :</span> <b>' + fmtDate(c.first_visit_at) + '</b></span>' +
                      '<span class="meta-item"><span class="meta-k">Dernière :</span> <b>' + fmtDate(c.last_visit_at) + '</b></span>' +
                      '<span class="meta-item"><span class="meta-k">Connexions :</span> <b>' + (c.visit_count || 0) + '</b></span>' +
                      ((c.phone_1 || c.phone_2) ? '<span class="meta-item"><span class="meta-k">Tél :</span> <b>' + esc([c.phone_1, c.phone_2].filter(Boolean).join(' · ')) + '</b></span>' : '') +
                      '<span class="meta-item"><span class="meta-k">Liens :</span> <b>' + ((c.checkout_full_url ? 1 : 0) + (c.checkout_discount_url ? 1 : 0)) + '/2</b></span>'
                    : '<span class="meta-item"><span class="meta-k">1ʳᵉ visite :</span> <b>' + fmtDate(c.first_visit_at) + '</b></span>' +
                      '<span class="meta-item"><span class="meta-k">Dernière :</span> <b>' + fmtDate(c.last_visit_at) + '</b></span>' +
                      '<span class="meta-item"><span class="meta-k">Visites :</span> <b>' + (c.visit_count || 0) + '</b></span>' +
                      '<span class="meta-item"><span class="meta-k">Confidentialité :</span> <b>' + (c.consent_at ? 'acceptée ' + fmtDate(c.consent_at) : '—') + '</b></span>';
                // Stats de perf : closer uniquement
                var stats = mode === 'closer'
                    ? '<div class="code-stats">' +
                        '<span class="cs"><b>' + (st.leads || 0) + '</b>leads</span>' +
                        '<span class="cs"><b>' + (st.calls || 0) + '</b>appels</span>' +
                        '<span class="cs"><b>' + (st.contacted || 0) + '</b>contactés</span>' +
                        '<span class="cs"><b>' + (st.rappels || 0) + '</b>à rappeler</span>' +
                        '<span class="cs"><b>' + (st.oui || 0) + '</b>dits oui</span>' +
                        '<span class="cs cs-green"><b>' + (st.ventes || 0) + '</b>ventes</span>' +
                        ((st.achats_seuls || 0) > 0 ? '<span class="cs cs-grey"><b>' + st.achats_seuls + '</b>achetés seuls</span>' : '') +
                        '<span class="cs"><b>' + pct(st.ventes || 0, st.leads || 0) + '</b>transfo</span>' +
                      '</div>'
                    : '';
                // Éditeur d'identifiants : closer uniquement
                var creds = mode === 'closer'
                    ? '<div class="code-creds" data-id="' + c.id + '">' +
                        '<button class="code-notes-btn js-cred-edit" data-id="' + c.id + '" type="button">&#128273; Modifier identifiants &amp; coordonnées</button>' +
                        '<div class="code-creds-edit" hidden>' +
                            '<div class="cred-grp-t">Connexion</div>' +
                            '<input class="js-cred-email" type="email" placeholder="Email de connexion" value="' + esc(c.email || '') + '">' +
                            '<input class="js-cred-pass" type="text" placeholder="Nouveau mot de passe (vide = inchangé)">' +
                            '<div class="cred-grp-t">Affiché au closer · téléphones</div>' +
                            '<input class="js-cred-p1" type="text" placeholder="Téléphone 1" value="' + esc(c.phone_1 || '') + '">' +
                            '<input class="js-cred-p2" type="text" placeholder="Téléphone 2" value="' + esc(c.phone_2 || '') + '">' +
                            '<div class="cred-grp-t">Affiché au closer · liens checkout</div>' +
                            '<input class="js-cred-cf" type="text" placeholder="Lien tarif complet (prospect)" value="' + esc(c.checkout_full_url || '') + '">' +
                            '<input class="js-cred-cd" type="text" placeholder="Lien checkout -5%" value="' + esc(c.checkout_discount_url || '') + '">' +
                            '<div class="code-notes-edit-actions">' +
                                '<button class="btn btn-sm js-cred-save" data-id="' + c.id + '" type="button">Enregistrer</button>' +
                                '<button class="btn btn-ghost btn-sm js-cred-cancel" type="button">Annuler</button>' +
                            '</div>' +
                            '<p class="js-cred-msg err"></p>' +
                        '</div>' +
                      '</div>'
                    : '';
                return '' +
                    '<div class="code-card' + (revoked ? ' is-revoked' : '') + '" data-id="' + c.id + '">' +
                        '<div class="code-top">' +
                            (mode === 'closer' ? '<span class="drag-grip js-drag" draggable="true" title="Glisser pour réordonner">&#x283F;</span>' : '') +
                            '<div class="code-name">' + esc(c.label) + ' ' + badge + '</div>' +
                            '<div class="code-actions">' + chip + action +
                                '<button class="code-del js-delete" data-id="' + c.id + '" title="Supprimer" aria-label="Supprimer">' +
                                    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>' +
                                '</button>' +
                            '</div>' +
                        '</div>' +
                        '<div class="code-meta">' + meta + '</div>' +
                        stats +
                        '<div class="code-notes" data-id="' + c.id + '">' +
                            '<div class="code-notes-view">' +
                                '<span class="code-notes-text">' + (c.notes ? linkifyText(c.notes) : '<span class="code-notes-empty">Aucune info</span>') + '</span>' +
                                '<button class="code-notes-btn js-note-edit" data-id="' + c.id + '" type="button">' + (c.notes ? 'Modifier' : '+ Ajouter une info') + '</button>' +
                            '</div>' +
                            '<div class="code-notes-edit" hidden>' +
                                '<textarea class="js-note-input" rows="2" placeholder="Lien profil, source, remarque…">' + esc(c.notes || '') + '</textarea>' +
                                '<div class="code-notes-edit-actions">' +
                                    '<button class="btn btn-sm js-note-save" data-id="' + c.id + '" type="button">Enregistrer</button>' +
                                    '<button class="btn btn-ghost btn-sm js-note-cancel" type="button">Annuler</button>' +
                                '</div>' +
                            '</div>' +
                        '</div>' +
                        creds +
                    '</div>';
            }

            function renderList(list, opts) {
                var host = document.getElementById(opts.host);
                var empty = document.getElementById(opts.empty);
                var came = 0, not = 0;
                list.forEach(function (c) {
                    var visited = (c.visit_count > 0) || !!c.first_visit_at;
                    if (visited) came++; else not++;
                });
                document.getElementById(opts.sumTotal).textContent = list.length;
                document.getElementById(opts.sumCame).textContent = came;
                document.getElementById(opts.sumNot).textContent = not;

                if (!list.length) { host.innerHTML = ''; empty.hidden = false; return; }
                empty.hidden = true;
                host.innerHTML = list.map(function (c) { return cardHtml(c, opts.mode); }).join('');
                attachCardHandlers(host);
                if (opts.mode === 'closer') bindCardDrag(host);
            }

            function attachCardHandlers(host) {
                host.querySelectorAll('.js-copy').forEach(function (b) {
                    b.addEventListener('click', function () { copyText(b.getAttribute('data-code'), b); });
                });
                host.querySelectorAll('.js-toggle').forEach(function (b) {
                    b.addEventListener('click', function () { toggleCode(+b.getAttribute('data-id'), b.getAttribute('data-active') === 'true'); });
                });
                host.querySelectorAll('.js-delete').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var id = +b.getAttribute('data-id');
                        var c = codesAll.find(function (x) { return x.id === id; });
                        var name = c ? c.label : '';
                        if (window.confirm('Supprimer définitivement « ' + name + ' » ?\n\nLes candidatures déjà reçues sont conservées.')) {
                            deleteCode(id);
                        }
                    });
                });
                host.querySelectorAll('.js-note-edit').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        box.querySelector('.code-notes-view').hidden = true;
                        box.querySelector('.code-notes-edit').hidden = false;
                        box.querySelector('.js-note-input').focus();
                    });
                });
                host.querySelectorAll('.js-note-cancel').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        box.querySelector('.code-notes-edit').hidden = true;
                        box.querySelector('.code-notes-view').hidden = false;
                    });
                });
                host.querySelectorAll('.js-note-save').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        saveNotes(+b.getAttribute('data-id'), box.querySelector('.js-note-input').value.trim());
                    });
                });
                host.querySelectorAll('.js-cred-edit').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-creds');
                        b.hidden = true;
                        box.querySelector('.code-creds-edit').hidden = false;
                        box.querySelector('.js-cred-email').focus();
                    });
                });
                host.querySelectorAll('.js-cred-cancel').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-creds');
                        box.querySelector('.code-creds-edit').hidden = true;
                        box.querySelector('.js-cred-msg').textContent = '';
                        box.querySelector('.js-cred-edit').hidden = false;
                    });
                });
                host.querySelectorAll('.js-cred-save').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-creds');
                        saveCreds(+b.getAttribute('data-id'), {
                            email: box.querySelector('.js-cred-email').value.trim(),
                            password: box.querySelector('.js-cred-pass').value,
                            phone_1: box.querySelector('.js-cred-p1').value.trim(),
                            phone_2: box.querySelector('.js-cred-p2').value.trim(),
                            checkout_full_url: box.querySelector('.js-cred-cf').value.trim(),
                            checkout_discount_url: box.querySelector('.js-cred-cd').value.trim(),
                        }, box.querySelector('.js-cred-msg'), b);
                    });
                });
            }

            async function saveCreds(id, fields, msgEl, btn) {
                var payload = { action: 'set-credentials', id: id };
                if (fields.email) payload.email = fields.email;
                if (fields.password) payload.password = fields.password;
                // Toujours envoyés (vide = on efface côté serveur)
                payload.phone_1 = fields.phone_1;
                payload.phone_2 = fields.phone_2;
                payload.checkout_full_url = fields.checkout_full_url;
                payload.checkout_discount_url = fields.checkout_discount_url;
                btn.disabled = true; msgEl.style.color = '#475569'; msgEl.textContent = 'Enregistrement…';
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e) { /* noop */ }
                    if (r.ok) { msgEl.style.color = '#16a34a'; msgEl.textContent = 'Enregistré.'; loadCodes(); }
                    else { msgEl.style.color = '#dc2626'; msgEl.textContent = d.error || 'Erreur.'; }
                } catch (e) { msgEl.style.color = '#dc2626'; msgEl.textContent = 'Erreur réseau.'; }
                btn.disabled = false;
            }

            function linkifyText(t) {
                return esc(t).replace(/(https?:\/\/[^\s]+)/g, function (u) {
                    return '<a href="' + u + '" target="_blank" rel="noopener noreferrer">' + u + '</a>';
                });
            }

            async function saveNotes(id, notes) {
                var c = codesAll.find(function (x) { return x.id === id; });
                if (c) c.notes = notes;          // MAJ optimiste
                splitRender();
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'code-notes', id: id, notes: notes }),
                    });
                } catch (e) { /* noop */ }
            }
            window.__renderCloserCodes = function (codes) { codesAll = Array.isArray(codes) ? codes : []; splitRender(); }; // démo

            async function loadCodes() {
                try {
                    var r = await fetch(API, { credentials: 'same-origin' });
                    if (r.status === 401) { showView('login'); return; }
                    var d = await r.json();
                    if (!r.ok) { document.getElementById('create-error').textContent = d.error || 'Erreur de chargement.'; return; }
                    codesAll = d.codes || [];
                    splitRender();
                } catch (e) {
                    document.getElementById('create-error').textContent = 'Erreur réseau.';
                }
            }

            async function toggleCode(id, active) {
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'revoke', id: id, active: active }),
                    });
                    loadCodes();
                } catch (e) { /* noop */ }
            }

            async function deleteCode(id) {
                // suppression optimiste
                codesAll = codesAll.filter(function (x) { return x.id !== id; });
                splitRender();
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'delete', id: id }),
                    });
                    loadCodes();
                } catch (e) { /* noop */ }
            }

            // --- Candidatures ---
            function candTag(label, value) {
                var v = (value || '').toLowerCase();
                var cls = v === 'oui' ? 'is-yes' : (v === 'non' ? 'is-no' : (value ? 'is-maybe' : ''));
                return '<span class="cand-tag ' + cls + '">' + label + ' : <b>' + esc(value || '—') + '</b></span>';
            }
            function linkify(url) {
                if (/^https?:\/\//i.test(url)) {
                    return '<a href="' + esc(url) + '" target="_blank" rel="noopener noreferrer">' + esc(url) + '</a>';
                }
                return esc(url || '—');
            }
            var candAll = [];
            var candFilter = 'all';

            function renderCandidatures(list) {
                candAll = Array.isArray(list) ? list : [];
                drawCandidatures();
            }

            function drawCandidatures() {
                var host = document.getElementById('candidatures');
                var empty = document.getElementById('cand-empty');
                var countEl = document.getElementById('tab-cand-count');

                // Comptes par statut
                var counts = { all: 0, top: 0, plus_tard: 0, poubelle: 0 };
                candAll.forEach(function (c) {
                    var s = c.status || 'nouveau';
                    if (s !== 'poubelle') counts.all++;
                    if (counts[s] != null) counts[s]++;
                });
                document.getElementById('cf-count-all').textContent = counts.all;
                document.getElementById('cf-count-top').textContent = counts.top;
                document.getElementById('cf-count-plus_tard').textContent = counts.plus_tard;
                document.getElementById('cf-count-poubelle').textContent = counts.poubelle;

                countEl.textContent = candAll.length;
                countEl.hidden = candAll.length === 0;

                // Filtre courant ("Tous" = tout sauf poubelle)
                var list = candAll.filter(function (c) {
                    var s = c.status || 'nouveau';
                    return candFilter === 'all' ? s !== 'poubelle' : s === candFilter;
                });

                if (!list.length) {
                    host.innerHTML = '';
                    empty.hidden = false;
                    empty.textContent = candAll.length ? 'Rien dans cette catégorie.' : 'Aucune candidature pour l\'instant.';
                    return;
                }
                empty.hidden = true;

                host.innerHTML = list.map(function (c) {
                    var s = c.status || 'nouveau';
                    function triBtn(val, label) {
                        return '<button class="tri-btn tri-' + val + (s === val ? ' is-active' : '') +
                            '" data-id="' + c.id + '" data-status="' + val + '" type="button">' + label + '</button>';
                    }
                    return '' +
                        '<div class="cand-card status-' + s + '">' +
                            '<div class="cand-top">' +
                                '<div class="cand-name">' + esc(c.full_name) +
                                    (c.code_label ? '<span class="cand-via">via ' + esc(c.code_label) + '</span>' : '') +
                                '</div>' +
                                '<div class="cand-when">' + fmtDate(c.created_at) + '</div>' +
                            '</div>' +
                            '<div class="cand-contact">' +
                                '<a href="mailto:' + esc(c.email) + '">' + esc(c.email) + '</a>' +
                                '<span>' + esc(c.phone) + '</span>' +
                            '</div>' +
                            '<div class="cand-tags">' +
                                candTag('High-ticket 1500€+', c.closed_highticket) +
                                candTag('100% résultat', c.ok_commission) +
                                candTag('Enregistrement', c.ok_recording) +
                                candTag('Dispo 3 juil', c.available_jul3) +
                            '</div>' +
                            '<div class="cand-block"><div class="q">Résultats concrets</div><div class="a">' + esc(c.results) + '</div></div>' +
                            '<div class="cand-block"><div class="q">Échantillon audio</div><div class="a">' + linkify(c.audio_url) + '</div></div>' +
                            '<div class="cand-block"><div class="q">Pourquoi cette opportunité</div><div class="a">' + esc(c.motivation) + '</div></div>' +
                            '<div class="cand-tri">' +
                                triBtn('top', '⭐ Top') +
                                triBtn('plus_tard', '🕓 Plus tard') +
                                triBtn('poubelle', '🗑 Poubelle') +
                            '</div>' +
                        '</div>';
                }).join('');

                host.querySelectorAll('.tri-btn').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var id = +b.getAttribute('data-id');
                        var val = b.getAttribute('data-status');
                        // re-cliquer le statut actif le remet à "nouveau"
                        var cur = (candAll.find(function (x) { return x.id === id; }) || {}).status || 'nouveau';
                        setCandStatus(id, cur === val ? 'nouveau' : val);
                    });
                });
            }

            async function setCandStatus(id, status) {
                var c = candAll.find(function (x) { return x.id === id; });
                if (c) c.status = status;            // MAJ optimiste
                drawCandidatures();
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'cand-status', id: id, status: status }),
                    });
                } catch (e) { /* noop */ }
            }

            window.__renderCloserCandidatures = renderCandidatures; // exposé pour aperçu/démo

            async function loadCandidatures() {
                try {
                    var r = await fetch(API + '?resource=candidatures', { credentials: 'same-origin' });
                    if (r.status === 401) { showView('login'); return; }
                    var d = await r.json();
                    if (!r.ok) return;
                    renderCandidatures(d.candidatures || []);
                } catch (e) { /* noop */ }
            }

            function enterAdmin() {
                showView('admin');
                loadCodes();
                loadSessions();
                loadCandidatures();
                // Restaure la vue (univers + onglets) après un rechargement de page
                try {
                    if (localStorage.getItem('adm_universe') === 'closers') switchUniverse('closers');
                    var tr = localStorage.getItem('adm_tab_recrut');
                    if (tr && tr !== 'tab-codes') switchTab(tr);
                    var tc = localStorage.getItem('adm_tab_closers');
                    if (tc && tc !== 'tab-closers') switchTab(tc);
                } catch (e) {}
            }
            document.getElementById('closers-refresh').addEventListener('click', function () {
                loadCodes();
                loadStats();
            });

            // Changement de session -> KPI + pool d'assignation suivent
            document.getElementById('session-select').addEventListener('change', function () {
                SESSION_DATE = this.value;
                updateSessionMeta();
                loadStats();
                POOL = []; SEL = {};
                if (!document.getElementById('panel-assign').hidden) { loadPool(); }
            });

            // --- Univers (1 = recrutement, 2 = mes closers) ---
            function switchUniverse(which) {
                var recrut = which === 'recrut';
                document.getElementById('u-recrut').classList.toggle('is-active', recrut);
                document.getElementById('u-closers').classList.toggle('is-active', !recrut);
                document.getElementById('universe-recrut').hidden = !recrut;
                document.getElementById('universe-closers').hidden = recrut;
                try { localStorage.setItem('adm_universe', which); } catch (e) {}
            }
            document.getElementById('u-recrut').addEventListener('click', function () { switchUniverse('recrut'); });
            document.getElementById('u-closers').addEventListener('click', function () { switchUniverse('closers'); });

            // --- Sous-onglets, groupés par univers ---
            var TABS = [
                { tab: 'tab-codes', panel: 'panel-codes', group: ['tab-codes', 'tab-candidatures'] },
                { tab: 'tab-candidatures', panel: 'panel-candidatures', group: ['tab-codes', 'tab-candidatures'] },
                { tab: 'tab-closers', panel: 'panel-closers', group: ['tab-closers', 'tab-assign'] },
                { tab: 'tab-assign', panel: 'panel-assign', group: ['tab-closers', 'tab-assign'] },
            ];
            function switchTab(which) {
                var def = TABS.find(function (t) { return t.tab === which; });
                if (!def) return;
                TABS.forEach(function (t) {
                    if (def.group.indexOf(t.tab) === -1) return;
                    var on = t.tab === which;
                    document.getElementById(t.tab).classList.toggle('is-active', on);
                    document.getElementById(t.panel).hidden = !on;
                });
                if (which === 'tab-candidatures') loadCandidatures();
                if (which === 'tab-assign') initAssignTab();
                try {
                    var key = def.group.indexOf('tab-closers') !== -1 ? 'adm_tab_closers' : 'adm_tab_recrut';
                    localStorage.setItem(key, which);
                } catch (e) {}
            }
            TABS.forEach(function (t) {
                document.getElementById(t.tab).addEventListener('click', function () { switchTab(t.tab); });
            });

            // Filtres candidatures
            document.querySelectorAll('.cand-filter').forEach(function (f) {
                f.addEventListener('click', function () {
                    candFilter = f.getAttribute('data-filter');
                    document.querySelectorAll('.cand-filter').forEach(function (x) {
                        x.classList.toggle('is-active', x === f);
                    });
                    drawCandidatures();
                });
            });

            // --- Boot : vérifie la session admin ---
            async function init() {
                try {
                    var r = await fetch(SESSION, { credentials: 'same-origin' });
                    var d = r.ok ? await r.json() : {};
                    if (d && d.authenticated) { enterAdmin(); return; }
                } catch (e) { /* noop */ }
                showView('login');
            }

            // --- Login ---
            document.getElementById('login-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var pwd = document.getElementById('admin-password').value;
                var btn = document.getElementById('login-btn');
                var errEl = document.getElementById('login-error');
                errEl.textContent = '';
                btn.disabled = true;
                try {
                    var r = await fetch(LOGIN, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ password: pwd }),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e2) { /* noop */ }
                    if (r.ok) { enterAdmin(); return; }
                    if (d.code === 'SETUP_REQUIRED') {
                        errEl.textContent = 'Aucun mot de passe admin défini. Configure-le d\'abord sur /es-cockpit.';
                    } else {
                        errEl.textContent = d.error || 'Mot de passe incorrect.';
                    }
                } catch (e3) {
                    errEl.textContent = 'Erreur réseau.';
                }
                btn.disabled = false;
            });

            // --- Logout ---
            document.getElementById('logout-btn').addEventListener('click', async function () {
                try { await fetch(LOGOUT, { method: 'POST', credentials: 'same-origin' }); } catch (e) { /* noop */ }
                showView('login');
            });

            // --- Création d'un code de recrutement (Univers 1) ---
            document.getElementById('code-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var label = document.getElementById('code-label').value.trim();
                var notes = document.getElementById('code-notes').value.trim();
                var btn = document.getElementById('code-btn');
                var errEl = document.getElementById('code-error');
                var box = document.getElementById('new-code');
                errEl.textContent = '';
                if (!label) { errEl.textContent = 'Entrez un nom.'; return; }
                btn.disabled = true;
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'create', label: label, notes: notes }),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e2) { /* noop */ }
                    if (r.ok && d.row) {
                        document.getElementById('new-code-name').textContent = d.row.label;
                        document.getElementById('new-code-val').textContent = d.row.code;
                        box.classList.add('is-shown');
                        document.getElementById('code-label').value = '';
                        document.getElementById('code-notes').value = '';
                        loadCodes();
                    } else {
                        errEl.textContent = d.error || 'Création impossible.';
                    }
                } catch (e3) {
                    errEl.textContent = 'Erreur réseau.';
                }
                btn.disabled = false;
            });

            document.getElementById('new-code-copy').addEventListener('click', function () {
                copyText(document.getElementById('new-code-val').textContent, this);
            });

            // --- Création d'un closer (Univers 2) ---
            document.getElementById('create-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var label = document.getElementById('create-label').value.trim();
                var email = document.getElementById('create-email').value.trim();
                var password = document.getElementById('create-password').value;
                var notes = document.getElementById('create-notes').value.trim();
                var btn = document.getElementById('create-btn');
                var errEl = document.getElementById('create-error');
                var box = document.getElementById('new-closer');
                errEl.textContent = '';
                if (!label) { errEl.textContent = 'Entrez un nom.'; return; }
                if (!email) { errEl.textContent = 'Entrez un email.'; return; }
                if (!password || password.length < 6) { errEl.textContent = 'Mot de passe : 6 caractères minimum.'; return; }
                btn.disabled = true;
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'create-closer', label: label, email: email, password: password, notes: notes }),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e2) { /* noop */ }
                    if (r.ok && d.row) {
                        document.getElementById('new-closer-name').textContent = d.row.label + ' — ' + (d.row.email || email);
                        box.classList.add('is-shown');
                        document.getElementById('create-label').value = '';
                        document.getElementById('create-email').value = '';
                        document.getElementById('create-password').value = '';
                        document.getElementById('create-notes').value = '';
                        loadCodes();
                        loadStats();
                    } else {
                        errEl.textContent = d.error || 'Création impossible.';
                    }
                } catch (e3) {
                    errEl.textContent = 'Erreur réseau.';
                }
                btn.disabled = false;
            });

            // ===== Onglet Assignation =====
            var POOL = [];
            var SEL = {};            // token -> true
            var ULTRA_FILTER = 'all'; // 'all' | 'meta' | 'orga'
            var assignLoaded = false;

            function isMeta(l) { return l.traffic_source === 'meta_ad'; }
            function srcTag(l) {
                return isMeta(l)
                    ? '<span class="pr-src pr-src-meta">Meta</span>'
                    : '<span class="pr-src pr-src-orga">Orga</span>';
            }

            function activeClosers() {
                return codesAll.filter(function (c) { return c.active !== false && c.email; });
            }
            function closerName(id) {
                var c = codesAll.find(function (x) { return x.id === id; });
                return c ? c.label : ('#' + id);
            }

            function fillCloserSelect() {
                var sel = document.getElementById('assign-closer');
                if (!sel) return;
                var opts = ['<option value="">— Choisir un closer —</option>'];
                activeClosers().forEach(function (c) {
                    opts.push('<option value="' + c.id + '">' + esc(c.label) + '</option>');
                });
                opts.push('<option value="__none__">↩︎ Désassigner (retirer)</option>');
                sel.innerHTML = opts.join('');
                var el = document.getElementById('el-closer');
                if (el) {
                    var eopts = ['<option value="">— Choisir un closer —</option>'];
                    activeClosers().forEach(function (c) {
                        eopts.push('<option value="' + c.id + '">' + esc(c.label) + '</option>');
                    });
                    el.innerHTML = eopts.join('');
                }
            }

            function poolRow(l) {
                var checked = SEL[l.token] ? ' checked' : '';
                var sub = [esc(l.pays || '—'), esc(l.telephone || 'sans tel.')].join(' · ');
                var tag = l.purchased
                    ? '<span class="pr-bought">acheté</span>'
                    : (l.assigned_closer_id != null ? '<span class="pr-assigned">→ ' + esc(closerName(l.assigned_closer_id)) + '</span>' : '');
                var mins = (l.watch_max_minutes != null) ? (l.watch_max_minutes + ' min') : '';
                return '<div class="pool-row">' +
                    '<input type="checkbox" class="js-pool-cb" data-token="' + esc(l.token) + '"' + checked + '>' +
                    '<div class="pr-main"><div class="pr-name">' + esc(l.prenom || 'Lead') + '</div><div class="pr-sub">' + sub + '</div></div>' +
                    srcTag(l) +
                    (mins ? '<span class="pr-mins">' + mins + '</span>' : '') + tag +
                    '</div>';
            }

            function renderPool() {
                var ultra = POOL.filter(function (l) { return (l.watch_max_minutes || 0) >= 81; });
                var rest = POOL.filter(function (l) { return (l.watch_max_minutes || 0) < 81; });
                // Compteurs des chips de filtre (sur les ultra)
                var uMeta = ultra.filter(isMeta).length;
                document.getElementById('uf-all').textContent = ultra.length;
                document.getElementById('uf-meta').textContent = uMeta;
                document.getElementById('uf-orga').textContent = ultra.length - uMeta;
                var ultraShown = ultra.filter(function (l) {
                    if (ULTRA_FILTER === 'meta') return isMeta(l);
                    if (ULTRA_FILTER === 'orga') return !isMeta(l);
                    return true;
                });
                var allHost = document.getElementById('pool-all');
                var ultraHost = document.getElementById('pool-ultra');
                document.getElementById('pool-all-count').textContent = rest.length;
                document.getElementById('pool-ultra-count').textContent = ultra.length;
                allHost.innerHTML = rest.length ? rest.map(poolRow).join('') : '<div class="pool-empty">Aucun inscrit.</div>';
                ultraHost.innerHTML = ultraShown.length ? ultraShown.map(poolRow).join('') : '<div class="pool-empty">Aucun lead pour ce filtre.</div>';
                document.querySelectorAll('.js-pool-cb').forEach(function (cb) {
                    cb.addEventListener('change', function () {
                        var t = cb.getAttribute('data-token');
                        if (cb.checked) SEL[t] = true; else delete SEL[t];
                        updateAssignBar();
                    });
                });
                document.getElementById('pool-all-check').checked = false;
                document.getElementById('pool-ultra-check').checked = false;
                updateAssignBar();
            }

            function updateAssignBar() {
                var n = Object.keys(SEL).length;
                document.getElementById('assign-bar').hidden = n === 0;
                document.getElementById('assign-count').textContent = n + ' sélectionné(s)';
                if (n === 0) {
                    var sb = document.getElementById('split-box');
                    if (sb) sb.hidden = true;
                }
            }

            // ---- Répartition équitable entre plusieurs closers ----
            function chosenCloserIds() {
                return Array.prototype.slice.call(document.querySelectorAll('#split-closers input:checked'))
                    .map(function (cb) { return Number(cb.value); });
            }
            function computeSplit(ids) {
                var selected = POOL.filter(function (l) { return SEL[l.token]; });
                var groups = { meta: [], orga: [] };
                selected.forEach(function (l) { (isMeta(l) ? groups.meta : groups.orga).push(l); });
                var res = {};
                ids.forEach(function (id) { res[id] = { meta: 0, orga: 0, tokens: [] }; });
                if (!ids.length) return res;
                ['meta', 'orga'].forEach(function (s, si) {
                    var arr = groups[s].slice().sort(function (a, b) {
                        return (b.watch_max_minutes || 0) - (a.watch_max_minutes || 0);
                    });
                    arr.forEach(function (l, i) {
                        var id = ids[(i + si) % ids.length]; // décalage par source = rotation du 1er choix
                        res[id][s]++; res[id].tokens.push(l.token);
                    });
                });
                return res;
            }
            function renderSplit() {
                var ids = chosenCloserIds();
                var host = document.getElementById('split-preview');
                if (ids.length < 2) {
                    host.innerHTML = '<div class="pool-empty">Coche au moins 2 closers.</div>';
                    return;
                }
                var res = computeSplit(ids);
                host.innerHTML = ids.map(function (id) {
                    var r = res[id]; var total = r.meta + r.orga;
                    return '<div class="split-card"><div class="sc-name">' + esc(closerName(id)) + ' reçoit</div>' +
                        '<div class="sc-total">' + total + ' lead' + (total > 1 ? 's' : '') + '</div>' +
                        '<div class="sc-break">' + r.meta + ' Meta · ' + r.orga + ' Orga</div></div>';
                }).join('');
            }
            function openSplit() {
                var out = document.getElementById('pool-result');
                var n = Object.keys(SEL).length;
                if (!n) { out.style.color = '#dc2626'; out.textContent = 'Coche au moins un lead.'; return; }
                var closers = activeClosers();
                if (closers.length < 2) { out.style.color = '#dc2626'; out.textContent = 'Il faut au moins 2 closers actifs pour répartir.'; return; }
                document.getElementById('split-total').textContent = n;
                document.getElementById('split-closers').innerHTML = closers.map(function (c) {
                    return '<label><input type="checkbox" value="' + c.id + '" checked> ' + esc(c.label) + '</label>';
                }).join('');
                document.querySelectorAll('#split-closers input').forEach(function (cb) {
                    cb.addEventListener('change', renderSplit);
                });
                renderSplit();
                var box = document.getElementById('split-box');
                box.hidden = false;
                box.scrollIntoView({ block: 'nearest' });
            }
            async function confirmSplit() {
                var ids = chosenCloserIds();
                var out = document.getElementById('pool-result');
                if (ids.length < 2) { out.style.color = '#dc2626'; out.textContent = 'Choisis au moins 2 closers.'; return; }
                var res = computeSplit(ids);
                var btn = document.getElementById('split-confirm');
                btn.disabled = true; out.style.color = '#475569'; out.textContent = 'Répartition…';
                try {
                    var done = 0;
                    for (var k = 0; k < ids.length; k++) {
                        var id = ids[k]; var tokens = res[id].tokens;
                        if (!tokens.length) continue;
                        var r = await fetch(API, {
                            method: 'POST', credentials: 'same-origin',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ action: 'assign', closer_id: id, tokens: tokens }),
                        });
                        var d = await r.json();
                        if (!r.ok) { out.style.color = '#dc2626'; out.textContent = (d.error || 'Erreur') + ' (' + closerName(id) + ').'; btn.disabled = false; return; }
                        done += (d.count || tokens.length);
                    }
                    out.style.color = '#16a34a'; out.textContent = done + ' lead(s) répartis sur ' + ids.length + ' closers.';
                    SEL = {};
                    document.getElementById('split-box').hidden = true;
                    await loadPool();
                    loadStats();
                } catch (e) { out.style.color = '#dc2626'; out.textContent = 'Erreur réseau.'; }
                btn.disabled = false;
            }

            async function loadPool() {
                var date = SESSION_DATE;
                var out = document.getElementById('pool-result');
                var btn = document.getElementById('pool-load');
                btn.disabled = true; out.style.color = '#475569'; out.textContent = 'Chargement…';
                SEL = {};
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'leads-pool', session_date: date || null }),
                    });
                    var d = await r.json();
                    if (!r.ok) { out.style.color = '#dc2626'; out.textContent = d.error || 'Erreur.'; btn.disabled = false; return; }
                    POOL = d.leads || [];
                    fillCloserSelect();
                    renderPool();
                    out.style.color = '#16a34a'; out.textContent = POOL.length + ' lead(s) chargé(s) pour le ' + frDate(date) + '.';
                } catch (e) { out.style.color = '#dc2626'; out.textContent = 'Erreur réseau.'; }
                btn.disabled = false;
            }

            function bindAssignControls() {
                document.getElementById('pool-load').addEventListener('click', loadPool);
                document.getElementById('assign-clear').addEventListener('click', function () {
                    SEL = {};
                    document.querySelectorAll('.js-pool-cb').forEach(function (cb) { cb.checked = false; });
                    document.getElementById('pool-all-check').checked = false;
                    document.getElementById('pool-ultra-check').checked = false;
                    updateAssignBar();
                });
                function selectAll(listId, masterId) {
                    document.getElementById(masterId).addEventListener('change', function () {
                        var on = this.checked;
                        document.querySelectorAll('#' + listId + ' .js-pool-cb').forEach(function (cb) {
                            cb.checked = on;
                            var t = cb.getAttribute('data-token');
                            if (on) SEL[t] = true; else delete SEL[t];
                        });
                        updateAssignBar();
                    });
                }
                selectAll('pool-all', 'pool-all-check');
                selectAll('pool-ultra', 'pool-ultra-check');

                document.getElementById('assign-do').addEventListener('click', async function () {
                    var tokens = Object.keys(SEL);
                    var out = document.getElementById('pool-result');
                    if (!tokens.length) { out.style.color = '#dc2626'; out.textContent = 'Coche au moins un lead.'; return; }
                    var val = document.getElementById('assign-closer').value;
                    if (!val) { out.style.color = '#dc2626'; out.textContent = 'Choisis un closer.'; return; }
                    var closer_id = val === '__none__' ? null : Number(val);
                    var label = closer_id === null ? 'désassignés' : ('assignés à ' + closerName(closer_id));
                    var btn = this; btn.disabled = true; out.style.color = '#475569'; out.textContent = 'Assignation…';
                    try {
                        var r = await fetch(API, {
                            method: 'POST', credentials: 'same-origin',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ action: 'assign', closer_id: closer_id, tokens: tokens }),
                        });
                        var d = await r.json();
                        if (r.ok) {
                            out.style.color = '#16a34a'; out.textContent = (d.count || tokens.length) + ' lead(s) ' + label + '.';
                            SEL = {};
                            await loadPool();
                            loadStats();
                        } else { out.style.color = '#dc2626'; out.textContent = d.error || 'Erreur.'; }
                    } catch (e) { out.style.color = '#dc2626'; out.textContent = 'Erreur réseau.'; }
                    btn.disabled = false;
                });

                // Filtre source sur la colonne ultra-qualifiés
                document.querySelectorAll('#ultra-filter button').forEach(function (b) {
                    b.addEventListener('click', function () {
                        ULTRA_FILTER = b.getAttribute('data-src');
                        document.querySelectorAll('#ultra-filter button').forEach(function (x) { x.classList.remove('is-active'); });
                        b.classList.add('is-active');
                        renderPool();
                    });
                });

                // Répartition équitable
                document.getElementById('assign-split-open').addEventListener('click', openSplit);
                document.getElementById('split-cancel').addEventListener('click', function () {
                    document.getElementById('split-box').hidden = true;
                });
                document.getElementById('split-confirm').addEventListener('click', confirmSplit);

                // Assignation par liste d'emails
                document.getElementById('el-check').addEventListener('click', checkEmailList);
                document.getElementById('el-assign').addEventListener('click', assignEmailList);
                document.getElementById('el-cancel').addEventListener('click', resetEmailList);
                document.getElementById('el-emails').addEventListener('input', invalidateEmailCheck);
                document.getElementById('el-closer').addEventListener('change', invalidateEmailCheck);
            }

            // ===== Assignation par liste d'emails =====
            var EL_STATE = null; // { closer_id, assignable:[tokens], conflicts:[{token,email,closer_id}] }
            function invalidateEmailCheck() {
                EL_STATE = null;
                document.getElementById('el-report').hidden = true;
                document.getElementById('el-actions').hidden = true;
                document.getElementById('el-msg').textContent = '';
            }
            function resetEmailList() {
                document.getElementById('el-emails').value = '';
                invalidateEmailCheck();
            }
            async function checkEmailList() {
                var msg = document.getElementById('el-msg');
                var emails = document.getElementById('el-emails').value
                    .split(/[\s,;]+/).map(function (e) { return e.trim().toLowerCase(); })
                    .filter(function (e) { return e && e.indexOf('@') !== -1; });
                emails = Array.from(new Set(emails));
                var closerId = Number(document.getElementById('el-closer').value);
                if (!emails.length) { msg.style.color = '#dc2626'; msg.textContent = 'Colle au moins un email.'; return; }
                if (!closerId) { msg.style.color = '#dc2626'; msg.textContent = 'Choisis un closer.'; return; }
                var btn = document.getElementById('el-check');
                btn.disabled = true; msg.style.color = '#475569'; msg.textContent = 'Vérification…';
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'leads-by-emails', emails: emails }),
                    });
                    var d = await r.json();
                    if (!r.ok) { msg.style.color = '#dc2626'; msg.textContent = d.error || 'Erreur.'; btn.disabled = false; return; }
                    var leads = d.leads || [];
                    var assignable = [], same = [], conflicts = [], bought = [];
                    leads.forEach(function (l) {
                        if (l.purchased) { bought.push(l); return; }
                        if (l.assigned_closer_id == null) { assignable.push(l); return; }
                        if (Number(l.assigned_closer_id) === closerId) { same.push(l); return; }
                        conflicts.push(l);
                    });
                    EL_STATE = { closer_id: closerId, assignable: assignable.map(function (l) { return l.token; }), conflicts: conflicts };
                    var html = [];
                    html.push('<div class="el-line ok"><b>' + assignable.length + '</b> lead(s) assignables à <b>' + esc(closerName(closerId)) + '</b>.</div>');
                    if (same.length) html.push('<div class="el-line"><b>' + same.length + '</b> déjà assigné(s) à ce closer — rien à faire.</div>');
                    if (bought.length) html.push('<div class="el-line"><b>' + bought.length + '</b> déjà acheteur(s) — jamais réassignés : <span class="el-detail">' + bought.map(function (l) { return esc(l.email); }).join(' · ') + '</span></div>');
                    if (d.not_found && d.not_found.length) html.push('<div class="el-line err"><b>' + d.not_found.length + '</b> introuvable(s) en base : <span class="el-detail">' + d.not_found.map(esc).join(' · ') + '</span></div>');
                    if (conflicts.length) {
                        html.push('<div class="el-line warn"><b>' + conflicts.length + '</b> déjà assigné(s) à un AUTRE closer — coche pour réassigner de force (sinon ils sont sautés) :' +
                            conflicts.map(function (l, i) {
                                return '<label class="el-conflict"><input type="checkbox" class="js-el-force" data-token="' + esc(l.token) + '"> ' + esc(l.email) + ' <b>→ actuellement ' + esc(closerName(Number(l.assigned_closer_id))) + '</b></label>';
                            }).join('') + '</div>');
                    }
                    var rep = document.getElementById('el-report');
                    rep.innerHTML = html.join(''); rep.hidden = false;
                    document.getElementById('el-actions').hidden = false;
                    updateElAssignLabel();
                    rep.querySelectorAll('.js-el-force').forEach(function (cb) { cb.addEventListener('change', updateElAssignLabel); });
                    msg.textContent = '';
                } catch (e) { msg.style.color = '#dc2626'; msg.textContent = 'Erreur réseau.'; }
                btn.disabled = false;
            }
            function elSelectedTokens() {
                if (!EL_STATE) return [];
                var t = EL_STATE.assignable.slice();
                document.querySelectorAll('#el-report .js-el-force:checked').forEach(function (cb) { t.push(cb.getAttribute('data-token')); });
                return t;
            }
            function updateElAssignLabel() {
                var n = elSelectedTokens().length;
                var b = document.getElementById('el-assign');
                b.textContent = 'Assigner ' + n + ' lead(s)';
                b.disabled = n === 0;
            }
            async function assignEmailList() {
                var msg = document.getElementById('el-msg');
                var tokens = elSelectedTokens();
                if (!EL_STATE || !tokens.length) { msg.style.color = '#dc2626'; msg.textContent = 'Rien à assigner.'; return; }
                var btn = document.getElementById('el-assign');
                btn.disabled = true; msg.style.color = '#475569'; msg.textContent = 'Assignation…';
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'assign', closer_id: EL_STATE.closer_id, tokens: tokens }),
                    });
                    var d = await r.json();
                    if (r.ok) {
                        msg.style.color = '#16a34a';
                        msg.textContent = (d.count || tokens.length) + ' lead(s) assignés à ' + closerName(EL_STATE.closer_id) + '.';
                        document.getElementById('el-report').hidden = true;
                        document.getElementById('el-actions').hidden = true;
                        document.getElementById('el-emails').value = '';
                        EL_STATE = null;
                        await loadPool();
                        loadStats();
                    } else { msg.style.color = '#dc2626'; msg.textContent = d.error || 'Erreur.'; btn.disabled = false; }
                } catch (e) { msg.style.color = '#dc2626'; msg.textContent = 'Erreur réseau.'; btn.disabled = false; }
            }

            function initAssignTab() {
                if (!assignLoaded) { bindAssignControls(); assignLoaded = true; }
                loadPool(); // recharge toujours selon la session courante
            }

            init();
        })();
    </script>
</body>
</html>
