---
// Admin des codes d'accès /closer — protégé par la session admin ES2 existante.
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — Codes d'accès closer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- is:global : la liste de codes est rendue en JS (innerHTML), donc non concernée par le scoping Astro -->
    <style is:global>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        [hidden] { display: none !important; }

        :root {
            color-scheme: light only;
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --ink: #0f172a;
            --ink-soft: #334155;
            --muted: #64748b;
            --line: #e2e8f0;
            --surface: #ffffff;
            --bg: #f1f5f9;
            --accent-soft: #eff6ff;
            --green: #16a34a;
            --green-soft: #f0fdf4;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }

        .wrap {
            max-width: 920px;
            margin: 0 auto;
            padding: clamp(20px, 4vw, 40px) clamp(16px, 3vw, 24px);
        }

        .view[hidden] { display: none; }

        .boot {
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-size: 0.95rem;
        }

        /* === Login === */
        .login-wrap {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 18px;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
        }

        .login-card {
            width: 100%;
            max-width: 380px;
            padding: clamp(26px, 5vw, 36px);
            text-align: center;
        }

        .login-card h1 { font-size: 1.25rem; font-weight: 800; margin-bottom: 6px; }
        .login-card p { font-size: 0.9rem; color: var(--muted); margin-bottom: 22px; }

        input[type="password"], input[type="text"] {
            width: 100%;
            padding: 13px 15px;
            font-family: inherit;
            font-size: 1rem;
            color: var(--ink);
            border: 2px solid var(--line);
            border-radius: 11px;
            background: #fff;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.16);
        }

        .btn {
            border: none;
            border-radius: 11px;
            padding: 13px 20px;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
            transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
            white-space: nowrap;
        }

        .btn:hover { transform: translateY(-1px); }
        .btn:disabled { opacity: 0.6; cursor: default; transform: none; }

        .btn-ghost {
            background: var(--surface);
            color: var(--ink-soft);
            border: 1px solid var(--line);
            box-shadow: none;
            font-weight: 600;
        }

        .btn-sm { padding: 8px 13px; font-size: 0.82rem; }

        .login-card .btn { width: 100%; margin-top: 14px; }
        .err { min-height: 1.1em; margin-top: 10px; font-size: 0.85rem; font-weight: 600; color: #dc2626; }

        /* === Header === */
        .head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            margin-bottom: 22px;
            flex-wrap: wrap;
        }

        .head h1 { font-size: clamp(1.3rem, 3vw, 1.7rem); font-weight: 900; letter-spacing: -0.02em; }
        .head p { font-size: 0.88rem; color: var(--muted); margin-top: 2px; }

        /* === Create === */
        .create-card { padding: 20px; margin-bottom: 18px; }
        .create-card h2 { font-size: 0.95rem; font-weight: 800; margin-bottom: 12px; }

        .create-form {
            display: grid;
            gap: 10px;
            grid-template-columns: 1fr;
        }

        @media (min-width: 600px) {
            .create-form { grid-template-columns: 1fr 1fr auto; align-items: center; }
        }

        .create-form input { width: 100%; }

        .new-code {
            display: none;
            margin-top: 14px;
            padding: 14px 16px;
            border-radius: 12px;
            background: var(--green-soft);
            border: 1px solid #bbf7d0;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .new-code.is-shown { display: flex; }
        .new-code-label { font-size: 0.85rem; color: #15803d; font-weight: 600; }
        .new-code-val { font-size: 1.15rem; font-weight: 800; letter-spacing: 0.06em; color: var(--ink); }

        /* === Summary === */
        .summary {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 18px;
        }

        .sum {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 14px 16px;
            text-align: center;
        }

        .sum-val { font-size: 1.5rem; font-weight: 900; letter-spacing: -0.02em; }
        .sum-val.is-green { color: var(--green); }
        .sum-val.is-muted { color: var(--muted); }
        .sum-label { font-size: 0.74rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }

        /* === Code cards === */
        .codes { display: grid; gap: 12px; }

        .code-card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px 18px;
        }

        .code-card.is-revoked { opacity: 0.62; }

        .code-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .code-name { font-size: 1.05rem; font-weight: 800; display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }

        .badge {
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            padding: 3px 9px;
            border-radius: 999px;
        }

        .badge-came { background: var(--green-soft); color: #15803d; border: 1px solid #bbf7d0; }
        .badge-not { background: #f8fafc; color: var(--muted); border: 1px solid var(--line); }
        .badge-revoked { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }

        .code-actions { display: flex; gap: 8px; align-items: center; }

        .code-del {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--muted);
            border-radius: 9px;
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex-shrink: 0;
            transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
        }

        .code-del:hover { color: #dc2626; border-color: #fecaca; background: #fef2f2; }
        .code-del svg { width: 16px; height: 16px; }

        .code-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            color: var(--primary-dark);
            background: var(--accent-soft);
            border: 1px solid #bfdbfe;
            border-radius: 9px;
            padding: 6px 11px;
        }

        .copy-btn {
            border: none;
            background: transparent;
            color: var(--primary-dark);
            cursor: pointer;
            padding: 2px;
            display: inline-flex;
            border-radius: 6px;
        }

        .copy-btn svg { width: 15px; height: 15px; }
        .copy-btn.copied { color: var(--green); }

        .code-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px 22px;
            margin-top: 12px;
            align-items: center;
        }

        .meta-item { font-size: 0.84rem; color: var(--ink-soft); }
        .meta-item b { color: var(--ink); font-weight: 700; }
        .meta-k { color: var(--muted); }

        /* === Note / infos sur la carte code === */
        .code-notes {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px dashed var(--line);
        }

        .code-notes-view {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            flex-wrap: wrap;
        }

        .code-notes-text {
            flex: 1;
            min-width: 0;
            font-size: 0.86rem;
            color: var(--ink-soft);
            line-height: 1.5;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .code-notes-text a { color: var(--primary-dark); font-weight: 600; word-break: break-all; }
        .code-notes-empty { color: var(--muted); font-style: italic; }

        .code-notes-btn {
            border: none;
            background: transparent;
            color: var(--primary-dark);
            font-family: inherit;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            padding: 2px 4px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .code-notes-btn:hover { text-decoration: underline; }

        .code-notes-edit textarea {
            width: 100%;
            padding: 10px 12px;
            font-family: inherit;
            font-size: 0.9rem;
            color: var(--ink);
            border: 2px solid var(--line);
            border-radius: 10px;
            background: #fff;
            resize: vertical;
        }

        .code-notes-edit textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.16);
        }

        .code-notes-edit-actions {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }

        /* === Onglets === */
        .tabs { display: flex; gap: 8px; margin-bottom: 18px; }

        .tab {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 11px;
            padding: 9px 16px;
            font-family: inherit;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .tab.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }

        .tab-count {
            background: var(--primary);
            color: #fff;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            padding: 1px 7px;
        }

        /* === Cartes candidature === */
        .cand-card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 18px 20px;
        }

        .cand-top {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            align-items: baseline;
            margin-bottom: 12px;
        }

        .cand-name { font-size: 1.1rem; font-weight: 800; }
        .cand-via { font-size: 0.8rem; font-weight: 600; color: var(--muted); margin-left: 8px; }
        .cand-when { font-size: 0.82rem; color: var(--muted); white-space: nowrap; }

        .cand-contact {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 18px;
            font-size: 0.88rem;
            margin-bottom: 14px;
        }
        .cand-contact a { color: var(--primary-dark); text-decoration: none; font-weight: 600; }
        .cand-contact span { color: var(--ink-soft); }

        .cand-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 6px; }

        .cand-tag {
            font-size: 0.78rem;
            font-weight: 600;
            border: 1px solid var(--line);
            border-radius: 999px;
            padding: 5px 11px;
            background: #f8fafc;
            color: var(--ink-soft);
        }
        .cand-tag b { color: var(--ink); font-weight: 700; }
        .cand-tag.is-yes { background: var(--green-soft); border-color: #bbf7d0; }
        .cand-tag.is-no { background: #fef2f2; border-color: #fecaca; }
        .cand-tag.is-maybe { background: var(--accent-soft); border-color: #bfdbfe; }

        .cand-block { margin-top: 12px; }
        .cand-block .q {
            font-size: 0.74rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--muted);
            margin-bottom: 4px;
        }
        .cand-block .a {
            font-size: 0.92rem;
            color: var(--ink-soft);
            white-space: pre-wrap;
            line-height: 1.55;
            word-break: break-word;
        }
        .cand-block .a a { color: var(--primary-dark); font-weight: 600; }

        /* === Filtres candidatures === */
        .cand-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 16px;
        }

        .cand-filter {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 999px;
            padding: 8px 14px;
            font-family: inherit;
            font-size: 0.85rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .cand-filter.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }

        .cf-count {
            background: var(--surface-tint);
            color: var(--muted);
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            padding: 1px 7px;
            min-width: 18px;
            text-align: center;
        }

        .cand-filter.is-active .cf-count { background: rgba(255, 255, 255, 0.22); color: #fff; }

        /* === Tri sur chaque carte === */
        .cand-tri {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 16px;
            padding-top: 14px;
            border-top: 1px solid var(--line);
        }

        .tri-btn {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 9px;
            padding: 7px 12px;
            font-family: inherit;
            font-size: 0.82rem;
            font-weight: 700;
            cursor: pointer;
            transition: border-color 0.12s ease, background 0.12s ease, color 0.12s ease;
        }

        .tri-btn:hover { border-color: var(--muted); }

        .tri-top.is-active { background: var(--green-soft); border-color: #bbf7d0; color: #15803d; }
        .tri-plus_tard.is-active { background: var(--accent-soft); border-color: #bfdbfe; color: var(--primary-dark); }
        .tri-poubelle.is-active { background: #fef2f2; border-color: #fecaca; color: #dc2626; }

        /* Liseré gauche selon statut */
        .cand-card.status-top { border-left: 3px solid var(--green); }
        .cand-card.status-plus_tard { border-left: 3px solid var(--primary); }
        .cand-card.status-poubelle { border-left: 3px solid #f87171; opacity: 0.6; }

        @media (max-width: 520px) {
            .summary { grid-template-columns: 1fr 1fr 1fr; }
            .create-form .btn { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="wrap">
        <div id="boot" class="view boot">Chargement…</div>

        <!-- Connexion admin -->
        <div id="login-view" class="view" hidden>
            <div class="login-wrap">
                <div class="card login-card">
                    <h1>Admin closer</h1>
                    <p>Accès réservé. Entrez le mot de passe admin.</p>
                    <form id="login-form">
                        <input type="password" id="admin-password" autocomplete="current-password" placeholder="Mot de passe admin" required />
                        <p id="login-error" class="err" role="alert"></p>
                        <button type="submit" id="login-btn" class="btn">Accéder</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tableau de bord -->
        <div id="admin-view" class="view" hidden>
            <div class="head">
                <div>
                    <h1>Codes d'accès closer</h1>
                    <p>Un code par closer + suivi des visites de la page /closer.</p>
                </div>
                <button id="logout-btn" class="btn btn-ghost btn-sm" type="button">Déconnexion</button>
            </div>

            <div class="tabs">
                <button class="tab is-active" id="tab-codes" type="button">Codes</button>
                <button class="tab" id="tab-candidatures" type="button">Candidatures <span class="tab-count" id="tab-cand-count" hidden>0</span></button>
            </div>

            <!-- Panneau Codes -->
            <div id="panel-codes" class="panel">
                <div class="card create-card">
                    <h2>Créer un code</h2>
                    <form id="create-form" class="create-form">
                        <input type="text" id="create-label" placeholder="Nom du closer (ex. Brice Malt)" autocomplete="off" required />
                        <input type="text" id="create-notes" placeholder="Lien profil / infos (optionnel)" autocomplete="off" />
                        <button type="submit" id="create-btn" class="btn">Générer le code</button>
                    </form>
                    <p id="create-error" class="err" role="alert"></p>
                    <div id="new-code" class="new-code">
                        <span class="new-code-label">Nouveau code pour <b id="new-code-name"></b> :</span>
                        <span style="display:inline-flex;align-items:center;gap:10px;">
                            <span class="new-code-val" id="new-code-val"></span>
                            <button class="copy-btn" id="new-code-copy" type="button" title="Copier" aria-label="Copier le code">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                            </button>
                        </span>
                    </div>
                </div>

                <div class="card">
                    <h2>Assignation des leads</h2>
                    <p style="margin:0 0 12px;color:#64748b;font-size:13px;">Répartit équitablement les leads qualifiés (non assignés, non acheteurs, avec téléphone) entre les closers <strong>actifs</strong>. Pour tester : mets min. minutes à <strong>0</strong> et laisse la date vide.</p>
                    <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
                        <label style="display:flex;flex-direction:column;gap:4px;font-size:12px;color:#475569;">Min. minutes vues<input type="number" id="assign-min" value="81" min="0" style="padding:9px;border:1px solid #cbd5e1;border-radius:8px;width:120px;"></label>
                        <label style="display:flex;flex-direction:column;gap:4px;font-size:12px;color:#475569;">Date session (vide = toutes)<input type="text" id="assign-date" placeholder="2026-07-02" style="padding:9px;border:1px solid #cbd5e1;border-radius:8px;width:150px;"></label>
                        <button type="button" id="assign-btn" class="btn">Répartir entre les closers</button>
                        <button type="button" id="unassign-btn" class="btn btn-ghost">Tout désassigner</button>
                    </div>
                    <p id="assign-result" style="margin:12px 0 0;font-size:13px;font-weight:600;"></p>
                </div>
                <script is:inline>
                (function () {
                    var EP = '/.netlify/functions/closer-admin';
                    var btn = document.getElementById('assign-btn');
                    var ubtn = document.getElementById('unassign-btn');
                    var out = document.getElementById('assign-result');
                    if (!btn) return;
                    btn.addEventListener('click', async function () {
                        var min = document.getElementById('assign-min').value;
                        var date = (document.getElementById('assign-date').value || '').trim();
                        btn.disabled = true; out.style.color = '#475569'; out.textContent = 'Répartition…';
                        try {
                            var r = await fetch(EP, { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'assign-split', min_minutes: min, session_date: date || null }) });
                            var d = await r.json();
                            if (r.ok) {
                                var detail = (d.perCloser || []).map(function (c) { return c.label + ' : ' + c.count; }).join(' · ');
                                out.textContent = d.total + ' leads répartis. ' + detail;
                                out.style.color = '#16a34a';
                            } else { out.textContent = d.error || 'Erreur'; out.style.color = '#dc2626'; }
                        } catch (e) { out.textContent = 'Erreur réseau'; out.style.color = '#dc2626'; }
                        btn.disabled = false;
                    });
                    ubtn.addEventListener('click', async function () {
                        if (!confirm('Désassigner TOUS les leads ?')) return;
                        ubtn.disabled = true; out.style.color = '#475569'; out.textContent = 'Réinitialisation…';
                        try {
                            var r = await fetch(EP, { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'unassign-all' }) });
                            out.textContent = r.ok ? 'Tout désassigné.' : 'Erreur'; out.style.color = r.ok ? '#16a34a' : '#dc2626';
                        } catch (e) { out.textContent = 'Erreur réseau'; out.style.color = '#dc2626'; }
                        ubtn.disabled = false;
                    });
                })();
                </script>

                <div class="summary">
                    <div class="sum"><div class="sum-val" id="sum-total">0</div><div class="sum-label">Codes</div></div>
                    <div class="sum"><div class="sum-val is-green" id="sum-came">0</div><div class="sum-label">Venus</div></div>
                    <div class="sum"><div class="sum-val is-muted" id="sum-not">0</div><div class="sum-label">Pas venus</div></div>
                </div>

                <div id="codes" class="codes"></div>
                <p id="codes-empty" class="boot" hidden>Aucun code pour l'instant. Créez-en un ci-dessus.</p>
            </div>

            <!-- Panneau Candidatures -->
            <div id="panel-candidatures" class="panel" hidden>
                <div class="cand-filters" id="cand-filters">
                    <button class="cand-filter is-active" data-filter="all" type="button">Tous <span class="cf-count" id="cf-count-all">0</span></button>
                    <button class="cand-filter" data-filter="top" type="button">⭐ Top <span class="cf-count" id="cf-count-top">0</span></button>
                    <button class="cand-filter" data-filter="plus_tard" type="button">🕓 Plus tard <span class="cf-count" id="cf-count-plus_tard">0</span></button>
                    <button class="cand-filter" data-filter="poubelle" type="button">🗑 Poubelle <span class="cf-count" id="cf-count-poubelle">0</span></button>
                </div>
                <div id="candidatures" class="codes"></div>
                <p id="cand-empty" class="boot" hidden>Aucune candidature pour l'instant.</p>
            </div>
        </div>
    </div>

    <script is:inline>
        (function () {
            var SESSION = '/.netlify/functions/admin-es2-session';
            var LOGIN = '/.netlify/functions/admin-es2-login';
            var LOGOUT = '/.netlify/functions/admin-es2-logout';
            var API = '/.netlify/functions/closer-admin';

            var boot = document.getElementById('boot');
            var loginView = document.getElementById('login-view');
            var adminView = document.getElementById('admin-view');

            var dtf = new Intl.DateTimeFormat('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
            function fmtDate(iso) {
                if (!iso) return '—';
                try { return dtf.format(new Date(iso)); } catch (e) { return '—'; }
            }
            function esc(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
                });
            }

            function showView(which) {
                boot.hidden = which !== 'boot';
                loginView.hidden = which !== 'login';
                adminView.hidden = which !== 'admin';
            }

            // --- Copie presse-papier ---
            function copyText(text, btnEl) {
                function ok() {
                    if (!btnEl) return;
                    btnEl.classList.add('copied');
                    setTimeout(function () { btnEl.classList.remove('copied'); }, 1400);
                }
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(ok).catch(function () { fallback(text); ok(); });
                } else { fallback(text); ok(); }
            }
            function fallback(text) {
                var ta = document.createElement('textarea');
                ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
                document.body.appendChild(ta); ta.select();
                try { document.execCommand('copy'); } catch (e) { /* noop */ }
                document.body.removeChild(ta);
            }

            // --- Rendu de la liste ---
            var codesAll = [];

            function renderCodes(codes) {
                codesAll = Array.isArray(codes) ? codes : [];
                var host = document.getElementById('codes');
                var empty = document.getElementById('codes-empty');
                var came = 0, not = 0;

                codes.forEach(function (c) {
                    var visited = (c.visit_count > 0) || !!c.first_visit_at;
                    if (c.active === false) { /* révoqué : compté ni venu ni pas-venu actif */ }
                    if (visited) came++; else not++;
                });

                document.getElementById('sum-total').textContent = codes.length;
                document.getElementById('sum-came').textContent = came;
                document.getElementById('sum-not').textContent = not;

                if (!codes.length) { host.innerHTML = ''; empty.hidden = false; return; }
                empty.hidden = true;

                host.innerHTML = codes.map(function (c) {
                    var visited = (c.visit_count > 0) || !!c.first_visit_at;
                    var revoked = c.active === false;
                    var badge = revoked
                        ? '<span class="badge badge-revoked">Révoqué</span>'
                        : (visited ? '<span class="badge badge-came">Venu</span>' : '<span class="badge badge-not">Pas venu</span>');
                    var action = revoked
                        ? '<button class="btn btn-ghost btn-sm js-toggle" data-id="' + c.id + '" data-active="true">Réactiver</button>'
                        : '<button class="btn btn-ghost btn-sm js-toggle" data-id="' + c.id + '" data-active="false">Révoquer</button>';
                    return '' +
                        '<div class="code-card' + (revoked ? ' is-revoked' : '') + '">' +
                            '<div class="code-top">' +
                                '<div class="code-name">' + esc(c.label) + ' ' + badge + '</div>' +
                                '<div class="code-actions">' +
                                    '<span class="code-chip">' + esc(c.code) +
                                        '<button class="copy-btn js-copy" data-code="' + esc(c.code) + '" title="Copier" aria-label="Copier">' +
                                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>' +
                                        '</button>' +
                                    '</span>' +
                                    action +
                                    '<button class="code-del js-delete" data-id="' + c.id + '" title="Supprimer" aria-label="Supprimer">' +
                                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>' +
                                    '</button>' +
                                '</div>' +
                            '</div>' +
                            '<div class="code-meta">' +
                                '<span class="meta-item"><span class="meta-k">1ʳᵉ visite :</span> <b>' + fmtDate(c.first_visit_at) + '</b></span>' +
                                '<span class="meta-item"><span class="meta-k">Dernière :</span> <b>' + fmtDate(c.last_visit_at) + '</b></span>' +
                                '<span class="meta-item"><span class="meta-k">Visites :</span> <b>' + (c.visit_count || 0) + '</b></span>' +
                                '<span class="meta-item"><span class="meta-k">Confidentialité :</span> <b>' + (c.consent_at ? 'acceptée ' + fmtDate(c.consent_at) : '—') + '</b></span>' +
                            '</div>' +
                            '<div class="code-notes" data-id="' + c.id + '">' +
                                '<div class="code-notes-view">' +
                                    '<span class="code-notes-text">' + (c.notes ? linkifyText(c.notes) : '<span class="code-notes-empty">Aucune info</span>') + '</span>' +
                                    '<button class="code-notes-btn js-note-edit" data-id="' + c.id + '" type="button">' + (c.notes ? 'Modifier' : '+ Ajouter une info') + '</button>' +
                                '</div>' +
                                '<div class="code-notes-edit" hidden>' +
                                    '<textarea class="js-note-input" rows="2" placeholder="Lien profil, source, remarque…">' + esc(c.notes || '') + '</textarea>' +
                                    '<div class="code-notes-edit-actions">' +
                                        '<button class="btn btn-sm js-note-save" data-id="' + c.id + '" type="button">Enregistrer</button>' +
                                        '<button class="btn btn-ghost btn-sm js-note-cancel" type="button">Annuler</button>' +
                                    '</div>' +
                                '</div>' +
                            '</div>' +
                        '</div>';
                }).join('');

                host.querySelectorAll('.js-copy').forEach(function (b) {
                    b.addEventListener('click', function () { copyText(b.getAttribute('data-code'), b); });
                });
                host.querySelectorAll('.js-toggle').forEach(function (b) {
                    b.addEventListener('click', function () { toggleCode(+b.getAttribute('data-id'), b.getAttribute('data-active') === 'true'); });
                });
                host.querySelectorAll('.js-delete').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var id = +b.getAttribute('data-id');
                        var c = codesAll.find(function (x) { return x.id === id; });
                        var name = c ? c.label : '';
                        if (window.confirm('Supprimer définitivement le code « ' + name + ' » ?\n\nLes candidatures déjà reçues sont conservées.')) {
                            deleteCode(id);
                        }
                    });
                });
                host.querySelectorAll('.js-note-edit').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        box.querySelector('.code-notes-view').hidden = true;
                        box.querySelector('.code-notes-edit').hidden = false;
                        var ta = box.querySelector('.js-note-input');
                        ta.focus();
                    });
                });
                host.querySelectorAll('.js-note-cancel').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        box.querySelector('.code-notes-edit').hidden = true;
                        box.querySelector('.code-notes-view').hidden = false;
                    });
                });
                host.querySelectorAll('.js-note-save').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        var val = box.querySelector('.js-note-input').value.trim();
                        saveNotes(+b.getAttribute('data-id'), val);
                    });
                });
            }

            function linkifyText(t) {
                return esc(t).replace(/(https?:\/\/[^\s]+)/g, function (u) {
                    return '<a href="' + u + '" target="_blank" rel="noopener noreferrer">' + u + '</a>';
                });
            }

            async function saveNotes(id, notes) {
                var c = codesAll.find(function (x) { return x.id === id; });
                if (c) c.notes = notes;          // MAJ optimiste
                renderCodes(codesAll);
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'code-notes', id: id, notes: notes }),
                    });
                } catch (e) { /* noop */ }
            }
            window.__renderCloserCodes = renderCodes; // exposé pour aperçu/démo

            async function loadCodes() {
                try {
                    var r = await fetch(API, { credentials: 'same-origin' });
                    if (r.status === 401) { showView('login'); return; }
                    var d = await r.json();
                    if (!r.ok) { document.getElementById('create-error').textContent = d.error || 'Erreur de chargement.'; return; }
                    renderCodes(d.codes || []);
                } catch (e) {
                    document.getElementById('create-error').textContent = 'Erreur réseau.';
                }
            }

            async function toggleCode(id, active) {
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'revoke', id: id, active: active }),
                    });
                    loadCodes();
                } catch (e) { /* noop */ }
            }

            async function deleteCode(id) {
                // suppression optimiste
                codesAll = codesAll.filter(function (x) { return x.id !== id; });
                renderCodes(codesAll);
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'delete', id: id }),
                    });
                    loadCodes();
                } catch (e) { /* noop */ }
            }

            // --- Candidatures ---
            function candTag(label, value) {
                var v = (value || '').toLowerCase();
                var cls = v === 'oui' ? 'is-yes' : (v === 'non' ? 'is-no' : (value ? 'is-maybe' : ''));
                return '<span class="cand-tag ' + cls + '">' + label + ' : <b>' + esc(value || '—') + '</b></span>';
            }
            function linkify(url) {
                if (/^https?:\/\//i.test(url)) {
                    return '<a href="' + esc(url) + '" target="_blank" rel="noopener noreferrer">' + esc(url) + '</a>';
                }
                return esc(url || '—');
            }
            var candAll = [];
            var candFilter = 'all';

            function renderCandidatures(list) {
                candAll = Array.isArray(list) ? list : [];
                drawCandidatures();
            }

            function drawCandidatures() {
                var host = document.getElementById('candidatures');
                var empty = document.getElementById('cand-empty');
                var countEl = document.getElementById('tab-cand-count');

                // Comptes par statut
                var counts = { all: 0, top: 0, plus_tard: 0, poubelle: 0 };
                candAll.forEach(function (c) {
                    var s = c.status || 'nouveau';
                    if (s !== 'poubelle') counts.all++;
                    if (counts[s] != null) counts[s]++;
                });
                document.getElementById('cf-count-all').textContent = counts.all;
                document.getElementById('cf-count-top').textContent = counts.top;
                document.getElementById('cf-count-plus_tard').textContent = counts.plus_tard;
                document.getElementById('cf-count-poubelle').textContent = counts.poubelle;

                countEl.textContent = candAll.length;
                countEl.hidden = candAll.length === 0;

                // Filtre courant ("Tous" = tout sauf poubelle)
                var list = candAll.filter(function (c) {
                    var s = c.status || 'nouveau';
                    return candFilter === 'all' ? s !== 'poubelle' : s === candFilter;
                });

                if (!list.length) {
                    host.innerHTML = '';
                    empty.hidden = false;
                    empty.textContent = candAll.length ? 'Rien dans cette catégorie.' : 'Aucune candidature pour l\'instant.';
                    return;
                }
                empty.hidden = true;

                host.innerHTML = list.map(function (c) {
                    var s = c.status || 'nouveau';
                    function triBtn(val, label) {
                        return '<button class="tri-btn tri-' + val + (s === val ? ' is-active' : '') +
                            '" data-id="' + c.id + '" data-status="' + val + '" type="button">' + label + '</button>';
                    }
                    return '' +
                        '<div class="cand-card status-' + s + '">' +
                            '<div class="cand-top">' +
                                '<div class="cand-name">' + esc(c.full_name) +
                                    (c.code_label ? '<span class="cand-via">via ' + esc(c.code_label) + '</span>' : '') +
                                '</div>' +
                                '<div class="cand-when">' + fmtDate(c.created_at) + '</div>' +
                            '</div>' +
                            '<div class="cand-contact">' +
                                '<a href="mailto:' + esc(c.email) + '">' + esc(c.email) + '</a>' +
                                '<span>' + esc(c.phone) + '</span>' +
                            '</div>' +
                            '<div class="cand-tags">' +
                                candTag('High-ticket 1500€+', c.closed_highticket) +
                                candTag('100% résultat', c.ok_commission) +
                                candTag('Enregistrement', c.ok_recording) +
                                candTag('Dispo 3 juil', c.available_jul3) +
                            '</div>' +
                            '<div class="cand-block"><div class="q">Résultats concrets</div><div class="a">' + esc(c.results) + '</div></div>' +
                            '<div class="cand-block"><div class="q">Échantillon audio</div><div class="a">' + linkify(c.audio_url) + '</div></div>' +
                            '<div class="cand-block"><div class="q">Pourquoi cette opportunité</div><div class="a">' + esc(c.motivation) + '</div></div>' +
                            '<div class="cand-tri">' +
                                triBtn('top', '⭐ Top') +
                                triBtn('plus_tard', '🕓 Plus tard') +
                                triBtn('poubelle', '🗑 Poubelle') +
                            '</div>' +
                        '</div>';
                }).join('');

                host.querySelectorAll('.tri-btn').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var id = +b.getAttribute('data-id');
                        var val = b.getAttribute('data-status');
                        // re-cliquer le statut actif le remet à "nouveau"
                        var cur = (candAll.find(function (x) { return x.id === id; }) || {}).status || 'nouveau';
                        setCandStatus(id, cur === val ? 'nouveau' : val);
                    });
                });
            }

            async function setCandStatus(id, status) {
                var c = candAll.find(function (x) { return x.id === id; });
                if (c) c.status = status;            // MAJ optimiste
                drawCandidatures();
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'cand-status', id: id, status: status }),
                    });
                } catch (e) { /* noop */ }
            }

            window.__renderCloserCandidatures = renderCandidatures; // exposé pour aperçu/démo

            async function loadCandidatures() {
                try {
                    var r = await fetch(API + '?resource=candidatures', { credentials: 'same-origin' });
                    if (r.status === 401) { showView('login'); return; }
                    var d = await r.json();
                    if (!r.ok) return;
                    renderCandidatures(d.candidatures || []);
                } catch (e) { /* noop */ }
            }

            function enterAdmin() {
                showView('admin');
                loadCodes();
                loadCandidatures();
            }

            // Onglets
            function switchTab(which) {
                var isCodes = which === 'codes';
                document.getElementById('tab-codes').classList.toggle('is-active', isCodes);
                document.getElementById('tab-candidatures').classList.toggle('is-active', !isCodes);
                document.getElementById('panel-codes').hidden = !isCodes;
                document.getElementById('panel-candidatures').hidden = isCodes;
                if (!isCodes) loadCandidatures();
            }
            document.getElementById('tab-codes').addEventListener('click', function () { switchTab('codes'); });
            document.getElementById('tab-candidatures').addEventListener('click', function () { switchTab('candidatures'); });

            // Filtres candidatures
            document.querySelectorAll('.cand-filter').forEach(function (f) {
                f.addEventListener('click', function () {
                    candFilter = f.getAttribute('data-filter');
                    document.querySelectorAll('.cand-filter').forEach(function (x) {
                        x.classList.toggle('is-active', x === f);
                    });
                    drawCandidatures();
                });
            });

            // --- Boot : vérifie la session admin ---
            async function init() {
                try {
                    var r = await fetch(SESSION, { credentials: 'same-origin' });
                    var d = r.ok ? await r.json() : {};
                    if (d && d.authenticated) { enterAdmin(); return; }
                } catch (e) { /* noop */ }
                showView('login');
            }

            // --- Login ---
            document.getElementById('login-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var pwd = document.getElementById('admin-password').value;
                var btn = document.getElementById('login-btn');
                var errEl = document.getElementById('login-error');
                errEl.textContent = '';
                btn.disabled = true;
                try {
                    var r = await fetch(LOGIN, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ password: pwd }),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e2) { /* noop */ }
                    if (r.ok) { enterAdmin(); return; }
                    if (d.code === 'SETUP_REQUIRED') {
                        errEl.textContent = 'Aucun mot de passe admin défini. Configure-le d\'abord sur /es-cockpit.';
                    } else {
                        errEl.textContent = d.error || 'Mot de passe incorrect.';
                    }
                } catch (e3) {
                    errEl.textContent = 'Erreur réseau.';
                }
                btn.disabled = false;
            });

            // --- Logout ---
            document.getElementById('logout-btn').addEventListener('click', async function () {
                try { await fetch(LOGOUT, { method: 'POST', credentials: 'same-origin' }); } catch (e) { /* noop */ }
                showView('login');
            });

            // --- Création ---
            document.getElementById('create-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var label = document.getElementById('create-label').value.trim();
                var notes = document.getElementById('create-notes').value.trim();
                var btn = document.getElementById('create-btn');
                var errEl = document.getElementById('create-error');
                var box = document.getElementById('new-code');
                errEl.textContent = '';
                if (!label) { errEl.textContent = 'Entrez un nom.'; return; }
                btn.disabled = true;
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'create', label: label, notes: notes }),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e2) { /* noop */ }
                    if (r.ok && d.row) {
                        document.getElementById('new-code-name').textContent = d.row.label;
                        document.getElementById('new-code-val').textContent = d.row.code;
                        box.classList.add('is-shown');
                        document.getElementById('create-label').value = '';
                        document.getElementById('create-notes').value = '';
                        loadCodes();
                    } else {
                        errEl.textContent = d.error || 'Création impossible.';
                    }
                } catch (e3) {
                    errEl.textContent = 'Erreur réseau.';
                }
                btn.disabled = false;
            });

            document.getElementById('new-code-copy').addEventListener('click', function () {
                copyText(document.getElementById('new-code-val').textContent, this);
            });

            init();
        })();
    </script>
</body>
</html>
