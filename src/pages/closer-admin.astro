---
// Admin des codes d'accès /closer — protégé par la session admin ES2 existante.
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — Codes d'accès closer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- is:global : la liste de codes est rendue en JS (innerHTML), donc non concernée par le scoping Astro -->
    <style is:global>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        [hidden] { display: none !important; }

        :root {
            color-scheme: light only;
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --ink: #0f172a;
            --ink-soft: #334155;
            --muted: #64748b;
            --line: #e2e8f0;
            --surface: #ffffff;
            --bg: #f1f5f9;
            --accent-soft: #eff6ff;
            --green: #16a34a;
            --green-soft: #f0fdf4;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }

        .wrap {
            max-width: 920px;
            margin: 0 auto;
            padding: clamp(20px, 4vw, 40px) clamp(16px, 3vw, 24px);
        }

        .view[hidden] { display: none; }

        .boot {
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-size: 0.95rem;
        }

        /* === Login === */
        .login-wrap {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 18px;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
            padding: clamp(16px, 3vw, 22px);
        }

        .login-card {
            width: 100%;
            max-width: 380px;
            padding: clamp(26px, 5vw, 36px);
            text-align: center;
        }

        .login-card h1 { font-size: 1.25rem; font-weight: 800; margin-bottom: 6px; }
        .login-card p { font-size: 0.9rem; color: var(--muted); margin-bottom: 22px; }

        input[type="password"], input[type="text"] {
            width: 100%;
            padding: 13px 15px;
            font-family: inherit;
            font-size: 1rem;
            color: var(--ink);
            border: 2px solid var(--line);
            border-radius: 11px;
            background: #fff;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.16);
        }

        .btn {
            border: none;
            border-radius: 11px;
            padding: 13px 20px;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
            transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
            white-space: nowrap;
        }

        .btn:hover { transform: translateY(-1px); }
        .btn:disabled { opacity: 0.6; cursor: default; transform: none; }

        .btn-ghost {
            background: var(--surface);
            color: var(--ink-soft);
            border: 1px solid var(--line);
            box-shadow: none;
            font-weight: 600;
        }

        .btn-sm { padding: 8px 13px; font-size: 0.82rem; }

        .login-card .btn { width: 100%; margin-top: 14px; }
        .err { min-height: 1.1em; margin-top: 10px; font-size: 0.85rem; font-weight: 600; color: #dc2626; }

        /* === Header === */
        .head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            margin-bottom: 22px;
            flex-wrap: wrap;
        }

        .head h1 { font-size: clamp(1.3rem, 3vw, 1.7rem); font-weight: 900; letter-spacing: -0.02em; }
        .head p { font-size: 0.88rem; color: var(--muted); margin-top: 2px; }

        /* === Create === */
        .create-card { padding: 20px; margin-bottom: 18px; }
        .create-card h2 { font-size: 0.95rem; font-weight: 800; margin-bottom: 12px; }

        .create-form {
            display: grid;
            gap: 10px;
            grid-template-columns: 1fr;
        }

        @media (min-width: 600px) {
            .create-form { grid-template-columns: 1fr 1fr auto; align-items: center; }
        }

        .create-form input { width: 100%; }

        .new-code {
            display: none;
            margin-top: 14px;
            padding: 14px 16px;
            border-radius: 12px;
            background: var(--green-soft);
            border: 1px solid #bbf7d0;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .new-code.is-shown { display: flex; }
        .new-code-label { font-size: 0.85rem; color: #15803d; font-weight: 600; }
        .new-code-val { font-size: 1.15rem; font-weight: 800; letter-spacing: 0.06em; color: var(--ink); }

        /* === Summary === */
        .summary {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 18px;
        }

        .sum {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 14px 16px;
            text-align: center;
        }

        .sum-val { font-size: 1.5rem; font-weight: 900; letter-spacing: -0.02em; }
        .sum-val.is-green { color: var(--green); }
        .sum-val.is-muted { color: var(--muted); }
        .sum-label { font-size: 0.74rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }

        /* === Code cards === */
        .codes { display: grid; gap: 12px; }

        .code-card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px 18px;
        }

        .code-card.is-revoked { opacity: 0.62; }

        .code-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .code-name { font-size: 1.05rem; font-weight: 800; display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }

        .badge {
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            padding: 3px 9px;
            border-radius: 999px;
        }

        .badge-came { background: var(--green-soft); color: #15803d; border: 1px solid #bbf7d0; }
        .badge-not { background: #f8fafc; color: var(--muted); border: 1px solid var(--line); }
        .badge-revoked { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }

        .code-actions { display: flex; gap: 8px; align-items: center; }

        .code-del {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--muted);
            border-radius: 9px;
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex-shrink: 0;
            transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
        }

        .code-del:hover { color: #dc2626; border-color: #fecaca; background: #fef2f2; }
        .code-del svg { width: 16px; height: 16px; }

        .code-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            color: var(--primary-dark);
            background: var(--accent-soft);
            border: 1px solid #bfdbfe;
            border-radius: 9px;
            padding: 6px 11px;
        }

        .copy-btn {
            border: none;
            background: transparent;
            color: var(--primary-dark);
            cursor: pointer;
            padding: 2px;
            display: inline-flex;
            border-radius: 6px;
        }

        .copy-btn svg { width: 15px; height: 15px; }
        .copy-btn.copied { color: var(--green); }

        .code-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px 22px;
            margin-top: 12px;
            align-items: center;
        }

        .meta-item { font-size: 0.84rem; color: var(--ink-soft); }
        .meta-item b { color: var(--ink); font-weight: 700; }
        .meta-k { color: var(--muted); }

        /* === Note / infos sur la carte code === */
        .code-notes {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px dashed var(--line);
        }

        .code-notes-view {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            flex-wrap: wrap;
        }

        .code-notes-text {
            flex: 1;
            min-width: 0;
            font-size: 0.86rem;
            color: var(--ink-soft);
            line-height: 1.5;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .code-notes-text a { color: var(--primary-dark); font-weight: 600; word-break: break-all; }
        .code-notes-empty { color: var(--muted); font-style: italic; }

        .code-notes-btn {
            border: none;
            background: transparent;
            color: var(--primary-dark);
            font-family: inherit;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            padding: 2px 4px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .code-notes-btn:hover { text-decoration: underline; }

        .code-notes-edit textarea {
            width: 100%;
            padding: 10px 12px;
            font-family: inherit;
            font-size: 0.9rem;
            color: var(--ink);
            border: 2px solid var(--line);
            border-radius: 10px;
            background: #fff;
            resize: vertical;
        }

        .code-notes-edit textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.16);
        }

        .code-notes-edit-actions {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }

        /* === Onglets === */
        .tabs { display: flex; gap: 8px; margin-bottom: 18px; }

        .tab {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 11px;
            padding: 9px 16px;
            font-family: inherit;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .tab.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }

        .tab-count {
            background: var(--primary);
            color: #fff;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            padding: 1px 7px;
        }

        /* === Cartes candidature === */
        .cand-card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 18px 20px;
        }

        .cand-top {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            align-items: baseline;
            margin-bottom: 12px;
        }

        .cand-name { font-size: 1.1rem; font-weight: 800; }
        .cand-via { font-size: 0.8rem; font-weight: 600; color: var(--muted); margin-left: 8px; }
        .cand-when { font-size: 0.82rem; color: var(--muted); white-space: nowrap; }

        .cand-contact {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 18px;
            font-size: 0.88rem;
            margin-bottom: 14px;
        }
        .cand-contact a { color: var(--primary-dark); text-decoration: none; font-weight: 600; }
        .cand-contact span { color: var(--ink-soft); }

        .cand-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 6px; }

        .cand-tag {
            font-size: 0.78rem;
            font-weight: 600;
            border: 1px solid var(--line);
            border-radius: 999px;
            padding: 5px 11px;
            background: #f8fafc;
            color: var(--ink-soft);
        }
        .cand-tag b { color: var(--ink); font-weight: 700; }
        .cand-tag.is-yes { background: var(--green-soft); border-color: #bbf7d0; }
        .cand-tag.is-no { background: #fef2f2; border-color: #fecaca; }
        .cand-tag.is-maybe { background: var(--accent-soft); border-color: #bfdbfe; }

        .cand-block { margin-top: 12px; }
        .cand-block .q {
            font-size: 0.74rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--muted);
            margin-bottom: 4px;
        }
        .cand-block .a {
            font-size: 0.92rem;
            color: var(--ink-soft);
            white-space: pre-wrap;
            line-height: 1.55;
            word-break: break-word;
        }
        .cand-block .a a { color: var(--primary-dark); font-weight: 600; }

        /* === Filtres candidatures === */
        .cand-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 16px;
        }

        .cand-filter {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 999px;
            padding: 8px 14px;
            font-family: inherit;
            font-size: 0.85rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .cand-filter.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }

        .cf-count {
            background: var(--surface-tint);
            color: var(--muted);
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            padding: 1px 7px;
            min-width: 18px;
            text-align: center;
        }

        .cand-filter.is-active .cf-count { background: rgba(255, 255, 255, 0.22); color: #fff; }

        /* === Tri sur chaque carte === */
        .cand-tri {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 16px;
            padding-top: 14px;
            border-top: 1px solid var(--line);
        }

        .tri-btn {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 9px;
            padding: 7px 12px;
            font-family: inherit;
            font-size: 0.82rem;
            font-weight: 700;
            cursor: pointer;
            transition: border-color 0.12s ease, background 0.12s ease, color 0.12s ease;
        }

        .tri-btn:hover { border-color: var(--muted); }

        .tri-top.is-active { background: var(--green-soft); border-color: #bbf7d0; color: #15803d; }
        .tri-plus_tard.is-active { background: var(--accent-soft); border-color: #bfdbfe; color: var(--primary-dark); }
        .tri-poubelle.is-active { background: #fef2f2; border-color: #fecaca; color: #dc2626; }

        /* Liseré gauche selon statut */
        .cand-card.status-top { border-left: 3px solid var(--green); }
        .cand-card.status-plus_tard { border-left: 3px solid var(--primary); }
        .cand-card.status-poubelle { border-left: 3px solid #f87171; opacity: 0.6; }

        @media (max-width: 520px) {
            .summary { grid-template-columns: 1fr 1fr 1fr; }
            .create-form .btn { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="wrap">
        <div id="boot" class="view boot">Chargement…</div>

        <!-- Connexion admin -->
        <div id="login-view" class="view" hidden>
            <div class="login-wrap">
                <div class="card login-card">
                    <h1>Admin closer</h1>
                    <p>Accès réservé. Entrez le mot de passe admin.</p>
                    <form id="login-form">
                        <input type="password" id="admin-password" autocomplete="current-password" placeholder="Mot de passe admin" required />
                        <p id="login-error" class="err" role="alert"></p>
                        <button type="submit" id="login-btn" class="btn">Accéder</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tableau de bord -->
        <div id="admin-view" class="view" hidden>
            <div class="head">
                <div>
                    <h1>Espace closers</h1>
                    <p>Gère tes closers, leurs identifiants, leurs perfs et l'assignation des leads.</p>
                </div>
                <button id="logout-btn" class="btn btn-ghost btn-sm" type="button">Déconnexion</button>
            </div>

            <!-- Sélecteur d'univers -->
            <div class="universe-tabs">
                <button class="utab is-active" id="u-recrut" type="button">
                    <span class="utab-t">Recrutement</span>
                    <span class="utab-s">Codes d'accès + candidatures</span>
                </button>
                <button class="utab" id="u-closers" type="button">
                    <span class="utab-t">Mes closers</span>
                    <span class="utab-s">Closers choisis + assignation</span>
                </button>
            </div>

            <!-- ===================== UNIVERS 1 : Recrutement ===================== -->
            <div id="universe-recrut">
                <div class="tabs subtabs">
                    <button class="tab is-active" id="tab-codes" type="button">Codes d'accès</button>
                    <button class="tab" id="tab-candidatures" type="button">Candidatures <span class="tab-count" id="tab-cand-count" hidden>0</span></button>
                </div>

                <!-- Panneau Codes d'accès -->
                <div id="panel-codes" class="panel">
                    <div class="card create-card">
                        <h2>Créer un code d'accès</h2>
                        <p class="assign-help">Un code rapide pour qu'une personne regarde la page de présentation <strong>/closer</strong> et poste sa candidature.</p>
                        <form id="code-form" class="create-form">
                            <input type="text" id="code-label" placeholder="Nom (ex. Brice Malt)" autocomplete="off" required />
                            <input type="text" id="code-notes" placeholder="Lien profil / infos (optionnel)" autocomplete="off" />
                            <button type="submit" id="code-btn" class="btn">Générer le code</button>
                        </form>
                        <p id="code-error" class="err" role="alert"></p>
                        <div id="new-code" class="new-code">
                            <span class="new-code-label">Nouveau code pour <b id="new-code-name"></b> :</span>
                            <span style="display:inline-flex;align-items:center;gap:10px;">
                                <span class="new-code-val" id="new-code-val"></span>
                                <button class="copy-btn" id="new-code-copy" type="button" title="Copier" aria-label="Copier le code">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                </button>
                            </span>
                        </div>
                    </div>

                    <div class="summary">
                        <div class="sum"><div class="sum-val" id="sum-total">0</div><div class="sum-label">Codes</div></div>
                        <div class="sum"><div class="sum-val is-green" id="sum-came">0</div><div class="sum-label">Venus</div></div>
                        <div class="sum"><div class="sum-val is-muted" id="sum-not">0</div><div class="sum-label">Pas venus</div></div>
                    </div>

                    <div id="codes" class="codes"></div>
                    <p id="codes-empty" class="boot" hidden>Aucun code pour l'instant. Créez-en un ci-dessus.</p>
                </div>

                <!-- Panneau Candidatures -->
                <div id="panel-candidatures" class="panel" hidden>
                    <div class="cand-filters" id="cand-filters">
                        <button class="cand-filter is-active" data-filter="all" type="button">Tous <span class="cf-count" id="cf-count-all">0</span></button>
                        <button class="cand-filter" data-filter="top" type="button">⭐ Top <span class="cf-count" id="cf-count-top">0</span></button>
                        <button class="cand-filter" data-filter="plus_tard" type="button">🕓 Plus tard <span class="cf-count" id="cf-count-plus_tard">0</span></button>
                        <button class="cand-filter" data-filter="poubelle" type="button">🗑 Poubelle <span class="cf-count" id="cf-count-poubelle">0</span></button>
                    </div>
                    <div id="candidatures" class="codes"></div>
                    <p id="cand-empty" class="boot" hidden>Aucune candidature pour l'instant.</p>
                </div>
            </div>

            <!-- ===================== UNIVERS 2 : Mes closers ===================== -->
            <div id="universe-closers" hidden>
                <div class="tabs subtabs">
                    <button class="tab is-active" id="tab-closers" type="button">Closers</button>
                    <button class="tab" id="tab-assign" type="button">Assignation</button>
                </div>

                <div class="session-bar">
                    <span class="session-bar-label">📅 Session</span>
                    <select id="session-select"></select>
                    <span id="session-meta" class="session-bar-meta"></span>
                </div>

                <!-- Panneau Closers -->
                <div id="panel-closers" class="panel">
                    <div class="panel-toolbar"><button type="button" id="closers-refresh" class="btn btn-sm">&#8635; Rafraîchir</button></div>
                    <div id="kpi-global" class="kpi-grid"></div>
                    <div id="recredit-box" class="recredit-box" hidden></div>

                    <div class="card create-card">
                        <h2>Ajouter un closer</h2>
                        <p class="assign-help">Les closers avec qui tu décides vraiment de travailler. Ils se connectent avec email + mot de passe à la console et à la documentation.</p>
                        <form id="create-form" class="create-form">
                            <input type="text" id="create-label" placeholder="Nom (ex. Brice Malt)" autocomplete="off" required />
                            <input type="email" id="create-email" placeholder="Email de connexion" autocomplete="off" required />
                            <input type="text" id="create-password" placeholder="Mot de passe (min. 6)" autocomplete="off" required />
                            <input type="text" id="create-notes" placeholder="Lien profil / infos (optionnel)" autocomplete="off" />
                            <button type="submit" id="create-btn" class="btn">Créer le closer</button>
                        </form>
                        <p id="create-error" class="err" role="alert"></p>
                        <div id="new-closer" class="new-code">
                            <span class="new-code-label">Closer créé : <b id="new-closer-name"></b>. Donne-lui l'email + le mot de passe que tu viens de saisir.</span>
