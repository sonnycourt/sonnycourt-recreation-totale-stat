---
// Admin des codes d'accès /closer — protégé par la session admin ES2 existante.
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — Codes d'accès closer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- is:global : la liste de codes est rendue en JS (innerHTML), donc non concernée par le scoping Astro -->
    <style is:global>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        [hidden] { display: none !important; }

        :root {
            color-scheme: light only;
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --ink: #0f172a;
            --ink-soft: #334155;
            --muted: #64748b;
            --line: #e2e8f0;
            --surface: #ffffff;
            --bg: #f1f5f9;
            --accent-soft: #eff6ff;
            --green: #16a34a;
            --green-soft: #f0fdf4;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }

        .wrap {
            max-width: 920px;
            margin: 0 auto;
            padding: clamp(20px, 4vw, 40px) clamp(16px, 3vw, 24px);
        }

        .view[hidden] { display: none; }

        .boot {
            min-height: 60vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-size: 0.95rem;
        }

        /* === Login === */
        .login-wrap {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 18px;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
        }

        .login-card {
            width: 100%;
            max-width: 380px;
            padding: clamp(26px, 5vw, 36px);
            text-align: center;
        }

        .login-card h1 { font-size: 1.25rem; font-weight: 800; margin-bottom: 6px; }
        .login-card p { font-size: 0.9rem; color: var(--muted); margin-bottom: 22px; }

        input[type="password"], input[type="text"] {
            width: 100%;
            padding: 13px 15px;
            font-family: inherit;
            font-size: 1rem;
            color: var(--ink);
            border: 2px solid var(--line);
            border-radius: 11px;
            background: #fff;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.16);
        }

        .btn {
            border: none;
            border-radius: 11px;
            padding: 13px 20px;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
            transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
            white-space: nowrap;
        }

        .btn:hover { transform: translateY(-1px); }
        .btn:disabled { opacity: 0.6; cursor: default; transform: none; }

        .btn-ghost {
            background: var(--surface);
            color: var(--ink-soft);
            border: 1px solid var(--line);
            box-shadow: none;
            font-weight: 600;
        }

        .btn-sm { padding: 8px 13px; font-size: 0.82rem; }

        .login-card .btn { width: 100%; margin-top: 14px; }
        .err { min-height: 1.1em; margin-top: 10px; font-size: 0.85rem; font-weight: 600; color: #dc2626; }

        /* === Header === */
        .head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            margin-bottom: 22px;
            flex-wrap: wrap;
        }

        .head h1 { font-size: clamp(1.3rem, 3vw, 1.7rem); font-weight: 900; letter-spacing: -0.02em; }
        .head p { font-size: 0.88rem; color: var(--muted); margin-top: 2px; }

        /* === Create === */
        .create-card { padding: 20px; margin-bottom: 18px; }
        .create-card h2 { font-size: 0.95rem; font-weight: 800; margin-bottom: 12px; }

        .create-form {
            display: grid;
            gap: 10px;
            grid-template-columns: 1fr;
        }

        @media (min-width: 600px) {
            .create-form { grid-template-columns: 1fr 1fr auto; align-items: center; }
        }

        .create-form input { width: 100%; }

        .new-code {
            display: none;
            margin-top: 14px;
            padding: 14px 16px;
            border-radius: 12px;
            background: var(--green-soft);
            border: 1px solid #bbf7d0;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .new-code.is-shown { display: flex; }
        .new-code-label { font-size: 0.85rem; color: #15803d; font-weight: 600; }
        .new-code-val { font-size: 1.15rem; font-weight: 800; letter-spacing: 0.06em; color: var(--ink); }

        /* === Summary === */
        .summary {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 18px;
        }

        .sum {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 14px 16px;
            text-align: center;
        }

        .sum-val { font-size: 1.5rem; font-weight: 900; letter-spacing: -0.02em; }
        .sum-val.is-green { color: var(--green); }
        .sum-val.is-muted { color: var(--muted); }
        .sum-label { font-size: 0.74rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }

        /* === Code cards === */
        .codes { display: grid; gap: 12px; }

        .code-card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px 18px;
        }

        .code-card.is-revoked { opacity: 0.62; }

        .code-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .code-name { font-size: 1.05rem; font-weight: 800; display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }

        .badge {
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            padding: 3px 9px;
            border-radius: 999px;
        }

        .badge-came { background: var(--green-soft); color: #15803d; border: 1px solid #bbf7d0; }
        .badge-not { background: #f8fafc; color: var(--muted); border: 1px solid var(--line); }
        .badge-revoked { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }

        .code-actions { display: flex; gap: 8px; align-items: center; }

        .code-del {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--muted);
            border-radius: 9px;
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex-shrink: 0;
            transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
        }

        .code-del:hover { color: #dc2626; border-color: #fecaca; background: #fef2f2; }
        .code-del svg { width: 16px; height: 16px; }

        .code-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            color: var(--primary-dark);
            background: var(--accent-soft);
            border: 1px solid #bfdbfe;
            border-radius: 9px;
            padding: 6px 11px;
        }

        .copy-btn {
            border: none;
            background: transparent;
            color: var(--primary-dark);
            cursor: pointer;
            padding: 2px;
            display: inline-flex;
            border-radius: 6px;
        }

        .copy-btn svg { width: 15px; height: 15px; }
        .copy-btn.copied { color: var(--green); }

        .code-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px 22px;
            margin-top: 12px;
            align-items: center;
        }

        .meta-item { font-size: 0.84rem; color: var(--ink-soft); }
        .meta-item b { color: var(--ink); font-weight: 700; }
        .meta-k { color: var(--muted); }

        /* === Note / infos sur la carte code === */
        .code-notes {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px dashed var(--line);
        }

        .code-notes-view {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            flex-wrap: wrap;
        }

        .code-notes-text {
            flex: 1;
            min-width: 0;
            font-size: 0.86rem;
            color: var(--ink-soft);
            line-height: 1.5;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .code-notes-text a { color: var(--primary-dark); font-weight: 600; word-break: break-all; }
        .code-notes-empty { color: var(--muted); font-style: italic; }

        .code-notes-btn {
            border: none;
            background: transparent;
            color: var(--primary-dark);
            font-family: inherit;
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            padding: 2px 4px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .code-notes-btn:hover { text-decoration: underline; }

        .code-notes-edit textarea {
            width: 100%;
            padding: 10px 12px;
            font-family: inherit;
            font-size: 0.9rem;
            color: var(--ink);
            border: 2px solid var(--line);
            border-radius: 10px;
            background: #fff;
            resize: vertical;
        }

        .code-notes-edit textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.16);
        }

        .code-notes-edit-actions {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }

        /* === Onglets === */
        .tabs { display: flex; gap: 8px; margin-bottom: 18px; }

        .tab {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 11px;
            padding: 9px 16px;
            font-family: inherit;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .tab.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }

        .tab-count {
            background: var(--primary);
            color: #fff;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            padding: 1px 7px;
        }

        /* === Cartes candidature === */
        .cand-card {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 18px 20px;
        }

        .cand-top {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            align-items: baseline;
            margin-bottom: 12px;
        }

        .cand-name { font-size: 1.1rem; font-weight: 800; }
        .cand-via { font-size: 0.8rem; font-weight: 600; color: var(--muted); margin-left: 8px; }
        .cand-when { font-size: 0.82rem; color: var(--muted); white-space: nowrap; }

        .cand-contact {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 18px;
            font-size: 0.88rem;
            margin-bottom: 14px;
        }
        .cand-contact a { color: var(--primary-dark); text-decoration: none; font-weight: 600; }
        .cand-contact span { color: var(--ink-soft); }

        .cand-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 6px; }

        .cand-tag {
            font-size: 0.78rem;
            font-weight: 600;
            border: 1px solid var(--line);
            border-radius: 999px;
            padding: 5px 11px;
            background: #f8fafc;
            color: var(--ink-soft);
        }
        .cand-tag b { color: var(--ink); font-weight: 700; }
        .cand-tag.is-yes { background: var(--green-soft); border-color: #bbf7d0; }
        .cand-tag.is-no { background: #fef2f2; border-color: #fecaca; }
        .cand-tag.is-maybe { background: var(--accent-soft); border-color: #bfdbfe; }

        .cand-block { margin-top: 12px; }
        .cand-block .q {
            font-size: 0.74rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--muted);
            margin-bottom: 4px;
        }
        .cand-block .a {
            font-size: 0.92rem;
            color: var(--ink-soft);
            white-space: pre-wrap;
            line-height: 1.55;
            word-break: break-word;
        }
        .cand-block .a a { color: var(--primary-dark); font-weight: 600; }

        /* === Filtres candidatures === */
        .cand-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 16px;
        }

        .cand-filter {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 999px;
            padding: 8px 14px;
            font-family: inherit;
            font-size: 0.85rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .cand-filter.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }

        .cf-count {
            background: var(--surface-tint);
            color: var(--muted);
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 800;
            padding: 1px 7px;
            min-width: 18px;
            text-align: center;
        }

        .cand-filter.is-active .cf-count { background: rgba(255, 255, 255, 0.22); color: #fff; }

        /* === Tri sur chaque carte === */
        .cand-tri {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 16px;
            padding-top: 14px;
            border-top: 1px solid var(--line);
        }

        .tri-btn {
            border: 1px solid var(--line);
            background: var(--surface);
            color: var(--ink-soft);
            border-radius: 9px;
            padding: 7px 12px;
            font-family: inherit;
            font-size: 0.82rem;
            font-weight: 700;
            cursor: pointer;
            transition: border-color 0.12s ease, background 0.12s ease, color 0.12s ease;
        }

        .tri-btn:hover { border-color: var(--muted); }

        .tri-top.is-active { background: var(--green-soft); border-color: #bbf7d0; color: #15803d; }
        .tri-plus_tard.is-active { background: var(--accent-soft); border-color: #bfdbfe; color: var(--primary-dark); }
        .tri-poubelle.is-active { background: #fef2f2; border-color: #fecaca; color: #dc2626; }

        /* Liseré gauche selon statut */
        .cand-card.status-top { border-left: 3px solid var(--green); }
        .cand-card.status-plus_tard { border-left: 3px solid var(--primary); }
        .cand-card.status-poubelle { border-left: 3px solid #f87171; opacity: 0.6; }

        @media (max-width: 520px) {
            .summary { grid-template-columns: 1fr 1fr 1fr; }
            .create-form .btn { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="wrap">
        <div id="boot" class="view boot">Chargement…</div>

        <!-- Connexion admin -->
        <div id="login-view" class="view" hidden>
            <div class="login-wrap">
                <div class="card login-card">
                    <h1>Admin closer</h1>
                    <p>Accès réservé. Entrez le mot de passe admin.</p>
                    <form id="login-form">
                        <input type="password" id="admin-password" autocomplete="current-password" placeholder="Mot de passe admin" required />
                        <p id="login-error" class="err" role="alert"></p>
                        <button type="submit" id="login-btn" class="btn">Accéder</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tableau de bord -->
        <div id="admin-view" class="view" hidden>
            <div class="head">
                <div>
                    <h1>Espace closers</h1>
                    <p>Gère tes closers, leurs identifiants, leurs perfs et l'assignation des leads.</p>
                </div>
                <button id="logout-btn" class="btn btn-ghost btn-sm" type="button">Déconnexion</button>
            </div>

            <div class="tabs">
                <button class="tab is-active" id="tab-closers" type="button">Closers</button>
                <button class="tab" id="tab-assign" type="button">Assignation</button>
                <button class="tab" id="tab-candidatures" type="button">Candidatures <span class="tab-count" id="tab-cand-count" hidden>0</span></button>
            </div>

            <!-- Panneau Closers -->
            <div id="panel-closers" class="panel">
                <div class="card create-card">
                    <h2>Ajouter un closer</h2>
                    <form id="create-form" class="create-form">
                        <input type="text" id="create-label" placeholder="Nom (ex. Brice Malt)" autocomplete="off" required />
                        <input type="email" id="create-email" placeholder="Email de connexion" autocomplete="off" required />
                        <input type="text" id="create-password" placeholder="Mot de passe (min. 6)" autocomplete="off" required />
                        <input type="text" id="create-notes" placeholder="Lien profil / infos (optionnel)" autocomplete="off" />
                        <button type="submit" id="create-btn" class="btn">Créer le closer</button>
                    </form>
                    <p id="create-error" class="err" role="alert"></p>
                    <div id="new-code" class="new-code">
                        <span class="new-code-label">Closer créé : <b id="new-code-name"></b>. Donne-lui l'email + le mot de passe que tu viens de saisir pour se connecter à la console et à la documentation.</span>
                    </div>
                </div>

                <div class="summary">
                    <div class="sum"><div class="sum-val" id="sum-total">0</div><div class="sum-label">Closers</div></div>
                    <div class="sum"><div class="sum-val is-green" id="sum-came">0</div><div class="sum-label">Déjà connectés</div></div>
                    <div class="sum"><div class="sum-val is-muted" id="sum-not">0</div><div class="sum-label">Jamais connectés</div></div>
                </div>

                <div id="codes" class="codes"></div>
                <p id="codes-empty" class="boot" hidden>Aucun closer pour l'instant. Ajoutez-en un ci-dessus.</p>
            </div>

            <!-- Panneau Assignation -->
            <div id="panel-assign" class="panel" hidden>
                <div class="card">
                    <h2>Assigner des leads à un closer</h2>
                    <p class="assign-help">Choisis la session, coche les leads que tu veux confier, puis assigne-les au closer choisi. Sélection <strong>manuelle</strong> : rien n'est réparti automatiquement.</p>
                    <div class="assign-controls">
                        <label>Session (date)<input type="text" id="pool-date" value="2026-07-02" placeholder="2026-07-02 (vide = toutes)"></label>
                        <button type="button" id="pool-load" class="btn">Charger les leads</button>
                    </div>
                    <div class="assign-bar" id="assign-bar" hidden>
                        <span id="assign-count" class="assign-count">0 sélectionné(s)</span>
                        <select id="assign-closer"></select>
                        <button type="button" id="assign-do" class="btn">Assigner</button>
                        <button type="button" id="assign-clear" class="btn btn-ghost">Vider</button>
                    </div>
                    <p id="pool-result" class="assign-result"></p>
                    <div class="pool-grid">
                        <div class="pool-col">
                            <h3>Inscrits pays riches <span id="pool-all-count" class="pool-badge">0</span></h3>
                            <div class="pool-list-head"><label><input type="checkbox" id="pool-all-check"> Tout cocher</label><span class="pool-col-note">hors ultra-qualifiés →</span></div>
                            <div id="pool-all" class="pool-list"></div>
                        </div>
                        <div class="pool-col">
                            <h3>Ultra-qualifiés · 1h20+ <span id="pool-ultra-count" class="pool-badge">0</span></h3>
                            <div class="pool-list-head"><label><input type="checkbox" id="pool-ultra-check"> Tout cocher</label><span class="pool-col-note">ont suivi jusqu'au CTA</span></div>
                            <div id="pool-ultra" class="pool-list"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Panneau Candidatures -->
            <div id="panel-candidatures" class="panel" hidden>
                <div class="cand-filters" id="cand-filters">
                    <button class="cand-filter is-active" data-filter="all" type="button">Tous <span class="cf-count" id="cf-count-all">0</span></button>
                    <button class="cand-filter" data-filter="top" type="button">⭐ Top <span class="cf-count" id="cf-count-top">0</span></button>
                    <button class="cand-filter" data-filter="plus_tard" type="button">🕓 Plus tard <span class="cf-count" id="cf-count-plus_tard">0</span></button>
                    <button class="cand-filter" data-filter="poubelle" type="button">🗑 Poubelle <span class="cf-count" id="cf-count-poubelle">0</span></button>
                </div>
                <div id="candidatures" class="codes"></div>
                <p id="cand-empty" class="boot" hidden>Aucune candidature pour l'instant.</p>
            </div>
        </div>
    </div>

    <style is:global>
      /* Stats perf par closer */
      .code-stats{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 2px;}
      .code-stats .cs{background:#f1f5f9;border-radius:8px;padding:5px 10px;font-size:12px;color:#475569;}
      .code-stats .cs b{color:#0f172a;font-size:14px;margin-right:3px;}
      .code-stats .cs-green{background:#dcfce7;color:#166534;} .code-stats .cs-green b{color:#15803d;}
      /* Éditeur identifiants */
      .code-creds{margin-top:8px;border-top:1px dashed #e2e8f0;padding-top:8px;}
      .code-creds-edit{margin-top:8px;display:flex;flex-direction:column;gap:8px;}
      .code-creds-edit input{padding:9px 11px;border:1px solid #cbd5e1;border-radius:8px;font-size:13px;}
      .js-cred-msg{margin:0;font-size:12px;min-height:14px;}
      /* Assignation */
      .assign-help{margin:0 0 14px;color:#64748b;font-size:13px;}
      .assign-controls{display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;margin-bottom:14px;}
      .assign-controls label{display:flex;flex-direction:column;gap:4px;font-size:12px;color:#475569;}
      .assign-controls input{padding:9px 11px;border:1px solid #cbd5e1;border-radius:8px;font-size:13px;width:230px;}
      .assign-bar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:10px 14px;margin-bottom:12px;position:sticky;top:8px;z-index:5;}
      .assign-bar .assign-count{font-weight:700;color:#1d4ed8;font-size:13px;}
      .assign-bar select{padding:8px 10px;border:1px solid #93c5fd;border-radius:8px;font-size:13px;min-width:180px;background:#fff;}
      .assign-result{margin:0 0 12px;font-size:13px;font-weight:600;min-height:16px;}
      .pool-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
      @media(max-width:760px){.pool-grid{grid-template-columns:1fr;}.assign-controls input{width:100%;}}
      .pool-col h3{font-size:14px;margin:0 0 8px;display:flex;align-items:center;gap:8px;color:#0f172a;}
      .pool-badge{background:#0f172a;color:#fff;border-radius:999px;font-size:11px;padding:2px 9px;font-weight:700;}
      .pool-list-head{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:#475569;margin-bottom:6px;}
      .pool-list-head label{display:flex;align-items:center;gap:6px;cursor:pointer;font-weight:600;}
      .pool-col-note{color:#94a3b8;font-style:italic;}
      .pool-list{border:1px solid #e2e8f0;border-radius:10px;background:#fff;max-height:520px;overflow-y:auto;}
      .pool-row{display:flex;align-items:center;gap:10px;padding:9px 12px;border-bottom:1px solid #f1f5f9;font-size:13px;}
      .pool-row:last-child{border-bottom:0;}
      .pool-row input[type=checkbox]{width:17px;height:17px;flex:0 0 auto;cursor:pointer;}
      .pool-row .pr-main{flex:1;min-width:0;}
      .pool-row .pr-name{font-weight:600;color:#0f172a;}
      .pool-row .pr-sub{color:#64748b;font-size:11.5px;margin-top:1px;}
      .pool-row .pr-mins{color:#1d4ed8;font-weight:700;font-size:12px;white-space:nowrap;}
      .pr-assigned{font-size:11px;background:#fef3c7;color:#92400e;border-radius:6px;padding:2px 7px;white-space:nowrap;}
      .pr-bought{font-size:11px;background:#dcfce7;color:#166534;border-radius:6px;padding:2px 7px;white-space:nowrap;}
      .pool-empty{padding:18px;text-align:center;color:#94a3b8;font-size:13px;}
    </style>
    <script is:inline>
        (function () {
            var SESSION = '/.netlify/functions/admin-es2-session';
            var LOGIN = '/.netlify/functions/admin-es2-login';
            var LOGOUT = '/.netlify/functions/admin-es2-logout';
            var API = '/.netlify/functions/closer-admin';

            var boot = document.getElementById('boot');
            var loginView = document.getElementById('login-view');
            var adminView = document.getElementById('admin-view');

            var dtf = new Intl.DateTimeFormat('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
            function fmtDate(iso) {
                if (!iso) return '—';
                try { return dtf.format(new Date(iso)); } catch (e) { return '—'; }
            }
            function esc(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
                });
            }

            function showView(which) {
                boot.hidden = which !== 'boot';
                loginView.hidden = which !== 'login';
                adminView.hidden = which !== 'admin';
            }

            // --- Copie presse-papier ---
            function copyText(text, btnEl) {
                function ok() {
                    if (!btnEl) return;
                    btnEl.classList.add('copied');
                    setTimeout(function () { btnEl.classList.remove('copied'); }, 1400);
                }
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(ok).catch(function () { fallback(text); ok(); });
                } else { fallback(text); ok(); }
            }
            function fallback(text) {
                var ta = document.createElement('textarea');
                ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
                document.body.appendChild(ta); ta.select();
                try { document.execCommand('copy'); } catch (e) { /* noop */ }
                document.body.removeChild(ta);
            }

            // --- Rendu de la liste ---
            var codesAll = [];
            var STATS = {};

            async function loadStats() {
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'stats' }),
                    });
                    if (!r.ok) return;
                    var d = await r.json();
                    STATS = d.stats || {};
                    if (codesAll.length) renderCodes(codesAll);
                } catch (e) { /* noop */ }
            }

            function renderCodes(codes) {
                codesAll = Array.isArray(codes) ? codes : [];
                var host = document.getElementById('codes');
                var empty = document.getElementById('codes-empty');
                var came = 0, not = 0;

                codes.forEach(function (c) {
                    var visited = (c.visit_count > 0) || !!c.first_visit_at;
                    if (c.active === false) { /* révoqué : compté ni venu ni pas-venu actif */ }
                    if (visited) came++; else not++;
                });

                document.getElementById('sum-total').textContent = codes.length;
                document.getElementById('sum-came').textContent = came;
                document.getElementById('sum-not').textContent = not;

                if (!codes.length) { host.innerHTML = ''; empty.hidden = false; return; }
                empty.hidden = true;

                host.innerHTML = codes.map(function (c) {
                    var visited = (c.visit_count > 0) || !!c.first_visit_at;
                    var revoked = c.active === false;
                    var st = STATS[c.id] || {};
                    var badge = revoked
                        ? '<span class="badge badge-revoked">Révoqué</span>'
                        : (visited ? '<span class="badge badge-came">Connecté</span>' : '<span class="badge badge-not">Jamais connecté</span>');
                    var action = revoked
                        ? '<button class="btn btn-ghost btn-sm js-toggle" data-id="' + c.id + '" data-active="true">Réactiver</button>'
                        : '<button class="btn btn-ghost btn-sm js-toggle" data-id="' + c.id + '" data-active="false">Révoquer</button>';
                    return '' +
                        '<div class="code-card' + (revoked ? ' is-revoked' : '') + '">' +
                            '<div class="code-top">' +
                                '<div class="code-name">' + esc(c.label) + ' ' + badge + '</div>' +
                                '<div class="code-actions">' +
                                    '<span class="code-chip">' + esc(c.code) +
                                        '<button class="copy-btn js-copy" data-code="' + esc(c.code) + '" title="Copier" aria-label="Copier">' +
                                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>' +
                                        '</button>' +
                                    '</span>' +
                                    action +
                                    '<button class="code-del js-delete" data-id="' + c.id + '" title="Supprimer" aria-label="Supprimer">' +
                                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>' +
                                    '</button>' +
                                '</div>' +
                            '</div>' +
                            '<div class="code-meta">' +
                                '<span class="meta-item"><span class="meta-k">Email :</span> <b>' + esc(c.email || '—') + '</b></span>' +
                                '<span class="meta-item"><span class="meta-k">1ʳᵉ connexion :</span> <b>' + fmtDate(c.first_visit_at) + '</b></span>' +
                                '<span class="meta-item"><span class="meta-k">Dernière :</span> <b>' + fmtDate(c.last_visit_at) + '</b></span>' +
                                '<span class="meta-item"><span class="meta-k">Connexions :</span> <b>' + (c.visit_count || 0) + '</b></span>' +
                            '</div>' +
                            '<div class="code-stats">' +
                                '<span class="cs"><b>' + (st.leads || 0) + '</b>leads</span>' +
                                '<span class="cs"><b>' + (st.calls || 0) + '</b>appels</span>' +
                                '<span class="cs"><b>' + (st.rappels || 0) + '</b>à rappeler</span>' +
                                '<span class="cs"><b>' + (st.oui || 0) + '</b>dits oui</span>' +
                                '<span class="cs cs-green"><b>' + (st.ventes || 0) + '</b>ventes</span>' +
                            '</div>' +
                            '<div class="code-notes" data-id="' + c.id + '">' +
                                '<div class="code-notes-view">' +
                                    '<span class="code-notes-text">' + (c.notes ? linkifyText(c.notes) : '<span class="code-notes-empty">Aucune info</span>') + '</span>' +
                                    '<button class="code-notes-btn js-note-edit" data-id="' + c.id + '" type="button">' + (c.notes ? 'Modifier' : '+ Ajouter une info') + '</button>' +
                                '</div>' +
                                '<div class="code-notes-edit" hidden>' +
                                    '<textarea class="js-note-input" rows="2" placeholder="Lien profil, source, remarque…">' + esc(c.notes || '') + '</textarea>' +
                                    '<div class="code-notes-edit-actions">' +
                                        '<button class="btn btn-sm js-note-save" data-id="' + c.id + '" type="button">Enregistrer</button>' +
                                        '<button class="btn btn-ghost btn-sm js-note-cancel" type="button">Annuler</button>' +
                                    '</div>' +
                                '</div>' +
                            '</div>' +
                            '<div class="code-creds" data-id="' + c.id + '">' +
                                '<button class="code-notes-btn js-cred-edit" data-id="' + c.id + '" type="button">&#128273; Modifier l\'email / le mot de passe</button>' +
                                '<div class="code-creds-edit" hidden>' +
                                    '<input class="js-cred-email" type="email" placeholder="Email de connexion" value="' + esc(c.email || '') + '">' +
                                    '<input class="js-cred-pass" type="text" placeholder="Nouveau mot de passe (vide = inchangé)">' +
                                    '<div class="code-notes-edit-actions">' +
                                        '<button class="btn btn-sm js-cred-save" data-id="' + c.id + '" type="button">Enregistrer</button>' +
                                        '<button class="btn btn-ghost btn-sm js-cred-cancel" type="button">Annuler</button>' +
                                    '</div>' +
                                    '<p class="js-cred-msg err"></p>' +
                                '</div>' +
                            '</div>' +
                        '</div>';
                }).join('');

                host.querySelectorAll('.js-copy').forEach(function (b) {
                    b.addEventListener('click', function () { copyText(b.getAttribute('data-code'), b); });
                });
                host.querySelectorAll('.js-toggle').forEach(function (b) {
                    b.addEventListener('click', function () { toggleCode(+b.getAttribute('data-id'), b.getAttribute('data-active') === 'true'); });
                });
                host.querySelectorAll('.js-delete').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var id = +b.getAttribute('data-id');
                        var c = codesAll.find(function (x) { return x.id === id; });
                        var name = c ? c.label : '';
                        if (window.confirm('Supprimer définitivement le code « ' + name + ' » ?\n\nLes candidatures déjà reçues sont conservées.')) {
                            deleteCode(id);
                        }
                    });
                });
                host.querySelectorAll('.js-note-edit').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        box.querySelector('.code-notes-view').hidden = true;
                        box.querySelector('.code-notes-edit').hidden = false;
                        var ta = box.querySelector('.js-note-input');
                        ta.focus();
                    });
                });
                host.querySelectorAll('.js-note-cancel').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        box.querySelector('.code-notes-edit').hidden = true;
                        box.querySelector('.code-notes-view').hidden = false;
                    });
                });
                host.querySelectorAll('.js-note-save').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-notes');
                        var val = box.querySelector('.js-note-input').value.trim();
                        saveNotes(+b.getAttribute('data-id'), val);
                    });
                });
                host.querySelectorAll('.js-cred-edit').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-creds');
                        b.hidden = true;
                        box.querySelector('.code-creds-edit').hidden = false;
                        box.querySelector('.js-cred-email').focus();
                    });
                });
                host.querySelectorAll('.js-cred-cancel').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-creds');
                        box.querySelector('.code-creds-edit').hidden = true;
                        box.querySelector('.js-cred-msg').textContent = '';
                        box.querySelector('.js-cred-edit').hidden = false;
                    });
                });
                host.querySelectorAll('.js-cred-save').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var box = b.closest('.code-creds');
                        saveCreds(+b.getAttribute('data-id'),
                            box.querySelector('.js-cred-email').value.trim(),
                            box.querySelector('.js-cred-pass').value,
                            box.querySelector('.js-cred-msg'), b);
                    });
                });
            }

            async function saveCreds(id, email, password, msgEl, btn) {
                var payload = { action: 'set-credentials', id: id };
                if (email) payload.email = email;
                if (password) payload.password = password;
                if (!email && !password) { msgEl.style.color = '#dc2626'; msgEl.textContent = 'Rien à modifier.'; return; }
                btn.disabled = true; msgEl.style.color = '#475569'; msgEl.textContent = 'Enregistrement…';
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e) { /* noop */ }
                    if (r.ok) { msgEl.style.color = '#16a34a'; msgEl.textContent = 'Identifiants mis à jour.'; loadCodes(); }
                    else { msgEl.style.color = '#dc2626'; msgEl.textContent = d.error || 'Erreur.'; }
                } catch (e) { msgEl.style.color = '#dc2626'; msgEl.textContent = 'Erreur réseau.'; }
                btn.disabled = false;
            }

            function linkifyText(t) {
                return esc(t).replace(/(https?:\/\/[^\s]+)/g, function (u) {
                    return '<a href="' + u + '" target="_blank" rel="noopener noreferrer">' + u + '</a>';
                });
            }

            async function saveNotes(id, notes) {
                var c = codesAll.find(function (x) { return x.id === id; });
                if (c) c.notes = notes;          // MAJ optimiste
                renderCodes(codesAll);
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'code-notes', id: id, notes: notes }),
                    });
                } catch (e) { /* noop */ }
            }
            window.__renderCloserCodes = renderCodes; // exposé pour aperçu/démo

            async function loadCodes() {
                try {
                    var r = await fetch(API, { credentials: 'same-origin' });
                    if (r.status === 401) { showView('login'); return; }
                    var d = await r.json();
                    if (!r.ok) { document.getElementById('create-error').textContent = d.error || 'Erreur de chargement.'; return; }
                    renderCodes(d.codes || []);
                } catch (e) {
                    document.getElementById('create-error').textContent = 'Erreur réseau.';
                }
            }

            async function toggleCode(id, active) {
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'revoke', id: id, active: active }),
                    });
                    loadCodes();
                } catch (e) { /* noop */ }
            }

            async function deleteCode(id) {
                // suppression optimiste
                codesAll = codesAll.filter(function (x) { return x.id !== id; });
                renderCodes(codesAll);
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'delete', id: id }),
                    });
                    loadCodes();
                } catch (e) { /* noop */ }
            }

            // --- Candidatures ---
            function candTag(label, value) {
                var v = (value || '').toLowerCase();
                var cls = v === 'oui' ? 'is-yes' : (v === 'non' ? 'is-no' : (value ? 'is-maybe' : ''));
                return '<span class="cand-tag ' + cls + '">' + label + ' : <b>' + esc(value || '—') + '</b></span>';
            }
            function linkify(url) {
                if (/^https?:\/\//i.test(url)) {
                    return '<a href="' + esc(url) + '" target="_blank" rel="noopener noreferrer">' + esc(url) + '</a>';
                }
                return esc(url || '—');
            }
            var candAll = [];
            var candFilter = 'all';

            function renderCandidatures(list) {
                candAll = Array.isArray(list) ? list : [];
                drawCandidatures();
            }

            function drawCandidatures() {
                var host = document.getElementById('candidatures');
                var empty = document.getElementById('cand-empty');
                var countEl = document.getElementById('tab-cand-count');

                // Comptes par statut
                var counts = { all: 0, top: 0, plus_tard: 0, poubelle: 0 };
                candAll.forEach(function (c) {
                    var s = c.status || 'nouveau';
                    if (s !== 'poubelle') counts.all++;
                    if (counts[s] != null) counts[s]++;
                });
                document.getElementById('cf-count-all').textContent = counts.all;
                document.getElementById('cf-count-top').textContent = counts.top;
                document.getElementById('cf-count-plus_tard').textContent = counts.plus_tard;
                document.getElementById('cf-count-poubelle').textContent = counts.poubelle;

                countEl.textContent = candAll.length;
                countEl.hidden = candAll.length === 0;

                // Filtre courant ("Tous" = tout sauf poubelle)
                var list = candAll.filter(function (c) {
                    var s = c.status || 'nouveau';
                    return candFilter === 'all' ? s !== 'poubelle' : s === candFilter;
                });

                if (!list.length) {
                    host.innerHTML = '';
                    empty.hidden = false;
                    empty.textContent = candAll.length ? 'Rien dans cette catégorie.' : 'Aucune candidature pour l\'instant.';
                    return;
                }
                empty.hidden = true;

                host.innerHTML = list.map(function (c) {
                    var s = c.status || 'nouveau';
                    function triBtn(val, label) {
                        return '<button class="tri-btn tri-' + val + (s === val ? ' is-active' : '') +
                            '" data-id="' + c.id + '" data-status="' + val + '" type="button">' + label + '</button>';
                    }
                    return '' +
                        '<div class="cand-card status-' + s + '">' +
                            '<div class="cand-top">' +
                                '<div class="cand-name">' + esc(c.full_name) +
                                    (c.code_label ? '<span class="cand-via">via ' + esc(c.code_label) + '</span>' : '') +
                                '</div>' +
                                '<div class="cand-when">' + fmtDate(c.created_at) + '</div>' +
                            '</div>' +
                            '<div class="cand-contact">' +
                                '<a href="mailto:' + esc(c.email) + '">' + esc(c.email) + '</a>' +
                                '<span>' + esc(c.phone) + '</span>' +
                            '</div>' +
                            '<div class="cand-tags">' +
                                candTag('High-ticket 1500€+', c.closed_highticket) +
                                candTag('100% résultat', c.ok_commission) +
                                candTag('Enregistrement', c.ok_recording) +
                                candTag('Dispo 3 juil', c.available_jul3) +
                            '</div>' +
                            '<div class="cand-block"><div class="q">Résultats concrets</div><div class="a">' + esc(c.results) + '</div></div>' +
                            '<div class="cand-block"><div class="q">Échantillon audio</div><div class="a">' + linkify(c.audio_url) + '</div></div>' +
                            '<div class="cand-block"><div class="q">Pourquoi cette opportunité</div><div class="a">' + esc(c.motivation) + '</div></div>' +
                            '<div class="cand-tri">' +
                                triBtn('top', '⭐ Top') +
                                triBtn('plus_tard', '🕓 Plus tard') +
                                triBtn('poubelle', '🗑 Poubelle') +
                            '</div>' +
                        '</div>';
                }).join('');

                host.querySelectorAll('.tri-btn').forEach(function (b) {
                    b.addEventListener('click', function () {
                        var id = +b.getAttribute('data-id');
                        var val = b.getAttribute('data-status');
                        // re-cliquer le statut actif le remet à "nouveau"
                        var cur = (candAll.find(function (x) { return x.id === id; }) || {}).status || 'nouveau';
                        setCandStatus(id, cur === val ? 'nouveau' : val);
                    });
                });
            }

            async function setCandStatus(id, status) {
                var c = candAll.find(function (x) { return x.id === id; });
                if (c) c.status = status;            // MAJ optimiste
                drawCandidatures();
                try {
                    await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'cand-status', id: id, status: status }),
                    });
                } catch (e) { /* noop */ }
            }

            window.__renderCloserCandidatures = renderCandidatures; // exposé pour aperçu/démo

            async function loadCandidatures() {
                try {
                    var r = await fetch(API + '?resource=candidatures', { credentials: 'same-origin' });
                    if (r.status === 401) { showView('login'); return; }
                    var d = await r.json();
                    if (!r.ok) return;
                    renderCandidatures(d.candidatures || []);
                } catch (e) { /* noop */ }
            }

            function enterAdmin() {
                showView('admin');
                loadCodes();
                loadStats();
                loadCandidatures();
            }

            // Onglets
            var TABS = [
                { tab: 'tab-closers', panel: 'panel-closers' },
                { tab: 'tab-assign', panel: 'panel-assign' },
                { tab: 'tab-candidatures', panel: 'panel-candidatures' },
            ];
            function switchTab(which) {
                TABS.forEach(function (t) {
                    var on = t.tab === which;
                    document.getElementById(t.tab).classList.toggle('is-active', on);
                    document.getElementById(t.panel).hidden = !on;
                });
                if (which === 'tab-candidatures') loadCandidatures();
                if (which === 'tab-assign') initAssignTab();
            }
            TABS.forEach(function (t) {
                document.getElementById(t.tab).addEventListener('click', function () { switchTab(t.tab); });
            });

            // Filtres candidatures
            document.querySelectorAll('.cand-filter').forEach(function (f) {
                f.addEventListener('click', function () {
                    candFilter = f.getAttribute('data-filter');
                    document.querySelectorAll('.cand-filter').forEach(function (x) {
                        x.classList.toggle('is-active', x === f);
                    });
                    drawCandidatures();
                });
            });

            // --- Boot : vérifie la session admin ---
            async function init() {
                try {
                    var r = await fetch(SESSION, { credentials: 'same-origin' });
                    var d = r.ok ? await r.json() : {};
                    if (d && d.authenticated) { enterAdmin(); return; }
                } catch (e) { /* noop */ }
                showView('login');
            }

            // --- Login ---
            document.getElementById('login-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var pwd = document.getElementById('admin-password').value;
                var btn = document.getElementById('login-btn');
                var errEl = document.getElementById('login-error');
                errEl.textContent = '';
                btn.disabled = true;
                try {
                    var r = await fetch(LOGIN, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ password: pwd }),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e2) { /* noop */ }
                    if (r.ok) { enterAdmin(); return; }
                    if (d.code === 'SETUP_REQUIRED') {
                        errEl.textContent = 'Aucun mot de passe admin défini. Configure-le d\'abord sur /es-cockpit.';
                    } else {
                        errEl.textContent = d.error || 'Mot de passe incorrect.';
                    }
                } catch (e3) {
                    errEl.textContent = 'Erreur réseau.';
                }
                btn.disabled = false;
            });

            // --- Logout ---
            document.getElementById('logout-btn').addEventListener('click', async function () {
                try { await fetch(LOGOUT, { method: 'POST', credentials: 'same-origin' }); } catch (e) { /* noop */ }
                showView('login');
            });

            // --- Création d'un closer ---
            document.getElementById('create-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var label = document.getElementById('create-label').value.trim();
                var email = document.getElementById('create-email').value.trim();
                var password = document.getElementById('create-password').value;
                var notes = document.getElementById('create-notes').value.trim();
                var btn = document.getElementById('create-btn');
                var errEl = document.getElementById('create-error');
                var box = document.getElementById('new-code');
                errEl.textContent = '';
                if (!label) { errEl.textContent = 'Entrez un nom.'; return; }
                if (!email) { errEl.textContent = 'Entrez un email.'; return; }
                if (!password || password.length < 6) { errEl.textContent = 'Mot de passe : 6 caractères minimum.'; return; }
                btn.disabled = true;
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'create-closer', label: label, email: email, password: password, notes: notes }),
                    });
                    var d = {};
                    try { d = await r.json(); } catch (e2) { /* noop */ }
                    if (r.ok && d.row) {
                        document.getElementById('new-code-name').textContent = d.row.label + ' — ' + (d.row.email || email);
                        box.classList.add('is-shown');
                        document.getElementById('create-label').value = '';
                        document.getElementById('create-email').value = '';
                        document.getElementById('create-password').value = '';
                        document.getElementById('create-notes').value = '';
                        loadCodes();
                        loadStats();
                    } else {
                        errEl.textContent = d.error || 'Création impossible.';
                    }
                } catch (e3) {
                    errEl.textContent = 'Erreur réseau.';
                }
                btn.disabled = false;
            });

            // ===== Onglet Assignation =====
            var POOL = [];
            var SEL = {};            // token -> true
            var assignLoaded = false;

            function activeClosers() {
                return codesAll.filter(function (c) { return c.active !== false; });
            }
            function closerName(id) {
                var c = codesAll.find(function (x) { return x.id === id; });
                return c ? c.label : ('#' + id);
            }

            function fillCloserSelect() {
                var sel = document.getElementById('assign-closer');
                if (!sel) return;
                var opts = ['<option value="">— Choisir un closer —</option>'];
                activeClosers().forEach(function (c) {
                    opts.push('<option value="' + c.id + '">' + esc(c.label) + '</option>');
                });
                opts.push('<option value="__none__">↩︎ Désassigner (retirer)</option>');
                sel.innerHTML = opts.join('');
            }

            function poolRow(l) {
                var checked = SEL[l.token] ? ' checked' : '';
                var sub = [esc(l.pays || '—'), esc(l.telephone || 'sans tel.')].join(' · ');
                var tag = l.purchased
                    ? '<span class="pr-bought">acheté</span>'
                    : (l.assigned_closer_id != null ? '<span class="pr-assigned">→ ' + esc(closerName(l.assigned_closer_id)) + '</span>' : '');
                var mins = (l.watch_max_minutes != null) ? (l.watch_max_minutes + ' min') : '';
                return '<div class="pool-row">' +
                    '<input type="checkbox" class="js-pool-cb" data-token="' + esc(l.token) + '"' + checked + '>' +
                    '<div class="pr-main"><div class="pr-name">' + esc(l.prenom || 'Lead') + '</div><div class="pr-sub">' + sub + '</div></div>' +
                    (mins ? '<span class="pr-mins">' + mins + '</span>' : '') + tag +
                    '</div>';
            }

            function renderPool() {
                var ultra = POOL.filter(function (l) { return (l.watch_max_minutes || 0) >= 81; });
                var rest = POOL.filter(function (l) { return (l.watch_max_minutes || 0) < 81; });
                var allHost = document.getElementById('pool-all');
                var ultraHost = document.getElementById('pool-ultra');
                document.getElementById('pool-all-count').textContent = rest.length;
                document.getElementById('pool-ultra-count').textContent = ultra.length;
                allHost.innerHTML = rest.length ? rest.map(poolRow).join('') : '<div class="pool-empty">Aucun inscrit.</div>';
                ultraHost.innerHTML = ultra.length ? ultra.map(poolRow).join('') : '<div class="pool-empty">Aucun ultra-qualifié.</div>';
                document.querySelectorAll('.js-pool-cb').forEach(function (cb) {
                    cb.addEventListener('change', function () {
                        var t = cb.getAttribute('data-token');
                        if (cb.checked) SEL[t] = true; else delete SEL[t];
                        updateAssignBar();
                    });
                });
                document.getElementById('pool-all-check').checked = false;
                document.getElementById('pool-ultra-check').checked = false;
                updateAssignBar();
            }

            function updateAssignBar() {
                var n = Object.keys(SEL).length;
                document.getElementById('assign-bar').hidden = n === 0;
                document.getElementById('assign-count').textContent = n + ' sélectionné(s)';
            }

            async function loadPool() {
                var date = (document.getElementById('pool-date').value || '').trim();
                var out = document.getElementById('pool-result');
                var btn = document.getElementById('pool-load');
                btn.disabled = true; out.style.color = '#475569'; out.textContent = 'Chargement…';
                SEL = {};
                try {
                    var r = await fetch(API, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'leads-pool', session_date: date || null }),
                    });
                    var d = await r.json();
                    if (!r.ok) { out.style.color = '#dc2626'; out.textContent = d.error || 'Erreur.'; btn.disabled = false; return; }
                    POOL = d.leads || [];
                    fillCloserSelect();
                    renderPool();
                    out.style.color = '#16a34a'; out.textContent = POOL.length + ' lead(s) chargé(s).';
                } catch (e) { out.style.color = '#dc2626'; out.textContent = 'Erreur réseau.'; }
                btn.disabled = false;
            }

            function bindAssignControls() {
                document.getElementById('pool-load').addEventListener('click', loadPool);
                document.getElementById('assign-clear').addEventListener('click', function () {
                    SEL = {};
                    document.querySelectorAll('.js-pool-cb').forEach(function (cb) { cb.checked = false; });
                    document.getElementById('pool-all-check').checked = false;
                    document.getElementById('pool-ultra-check').checked = false;
                    updateAssignBar();
                });
                function selectAll(listId, masterId) {
                    document.getElementById(masterId).addEventListener('change', function () {
                        var on = this.checked;
                        document.querySelectorAll('#' + listId + ' .js-pool-cb').forEach(function (cb) {
                            cb.checked = on;
                            var t = cb.getAttribute('data-token');
                            if (on) SEL[t] = true; else delete SEL[t];
                        });
                        updateAssignBar();
                    });
                }
                selectAll('pool-all', 'pool-all-check');
                selectAll('pool-ultra', 'pool-ultra-check');

                document.getElementById('assign-do').addEventListener('click', async function () {
                    var tokens = Object.keys(SEL);
                    var out = document.getElementById('pool-result');
                    if (!tokens.length) { out.style.color = '#dc2626'; out.textContent = 'Coche au moins un lead.'; return; }
                    var val = document.getElementById('assign-closer').value;
                    if (!val) { out.style.color = '#dc2626'; out.textContent = 'Choisis un closer.'; return; }
                    var closer_id = val === '__none__' ? null : Number(val);
                    var label = closer_id === null ? 'désassignés' : ('assignés à ' + closerName(closer_id));
                    var btn = this; btn.disabled = true; out.style.color = '#475569'; out.textContent = 'Assignation…';
                    try {
                        var r = await fetch(API, {
                            method: 'POST', credentials: 'same-origin',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ action: 'assign', closer_id: closer_id, tokens: tokens }),
                        });
                        var d = await r.json();
                        if (r.ok) {
                            out.style.color = '#16a34a'; out.textContent = (d.count || tokens.length) + ' lead(s) ' + label + '.';
                            SEL = {};
                            await loadPool();
                            loadStats();
                        } else { out.style.color = '#dc2626'; out.textContent = d.error || 'Erreur.'; }
                    } catch (e) { out.style.color = '#dc2626'; out.textContent = 'Erreur réseau.'; }
                    btn.disabled = false;
                });
            }

            function initAssignTab() {
                if (!assignLoaded) { bindAssignControls(); assignLoaded = true; loadPool(); }
                else { fillCloserSelect(); }
            }

            init();
        })();
    </script>
</body>
</html>
