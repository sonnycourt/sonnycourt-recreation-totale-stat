            leaf: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 11"/></svg>`,
            zap: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
            gift: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>`
        };

        function updateSeasonalBadge() {
            const currentMonth = new Date().getMonth() + 1;
            const badge = badges[currentMonth] || badges[1];
            const iconSVG = iconSVGs[badge.icon] || iconSVGs.rocket;

            const badgeEl = document.getElementById('scarcityBadge');
            if (badgeEl) {
                const iconEl = badgeEl.querySelector('.badge-icon');
                const textEl = badgeEl.querySelector('.badge-text');
                
                if (iconEl) {
                    iconEl.innerHTML = iconSVG;
                }
                if (textEl) {
                    textEl.textContent = badge.text;
                }
            }
        }

        // FAQ Toggle - approche avec event listeners
        document.addEventListener('DOMContentLoaded', function() {
            // Si mode stvalentin, forcer le badge St-Valentin
            const urlParamsBadge = new URLSearchParams(window.location.search);
            if (urlParamsBadge.get('preview') === 'stvalentin') {
                const heartSVG = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`;
                const badgeEl = document.getElementById('scarcityBadge');
                if (badgeEl) {
                    const iconEl = badgeEl.querySelector('.badge-icon');
                    const textEl = badgeEl.querySelector('.badge-text');
                    if (iconEl) iconEl.innerHTML = heartSVG;
                    if (textEl) textEl.textContent = 'OFFRE ST-VALENTIN -50%';
                }
            } else if (urlParamsBadge.get('preview') === 'promo') {
                const promoConfig = document.getElementById('promo-config');
                const promoBadge = promoConfig ? promoConfig.dataset.badge : null;
                if (promoBadge) {
                    const badgeEl = document.getElementById('scarcityBadge');
                    if (badgeEl) {
                        const textEl = badgeEl.querySelector('.badge-text');
                        if (textEl) textEl.textContent = promoBadge;
                    }
                }
            } else {
                updateSeasonalBadge();
            }
            const faqQuestions = document.querySelectorAll('.faq-question');

            faqQuestions.forEach(question => {
                question.addEventListener('click', function() {
                    const faqItem = this.parentElement;
                    const answer = faqItem.querySelector('.faq-answer');

                    // Fermer toutes les autres FAQ
                    document.querySelectorAll('.faq-item').forEach(item => {
                        if (item !== faqItem) {
                            item.classList.remove('active');
                            const otherAnswer = item.querySelector('.faq-answer');
                            if (otherAnswer) {
                                otherAnswer.classList.remove('active');
                            }
                        }
                    });

                    // Ouvrir/fermer la FAQ cliquée
                    faqItem.classList.toggle('active');
                    if (answer) {
                        answer.classList.toggle('active');
                    }
                });
            });
        });

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Intersection Observer for fade-in animations
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in').forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(20px)';
            el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
            observer.observe(el);
        });

        // Parallax effect removed - was causing visual issues

        // External scripts
        const elfsightScript = document.createElement('script');
        elfsightScript.src = 'https://static.elfsight.com/platform/platform.js';
        elfsightScript.async = true;
        document.body.appendChild(elfsightScript);

        const wistiaScript = document.createElement('script');
        wistiaScript.src = 'https://fast.wistia.net/assets/external/E-v1.js';
        wistiaScript.async = true;
        document.body.appendChild(wistiaScript);

        // Custom Video Play Buttons
        document.querySelectorAll('.custom-play-button').forEach(button => {
            button.addEventListener('click', function() {
                const videoId = this.getAttribute('data-video');
                const video = document.querySelector(`.review-video[data-video="${videoId}"]`);
                const videoCard = this.closest('.video-card');

                if (video) {
                    if (video.paused) {
                        if (!video.hasAttribute('controls')) {
                            video.setAttribute('controls', '');
                        }
                        videoCard.classList.add('has-played');
                        video.play();
                        videoCard.classList.add('playing');
                        videoCard.classList.remove('paused');
                    } else {
                        video.pause();
                        videoCard.classList.remove('playing');
                        videoCard.classList.add('paused');
                    }
                }
            });
        });

        // Handle video play/pause events to show/hide custom button
        document.querySelectorAll('.review-video').forEach(video => {
            const videoCard = video.closest('.video-card');

            video.addEventListener('play', function() {
                videoCard.classList.add('playing');
                videoCard.classList.remove('paused');
                // Hide the custom button completely when video starts playing
                const videoId = video.getAttribute('data-video');
                const button = document.querySelector(`.custom-play-button[data-video="${videoId}"]`);
                if (button) {
                    button.style.opacity = '0';
                    button.style.visibility = 'hidden';
                    button.style.pointerEvents = 'none';
                }
            });

            video.addEventListener('pause', function() {
                videoCard.classList.remove('playing');

                if (this.currentTime === 0 || this.ended) {
                    videoCard.classList.remove('paused');
                    // Hide button at start/end of video
                    const videoId = video.getAttribute('data-video');
                    const button = document.querySelector(`.custom-play-button[data-video="${videoId}"]`);
                    if (button) {
                        button.style.opacity = '0';
                        button.style.visibility = 'hidden';
                        button.style.pointerEvents = 'none';
                    }
                } else {
                    videoCard.classList.add('paused');
                    // Show play button when paused in middle of video
                    const videoId = video.getAttribute('data-video');
                    const button = document.querySelector(`.custom-play-button[data-video="${videoId}"]`);
                    if (button) {
                        button.style.opacity = '1';
