                rgba(59, 130, 246, 0.06) 100%
            );
            border-radius: 20px;
            opacity: 0.6;
            transition: opacity 0.4s ease;
            pointer-events: none;
            z-index: 2;
        }

        .premium-frame:hover .subtle-overlay {
            opacity: 0.8;
        }


        .cta-button-final {
            display: inline-block;
            padding: 20px 50px;
            font-size: 1.2rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #FFFFFF;
            background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 50%, #3B82F6 100%);
            background-size: 200% 200%;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow:
              0 10px 30px rgba(59, 130, 246, 0.4),
              inset 0 0 0 2px rgba(255, 255, 255, 0.1);
            position: relative;
            overflow: hidden;
            text-decoration: none;
            animation: buttonPulse 2s ease-in-out infinite;
        }

        .cta-button-final::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
              45deg,
              transparent 30%,
              rgba(255, 255, 255, 0.3) 50%,
              transparent 70%
            );
            transform: rotate(45deg);
            transition: all 0.6s;
            animation: buttonShine 3s ease-in-out infinite;
            pointer-events: none;
        }

        .cta-button-final:hover {
            background-position: 100% 100%;
            transform: scale(1.05);
            box-shadow:
              0 20px 50px rgba(59, 130, 246, 0.7),
              inset 0 0 0 2px rgba(255, 255, 255, 0.3),
              0 0 80px rgba(59, 130, 246, 0.5);
            animation: none;
        }

        /* CORRECTION CRITIQUE : Boutons CTA dans section scarcity - UNIQUEMENT ROUGE */
        .scarcity-section .cta-button-final {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%) !important;
            box-shadow:
              0 10px 40px rgba(220, 38, 38, 0.5) !important,
              inset 0 0 0 2px rgba(255, 255, 255, 0.1) !important;
            /* Animation supprimée pour plus de sobriété */
            /* Forcer l'absence totale de glow violet */
            filter: none !important;
            -webkit-filter: none !important;
            text-shadow: none !important;
            -webkit-text-stroke: none !important;
        }

        .scarcity-section .cta-button-final:hover {
            box-shadow:
              0 15px 50px rgba(220, 38, 38, 0.7) !important,
              inset 0 0 0 2px rgba(255, 255, 255, 0.3) !important;
            animation: none !important; /* Supprimer l'animation hover violette */
            /* Forcer l'absence totale de glow violet au hover */
            filter: none !important;
            -webkit-filter: none !important;
            text-shadow: none !important;
            -webkit-text-stroke: none !important;
        }

        .cta-button-final:active {
            transform: scale(1.02);
        }

        /* Animations EXACTES de access-optin.html */
        @keyframes buttonPulse {
            0%, 100% {
              transform: scale(1);
              box-shadow:
                0 10px 30px rgba(59, 130, 246, 0.4),
                inset 0 0 0 2px rgba(255, 255, 255, 0.1);
            }
            50% {
              transform: scale(1.02);
              box-shadow:
                0 15px 40px rgba(59, 130, 246, 0.6),
                inset 0 0 0 2px rgba(255, 255, 255, 0.2);
            }
        }


        @keyframes buttonShine {
            0% {
              transform: rotate(45deg) translateX(-200%);
            }
              100% {
              transform: rotate(45deg) translateX(200%);
            }
        }

        @keyframes titleGradient {
            0% {
