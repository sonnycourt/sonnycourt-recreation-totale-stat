---
import BlackFridayBanner from '../components/BlackFridayBanner.astro';
import GAConsentMode from '../components/GAConsentMode.astro';
import PromoBanner from '../components/PromoBanner.astro';
import { getPromoBannerMessage, getPromoCheckoutCode, getPromoLabel, isPromoActiveFor, promo } from '../config/promo';
const currentYear = new Date().getFullYear();
---

<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Esprit Subconscient 2.0 — La formation pour reprogrammer ton subconscient</title>
    <meta name="description" content="Accès à la formation Esprit Subconscient 2.0 : reprogramme ton subconscient et manifeste la vie de tes rêves avec la méthode de Sonny Court.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Esprit Subconscient 2.0 — La formation pour reprogrammer ton subconscient" />
    <meta property="og:description" content="Accès à la formation Esprit Subconscient 2.0 : reprogramme ton subconscient et manifeste la vie de tes rêves avec la méthode de Sonny Court." />
    <meta property="og:image" content={new URL("/media/pages/sonnycourt_share.webp", Astro.url)} />
    <meta property="og:url" content={Astro.url.href} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Esprit Subconscient 2.0 — La formation pour reprogrammer ton subconscient" />
    <meta name="twitter:description" content="Accès à la formation Esprit Subconscient 2.0 : reprogramme ton subconscient et manifeste la vie de tes rêves avec la méthode de Sonny Court." />
    <meta name="twitter:image" content={new URL("/media/pages/sonnycourt_share.webp", Astro.url)} />
    
    <!-- GA4 Consent Mode v2 -->
    <GAConsentMode />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;700;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;700;900&display=swap"></noscript>

    <!-- Start of Async ProveSource Code -->
