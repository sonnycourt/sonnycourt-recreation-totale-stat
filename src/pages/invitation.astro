            line-height: 1.7;
            margin-bottom: 25px;
        }

        .descriptive-highlight {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--primary-purple);
            margin-bottom: 30px;
            background: linear-gradient(135deg, var(--primary-purple), #60A5FA);
