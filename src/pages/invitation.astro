            background: linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(20, 20, 20, 0.7));
            border-color: rgba(59, 130, 246, 0.4);
            box-shadow: 0 15px 40px rgba(59, 130, 246, 0.15);
