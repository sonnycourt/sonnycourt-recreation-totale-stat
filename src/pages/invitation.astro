            display: block;
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(219, 234, 254, 0.88);
            font-weight: 700;
        }

        .scarcity-card {
            width: 100%;
            max-width: 520px;
            margin: 20px 0 0;
            padding: 14px 14px 12px;
            border-radius: 14px;
            border: 1px solid rgba(239, 68, 68, 0.55);
            background: radial-gradient(120% 130% at 0% 0%, rgba(220, 38, 38, 0.24) 0%, rgba(69, 10, 10, 0.30) 45%, rgba(15, 23, 42, 0.72) 100%);
            box-shadow: 0 14px 30px rgba(127, 29, 29, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.08);
            text-align: left;
        }

        .scarcity-kicker {
            margin: 0 0 8px;
            font-size: 0.70rem;
            text-transform: uppercase;
            letter-spacing: 0.10em;
            color: #fee2e2;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .scarcity-kicker::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 999px;
            background: #ef4444;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.7);
        }
        .scarcity-phase1-total {
            display: none;
            margin: 10px 0 12px;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid rgba(248, 113, 113, 0.55);
            background: linear-gradient(135deg, rgba(127, 29, 29, 0.55), rgba(153, 27, 27, 0.28));
            box-shadow: inset 0 0 0 1px rgba(127, 29, 29, 0.35), 0 8px 22px rgba(127, 29, 29, 0.30);
        }
        .scarcity-soldout-stamp {
            flex: 0 0 auto;
            padding: 6px 10px;
            border-radius: 6px;
            background: #b91c1c;
            color: #fff;
            font-size: 0.66rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.16em;
            border: 1px solid rgba(254, 202, 202, 0.55);
            text-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);
            transform: rotate(-3deg);
        }
        .scarcity-soldout-line {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            line-height: 1.2;
            min-width: 0;
        }
        .scarcity-soldout-count {
            font-size: 0.95rem;
            font-weight: 800;
            color: #fff;
            text-decoration: line-through;
            text-decoration-thickness: 2px;
            text-decoration-color: rgba(254, 202, 202, 0.9);
        }
        .scarcity-soldout-slash {
            opacity: 0.75;
            font-weight: 700;
        }
        .scarcity-soldout-text {
            font-size: 0.76rem;
            font-weight: 600;
            color: #fecaca;
            margin-top: 3px;
            letter-spacing: 0.01em;
        }
        .scarcity-phase2-note {
            display: none;
            margin: 0 0 12px;
            align-items: center;
            gap: 10px;
            padding: 7px 12px;
            border-radius: 999px;
            border: 1px solid rgba(110, 231, 183, 0.45);
            background: linear-gradient(135deg, rgba(6, 78, 59, 0.55), rgba(4, 120, 87, 0.20));
            font-size: 0.78rem;
            font-weight: 700;
            color: #d1fae5;
            box-shadow: 0 6px 16px rgba(6, 95, 70, 0.18);
        }
        .scarcity-phase2-pulse {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #34d399;
            box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.65);
            animation: scarcityPulse 1.6s ease-out infinite;
        }
        .scarcity-phase2-text strong {
            color: #fff;
            font-weight: 800;
        }
        .scarcity-phase1-total.is-visible {
            display: flex;
        }
        .scarcity-phase2-note.is-visible {
            display: inline-flex;
        }
        @keyframes scarcityPulse {
            0% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.65); }
            70% { box-shadow: 0 0 0 10px rgba(52, 211, 153, 0); }
            100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0); }
        }

        .scarcity-main {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap;
        }

        .scarcity-label {
            margin: 0;
            color: rgba(255, 255, 255, 0.96);
            font-size: 0.92rem;
            font-weight: 700;
        }

        .scarcity-value {
            display: inline-flex;
            align-items: baseline;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(220, 38, 38, 0.28);
            border: 1px solid rgba(252, 165, 165, 0.72);
        }

        .scarcity-number {
            font-size: 1.42rem;
            line-height: 1;
            font-weight: 900;
            color: #fff;
        }

        .scarcity-unit {
            font-size: 0.80rem;
            letter-spacing: 0.06em;
            color: #ffe4e6;
            font-weight: 700;
        }
        .scarcity-denominator {
            display: none;
            font-size: 0.95rem;
            line-height: 1;
            font-weight: 800;
            color: rgba(255, 228, 230, 0.92);
        }
        .scarcity-denominator.is-visible {
            display: inline;
        }

        .scarcity-meter {
            margin-top: 10px;
            width: 100%;
            height: 7px;
            border-radius: 999px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(252, 165, 165, 0.35);
        }

        .scarcity-meter__fill {
            height: 100%;
            width: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, #ef4444, #dc2626);
            box-shadow: 0 0 14px rgba(239, 68, 68, 0.55);
        }
        .inv-offer-expired {
            position: fixed;
            inset: 0;
            z-index: 200000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 18px;
            background: rgba(2, 6, 23, 0.92);
            backdrop-filter: blur(10px);
        }
        .inv-offer-expired.is-visible {
            display: flex;
        }
        html.inv-offer-lock,
        html.inv-offer-lock body {
            overflow: hidden;
            height: 100%;
        }
        .inv-offer-expired__panel {
            width: min(560px, 100%);
            border-radius: 16px;
            border: 1px solid rgba(248, 113, 113, 0.45);
            background: linear-gradient(135deg, rgba(127, 29, 29, 0.55), rgba(15, 23, 42, 0.92));
            box-shadow: 0 24px 70px rgba(127, 29, 29, 0.35);
            padding: 22px 18px 18px;
            text-align: center;
        }
        .inv-offer-expired__title {
            margin: 0;
            font-size: clamp(1.15rem, 2.6vw, 1.45rem);
            font-weight: 900;
            letter-spacing: 0.02em;
            color: #fff1f2;
        }
        .inv-offer-expired__copy {
            margin: 10px 0 14px;
            font-size: 0.95rem;
            line-height: 1.45;
            color: #fecdd3;
        }
        .inv-offer-expired__btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0 16px;
            border-radius: 12px;
            border: 1px solid rgba(251, 113, 133, 0.55);
            background: rgba(225, 29, 72, 0.35);
            color: #fff;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 900;
        }

        .invitation-offer-zone #current-places {
            background: none;
            -webkit-text-fill-color: initial;
            color: #fff;
            animation: none;
        }

        .scarcity-container {
            position: relative;
            z-index: 2;
            max-width: 900px;
            margin: 0 auto;
        }


        /* Badge OFFRE -50% */
        .scarcity-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 8px 20px;
            background: rgba(239, 68, 68, 0.2);
            border: 1px solid rgba(239, 68, 68, 0.4);
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            color: #ef4444;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
            margin-left: auto;
            margin-right: auto;
            width: auto;
        }

        .scarcity-badge .badge-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            flex-shrink: 0;
        }

        .scarcity-badge .badge-icon svg {
            width: 24px;
            height: 24px;
            color: #ef4444;
        }

        .scarcity-badge .badge-text {
            display: inline-block;
        }

        /* URGENT COUNTER - MAIN PANIC ELEMENT */
        .urgent-counter {
            background: linear-gradient(135deg,
                rgba(220, 38, 38, 0.15) 0%,
                rgba(185, 28, 28, 0.12) 30%,
                rgba(220, 38, 38, 0.18) 70%,
                rgba(185, 28, 28, 0.15) 100%);
            border-radius: 25px;
            padding: 40px 30px;
            border: 3px solid rgba(220, 38, 38, 0.4);
            box-shadow: 0 20px 60px rgba(220, 38, 38, 0.25);
            position: relative;
            overflow: hidden;
            /* counterPulse removed for perf */
            text-align: center; /* Centrer le badge et autres éléments */
        }

        /* Reflet premium sur le compteur */
        .urgent-counter::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 50%;
            background: linear-gradient(135deg,
                rgba(255, 255, 255, 0.1) 0%,
                rgba(255, 255, 255, 0.05) 50%,
                transparent 100%);
            border-radius: 25px 25px 0 0;
            pointer-events: none;
        }

        .urgent-counter.sold-out {
            /* Même design que l'état normal - pas d'effet spécial */
            background: linear-gradient(135deg,
                rgba(220, 38, 38, 0.12) 0%,
                rgba(185, 28, 28, 0.08) 50%,
                rgba(220, 38, 38, 0.12) 100%);
            border: 2px solid rgba(220, 38, 38, 0.3);
            box-shadow: 0 15px 40px rgba(220, 38, 38, 0.2);
            /* Supprimer les effets spéciaux */
            animation: none;
        }

        /* COUNTER HEADER - URGENCY FLAMES */
        .counter-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 15px; /* Réduire la marge pour desktop */
            position: relative;
        }


        .urgency-text {
            font-size: 1.4rem;
            font-weight: 800;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: center;
            position: relative;
        }

        .scarcity-title {
            margin-bottom: 60px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Garder le même style pour urgency-text en sold-out */

        /* COUNTER DISPLAY - GIANT NUMBERS */
        .counter-display {
            text-align: center;
            margin-bottom: 30px;
            margin-top: -20px; /* Remonter davantage le compteur pour desktop */
        }

        .counter-number {
            font-size: 6rem;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 15px;
            position: relative;
        }

        #current-places {
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            /* gentlePulse removed for perf */
        }

        .urgent-counter.sold-out #current-places {
            /* Même style que l'état normal */
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            /* gentlePulse removed for perf */
        }

        .counter-slash {
            font-size: 4rem;
            font-weight: 700;
            color: #dc2626;
            margin: 0 5px;
        }

        .counter-total {
            color: #666;
            font-size: 3rem;
            font-weight: 600;
        }

        .counter-label {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 2px;
            /* Animation supprimée pour plus de calme */
            margin-top: -35px; /* Remonter encore plus le texte pour desktop */
        }

        /* counter-label garde le même style blanc en sold-out */

        /* URGENCY METER - VISUAL PROGRESS */
        .urgency-meter {
            margin-bottom: 30px;
        }

        .meter-container {
            width: 100%;
            height: 12px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 25px;
            overflow: hidden;
            margin-bottom: 20px;
            position: relative;
        }

        .meter-fill {
            height: 100%;
            background: linear-gradient(90deg, #dc2626 0%, #b91c1c 100%);
            border-radius: 25px;
            transition: width 0.8s ease;
            position: relative;
        }

        .meter-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg,
                transparent 0%,
                rgba(255, 255, 255, 0.3) 50%,
                transparent 100%);
            /* Animation supprimée pour plus de sobriété */
        }


        /* WARNING MESSAGE - DANGER ZONE */
        .warning-message {
            background: linear-gradient(135deg, rgba(220, 38, 38, 0.15) 0%, rgba(185, 28, 28, 0.15) 100%);
            border: 2px solid rgba(220, 38, 38, 0.4);
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
            /* Assurer que le conteneur reste parfaitement stable */
            transform: none !important;
            animation: none !important;
            transition: none !important;
        }

        .warning-message.high {
            background: linear-gradient(135deg, rgba(220, 38, 38, 0.25) 0%, rgba(185, 28, 28, 0.2) 100%);
            border-color: rgba(220, 38, 38, 0.6);
            /* Animation supprimée */
        }

        .warning-message.critical {
            background: linear-gradient(135deg, rgba(51, 51, 51, 0.3) 0%, rgba(220, 38, 38, 0.25) 100%);
            border-color: #333;
            /* Animation supprimée pour éviter tout mouvement */
        }


        .warning-text {
            font-size: 1.1rem;
            font-weight: 700;
            color: #ffffff;
            /* Assurer que le texte reste parfaitement statique */
            position: relative;
            transform: none !important;
            animation: none !important;
            transition: none !important;
        }

        .warning-text strong {
            color: #ffffff;
            /* Animation supprimée */
        }


        /* CTA Section - URGENT CALL */
        .cta-section {
            text-align: center;
            margin-top: 30px;
        }

        .scarcity-cta-button {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: white !important;
            font-size: 1.4rem;
            font-weight: 800;
            padding: 22px 60px;
            border-radius: 50px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 15px;
            transition: all 0.3s ease;
            box-shadow:
                0 10px 40px rgba(220, 38, 38, 0.5),
                0 0 0 1px rgba(220, 38, 38, 0.3);
            border: none;
            cursor: pointer;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
            /* Supprimer tout effet violet/bleu potentiel */
            filter: none;
            -webkit-filter: none;
        }

        /* Brillance premium sur le bouton */
        .scarcity-cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg,
                transparent,
                rgba(255, 255, 255, 0.2),
                transparent);
            transition: left 0.6s ease;
        }

        .scarcity-cta-button:hover::before {
            left: 100%;
        }

        .scarcity-cta-button:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 15px 50px rgba(220, 38, 38, 0.7);
        }

        .scarcity-cta-button.sold-out {
            /* Même design que l'état normal mais désactivé */
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: white !important;
            cursor: not-allowed;
            pointer-events: none;
            opacity: 0.8; /* Légèrement transparent mais pas gris */
            transform: none;
            box-shadow: 0 10px 40px rgba(220, 38, 38, 0.5);
            /* Forcer l'absence totale de glow violet en sold-out */
            filter: none !important;
            -webkit-filter: none !important;
            text-shadow: none !important;
            -webkit-text-stroke: none !important;
        }

        .scarcity-cta-button.sold-out:hover {
            /* Même hover que normal mais désactivé */
            transform: none;
            box-shadow: 0 10px 40px rgba(220, 38, 38, 0.5);
        }

        .scarcity-cta-button.sold-out .cta-arrow {
            /* Garder la flèche visible mais en blanc */
            color: white;
            opacity: 0.8;
        }

        .cta-arrow {
            font-size: 1.4rem;
            transition: transform 0.3s ease;
            /* Animation supprimée pour plus de calme */
        }

        .scarcity-cta-button:hover .cta-arrow {
            transform: translateX(8px);
        }

        /* CTA Benefits */
        .cta-benefits {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
            margin-bottom: 30px;
        }

        .benefit {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 18px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            border: 1px solid rgba(220, 38, 38, 0.3);
        }

        .benefit-icon {
            font-size: 1.2rem;
        }

        .benefit-text {
            font-size: 0.9rem;
            color: #333;
            font-weight: 600;
        }

        /* Sold Out State */
        .sold-out-state {
            text-align: center;
            padding: 50px 30px;
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            border-radius: 25px;
            box-shadow: 0 15px 50px rgba(220, 38, 38, 0.4);
            animation: soldOutPulse 1s ease-in-out infinite;
            margin-top: 30px;
        }

        .sold-out-content {
            color: white;
        }

        .sold-out-icon {
            display: none;
        }

        .sold-out-title {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sold-out-description {
            font-size: 1.1rem;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .reminder-btn {
            background: rgba(255, 255, 255, 0.25);
            color: white;
            border: 2px solid white;
            padding: 15px 30px;
            border-radius: 30px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .reminder-btn:hover {
            background: white;
            color: #dc2626;
            transform: scale(1.05);
        }

        /* ANIMATIONS - PANIC EFFECTS */
        @keyframes counterPulse {
            0%, 100% {
                box-shadow: 0 15px 50px rgba(220, 38, 38, 0.25);
                transform: scale(1);
            }
            50% {
                box-shadow: 0 18px 55px rgba(220, 38, 38, 0.35);
                transform: scale(1.005); /* Plus subtil */
            }
        }


        @keyframes numberThrob {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.03); } /* Plus subtil */
        }

        /* Animation pulse légère pour le nombre de places */
        @keyframes gentlePulse {
            0%, 100% {
                transform: scale(1);
                opacity: 1;
            }
            50% {
                transform: scale(1.08); /* Pulse très léger */
                opacity: 0.95;
            }
        }

        @keyframes soldOutPulse {
            0%, 100% {
                transform: scale(1);
                box-shadow: 0 15px 50px rgba(220, 38, 38, 0.4);
            }
            50% {
                transform: scale(1.02);
                box-shadow: 0 20px 60px rgba(220, 38, 38, 0.6);
            }
        }


        /* Mobile Responsive - URGENT DESIGN */
        @media (max-width: 768px) {
            .scarcity-section {
                padding: 50px 0;
            }

            .urgent-counter {
                padding: 30px 20px;
                margin: 0 10px;
            }

            .counter-header {
                margin-bottom: 10px; /* Réduire aussi pour mobile */
            }

            .counter-display {
                margin-top: -5px; /* Ajustement plus subtil pour mobile */
            }

            .counter-label {
                margin-top: -15px; /* Ajustement pour mobile */
            }

            .urgency-text {
                font-size: 1.1rem;
            }

            .scarcity-title {
                margin-bottom: 40px;
            }

            .counter-number {
                font-size: 4rem;
                gap: 5px;
            }

            #current-places {
                font-size: 4rem;
            }

            .counter-slash {
                font-size: 2.5rem;
            }

            .counter-total {
                font-size: 2rem;
            }

            .counter-label {
            font-size: 1.2rem;
                letter-spacing: 1px;
            }

            .urgency-meter {
                margin-bottom: 20px;
            }


            .warning-message {
                padding: 15px;
                margin: 20px 10px 0;
            }

            .warning-text {
                font-size: 1rem;
            }

            .scarcity-cta-button {
                font-size: 1.1rem;
                padding: 18px 40px;
                margin-bottom: 15px;
            }

            .cta-benefits {
                gap: 15px;
                margin-bottom: 20px;
            }

            .benefit {
                padding: 10px 14px;
                font-size: 0.85rem;
            }

            .sold-out-state {
                padding: 35px 20px;
                margin: 20px 10px 0;
            }


            .sold-out-title {
                font-size: 1.8rem;
                letter-spacing: 1px;
            }

            .sold-out-description {
                font-size: 1rem;
            }

            .reminder-btn {
                padding: 12px 25px;
                font-size: 0.9rem;
            }
        }

        /* Extra Small Mobile */
        @media (max-width: 480px) {
            .counter-number {
                font-size: 3.5rem;
            }

            #current-places {
                font-size: 3.5rem;
            }

            .counter-slash {
                font-size: 2rem;
            }

            .counter-total {
                font-size: 1.8rem;
            }

            .urgency-text {
                font-size: 1rem;
                text-align: center;
            }

            .scarcity-cta-button {
                font-size: 1rem;
                padding: 16px 35px;
            }

            .benefit {
                padding: 8px 12px;
            }
        }

        /* Background Elements */
        .scarcity-bg-elements {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
