        .ss-story-card p {
            color: var(--text-secondary);
            font-size: clamp(0.95rem, 1.1vw, 1.04rem);
            line-height: 1.82;
            margin: 0 0 0.9em;
        }

        .ss-blockquote {
            margin: clamp(18px, 2.5vw, 26px) 0;
            padding: clamp(18px, 2.5vw, 24px) clamp(20px, 3vw, 26px);
            background: rgba(59, 130, 246, 0.07);
            border-left: 3px solid rgba(96, 165, 250, 0.5);
            border-radius: 0 12px 12px 0;
            font-style: italic;
            color: rgba(255, 255, 255, 0.92);
            font-size: clamp(0.96rem, 1.1vw, 1.04rem);
