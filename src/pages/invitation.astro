    <style>html{opacity:0}html.ready{opacity:1;transition:opacity .15s ease}</style>
</head>
<body>
    <PromoBanner formation="manifest" />
    <div id="promo-config"
      data-start={promo.start}
      data-deadline={promo.deadline}
      data-badge={promo.badgeText}
      data-active={isPromoActiveFor('manifest').toString()}
      data-promo-label={getPromoLabel()}
      data-banner-message={getPromoBannerMessage()}
      data-checkout-code={getPromoCheckoutCode('manifest')}
      data-price-original={promo.formations.manifest.priceOriginal}
      data-price-promo={promo.formations.manifest.pricePromo}
      data-installment-count={promo.formations.manifest.installmentCount}
      data-installment-price={promo.formations.manifest.installmentPrice}
      style="display:none;"></div>
    {/* BlackFriday Banner désactivé - Réactiver l'année prochaine en changeant show={false} en show={true} */}
    <BlackFridayBanner show={false} discount={70} />
    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="guarantee-title guarantee-title--split hero-page-title">
                    <span class="hero-page-title__stack">
                        <span class="guarantee-title-main">Le seul accompagnement dont tu as besoin</span>
                        <span class="guarantee-title-accent">pour reprogrammer ton subconscient</span>
                        <span class="guarantee-title-accent">et manifester la vie de tes rêves.</span>
                    </span>
                </h1>

                <div class="hero-cover-container">
                    <div class="premium-frame">
                        <div class="frame-border"></div>
                        <div class="glare-effect"></div>
                        <img src="/media/pages/ES20-banner.webp"
                             alt="Cover ES 2.0 - papillon bleu"
                             class="hero-cover-image">
                        <div class="subtle-overlay"></div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Scarcity Section -->
    <section class="scarcity-section">
        <div class="container">
            <div class="invitation-offer-zone">
                <p class="offer-countdown-title">L'offre expire dans :</p>
                <div class="offer-countdown-grid">
                    <div class="offer-countdown-box"><span id="offer-days" class="offer-countdown-value">03</span><span class="offer-countdown-label">Jours</span></div>
                    <div class="offer-countdown-box"><span id="offer-hours" class="offer-countdown-value">01</span><span class="offer-countdown-label">Heures</span></div>
                    <div class="offer-countdown-box"><span id="offer-minutes" class="offer-countdown-value">29</span><span class="offer-countdown-label">Minutes</span></div>
                    <div class="offer-countdown-box"><span id="offer-seconds" class="offer-countdown-value">44</span><span class="offer-countdown-label">Secondes</span></div>
                </div>

                <div class="scarcity-card" id="scarcity-card" aria-live="polite">
                    <p class="scarcity-kicker">Nombre de places limitées</p>
                    <div class="scarcity-phase1-total">
                        <span class="scarcity-soldout-stamp">Sold out</span>
                        <div class="scarcity-soldout-line">
                            <span class="scarcity-soldout-count">30<span class="scarcity-soldout-slash">/30</span> places vendues</span>
                            <span class="scarcity-soldout-text">parties en quelques heures</span>
                        </div>
                    </div>
                    <div class="scarcity-phase2-note">
                        <span class="scarcity-phase2-pulse"></span>
                        <span class="scarcity-phase2-text"><strong>10 places rouvertes</strong> exceptionnellement</span>
                    </div>
                    <div class="scarcity-main">
                        <p class="scarcity-label">Places restantes</p>
                        <div class="scarcity-value">
                            <span class="scarcity-number" id="current-places">30</span>
                            <span class="scarcity-denominator">/ 10</span>
                            <span class="scarcity-unit">places</span>
                        </div>
                    </div>
                    <div class="scarcity-meter" aria-hidden="true">
                        <div class="scarcity-meter__fill"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <div class="container">
            <h2 class="guarantee-title guarantee-title--split features-morphosis-title">
                <span class="guarantee-title-main">Ta métamorphose</span>
                <span class="guarantee-title-accent">en 5 étapes</span>
            </h2>
            <div class="feature-card fade-in">
                <div class="feature-content">
                    <span class="feature-number" aria-hidden="true">01</span>
                    <h3><span>L'aube avant la</span> lumière</h3>
                    <p>Tu dormais sans le savoir, enveloppé d'une inconscience si familière que tu la prenais pour la vie. Puis cette masterclass a posé des mots sur ce qui te bloquait depuis toujours. La coquille s'est fissurée de l'intérieur.</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/1-etape-es.webp?v=20260324" alt="Étape 1 - L'aube avant la lumière">
                </div>
            </div>

            <div class="feature-card fade-in">
                <div class="feature-content">
                    <span class="feature-number" aria-hidden="true">02</span>
                    <h3><span>Entre deux</span> mondes</h3>
                    <p>Tu n'es plus qui tu étais. Pas encore qui tu veux devenir. C'est l'instant clef de ta transformation. Celui où le savoir seul ne protège de rien. Sans matière pour te nourrir, sans action pour avancer, sans structure pour te protéger, sans cela, le papillon meurt avant d'avoir existé.</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/2-etape-es.webp" alt="Étape 2 - Entre deux mondes">
                </div>
            </div>

            <div class="feature-card fade-in">
                <div class="feature-content">
                    <span class="feature-number" aria-hidden="true">03</span>
                    <h3><span>Disparaître pour</span> renaître</h3>
                    <p>Dans le cocon, la chenille se dissout entièrement. Elle cesse d'être pour devenir autre chose. C'est la loi de toute vraie transformation. On ne devient pas ce qu'on veut en ajoutant. On le devient en laissant mourir ce qu'on était. À l'extérieur, rien ne se voit. À l'intérieur, tout change.</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/3-etape-es.webp" alt="Étape 3 - Disparaître pour renaître">
                </div>
            </div>

            <div class="feature-card fade-in">
                <div class="feature-content">
                    <span class="feature-number" aria-hidden="true">04</span>
                    <h3><span>Les premiers</span> signes</h3>
                    <p>Le papillon ne vole pas encore. Mais il sait déjà que le ciel est à lui. Les premières synchronicités arrivent. Une rencontre inattendue. Une porte qui s'ouvre. Une coïncidence trop parfaite pour en être une. Ce ne sont pas des preuves... Tu n'en as plus besoin. Ce sont des confirmations.</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/4-etape-es.webp" alt="Étape 4 - Les premiers signes">
                </div>
            </div>

            <div class="feature-card fade-in">
                <div class="feature-content">
                    <span class="feature-number" aria-hidden="true">05</span>
                    <h3><span>Ta vraie nature</span> révélée</h3>
                    <p>Le papillon ne se souvient plus d'avoir été chenille. Il vole... C'est tout ce qu'il connaît. Tu n'essaies plus de changer ta vie. Tu la vis. Tes désirs ne sont plus des rêves, ils sont ta réalité quotidienne. Et au fond de toi, une vérité silencieuse : tu n'es pas devenu quelqu'un d'autre. Tu es enfin qui tu étais depuis toujours.</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/5-etape-es.webp" alt="Étape 5 - Ta vraie nature révélée">
                </div>
            </div>
        </div>
    </section>

    <!-- Ce que tu vas obtenir + bonus + prix + CTA (un seul fond) -->
    <section class="descriptive-section">
        <div class="container">
            <div class="descriptive-content">
                <div class="es2-obtain-heading">
                    <h2 class="guarantee-title guarantee-title--split"><span class="guarantee-title-main">Ce que tu vas obtenir avec </span><span class="guarantee-title-accent">Esprit Subconscient 2.0</span></h2>
                    <p class="es2-obtain-subtitle">La transformation complète sur 6 mois</p>
                </div>

                <div class="descriptive-image-wrapper">
                    <div class="descriptive-image-frame">
                        <img src="/media/pages/es2-bundle.webp"
                             alt="Formation MANIFEST - Sonny Court"
                             class="descriptive-image">
                        <div class="descriptive-image-glow"></div>
                    </div>
                </div>

                <div class="descriptive-text">
                    <!-- Section 1 — Ce que tu vas obtenir -->
                    <section class="es2-obtain-section">
                        <div class="es2-obtain-volume">
                            <span class="es2-volume-pill">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                36h+ de contenus
                            </span>
                            <span class="es2-volume-sep">·</span>
                            <span class="es2-volume-label">Un système de transformation sur 6 mois</span>
                        </div>
                        <div class="es2-obtain-container">
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Un subconscient reprogrammé en profondeur</h3>
                                    <p>Tu sauras exactement comment accéder à ton subconscient et le reprogrammer sur commande pour qu'il travaille POUR toi, pas contre toi.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>La fin des croyances limitantes qui te sabotent depuis toujours</h3>
                                    <p>Tu identifieras enfin les vraies racines de tes blocages financiers, amoureux et professionnels. Et tu sauras comment les désamorcer définitivement.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>La capacité d'incarner n'importe quel état d'être sur commande</h3>
                                    <p>Confiance, paix, abondance, magnétisme. Tu sauras activer ces états quand tu en as besoin, peu importe ton point de départ.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Une transformation qui s'ancre même pendant ton sommeil</h3>
                                    <p>Tu apprendras à utiliser les moments où ton cerveau est le plus réceptif pour que ta reprogrammation continue 24h sur 24, sans effort conscient.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Une clarté mentale que tu n'as jamais eue</h3>
                                    <p>Finies les ruminations, les doutes permanents, les pensées qui tournent en rond. Tu sauras comment reprendre le contrôle complet de ton espace mental.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Le pouvoir de manifester ta nouvelle vie avec précision</h3>
                                    <p>Tu comprendras pourquoi la majorité des gens échouent à manifester et tu maîtriseras les lois précises qui gouvernent la création de ta réalité.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Une transformation qui se voit de l'extérieur</h3>
                                    <p>Ton énergie, ta présence, ta façon de parler, ta posture. Les gens autour de toi vont remarquer que quelque chose a changé sans pouvoir mettre le doigt dessus.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Une méthodologie basée sur les neurosciences</h3>
                                    <p>Pas de spiritualité floue. Chaque technique est ancrée dans la compréhension scientifique du fonctionnement du cerveau humain.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Un parcours structuré sur 6 mois</h3>
                                    <p>Un plan précis semaine par semaine, module par module. Tu sais toujours où tu en es et où tu vas.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Des outils à utiliser pour le reste de ta vie</h3>
                                    <p>Vidéos démonstratives, audios guidés, exercices mentaux accompagnés, fiches d'implémentation. Une boîte à outils complète que tu pourras utiliser bien au-delà des 6 mois de la formation.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Un accès qui te suit partout</h3>
                                    <p>Sur ton téléphone, ta tablette, ton ordinateur. La formation t'accompagne où que tu sois, quand tu veux.</p>
                                </div>
                            </div>
                            <div class="es2-obtain-item">
                                <svg class="es2-check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#2563eb"/><path d="M7.5 12.5 10.5 15.5 16.5 9" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <div>
                                    <h3>Des mises à jour à vie</h3>
                                    <p>Le programme évolue, et tu en bénéficies pour toujours. Tu achètes une transformation, pas un produit figé. (Mises à jour mensuelles).</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Section 2 — Les 3 bonus exclusifs -->
                    <section class="es2-bonus-section">
                        <p class="es2-bonus-kicker">Et en rejoignant aujourd'hui</p>
                        <h2 class="es2-bonus-title">Tu reçois aussi ces 3 bonus exclusifs</h2>
                        <div class="es2-bonus-grid">
                            <div class="es2-bonus-card">
                                <div class="es2-bonus-body">
                                    <span class="es2-bonus-badge">Bonus 1</span>
                                    <h3 class="es2-bonus-name">Morpho — Ton compagnon IA de transformation</h3>
                                    <p class="es2-bonus-desc">12 mois d'accès à l'application web réservée exclusivement aux membres de la formation. Ton journal quotidien, ton coach IA disponible 24/7 qui te connaît personnellement, ton tableau de progression visuelle. Aucun autre système de développement personnel francophone ne propose ça.<br><a href="https://morpho.day" target="_blank" rel="noopener noreferrer">Aperçu sur morpho.day</a></p>
                                </div>
                                <div class="es2-bonus-val">
                                    <span class="es2-bonus-val-label">Valeur</span>
                                    <span class="es2-bonus-val-amount">597€</span>
                                </div>
                            </div>
                            <div class="es2-bonus-card">
                                <div class="es2-bonus-body">
                                    <span class="es2-bonus-badge">Bonus 2</span>
                                    <h3 class="es2-bonus-name">La communauté Volt — Accès à vie</h3>
                                    <p class="es2-bonus-desc">Rejoins pour toujours des centaines de personnes qui font exactement le même travail que toi. Pas 6 mois. Pas 1 an. À vie. Partages quotidiens, victoires collectives, soutien permanent dans chaque étape de ta vie, pas juste pendant la formation.</p>
                                </div>
                                <div class="es2-bonus-val">
                                    <span class="es2-bonus-val-label">Valeur</span>
                                    <span class="es2-bonus-val-amount">997€</span>
                                </div>
                            </div>
                            <div class="es2-bonus-card">
                                <div class="es2-bonus-body">
                                    <span class="es2-bonus-badge">Bonus 3</span>
                                    <h3 class="es2-bonus-name">Ta consultation privée avec Sonny au jour 30</h3>
                                    <p class="es2-bonus-desc">Au bout de 30 jours, je t'envoie un formulaire personnel sur ton avancée, tes blocages et tes premières transformations. En retour, je t'écris personnellement un feedback complet avec des recommandations adaptées à TA situation. Pas un email automatisé. Un vrai échange entre toi et moi.</p>
                                </div>
                                <div class="es2-bonus-val">
                                    <span class="es2-bonus-val-label">Valeur</span>
                                    <span class="es2-bonus-val-amount">497€</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Price Reveal Section -->
