        .sales-quote-avatar {
            flex-shrink: 0;
            width: 48px;
            height: 48px;
            aspect-ratio: 1 / 1;
            border-radius: 10px;
            border: 1px dashed rgba(96, 165, 250, 0.45);
            background: linear-gradient(145deg, rgba(59, 130, 246, 0.18) 0%, rgba(15, 23, 42, 0.45) 100%);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
        }

        img.sales-quote-avatar {
            object-fit: cover;
            border-style: solid;
            border-color: rgba(96, 165, 250, 0.3);
        }

        .ss-mini-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: clamp(14px, 2vw, 18px);
            margin: clamp(28px, 4vw, 40px) 0;
        }

        .ss-mini-card {
            padding: clamp(18px, 2.5vw, 24px);
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 14px;
            transition: border-color 0.25s ease;
        }

        .ss-mini-card:hover {
            border-color: rgba(96, 165, 250, 0.25);
        }

        .ss-mini-card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }

        .ss-mini-card-header .sales-quote-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
        }

        .ss-mini-card-header strong {
            color: #e2e8f0;
            font-size: clamp(0.88rem, 1vw, 0.95rem);
        }

        .ss-mini-card p {
            margin: 0;
            font-style: italic;
            color: rgba(255, 255, 255, 0.78);
            font-size: clamp(0.9rem, 1.05vw, 0.98rem);
            line-height: 1.72;
        }

        .ss-callout {
            margin: clamp(32px, 5vw, 48px) 0;
            padding: clamp(24px, 3.5vw, 32px);
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            text-align: center;
        }

        .ss-callout--accent {
            background: rgba(59, 130, 246, 0.06);
            border-color: rgba(96, 165, 250, 0.2);
        }

        .ss-callout p {
            color: var(--text-secondary);
            font-size: clamp(1rem, 1.15vw, 1.08rem);
            line-height: 1.8;
            margin: 0 0 0.7em;
        }

        .ss-callout p:last-child {
            margin-bottom: 0;
        }

        .ss-callout strong {
            color: #e2e8f0;
        }

        .ss-final-push {
            text-align: center;
            font-size: clamp(1.1rem, 1.5vw, 1.24rem);
            color: #fff;
            margin: clamp(28px, 4vw, 40px) 0 0;
        }

        .sales-closing-title {
            font-size: clamp(1.2rem, 2.4vw, 1.48rem);
            font-weight: 700;
            color: #fff;
            margin: clamp(48px, 7vw, 72px) 0 clamp(14px, 2vw, 18px);
            line-height: 1.35;
            text-align: center;
        }

        .sales-stories-cta {
            text-align: center;
            margin-top: clamp(28px, 4vw, 40px);
        }

        .sales-stories-cta .cta-button-final {
            display: inline-flex;
        }

        /* Video Reviews Block (inside guarantee section) */
        .video-reviews-block {
            text-align: center;
            margin-bottom: clamp(80px, 14vw, 180px);
        }

        .video-reviews-block .section-subtitle {
            text-align: center;
            color: var(--text-secondary);
            font-size: clamp(1rem, 1.3vw, 1.2rem);
            margin-bottom: clamp(32px, 5vw, 60px);
            font-style: italic;
        }

        .video-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: clamp(16px, 2.5vw, 32px);
            margin-top: clamp(32px, 5vw, 60px);
            max-width: 960px;
            margin-left: auto;
            margin-right: auto;
        }

        .video-card {
            background: linear-gradient(165deg, rgba(255, 255, 255, 0.04), rgba(15, 23, 42, 0.5));
            border: 1px solid rgba(96, 165, 250, 0.2);
            border-radius: 20px;
            padding: clamp(10px, 1.5vw, 16px);
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
            box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
            aspect-ratio: 9 / 16;
        }

        .video-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(59, 130, 246, 0.22);
            border-color: rgba(96, 165, 250, 0.45);
        }

        .review-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 14px;
            background: var(--dark-bg);
            outline: none;
        }

        .review-video:focus {
            outline: 2px solid rgba(96, 165, 250, 0.6);
            outline-offset: 4px;
        }

        /* Custom Play Button */
        .custom-play-button {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: clamp(44px, 8vw, 72px);
            height: clamp(44px, 8vw, 72px);
            background: none;
            border: none;
            cursor: pointer;
            z-index: 15;
            transition: transform 0.3s ease, opacity 0.3s ease;
            opacity: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .custom-play-button:hover {
            transform: translate(-50%, -50%) scale(1.1);
        }

        .custom-play-button:active {
            transform: translate(-50%, -50%) scale(0.95);
        }

        .custom-play-button svg {
            width: 100%;
            height: 100%;
            filter: drop-shadow(0 4px 8px rgba(59, 130, 246, 0.3));
        }

        /* Hide/show play and pause icons */
        .custom-play-button .play-icon,
        .custom-play-button .pause-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            transition: opacity 0.3s ease;
        }

        /* Hide pause icon by default */
        .custom-play-button .pause-icon {
            display: none;
        }

        .custom-play-button svg circle {
            transition: all 0.3s ease;
        }

        .custom-play-button:hover svg circle {
            r: 13;
            stroke-width: 3;
        }

        /* Hide custom play button when video is playing */
        .video-card.playing .custom-play-button {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        /* Show custom play button when paused (but hide at start/end) */
        .video-card.paused .custom-play-button {
            opacity: 1;
            pointer-events: auto;
        }

        /* Blue-tinted overlay before first play */
        .video-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(180deg,
                rgba(15, 23, 42, 0.25) 0%,
                rgba(30, 58, 138, 0.18) 40%,
                rgba(15, 23, 42, 0.45) 100%);
            border-radius: 14px;
            z-index: 4;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }

        .video-card.has-played::after {
            opacity: 0;
        }

        /* Bonus Section */
        .bonus-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--dark-bg) 0%, var(--darker-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .bonus-card {
            background: var(--card-bg);
            border: 2px solid var(--primary-purple);
            border-radius: 24px;
            padding: 60px;
            margin-bottom: 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .bonus-badge {
            position: absolute;
            top: 30px;
            left: 30px;
            background: var(--gradient-primary);
            color: var(--darker-bg);
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .bonus-content {
            padding-top: 40px;
        }

        .bonus-title {
            font-size: 2.5rem;
            margin-bottom: 20px;
            color: var(--primary-purple);
            font-weight: 700;
        }

        .bonus-subtitle {
            font-size: 1.5rem;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .bonus-description {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.8;
        }

        .bonus-image {
            position: relative;
        }

        .bonus-image img {
            width: 100%;
            border-radius: 16px;
            filter: brightness(0.9);
            transition: all 0.3s ease;
        }

        .bonus-card:hover .bonus-image img {
            filter: brightness(1);
            transform: scale(1.05);
        }

        /* Guarantee Section */
        .guarantee-section {
            padding: 140px 0;
            background:
                radial-gradient(circle at 30% 20%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(255, 215, 0, 0.04) 0%, transparent 50%),
                linear-gradient(180deg, var(--darker-bg) 0%, var(--dark-bg) 100%);
            position: relative;
            z-index: 2;
            overflow: hidden;
        }

        .guarantee-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image:
                radial-gradient(circle at 20% 30%, rgba(59, 130, 246, 0.03) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(255, 215, 0, 0.02) 0%, transparent 40%);
            pointer-events: none;
        }

        .guarantee-hero {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            margin-bottom: 80px;
            position: relative;
            gap: 18px;
        }

        .guarantee-shield {
            position: relative;
            margin-bottom: 0;
            display: inline-block;
        }

        .shield-icon {
            width: 280px;
            height: 280px;
            border-radius: 0;
            object-fit: contain;
            color: var(--primary-purple);
            filter:
                drop-shadow(0 0 20px rgba(59, 130, 246, 0.6))
                drop-shadow(0 0 40px rgba(59, 130, 246, 0.3))
                drop-shadow(0 0 60px rgba(59, 130, 246, 0.2));
            /* animation removed for perf */
        }

        .shield-glow {
            position: absolute;
            top: -40px;
            left: -40px;
            right: -40px;
            bottom: -40px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.25) 0%, transparent 70%);
            /* animation removed for perf */
            border-radius: 50%;
            pointer-events: none;
        }

        .guarantee-title {
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            font-weight: 800;
            margin-bottom: 25px;
            background: linear-gradient(135deg, #60A5FA 0%, #3B82F6 50%, #1D4ED8 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.2;
            text-shadow: 0 0 30px rgba(59, 130, 246, 0.3);
            text-align: center;
            text-transform: uppercase;
        }

        .guarantee-title--split {
            display: inline-block;
            margin-inline: auto;
            max-width: 900px;
        }

        .guarantee-title-main {
            color: #fff;
            background: none;
            -webkit-background-clip: initial;
            -webkit-text-fill-color: #fff;
            background-clip: initial;
        }

        .guarantee-title-accent {
            background: linear-gradient(135deg, #60A5FA 0%, #3B82F6 50%, #1D4ED8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .features-morphosis-title.guarantee-title.guarantee-title--split {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
            margin-bottom: clamp(40px, 6vw, 72px);
            text-align: center;
            gap: 0.12em;
            line-height: 1.15;
        }

        .features-morphosis-title .guarantee-title-main,
        .features-morphosis-title .guarantee-title-accent {
            display: block;
            width: fit-content;
            max-width: 100%;
        }

        /* Hero H1 : même échelle / typo que .guarantee-title ; pas de dégradé sur le bloc ; lignes lisibles */
        .hero-page-title.guarantee-title {
            margin: 0 auto 28px;
            max-width: min(100%, 920px);
            background: none;
            background-size: auto;
            -webkit-text-fill-color: unset;
            background-clip: unset;
            filter: none;
            text-shadow: none;
        }

        .hero-page-title.guarantee-title.guarantee-title--split {
            display: block;
        }

        .hero-page-title .hero-page-title__stack {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.08em;
            line-height: 1.18;
        }

        .hero-page-title .hero-page-title__stack > span {
            display: block;
            max-width: 100%;
        }

        /* Style spécifique pour le titre de la section scarcity */
        .scarcity-title {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        /* Emoji en noir/blanc normal */
        .scarcity-emoji {
            font-size: 2.5rem;
            color: #000000;
            text-shadow: none;
            background: none;
            -webkit-text-fill-color: #000000;
        }

        /* Texte en rouge avec gradient */
        .scarcity-text {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 50%, #991b1b 100%);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(220, 38, 38, 0.5);
            /* gradientShift removed for perf */
            font-size: clamp(2rem, 3vw, 2.8rem);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
        }


        @keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
            100% {
                background-position: 0% 50%;
            }
        }

        .guarantee-badge {
            background:
                linear-gradient(135deg, var(--primary-purple) 0%, #60A5FA 100%);
            color: white;
            padding: 12px 30px;
            border-radius: 30px;
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
            margin-top: 2px;
            box-shadow:
                0 8px 20px rgba(59, 130, 246, 0.4),
                inset 0 0 0 1px rgba(255, 255, 255, 0.1);
        }

        .guarantee-content {
            max-width: 1000px;
            margin: 0 auto;
        }

        .guarantee-intro {
            margin-bottom: 60px;
        }

        .guarantee-text-large {
            font-size: 1.4rem;
            color: var(--text-primary);
            line-height: 1.6;
            text-align: center;
            font-weight: 500;
            margin: 0;
        }

        .guarantee-main {
            margin-bottom: 80px;
        }

        .guarantee-highlight {
            background:
                linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(59, 130, 246, 0.05) 100%),
                rgba(20, 20, 20, 0.8);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 24px;
            padding: 40px;
            margin-bottom: 60px;
            display: flex;
            align-items: center;
            gap: 30px;
            position: relative;
            overflow: hidden;
        }

        .guarantee-highlight::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(59, 130, 246, 0.1),
                transparent
            );
            transition: left 1s ease;
        }

        .guarantee-highlight:hover::before {
            left: 100%;
        }

        .highlight-icon {
            width: 60px;
            height: 60px;
            color: var(--primary-purple);
            flex-shrink: 0;
            filter: drop-shadow(0 0 10px rgba(59, 130, 246, 0.5));
        }

        .guarantee-highlight-text {
            font-size: 1.3rem;
            color: var(--text-primary);
            line-height: 1.6;
            margin: 0;
            font-weight: 500;
        }

        .guarantee-steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }

        .step-item {
            background: var(--card-bg);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 16px;
            padding: 30px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .step-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.05) 0%, transparent 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .step-item:hover::before {
            opacity: 1;
        }

        .step-item:hover {
            transform: translateY(-5px);
            border-color: rgba(59, 130, 246, 0.4);
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2);
        }

        .step-number {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--primary-purple) 0%, #60A5FA 100%);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0 auto 20px;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }

        .step-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 10px;
        }

        .step-description {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.5;
            margin: 0;
        }

        .guarantee-conditions {
            background: var(--card-bg);
            border: 2px solid rgba(59, 130, 246, 0.3);
            border-radius: 24px;
            padding: 50px;
            margin-bottom: 60px;
            text-align: center;
            position: relative;
        }

        .conditions-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 25px;
        }

        .guarantee-text {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.7;
            margin: 0 0 30px 0;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .guarantee-reassurance {
            list-style: none;
            margin: 0 auto;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
            align-items: stretch;
            justify-content: center;
            gap: clamp(10px, 2vw, 16px);
            max-width: 900px;
        }

        .guarantee-pill {
            margin: 0;
            padding: 0.65em 1.15em;
            font-size: clamp(0.85rem, 1.8vw, 0.98rem);
            font-weight: 600;
            letter-spacing: 0.02em;
            color: rgba(226, 232, 240, 0.95);
            background: linear-gradient(165deg, rgba(255, 255, 255, 0.06), rgba(15, 23, 42, 0.45));
            border: 1px solid rgba(96, 165, 250, 0.28);
            border-radius: 999px;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.18);
            text-align: center;
            line-height: 1.35;
        }

        @media (max-width: 520px) {
            .guarantee-pill {
                flex: 1 1 100%;
            }
        }

        .guarantee-trust {
            background:
                linear-gradient(135deg, rgba(59, 130, 246, 0.08) 0%, rgba(59, 130, 246, 0.04) 100%),
                rgba(20, 20, 20, 0.9);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 24px;
            padding: 50px;
            text-align: center;
            position: relative;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }

        .trust-icon {
            position: relative;
            margin-bottom: 30px;
            display: inline-block;
            isolation: isolate;
        }

        .trust-glow {
            position: absolute;
            z-index: 0;
            inset: -42px -58px -38px -58px;
            background:
                radial-gradient(
                    ellipse 72% 68% at 50% 48%,
                    rgba(96, 165, 250, 0.1) 0%,
                    rgba(59, 130, 246, 0.04) 45%,
                    rgba(59, 130, 246, 0) 72%
                ),
                radial-gradient(
                    ellipse 100% 92% at 50% 52%,
                    rgba(59, 130, 246, 0.07) 0%,
                    rgba(37, 99, 235, 0.028) 48%,
                    rgba(59, 130, 246, 0.008) 72%,
                    rgba(59, 130, 246, 0) 100%
                );
            pointer-events: none;
        }

        .trust-icon svg {
            position: relative;
            z-index: 1;
            width: 80px;
            height: 80px;
            color: var(--primary-purple);
            filter:
                drop-shadow(0 0 22px rgba(96, 165, 250, 0.18))
                drop-shadow(0 0 44px rgba(59, 130, 246, 0.1))
                drop-shadow(0 0 72px rgba(37, 99, 235, 0.05));
        }

        .trust-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 25px;
        }

        .trust-text {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.7;
            margin-bottom: 20px;
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
        }

        .trust-text:last-child {
            margin-bottom: 0;
        }

        @keyframes shieldPulse {
            0%, 100% {
                transform: scale(1);
                filter:
                    drop-shadow(0 0 20px rgba(59, 130, 246, 0.6))
                    drop-shadow(0 0 40px rgba(59, 130, 246, 0.4));
            }
            50% {
                transform: scale(1.05);
                filter:
                    drop-shadow(0 0 25px rgba(59, 130, 246, 0.8))
                    drop-shadow(0 0 50px rgba(59, 130, 246, 0.6));
            }
        }

        @keyframes shieldGlowPulse {
            0%, 100% {
                opacity: 0.3;
                transform: scale(1);
            }
            50% {
                opacity: 0.6;
                transform: scale(1.1);
            }
        }

        @keyframes trustPulse {
            0%, 100% {
                transform: scale(1);
                filter:
                    drop-shadow(0 0 15px rgba(59, 130, 246, 0.5))
                    drop-shadow(0 0 30px rgba(59, 130, 246, 0.3));
            }
            50% {
                transform: scale(1.02);
                filter:
                    drop-shadow(0 0 20px rgba(59, 130, 246, 0.7))
                    drop-shadow(0 0 40px rgba(59, 130, 246, 0.5));
            }
        }

        @keyframes trustGlowPulse {
            0%, 100% {
                opacity: 0.3;
                transform: scale(1);
            }
            50% {
                opacity: 0.5;
                transform: scale(1.05);
            }
        }

        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
                opacity: 1;
            }
            50% {
                transform: scale(1.05);
                opacity: 0.9;
            }
        }

        @media (max-width: 768px) {
            .guarantee-highlight {
                flex-direction: column;
                text-align: center;
                gap: 20px;
                padding: 30px;
            }

            .guarantee-steps {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .guarantee-conditions {
                padding: 30px;
            }

            .guarantee-trust {
                padding: 30px;
            }

            .shield-icon {
                width: 200px;
                height: 200px;
            }

            .guarantee-title {
                font-size: 2rem;
            }

            .trust-icon svg {
                width: 60px;
                height: 60px;
            }

            .trust-glow {
                inset: -30px -42px -26px -42px;
            }
        }

        /* Modules Section */
        .modules-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--darker-bg) 0%, var(--dark-bg) 50%, var(--darker-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .modules-heading-anchor {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: clamp(28px, 4vw, 44px);
        }

        .modules-section-heading.guarantee-title.guarantee-title--split {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: fit-content;
            max-width: min(100%, 920px);
            margin: 0;
            padding: 0 clamp(8px, 2vw, 16px);
            box-sizing: border-box;
            background: none;
            background-size: auto;
            -webkit-text-fill-color: unset;
            background-clip: unset;
            text-shadow: none;
            gap: 0.1em;
            line-height: 1.15;
        }

        .modules-section-heading .guarantee-title-main,
        .modules-section-heading .guarantee-title-accent {
            display: block;
            text-align: center;
            width: fit-content;
            max-width: 100%;
            margin-left: auto;
            margin-right: auto;
        }

        .modules-grid {
            display: flex;
            flex-direction: column;
            gap: 0;
            max-width: 900px;
            margin: 0 auto;
        }

        .modules-intro {
            max-width: 900px;
            margin: 0 auto clamp(48px, 6vw, 72px);
            padding: clamp(24px, 3vw, 36px) clamp(28px, 3.5vw, 42px);
            background:
                radial-gradient(ellipse 80% 60% at 20% 30%, rgba(59, 130, 246, 0.06) 0%, transparent 70%),
                linear-gradient(165deg, rgba(255, 255, 255, 0.05), rgba(15, 23, 42, 0.5));
            border: 1px solid rgba(96, 165, 250, 0.18);
            border-radius: 18px;
            text-align: left;
            position: relative;
        }

        .modules-intro::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent 5%, rgba(96, 165, 250, 0.4) 50%, transparent 95%);
            border-radius: 18px 18px 0 0;
        }

        .modules-intro-kicker {
            display: inline-block;
            margin: 0 0 14px;
            padding: 4px 12px;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(147, 197, 253, 0.95);
            background: rgba(59, 130, 246, 0.12);
            border: 1px solid rgba(96, 165, 250, 0.2);
            border-radius: 999px;
        }

        .modules-intro-title {
            margin: 0 0 14px;
            font-size: clamp(1.15rem, 1.8vw, 1.5rem);
            font-weight: 700;
            color: #f1f5f9;
            line-height: 1.35;
        }

        .modules-intro-text {
            margin: 0;
            font-size: clamp(0.95rem, 1.15vw, 1.05rem);
            color: var(--text-secondary);
            line-height: 1.75;
        }

        .module-heading-text {
            flex: 1;
            min-width: 0;
            text-align: left;
        }

        .module-heading-text .module-title {
            font-size: clamp(1.15rem, 2vw, 1.65rem);
            line-height: 1.3;
        }

        .module-subtitle {
            margin: 6px 0 0;
            font-size: clamp(0.92rem, 1.25vw, 1.05rem);
            font-weight: 500;
            font-style: italic;
            color: rgba(203, 213, 225, 0.82);
            line-height: 1.5;
        }

        .module-unlock {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin: clamp(20px, 3vw, 28px) 0 0;
            padding: 7px 16px;
            font-size: clamp(0.72rem, 0.95vw, 0.82rem);
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(147, 197, 253, 0.95);
            background: rgba(59, 130, 246, 0.1);
            border: 1px solid rgba(96, 165, 250, 0.2);
            border-radius: 999px;
        }

        .module-unlock::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #60a5fa;
            flex-shrink: 0;
        }

        .module-card {
            background: linear-gradient(165deg, rgba(255, 255, 255, 0.04), rgba(15, 23, 42, 0.55));
            border: 1px solid rgba(96, 165, 250, 0.14);
            border-radius: 20px;
            padding: clamp(32px, 4.5vw, 50px);
            position: relative;
            z-index: 1;
            overflow: hidden;
            transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.22);
            margin-bottom: clamp(18px, 2.5vw, 28px);
        }

        .module-card:last-child {
            margin-bottom: 0;
        }

        .module-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent 5%, rgba(96, 165, 250, 0.35) 50%, transparent 95%);
            border-radius: 20px 20px 0 0;
        }

        .module-card:hover {
            transform: translateY(-5px);
            box-shadow:
                0 20px 50px rgba(0, 0, 0, 0.32),
                0 0 48px rgba(59, 130, 246, 0.1);
            border-color: rgba(96, 165, 250, 0.32);
        }

        .module-header {
            display: flex;
            align-items: flex-start;
            gap: clamp(16px, 2.5vw, 24px);
            margin-bottom: clamp(18px, 2.5vw, 26px);
        }

        .module-number {
            width: clamp(44px, 5vw, 56px);
            height: clamp(44px, 5vw, 56px);
            background: linear-gradient(145deg, var(--primary-purple), #60A5FA);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: clamp(1.1rem, 1.6vw, 1.35rem);
            font-weight: 800;
            flex-shrink: 0;
            box-shadow:
                0 6px 18px rgba(59, 130, 246, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.15);
            letter-spacing: -0.02em;
        }

        .module-title {
            font-size: clamp(1.3rem, 2.1vw, 1.8rem);
            font-weight: 700;
            color: #f1f5f9;
            margin: 0;
        }

        .module-content {
            line-height: 1.8;
        }

        .module-description {
            color: var(--text-secondary);
            font-size: clamp(0.95rem, 1.1vw, 1.08rem);
            margin-bottom: 0;
            line-height: 1.78;
        }

        .module-conclusion {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.05));
            padding: 25px;
            border-radius: 12px;
            margin-top: 25px;
            border: 1px solid rgba(59, 130, 246, 0.3);
        }

        .module-conclusion p {
            color: var(--text-primary);
            font-size: 1.1rem;
            font-weight: 600;
            margin: 0;
            text-align: center;
        }

        /* ===== Section 1 — Ce que tu vas obtenir ===== */
        .es2-obtain-section {
            margin: clamp(48px, 7vw, 80px) 0 clamp(40px, 6vw, 64px);
            text-align: left;
            width: 100%;
        }

        .es2-obtain-section:has(+ .es2-bonus-section) {
            margin-bottom: clamp(20px, 3vw, 32px);
        }

        .es2-obtain-volume {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin: 0 0 clamp(14px, 2vw, 20px);
            padding: clamp(12px, 1.6vw, 16px) clamp(16px, 2vw, 22px);
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid rgba(96, 165, 250, 0.2);
            border-radius: 10px;
        }

        .es2-volume-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: clamp(0.85rem, 1.15vw, 0.95rem);
            font-weight: 800;
            color: #60a5fa;
            letter-spacing: 0.02em;
        }

        .es2-volume-pill svg {
            flex-shrink: 0;
            color: #60a5fa;
        }

        .es2-volume-sep {
            color: rgba(255, 255, 255, 0.2);
            font-size: 1.1rem;
        }

        .es2-volume-label {
            font-size: clamp(0.85rem, 1.15vw, 0.95rem);
            font-weight: 500;
            color: rgba(255, 255, 255, 0.55);
        }

        .es2-obtain-heading {
            width: 100%;
            text-align: center;
            margin: 0 0 clamp(24px, 4vw, 36px);
        }

        .es2-obtain-heading .guarantee-title {
            margin-bottom: 0;
        }

        .es2-obtain-subtitle {
            text-align: center;
            margin: 14px 0 0;
            font-size: clamp(0.95rem, 1.35vw, 1.2rem);
            color: var(--text-secondary);
            font-style: italic;
            opacity: 0.85;
        }

        .es2-obtain-container {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 16px;
            padding: clamp(28px, 4vw, 44px) clamp(28px, 4vw, 44px);
        }

        .es2-obtain-item {
            display: flex;
            align-items: flex-start;
            gap: clamp(14px, 1.8vw, 20px);
            padding: clamp(16px, 2vw, 22px) 0;
        }

        .es2-obtain-item + .es2-obtain-item {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .es2-obtain-item:first-child {
            padding-top: 0;
        }

        .es2-obtain-item:last-child {
            padding-bottom: 0;
        }

        .es2-check {
            flex-shrink: 0;
            width: 26px;
            height: 26px;
            margin-top: 1px;
        }

        .es2-obtain-item h3 {
            margin: 0 0 5px;
            font-size: clamp(0.95rem, 1.35vw, 1.08rem);
            font-weight: 700;
            color: #f1f5f9;
            line-height: 1.35;
        }

        .es2-obtain-item p {
            margin: 0;
            font-size: clamp(0.84rem, 1.1vw, 0.94rem);
            color: rgba(255, 255, 255, 0.45);
            line-height: 1.6;
        }

        /* ===== Section 2 — Bonus exclusifs ===== */
        .es2-bonus-section {
            margin: clamp(48px, 7vw, 80px) 0 clamp(48px, 7vw, 80px);
            text-align: left;
            width: 100%;
        }

        .es2-obtain-section + .es2-bonus-section {
            margin-top: clamp(20px, 3vw, 36px);
        }

        .es2-bonus-kicker {
            text-align: left;
            margin: 0 0 8px;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(147, 197, 253, 0.7);
        }

        .es2-bonus-title {
            font-size: clamp(1.35rem, 2.8vw, 2rem);
            font-weight: 800;
            color: #fff;
            text-align: left;
            margin: 0 0 clamp(32px, 5vw, 48px);
            letter-spacing: 0.01em;
            line-height: 1.3;
        }

        .es2-bonus-grid {
            display: flex;
            flex-direction: column;
            gap: clamp(14px, 2vw, 18px);
        }

        .es2-bonus-card {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: clamp(20px, 3vw, 40px);
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 14px;
            padding: clamp(24px, 3vw, 36px) clamp(24px, 3vw, 36px);
        }

        .es2-bonus-body {
            flex: 1;
            min-width: 0;
        }

        .es2-bonus-badge {
            display: inline-block;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #60a5fa;
            margin-bottom: 12px;
        }

        .es2-bonus-name {
            margin: 0 0 clamp(8px, 1.2vw, 14px);
            font-size: clamp(1.08rem, 1.6vw, 1.3rem);
            font-weight: 700;
            color: #f1f5f9;
            line-height: 1.3;
        }

        .es2-bonus-desc {
            margin: 0;
            font-size: clamp(0.84rem, 1.1vw, 0.94rem);
            color: rgba(255, 255, 255, 0.45);
            line-height: 1.65;
        }

        .es2-bonus-desc a {
            color: #60a5fa;
            text-decoration: underline;
            text-underline-offset: 2px;
            font-weight: 600;
        }

        .es2-bonus-desc a:hover {
            color: #93c5fd;
        }

        .es2-bonus-val {
            flex-shrink: 0;
            text-align: right;
            padding-top: 4px;
        }

        .es2-bonus-val-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.35);
            margin-bottom: 2px;
        }

        .es2-bonus-val-amount {
            display: block;
            font-size: clamp(1.5rem, 2.5vw, 2rem);
            font-weight: 800;
            color: rgba(255, 255, 255, 0.85);
            letter-spacing: -0.02em;
            line-height: 1.1;
        }

        .es2-investment-anchor {
            margin: clamp(24px, 4vw, 34px) 0 clamp(20px, 3vw, 28px);
            padding: clamp(16px, 2.5vw, 22px) clamp(18px, 2.5vw, 24px);
            border: 1px solid rgba(96, 165, 250, 0.24);
            border-radius: 12px;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.12), rgba(15, 23, 42, 0.45));
            text-align: left;
        }

        .es2-investment-kicker {
            margin: 0 0 6px;
            font-size: 0.78rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(147, 197, 253, 0.8);
            font-weight: 700;
        }

        .es2-investment-main {
            margin: 0;
            font-size: clamp(0.98rem, 1.4vw, 1.2rem);
            color: #e2e8f0;
            line-height: 1.45;
            font-weight: 500;
        }

        .es2-investment-main strong {
            color: #ffffff;
            font-weight: 800;
        }

        .es2-investment-anchor--after-pricing {
            margin-top: clamp(20px, 3vw, 32px);
            margin-bottom: 0;
        }

        .es2-scarcity-block {
            margin: clamp(28px, 4vw, 40px) 0 clamp(28px, 4vw, 48px);
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            justify-content: center;
        }

        @media (min-width: 769px) {
            .es2-scarcity-block {
                margin-bottom: clamp(48px, 5vw, 72px);
            }
        }

        .es2-scarcity-block .scarcity-card {
            margin: 0 auto;
        }

        /* Descriptive Section */
        .descriptive-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--dark-bg) 0%, var(--darker-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .descriptive-content {
            display: flex;
            flex-direction: column;
            gap: 60px;
            align-items: center;
            max-width: 1000px;
            margin: 0 auto;
        }

        .descriptive-image-wrapper {
            position: relative;
            display: flex;
            justify-content: center;
        }

        .descriptive-image-frame {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            box-shadow:
                0 25px 50px rgba(0, 0, 0, 0.4),
                0 0 80px rgba(59, 130, 246, 0.2);
            transition: all 0.4s ease;
        }

        .descriptive-image-frame:hover {
            transform: translateY(-10px);
            box-shadow:
                0 35px 70px rgba(0, 0, 0, 0.5),
                0 0 100px rgba(59, 130, 246, 0.3);
        }

        .descriptive-image {
            width: 100%;
            max-width: 600px;
            height: auto;
            border-radius: 24px;
            transition: all 0.4s ease;
        }

        .descriptive-image-frame:hover .descriptive-image {
            transform: scale(1.02);
        }

        .descriptive-image-glow {
            position: absolute;
            top: -10px;
            left: -10px;
            right: -10px;
            bottom: -10px;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.3), rgba(59, 130, 246, 0.1));
            border-radius: 28px;
            z-index: -1;
            opacity: 0.7;
        }

        /* Price Reveal Section */
        .price-reveal-section {
            text-align: center;
            margin: clamp(32px, 5vw, 56px) 0 clamp(24px, 4vw, 40px);
        }

        .price-headline {
