---
// Page checkout direct ES2 avec Spiffy embed (/invitation-es2).
// Page autonome, en parallèle du funnel actuel : rien d'existant ne pointe ici.
// Countdown = offre_expires_at du lead (token webinaire), vérifié côté serveur.
// Notifications d'achat = même moteur scarcity que la page /invitation.
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Rejoindre Esprit Subconscient 2.0</title>
  <meta name="description" content="Complète ton inscription à Esprit Subconscient 2.0." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <script is:inline>
"use strict";!function(i,t){var f=t.spiffy=t.spiffy||[];if(!f.init){
if(f.invoked)return void(t.console&&console.error&&console.warn("Spiffy Elements included twice."))
;f.invoked=!0,f.methods=["identify","config","debug","off","on"],f.factory=function(i){
return function(){var t=Array.prototype.slice.call(arguments);return t.unshift(i),f.push(t),f}},
f.methods.forEach(function(i){spiffy[i]=f.factory(i)}),f.load=function(t,f){if(!spiffy.ACCOUNT){
spiffy.ACCOUNT=t,spiffy.DOMAIN=f;var e=i.createElement("script");e.type="text/javascript",
e.async=!0,e.crossorigin="anonymous",e.src="https://js.static.spiffy.co/spiffy.js?a="+t
;var n=i.getElementsByTagName("script")[0];n.parentNode.insertBefore(e,n)}}}}(document,window),
spiffy.SNIPPET_VERSION="1.1.0";
spiffy.config({
    hideSidebar: false,
})
spiffy.load("sonnycourt");
  </script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: radial-gradient(1200px 600px at 50% -100px, rgba(59, 130, 246, 0.18), transparent 60%), #0f172a;
      color: #fff;
      min-height: 100vh;
    }
    .page {
      max-width: 980px;
      margin: 0 auto;
      padding: 48px 16px 80px;
    }
    .hero { text-align: center; margin-bottom: 28px; }
    .hero-badge {
      display: inline-block;
      padding: 6px 14px;
      border-radius: 999px;
      border: 1px solid rgba(96, 165, 250, 0.45);
      background: rgba(59, 130, 246, 0.14);
      color: #93c5fd;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }
    .hero h1 {
      font-size: clamp(28px, 5vw, 44px);
      font-weight: 900;
      line-height: 1.15;
      letter-spacing: -0.01em;
      margin-bottom: 12px;
    }
    .hero h1 .accent { color: #60a5fa; display: block; margin-top: 4px; }
    .hero h1.hero-upper { text-transform: uppercase; letter-spacing: 0.01em; }
    @media (min-width: 769px) {
      /* Desktop : la virgule de la 1re ligne respire, le badge ne colle pas au H1 */
      .hero h1 .accent { margin-top: 18px; }
      .hero-badge { margin-bottom: 28px; }
    }
    .hero .sub {
      font-size: clamp(15px, 2.5vw, 18px);
      line-height: 1.55;
      color: rgba(255, 255, 255, 0.78);
      max-width: 620px;
      margin: 0 auto;
    }
    .hero .sub--voice {
      margin-top: 14px;
      font-size: clamp(14px, 2.2vw, 16px);
      color: rgba(255, 255, 255, 0.62);
      font-style: italic;
    }
    /* Countdown (intégré au bloc scarcity, thème rouge) */
    .offer-countdown { margin: 0; text-align: center; display: none; }
    .offer-countdown.is-visible { display: block; }
    .offer-countdown-title {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.55);
      margin-bottom: 10px;
    }
    .offer-countdown-grid {
      display: inline-flex;
      gap: 8px;
    }
    .offer-countdown-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-width: 62px;
      padding: 9px 8px;
      border-radius: 12px;
      border: 1px solid rgba(248, 113, 113, 0.24);
      background: rgba(2, 6, 23, 0.45);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .offer-countdown-value {
      font-size: 24px;
      font-weight: 900;
      color: #fff;
      font-variant-numeric: tabular-nums;
      text-shadow: 0 0 18px rgba(239, 68, 68, 0.45);
    }
    .offer-countdown-label {
      font-size: 10px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-top: 2px;
    }
    .scarcity-divider {
      height: 1px;
      margin: 16px 4px 14px;
      background: linear-gradient(90deg, rgba(248, 113, 113, 0), rgba(248, 113, 113, 0.35), rgba(248, 113, 113, 0));
    }
    /* Barre de progression préremplissage : encadré bleu premium, jumeau du bloc rouge */
    .prefill-progress {
      display: none;
      position: relative;
      margin: 30px auto 0;
      width: 100%;
      padding: 18px 26px 16px;
      border-radius: 16px;
      border: 1px solid rgba(96, 165, 250, 0.32);
      background:
        radial-gradient(140% 180% at 50% -40%, rgba(37, 99, 235, 0.22) 0%, rgba(15, 23, 42, 0.55) 55%, rgba(15, 23, 42, 0.85) 100%);
      box-shadow:
        0 18px 45px rgba(30, 58, 138, 0.22),
        0 0 0 1px rgba(255, 255, 255, 0.03),
        inset 0 1px 0 rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(8px);
    }
    .prefill-progress.is-visible { display: block; }
    .prefill-progress::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      padding: 1px;
      background: linear-gradient(135deg, rgba(96, 165, 250, 0.45), rgba(96, 165, 250, 0) 40%, rgba(96, 165, 250, 0) 60%, rgba(96, 165, 250, 0.25));
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }
    .page.is-locked .prefill-progress, .page.is-expired .prefill-progress { display: none; }
    .prefill-progress__row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .prefill-progress__label {
      font-size: 14.5px;
      font-weight: 800;
      color: #fff;
    }
    .prefill-progress__pct {
      font-size: 16px;
      font-weight: 900;
      color: #60a5fa;
      font-variant-numeric: tabular-nums;
      text-shadow: 0 0 16px rgba(59, 130, 246, 0.5);
    }
    .prefill-progress__bar {
      height: 14px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.09);
      box-shadow: inset 0 1px 3px rgba(2, 6, 23, 0.5);
    }
    .prefill-progress__fill {
      position: relative;
      height: 100%;
      width: 0;
      border-radius: inherit;
      overflow: hidden;
      background: linear-gradient(90deg, #60a5fa, #2563eb);
      box-shadow: 0 0 16px rgba(59, 130, 246, 0.6);
      transition: width 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .prefill-progress__fill::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, rgba(255, 255, 255, 0) 20%, rgba(255, 255, 255, 0.38) 50%, rgba(255, 255, 255, 0) 80%);
      background-size: 220% 100%;
      animation: prefillShimmer 1.9s linear infinite;
    }
    @keyframes prefillShimmer {
      0% { background-position: 160% 0; }
      100% { background-position: -60% 0; }
    }
    .prefill-progress__hint {
      margin-top: 9px;
      font-size: 12.5px;
      color: rgba(255, 255, 255, 0.62);
    }
    /* Checkout */
    .checkout-wrap {
      margin-top: 34px;
      /* Fond transparent : le thème sombre de la page traverse l'embed
         (le checkout Spiffy est lui-même en fond transparent via son Custom CSS). */
    }
    .checkout-note {
      text-align: center;
      margin-top: 16px;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.55);
    }
    /* Scarcity : bloc custom premium, juste les places restantes */
    .scarcity-card {
      position: relative;
      width: 100%;
      margin: 26px auto 0;
      padding: 18px 26px 16px;
      border-radius: 16px;
      border: 1px solid rgba(248, 113, 113, 0.32);
      background:
        radial-gradient(140% 180% at 50% -40%, rgba(220, 38, 38, 0.22) 0%, rgba(15, 23, 42, 0.55) 55%, rgba(15, 23, 42, 0.85) 100%);
      box-shadow:
        0 18px 45px rgba(127, 29, 29, 0.22),
        0 0 0 1px rgba(255, 255, 255, 0.03),
        inset 0 1px 0 rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(8px);
      text-align: center;
      display: none;
    }
    .scarcity-card.is-visible { display: block; }
    .scarcity-card::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      padding: 1px;
      background: linear-gradient(135deg, rgba(248, 113, 113, 0.45), rgba(248, 113, 113, 0) 40%, rgba(248, 113, 113, 0) 60%, rgba(248, 113, 113, 0.25));
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      pointer-events: none;
    }
    .scarcity-top { margin-bottom: 10px; }
    .scarcity-live {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #fecaca;
    }
    .scarcity-live__dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #ef4444;
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6);
      animation: scarcityPulse 1.8s ease-out infinite;
    }
    @keyframes scarcityPulse {
      0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6); }
      70% { box-shadow: 0 0 0 9px rgba(239, 68, 68, 0); }
      100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }
    .scarcity-main {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
    }
    .scarcity-number {
      font-size: 54px;
      line-height: 0.95;
      font-weight: 900;
      color: #fff;
      font-variant-numeric: tabular-nums;
      text-shadow: 0 0 26px rgba(239, 68, 68, 0.45);
    }
    .scarcity-caption {
      text-align: left;
      font-size: 13px;
      line-height: 1.25;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.72);
    }
    .scarcity-meter {
      margin-top: 14px;
      width: 100%;
      height: 4px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.10);
    }
    .scarcity-meter__fill {
      height: 100%;
      width: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #f87171, #dc2626);
      box-shadow: 0 0 12px rgba(239, 68, 68, 0.55);
      transition: width 0.6s ease;
    }
    @media (max-width: 768px) {
      .scarcity-number { font-size: 44px; }
    }
    /* Témoignages vidéo (mêmes visuels que /invitation) */
    .video-reviews { margin-top: 56px; text-align: center; }
    .page.is-locked .video-reviews, .page.is-expired .video-reviews { display: none; }
    .video-reviews__title {
      font-size: clamp(22px, 3.5vw, 30px);
      font-weight: 900;
    }
    .video-reviews__title .accent { color: #60a5fa; }
    .video-reviews__sub {
      margin-top: 8px;
      font-size: 14.5px;
      color: rgba(255, 255, 255, 0.65);
    }
    .video-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(16px, 2.5vw, 32px);
      margin-top: clamp(24px, 4vw, 40px);
    }
    .video-card {
      background: linear-gradient(165deg, rgba(255, 255, 255, 0.04), rgba(15, 23, 42, 0.5));
      border: 1px solid rgba(96, 165, 250, 0.2);
      border-radius: 20px;
      padding: clamp(10px, 1.5vw, 16px);
      overflow: hidden;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
      aspect-ratio: 9 / 16;
    }
    .review-video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 14px;
      background: #0f172a;
      outline: none;
      cursor: pointer;
    }
    .custom-play-button {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: clamp(44px, 8vw, 72px);
      height: clamp(44px, 8vw, 72px);
      background: none;
      border: none;
      cursor: pointer;
      z-index: 5;
      transition: opacity 0.3s ease, transform 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .custom-play-button svg { width: 100%; height: 100%; filter: drop-shadow(0 6px 18px rgba(2, 6, 23, 0.5)); }
    .custom-play-button .pause-icon { display: none; }
    .video-card.playing .custom-play-button { opacity: 0; pointer-events: none; }
    .video-card.playing:hover .custom-play-button { opacity: 1; pointer-events: auto; }
    .video-card.playing .play-icon { display: none; }
    .video-card.playing .pause-icon { display: block; }
    @media (max-width: 768px) {
      .video-grid { grid-template-columns: 1fr; max-width: 340px; margin-left: auto; margin-right: auto; }
    }
    /* Exit popup (desktop uniquement) */
    .exit-popup {
      position: fixed;
      inset: 0;
      z-index: 100000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(2, 6, 23, 0.82);
      backdrop-filter: blur(10px);
    }
    .exit-popup.is-visible { display: flex; }
    .exit-popup__panel {
      position: relative;
      width: min(560px, 100%);
      padding: 42px 38px 34px;
      border-radius: 20px;
      border: 1px solid rgba(96, 165, 250, 0.35);
      background:
        radial-gradient(130% 160% at 50% -30%, rgba(37, 99, 235, 0.25) 0%, rgba(15, 23, 42, 0.97) 55%, rgba(15, 23, 42, 1) 100%);
      box-shadow: 0 40px 120px rgba(2, 6, 23, 0.8), 0 0 60px rgba(59, 130, 246, 0.15);
      text-align: center;
      overflow: hidden;
      animation: exitPopIn 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    }
    @keyframes exitPopIn {
      from { opacity: 0; transform: translateY(18px) scale(0.97); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .exit-popup__glow {
      position: absolute;
      top: -80px;
      left: 50%;
      transform: translateX(-50%);
      width: 300px;
      height: 160px;
      background: radial-gradient(closest-side, rgba(96, 165, 250, 0.35), transparent);
      pointer-events: none;
    }
    .exit-popup__close {
      position: absolute;
      top: 14px;
      right: 16px;
      width: 34px;
      height: 34px;
      border: none;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.7);
      font-size: 20px;
      line-height: 1;
      cursor: pointer;
    }
    .exit-popup__close:hover { background: rgba(255, 255, 255, 0.15); }
    .exit-popup__kicker {
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #93c5fd;
      margin-bottom: 12px;
    }
    .exit-popup__title {
      font-size: clamp(24px, 4vw, 32px);
      font-weight: 900;
      margin-bottom: 16px;
    }
    .exit-popup__text {
      font-size: 15.5px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.78);
      margin-bottom: 14px;
    }
    .exit-popup__text--strong { color: #fff; font-weight: 600; }
    .exit-popup__cta {
      display: block;
      width: 100%;
      height: 54px;
      margin-top: 22px;
      border: none;
      border-radius: 12px;
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      color: #fff;
      font-size: 16px;
      font-weight: 800;
      font-family: inherit;
      cursor: pointer;
      box-shadow: 0 10px 30px rgba(37, 99, 235, 0.4);
      transition: transform 0.12s ease;
    }
    .exit-popup__cta:active { transform: scale(0.985); }
    .exit-popup__reassure {
      margin-top: 12px;
      font-size: 12.5px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.55);
    }
    .exit-popup__dismiss {
      margin-top: 14px;
      background: none;
      border: none;
      font-size: 12.5px;
      font-family: inherit;
      color: rgba(255, 255, 255, 0.4);
      text-decoration: underline;
      cursor: pointer;
    }
    .exit-popup__dismiss:hover { color: rgba(255, 255, 255, 0.6); }
    /* Gate d'identification (pas de token trouvé) */
    .page.is-locked .checkout-wrap,
    .page.is-locked .checkout-note,
    .page.is-locked .scarcity-card,
    .page.is-expired .scarcity-card,
    .page.is-locked .offer-countdown { display: none; }
    .gate-overlay {
      display: none;
      margin: 40px auto 0;
      max-width: 460px;
      padding: 34px 26px;
      border-radius: 18px;
      border: 1px solid rgba(96, 165, 250, 0.3);
      background: rgba(15, 23, 42, 0.9);
      box-shadow: 0 24px 70px rgba(2, 6, 23, 0.45);
      text-align: center;
    }
    .gate-overlay.is-visible { display: block; }
    .gate-overlay h2 { font-size: 21px; font-weight: 900; margin-bottom: 8px; }
    .gate-overlay p { color: rgba(255, 255, 255, 0.72); font-size: 14.5px; line-height: 1.55; margin-bottom: 18px; }
    .gate-form { display: flex; flex-direction: column; gap: 10px; }
    .gate-input {
      height: 48px;
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(2, 6, 23, 0.6);
      color: #fff;
      font-size: 15px;
      font-family: inherit;
      padding: 0 14px;
      outline: none;
    }
    .gate-input:focus { border-color: rgba(96, 165, 250, 0.7); }
    .gate-btn {
      height: 48px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      color: #fff;
      font-size: 15px;
      font-weight: 800;
      font-family: inherit;
      cursor: pointer;
      transition: transform 0.12s ease;
    }
    .gate-btn:active { transform: scale(0.98); }
    .gate-btn[disabled] { opacity: 0.6; cursor: wait; }
    .gate-error {
      display: none;
      margin-top: 12px;
      font-size: 13.5px;
      line-height: 1.5;
      color: #fca5a5;
    }
    .gate-error.on { display: block; }
    .gate-error a { color: #93c5fd; }
    /* Offre expirée */
    .expired-overlay {
      display: none;
      text-align: center;
      margin-top: 40px;
      padding: 40px 24px;
      border-radius: 18px;
      border: 1px solid rgba(148, 163, 184, 0.25);
      background: rgba(15, 23, 42, 0.85);
    }
    .expired-overlay.is-visible { display: block; }
    .expired-overlay .icon { font-size: 40px; margin-bottom: 12px; }
    .expired-overlay h2 { font-size: 24px; font-weight: 900; margin-bottom: 8px; }
    .expired-overlay p { color: rgba(255, 255, 255, 0.72); line-height: 1.55; max-width: 480px; margin: 0 auto; }
    .is-expired .checkout-wrap, .is-expired .offer-countdown { display: none; }
    /* Toast notifications d'achat (identique /invitation) */
    .purchase-toast {
      position: fixed;
      left: 20px;
      bottom: 20px;
      z-index: 9999;
      opacity: 0;
      transform: translateY(20px);
      pointer-events: none;
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .purchase-toast.show { opacity: 1; transform: translateY(0); }
    .purchase-toast__content {
      display: flex;
      align-items: center;
      gap: 10px;
      max-width: 360px;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid rgba(59, 130, 246, 0.3);
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.95));
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(59, 130, 246, 0.2);
      backdrop-filter: blur(10px);
    }
    .purchase-toast__thumb-wrap { position: relative; width: 58px; height: 58px; flex-shrink: 0; }
    .purchase-toast__thumb {
      width: 58px; height: 58px; border-radius: 9px; object-fit: cover; display: block;
      border: 1px solid rgba(59, 130, 246, 0.4);
      box-shadow: 0 4px 16px rgba(2, 6, 23, 0.35);
    }
    .purchase-toast__thumb-flag {
      position: absolute; right: -4px; bottom: -4px; font-size: 14px; line-height: 1;
      filter: drop-shadow(0 2px 6px rgba(2, 6, 23, 0.5));
    }
    .purchase-toast__text { margin: 0; font-size: 14px; line-height: 1.35; color: #fff; }
    .purchase-toast__name { color: #60a5fa !important; font-weight: 900 !important; text-shadow: 0 0 10px rgba(96, 165, 250, 0.35); }
    .purchase-toast__action { color: rgba(255, 255, 255, 0.72); }
    .purchase-toast__course { display: block; margin-top: 2px; color: #ffffff !important; font-weight: 400 !important; }
    @media (max-width: 1023px) {
      .purchase-toast { left: 10px; right: 10px; top: 10px; bottom: auto; transform: translateY(-20px); }
      .purchase-toast__content { max-width: 100%; }
      .page { padding-top: 32px; }
    }
  </style>
</head>
<body>
  <div class="page is-locked" id="page">
    <header class="hero">
      <div class="hero-badge">Offre réservée aux participants de la masterclass</div>
      <h1 class="hero-upper">Ta transformation a déjà commencé,<span class="accent">mais le moment de vérité, c'est maintenant.</span></h1>
      <p class="sub">La masterclass était la première étape, et tu l'as faite jusqu'au bout 👏<br />Ne t'arrête pas en si bon chemin : Ton deuxième pas vers ta nouvelle vie, tu le fais maintenant.</p>
      <p class="sub sub--voice">Et si une voix te demande « est-ce que moi, je vais y arriver ? » : Tu viens de te le prouver. Le plus dur est fait. La suite, c'est 15 minutes par jour, pour des premiers résultats en moins de 2 semaines.</p>
      <div class="scarcity-card" id="scarcity-card" aria-live="polite">
        <div class="scarcity-top">
          <span class="scarcity-live"><span class="scarcity-live__dot"></span>Offre limitée</span>
        </div>
        <div class="offer-countdown" id="offer-countdown">
          <p class="offer-countdown-title">Expire dans</p>
          <div class="offer-countdown-grid">
            <div class="offer-countdown-box"><span id="offer-days" class="offer-countdown-value">--</span><span class="offer-countdown-label">Jours</span></div>
            <div class="offer-countdown-box"><span id="offer-hours" class="offer-countdown-value">--</span><span class="offer-countdown-label">Heures</span></div>
            <div class="offer-countdown-box"><span id="offer-minutes" class="offer-countdown-value">--</span><span class="offer-countdown-label">Min</span></div>
            <div class="offer-countdown-box"><span id="offer-seconds" class="offer-countdown-value">--</span><span class="offer-countdown-label">Sec</span></div>
          </div>
        </div>
        <div class="scarcity-divider" aria-hidden="true"></div>
        <div class="scarcity-main">
          <span class="scarcity-number" id="current-places">–</span>
          <span class="scarcity-caption">places<br />restantes</span>
        </div>
        <div class="scarcity-meter" aria-hidden="true">
          <div class="scarcity-meter__fill"></div>
        </div>
      </div>
    </header>

    <div class="prefill-progress" id="prefill-progress">
      <div class="prefill-progress__row">
        <span class="prefill-progress__label">Ton inscription a déjà commencé</span>
        <span class="prefill-progress__pct">60&nbsp;%</span>
      </div>
      <div class="prefill-progress__bar"><div class="prefill-progress__fill" id="prefill-fill"></div></div>
      <p class="prefill-progress__hint">Tes infos sont préremplies : il ne reste que le paiement.</p>
    </div>

    <section class="checkout-wrap" id="checkout-slot">
      <!-- L'élément <spiffy-checkout> est injecté en JS avec les infos du lead
           préremplies (name_first, email) une fois le token résolu. -->
    </section>

    <section class="video-reviews" id="video-reviews">
      <h2 class="video-reviews__title">Témoignages <span class="accent">vidéo</span></h2>
      <p class="video-reviews__sub">Découvre les expériences réelles de nos participants</p>
      <div class="video-grid">
        <div class="video-card">
          <video class="review-video" controlslist="nodownload nofullscreen noremoteplayback" disablepictureinpicture playsinline preload="metadata">
            <source src="https://sonnycourt-videos-public.b-cdn.net/review%20Malika%20(Sans%20Date%20et%20avec%20compression).mp4" type="video/mp4">
            Ton navigateur ne supporte pas la lecture de vidéos.
          </video>
          <button class="custom-play-button" type="button" aria-label="Lire le témoignage">
            <svg class="play-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="#3B82F6" stroke="#3B82F6" stroke-width="2"/><path d="M9 8.5L16 12L9 15.5V8.5Z" fill="white"/></svg>
            <svg class="pause-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="#3B82F6" stroke="#3B82F6" stroke-width="2"/><rect x="8" y="8" width="3" height="8" fill="white"/><rect x="13" y="8" width="3" height="8" fill="white"/></svg>
          </button>
        </div>
        <div class="video-card">
          <video class="review-video" controlslist="nodownload nofullscreen noremoteplayback" disablepictureinpicture playsinline preload="metadata">
            <source src="https://sonnycourt-videos-public.b-cdn.net/TE%CC%81MOIGNAGES%20-%20Vide%CC%81os/john.lelong95310%40gmail.com%20(John).mp4" type="video/mp4">
            Ton navigateur ne supporte pas la lecture de vidéos.
          </video>
          <button class="custom-play-button" type="button" aria-label="Lire le témoignage">
            <svg class="play-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="#3B82F6" stroke="#3B82F6" stroke-width="2"/><path d="M9 8.5L16 12L9 15.5V8.5Z" fill="white"/></svg>
            <svg class="pause-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="#3B82F6" stroke="#3B82F6" stroke-width="2"/><rect x="8" y="8" width="3" height="8" fill="white"/><rect x="13" y="8" width="3" height="8" fill="white"/></svg>
          </button>
        </div>
        <div class="video-card">
          <video class="review-video" controlslist="nodownload nofullscreen noremoteplayback" disablepictureinpicture playsinline preload="metadata">
            <source src="https://sonnycourt-videos-public.b-cdn.net/TE%CC%81MOIGNAGES%20-%20Vide%CC%81os/Emilie.Tasserit%40Outlook.Fr%20(Emilie).mp4" type="video/mp4">
            Ton navigateur ne supporte pas la lecture de vidéos.
          </video>
          <button class="custom-play-button" type="button" aria-label="Lire le témoignage">
            <svg class="play-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="#3B82F6" stroke="#3B82F6" stroke-width="2"/><path d="M9 8.5L16 12L9 15.5V8.5Z" fill="white"/></svg>
            <svg class="pause-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="#3B82F6" stroke="#3B82F6" stroke-width="2"/><rect x="8" y="8" width="3" height="8" fill="white"/><rect x="13" y="8" width="3" height="8" fill="white"/></svg>
          </button>
        </div>
      </div>
    </section>

    <div class="gate-overlay" id="gate-overlay">
      <h2>Retrouvons ton invitation</h2>
      <p>Cette offre est réservée aux participants de la masterclass. Entre l'email utilisé lors de ton inscription pour retrouver ton accès et ton temps restant.</p>
      <form class="gate-form" id="gate-form">
        <input type="email" class="gate-input" id="gate-email" placeholder="ton@email.com" autocomplete="email" required />
        <button type="submit" class="gate-btn" id="gate-btn">Accéder à mon offre</button>
      </form>
      <p class="gate-error" id="gate-error"></p>
    </div>

    <div class="expired-overlay" id="expired-overlay">
      <div class="icon">⏳</div>
      <h2>L'offre n'est plus disponible</h2>
      <p>Ta fenêtre d'inscription est terminée. Si tu as des questions, contacte le support&nbsp;: support@sonnycourt.com</p>
    </div>
  </div>

  <div class="exit-popup" id="exit-popup" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="exit-popup__panel">
      <button type="button" class="exit-popup__close" id="exit-popup-close" aria-label="Fermer">&times;</button>
      <div class="exit-popup__glow" aria-hidden="true"></div>
      <p class="exit-popup__kicker">Avant de partir</p>
      <h2 class="exit-popup__title">Attends une seconde.</h2>
      <p class="exit-popup__text">
        Tu sais ce qui t'attend si tu fermes cette page : la même vie, les mêmes pensées qui tournent en rond.
      </p>
      <p class="exit-popup__text exit-popup__text--strong">
        Tu as tenu plus d'une heure face à toi-même. Une partie de toi a déjà dit oui.
      </p>
      <button type="button" class="exit-popup__cta" id="exit-popup-cta">Je choisis ma nouvelle vie →</button>
      <p class="exit-popup__reassure">✓ Garantie 30 jours &nbsp;·&nbsp; ✓ environ 6 € par jour</p>
      <button type="button" class="exit-popup__dismiss" id="exit-popup-dismiss">Non merci, je préfère avancer seul</button>
    </div>
  </div>

  <div id="purchase-toast" class="purchase-toast" aria-live="polite">
    <div class="purchase-toast__content">
      <div class="purchase-toast__thumb-wrap">
        <img class="purchase-toast__thumb" src="/media/pages/es2-square-sonny.webp" alt="" aria-hidden="true" />
        <span id="purchase-toast-flag" class="purchase-toast__thumb-flag">🇫🇷</span>
      </div>
      <p class="purchase-toast__text" id="purchase-toast-text"><span class="purchase-toast__name">Sophie</span> <span class="purchase-toast__action">vient de rejoindre</span><br /><span class="purchase-toast__course">Esprit Subconscient 2.0</span></p>
    </div>
  </div>

  <script>
    import { startScarcityEngine, getCurrentWindow, SCARCITY_WINDOW_START_AFTER_SESSION_MS } from '../lib/scarcity-engine';

    document.addEventListener('DOMContentLoaded', async function () {
      const params = new URLSearchParams(window.location.search);
      const isPreview = params.get('preview') === 'true' || params.get('preview') === 'dev';
      const TOKEN_KEY = 'masterclass_es2_token';

      // Token : URL -> localStorage -> cookie. S'il existe quelque part, on ne
      // demande rien au visiteur ; sinon, gate d'identification par email.
      function readCookieToken() {
        const m = document.cookie.match(/(?:^|;\s*)masterclass_es2_token=([^;]+)/);
        return m ? decodeURIComponent(m[1]).trim() : '';
      }
      const urlToken = (params.get('t') || params.get('token') || '').trim();
      let token = urlToken;
      if (!token) {
        try { token = (localStorage.getItem(TOKEN_KEY) || '').trim(); } catch (e) { /* noop */ }
      }
      if (!token) token = readCookieToken();
      if (token) {
        try { localStorage.setItem(TOKEN_KEY, token); } catch (e) { /* noop */ }
      }

      const pageEl = document.getElementById('page');
      const gateEl = document.getElementById('gate-overlay');
      const CHECKOUT_BASE = 'https://sonnycourt.spiffy.co/checkout/esprit-subconscient-2-0-2';
      let checkoutMounted = false;
      // Monte l'embed avec les infos du lead préremplies (name_first, email).
      // Le nom de famille n'existe pas en base masterclass, Spiffy le demandera.
      function mountCheckout(lead) {
        if (checkoutMounted) return;
        checkoutMounted = true;
        // encodeURIComponent (espace -> %20) : Spiffy ne décode pas le "+"
        // produit par URLSearchParams dans les champs texte.
        const parts = [];
        if (lead && lead.prenom) parts.push('name_first=' + encodeURIComponent(lead.prenom));
        if (lead && lead.email) parts.push('email=' + encodeURIComponent(lead.email));
        if (lead && lead.pays && lead.pays !== 'Autre') parts.push('country=' + encodeURIComponent(lead.pays));
        const el = document.createElement('spiffy-checkout');
        el.setAttribute('url', parts.length ? CHECKOUT_BASE + '?' + parts.join('&') : CHECKOUT_BASE);
        document.getElementById('checkout-slot').appendChild(el);
        // Barre "déjà commencé" : uniquement si le préremplissage a réellement eu lieu.
        if (lead && (lead.prenom || lead.email)) {
          const prog = document.getElementById('prefill-progress');
          const fill = document.getElementById('prefill-fill');
          if (prog && fill) {
            prog.classList.add('is-visible');
            setTimeout(function () { fill.style.width = '60%'; }, 300);
          }
        }
      }
      function unlockPage() {
        pageEl.classList.remove('is-locked');
        gateEl.classList.remove('is-visible');
      }
      function showGate() {
        pageEl.classList.add('is-locked');
        gateEl.classList.add('is-visible');
      }

      const countdownEl = document.getElementById('offer-countdown');
      const pad2 = (n) => String(n).padStart(2, '0');
      let offerExpiryMs = null;
      let sessionStartsAtMs = null;
      let countdownInterval = null;

      function renderCountdown() {
        if (!Number.isFinite(offerExpiryMs)) return;
        const diff = Math.max(0, offerExpiryMs - Date.now());
        const total = Math.floor(diff / 1000);
        const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = pad2(v); };
        set('offer-days', Math.floor(total / 86400));
        set('offer-hours', Math.floor((total % 86400) / 3600));
        set('offer-minutes', Math.floor((total % 3600) / 60));
        set('offer-seconds', total % 60);
        if (diff <= 0) lockExpired();
      }

      function lockExpired() {
        if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
        document.getElementById('page').classList.add('is-expired');
        const overlay = document.getElementById('expired-overlay');
        if (overlay) overlay.classList.add('is-visible');
      }

      // --- Gate + récupération de l'expiration réelle du lead (source serveur) ---
      if (isPreview) {
        // Aperçu interne : pas de token requis, countdown sur la fenêtre courante.
        const win = getCurrentWindow(Date.now());
        offerExpiryMs = win.endMs;
        sessionStartsAtMs = win.startMs - SCARCITY_WINDOW_START_AFTER_SESSION_MS;
        unlockPage();
        mountCheckout(null);
      } else if (token) {
        try {
          const res = await fetch('/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token));
          if (res.ok) {
            const data = await res.json();
            const exp = new Date(data.offreExpiresAt || data.offre_expires_at || '').getTime();
            const ses = new Date(data.sessionStartsAt || data.session_date || '').getTime();
            if (Number.isFinite(exp)) offerExpiryMs = exp;
            if (Number.isFinite(ses)) sessionStartsAtMs = ses;
            unlockPage();
            mountCheckout({ prenom: data.prenom || '', email: data.email || '', pays: data.pays || '' });
          } else if (res.status === 404 || res.status === 400) {
            // Token inconnu en base : on nettoie et on demande l'email.
            try { localStorage.removeItem(TOKEN_KEY); } catch (e) { /* noop */ }
            showGate();
          } else {
            // Erreur serveur passagère : on ne bloque pas un acheteur.
            unlockPage();
            mountCheckout(null);
          }
        } catch (e) {
          // Réseau KO : on ne bloque pas un acheteur, countdown absent.
          unlockPage();
          mountCheckout(null);
        }
      } else {
        showGate();
      }

      // --- Gate : retrouver le token via l'email d'inscription masterclass ---
      const gateForm = document.getElementById('gate-form');
      const gateBtn = document.getElementById('gate-btn');
      const gateErr = document.getElementById('gate-error');
      if (gateForm) {
        gateForm.addEventListener('submit', async function (ev) {
          ev.preventDefault();
          const email = (document.getElementById('gate-email').value || '').trim().toLowerCase();
          if (!email) return;
          gateErr.classList.remove('on');
          gateBtn.disabled = true;
          const prevLabel = gateBtn.textContent;
          gateBtn.textContent = 'Recherche…';
          try {
            const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            });
            const data = await res.json().catch(function () { return {}; });
            if (res.ok && data.reason === 'already_registered' && data.token) {
              try { localStorage.setItem(TOKEN_KEY, data.token); } catch (e) { /* noop */ }
              window.location.replace('/invitation-es2/?t=' + encodeURIComponent(data.token));
              return;
            }
            if (res.ok && data.eligible === true) {
              gateErr.innerHTML = 'Aucune inscription trouvée avec cet email. Utilise l\'email de ton inscription à la masterclass, ou <a href="/masterclass/">inscris-toi ici</a>.';
            } else if (res.ok && data.reason === 'excluded') {
              gateErr.innerHTML = 'Un problème avec ton accès ? Écris-nous : <a href="mailto:support@sonnycourt.com">support@sonnycourt.com</a>';
            } else {
              gateErr.textContent = 'Erreur de connexion, réessaie dans un instant.';
            }
            gateErr.classList.add('on');
          } catch (e) {
            gateErr.textContent = 'Erreur réseau, vérifie ta connexion et réessaie.';
            gateErr.classList.add('on');
          }
          gateBtn.disabled = false;
          gateBtn.textContent = prevLabel;
        });
      }

      if (Number.isFinite(offerExpiryMs)) {
        if (offerExpiryMs - Date.now() <= 0) {
          lockExpired();
        } else {
          countdownEl.classList.add('is-visible');
          const card = document.getElementById('scarcity-card');
          if (card) card.classList.add('is-visible');
          renderCountdown();
          countdownInterval = setInterval(renderCountdown, 1000);
        }
      }

      // --- Exit popup : desktop uniquement, une fois par session ---
      (function () {
        const popup = document.getElementById('exit-popup');
        if (!popup) return;
        const EXIT_KEY = 'es2_exit_popup_shown';
        const isDesktop = window.matchMedia('(pointer: fine)').matches && window.innerWidth >= 1024;
        function canShow() {
          if (!isDesktop) return false;
          if (pageEl.classList.contains('is-locked') || pageEl.classList.contains('is-expired')) return false;
          try { if (sessionStorage.getItem(EXIT_KEY)) return false; } catch (e) { /* noop */ }
          return true;
        }
        function openPopup() {
          if (!canShow()) return;
          try { sessionStorage.setItem(EXIT_KEY, '1'); } catch (e) { /* noop */ }
          popup.classList.add('is-visible');
          popup.setAttribute('aria-hidden', 'false');
        }
        function closePopup() {
          popup.classList.remove('is-visible');
          popup.setAttribute('aria-hidden', 'true');
        }
        document.addEventListener('mouseout', function (ev) {
          if (!ev.relatedTarget && ev.clientY <= 0) openPopup();
        });
        document.addEventListener('keydown', function (ev) {
          if (ev.key === 'Escape') closePopup();
        });
        popup.addEventListener('click', function (ev) {
          if (ev.target === popup) closePopup();
        });
        document.getElementById('exit-popup-close').addEventListener('click', closePopup);
        document.getElementById('exit-popup-dismiss').addEventListener('click', closePopup);
        document.getElementById('exit-popup-cta').addEventListener('click', function () {
          closePopup();
          const target = document.getElementById('checkout-slot');
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      })();

      // --- Témoignages vidéo : lecture exclusive (une vidéo à la fois) ---
      document.querySelectorAll('.video-card').forEach(function (card) {
        const video = card.querySelector('video');
        const btn = card.querySelector('.custom-play-button');
        if (!video || !btn) return;
        function toggle() {
          if (video.paused) {
            document.querySelectorAll('.video-card video').forEach(function (v) {
              if (v !== video) v.pause();
            });
            video.play();
          } else {
            video.pause();
          }
        }
        btn.addEventListener('click', toggle);
        video.addEventListener('click', toggle);
        video.addEventListener('play', function () { card.classList.add('playing'); });
        video.addEventListener('pause', function () { card.classList.remove('playing'); });
        video.addEventListener('ended', function () { card.classList.remove('playing'); });
      });

      // --- Notifications d'achat (même moteur que /invitation) ---
      const toast = document.getElementById('purchase-toast');
      const toastFlag = document.getElementById('purchase-toast-flag');
      const toastText = document.getElementById('purchase-toast-text');
      if (toast && toastFlag && toastText
          && !pageEl.classList.contains('is-expired')
          && !pageEl.classList.contains('is-locked')) {
        let hideTimer = null;
        let queueGapTimer = null;
        const toastQueue = [];
        let toastBusy = false;
        function flushToastQueue() {
          if (toastBusy) return;
          const next = toastQueue.shift();
          if (!next) return;
          toastBusy = true;
          const actionText = next.mode === 'replay'
            ? `a rejoint il y a ${next.detail || 'quelques instants'}`
            : 'vient de rejoindre';
          toastFlag.textContent = next.purchase.flag;
          toastText.innerHTML = `<span class="purchase-toast__name">${next.purchase.name}</span> <span class="purchase-toast__action">${actionText}</span><br /><span class="purchase-toast__course">Esprit Subconscient 2.0</span>`;
          toast.classList.add('show');
          if (hideTimer) clearTimeout(hideTimer);
          if (queueGapTimer) clearTimeout(queueGapTimer);
          hideTimer = setTimeout(function () {
            toast.classList.remove('show');
            queueGapTimer = setTimeout(function () {
              toastBusy = false;
              flushToastQueue();
            }, 1000);
          }, 4000);
        }

        const fallbackWin = getCurrentWindow(Date.now());
        const windowStartMs = Number.isFinite(sessionStartsAtMs)
          ? sessionStartsAtMs + SCARCITY_WINDOW_START_AFTER_SESSION_MS
          : fallbackWin.startMs;
        const windowEndMs = Number.isFinite(offerExpiryMs) ? offerExpiryMs : fallbackWin.endMs;

        // Bloc places restantes : chiffre + jauge, alimenté par le même moteur
        // que /invitation (mêmes valeurs au même moment sur les deux pages).
        const scarcityCard = document.getElementById('scarcity-card');
        function updatePhaseUi(phase, seats) {
          const numEl = document.getElementById('current-places');
          if (numEl) numEl.textContent = String(seats);
          const denominator = phase === 'phase2' ? 10 : 30;
          const pct = (Math.max(0, Math.min(denominator, seats)) / denominator) * 100;
          document.querySelectorAll('.scarcity-meter__fill').forEach(function (el) {
            el.style.width = `${pct}%`;
          });
        }

        startScarcityEngine({
          now: () => Date.now(),
          isActive: () => !document.getElementById('page').classList.contains('is-expired'),
          windowStartMs,
          windowEndMs,
          enableReplay: true,
          onSeatsLeft: function (seatsLeft, _soldCount, phase) {
            const seats = Math.max(0, Math.min(30, Number(seatsLeft) || 0));
            if (scarcityCard) scarcityCard.classList.add('is-visible');
            updatePhaseUi(phase, seats);
          },
          onNotification: function (purchase, mode, detail) {
            toastQueue.push({ purchase, mode, detail });
            if (!toastBusy) flushToastQueue();
          },
        });
      }
    });
  </script>
</body>
</html>
