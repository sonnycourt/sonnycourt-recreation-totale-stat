---
// Page checkout direct ES2 avec Spiffy embed (/invitation-es2).
// Page autonome, en parallèle du funnel actuel : rien d'existant ne pointe ici.
// Countdown = offre_expires_at du lead (token webinaire), vérifié côté serveur.
// Notifications d'achat = même moteur scarcity que la page /invitation.
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Rejoindre Esprit Subconscient 2.0</title>
  <meta name="description" content="Complète ton inscription à Esprit Subconscient 2.0." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
  <script is:inline>
"use strict";!function(i,t){var f=t.spiffy=t.spiffy||[];if(!f.init){
if(f.invoked)return void(t.console&&console.error&&console.warn("Spiffy Elements included twice."))
;f.invoked=!0,f.methods=["identify","config","debug","off","on"],f.factory=function(i){
return function(){var t=Array.prototype.slice.call(arguments);return t.unshift(i),f.push(t),f}},
f.methods.forEach(function(i){spiffy[i]=f.factory(i)}),f.load=function(t,f){if(!spiffy.ACCOUNT){
spiffy.ACCOUNT=t,spiffy.DOMAIN=f;var e=i.createElement("script");e.type="text/javascript",
e.async=!0,e.crossorigin="anonymous",e.src="https://js.static.spiffy.co/spiffy.js?a="+t
;var n=i.getElementsByTagName("script")[0];n.parentNode.insertBefore(e,n)}}}}(document,window),
spiffy.SNIPPET_VERSION="1.1.0";
spiffy.config({
    hideSidebar: false,
})
spiffy.load("sonnycourt");
  </script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: radial-gradient(1200px 600px at 50% -100px, rgba(59, 130, 246, 0.18), transparent 60%), #0f172a;
      color: #fff;
      min-height: 100vh;
    }
    .page {
      max-width: 980px;
      margin: 0 auto;
      padding: 48px 16px 80px;
    }
    .hero { text-align: center; margin-bottom: 28px; }
    .hero-badge {
      display: inline-block;
      padding: 6px 14px;
      border-radius: 999px;
      border: 1px solid rgba(96, 165, 250, 0.45);
      background: rgba(59, 130, 246, 0.14);
      color: #93c5fd;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }
    .hero h1 {
      font-size: clamp(28px, 5vw, 44px);
      font-weight: 900;
      line-height: 1.15;
      letter-spacing: -0.01em;
      margin-bottom: 12px;
    }
    .hero h1 .accent { color: #60a5fa; }
    .hero .sub {
      font-size: clamp(15px, 2.5vw, 18px);
      line-height: 1.55;
      color: rgba(255, 255, 255, 0.78);
      max-width: 620px;
      margin: 0 auto;
    }
    /* Countdown */
    .offer-countdown { margin: 26px auto 0; text-align: center; display: none; }
    .offer-countdown.is-visible { display: block; }
    .offer-countdown-title {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.65);
      margin-bottom: 10px;
    }
    .offer-countdown-grid {
      display: inline-flex;
      gap: 8px;
    }
    .offer-countdown-box {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-width: 66px;
      padding: 10px 8px;
      border-radius: 12px;
      border: 1px solid rgba(96, 165, 250, 0.3);
      background: rgba(15, 23, 42, 0.85);
      box-shadow: 0 8px 24px rgba(2, 6, 23, 0.35);
    }
    .offer-countdown-value {
      font-size: 26px;
      font-weight: 900;
      color: #7dd3fc;
      font-variant-numeric: tabular-nums;
    }
    .offer-countdown-label {
      font-size: 11px;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.55);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-top: 2px;
    }
    /* Checkout */
    .checkout-wrap {
      margin-top: 34px;
      /* Fond transparent : le thème sombre de la page traverse l'embed
         (le checkout Spiffy est lui-même en fond transparent via son Custom CSS). */
    }
    .checkout-note {
      text-align: center;
      margin-top: 16px;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.55);
    }
    /* Scarcity places (mêmes visuels que /invitation) */
    .scarcity-card {
      width: 100%;
      max-width: 520px;
      margin: 22px auto 0;
      padding: 14px 14px 12px;
      border-radius: 14px;
      border: 1px solid rgba(239, 68, 68, 0.55);
      background: radial-gradient(120% 130% at 0% 0%, rgba(220, 38, 38, 0.24) 0%, rgba(69, 10, 10, 0.30) 45%, rgba(15, 23, 42, 0.72) 100%);
      box-shadow: 0 14px 30px rgba(127, 29, 29, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      text-align: left;
      display: none;
    }
    .scarcity-card.is-visible { display: block; }
    .scarcity-kicker {
      margin: 0 0 8px;
      font-size: 0.70rem;
      text-transform: uppercase;
      letter-spacing: 0.10em;
      color: #fee2e2;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .scarcity-kicker::before {
      content: '';
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #ef4444;
      box-shadow: 0 0 10px rgba(239, 68, 68, 0.7);
    }
    .scarcity-phase1-total {
      display: none;
      margin: 10px 0 12px;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid rgba(248, 113, 113, 0.55);
      background: linear-gradient(135deg, rgba(127, 29, 29, 0.55), rgba(153, 27, 27, 0.28));
      box-shadow: inset 0 0 0 1px rgba(127, 29, 29, 0.35), 0 8px 22px rgba(127, 29, 29, 0.30);
    }
    .scarcity-soldout-stamp {
      flex: 0 0 auto;
      padding: 6px 10px;
      border-radius: 6px;
      background: #b91c1c;
      color: #fff;
      font-size: 0.66rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      border: 1px solid rgba(254, 202, 202, 0.55);
      text-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);
      transform: rotate(-3deg);
    }
    .scarcity-soldout-line {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      line-height: 1.2;
      min-width: 0;
    }
    .scarcity-soldout-count {
      font-size: 0.95rem;
      font-weight: 800;
      color: #fff;
      text-decoration: line-through;
      text-decoration-thickness: 2px;
      text-decoration-color: rgba(254, 202, 202, 0.9);
    }
    .scarcity-soldout-slash { opacity: 0.75; font-weight: 700; }
    .scarcity-soldout-text {
      font-size: 0.76rem;
      font-weight: 600;
      color: #fecaca;
      margin-top: 3px;
      letter-spacing: 0.01em;
    }
    .scarcity-phase2-note {
      display: none;
      margin: 0 0 12px;
      align-items: center;
      gap: 10px;
      padding: 7px 12px;
      border-radius: 999px;
      border: 1px solid rgba(110, 231, 183, 0.45);
      background: linear-gradient(135deg, rgba(6, 78, 59, 0.55), rgba(4, 120, 87, 0.20));
      font-size: 0.78rem;
      font-weight: 700;
      color: #d1fae5;
      box-shadow: 0 6px 16px rgba(6, 95, 70, 0.18);
    }
    .scarcity-phase2-pulse {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #34d399;
      box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.65);
      animation: scarcityPulse 1.6s ease-out infinite;
    }
    .scarcity-phase2-text strong { color: #fff; font-weight: 800; }
    .scarcity-phase1-total.is-visible { display: flex; }
    .scarcity-phase2-note.is-visible { display: inline-flex; }
    @keyframes scarcityPulse {
      0% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.65); }
      70% { box-shadow: 0 0 0 10px rgba(52, 211, 153, 0); }
      100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0); }
    }
    .scarcity-main {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }
    .scarcity-label {
      margin: 0;
      color: rgba(255, 255, 255, 0.96);
      font-size: 0.92rem;
      font-weight: 700;
    }
    .scarcity-value {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(220, 38, 38, 0.28);
      border: 1px solid rgba(252, 165, 165, 0.72);
    }
    .scarcity-number {
      font-size: 1.42rem;
      line-height: 1;
      font-weight: 900;
      color: #fff;
    }
    .scarcity-unit {
      font-size: 0.80rem;
      letter-spacing: 0.06em;
      color: #ffe4e6;
      font-weight: 700;
    }
    .scarcity-denominator {
      display: none;
      font-size: 0.95rem;
      line-height: 1;
      font-weight: 800;
      color: rgba(255, 228, 230, 0.92);
    }
    .scarcity-denominator.is-visible { display: inline; }
    .scarcity-meter {
      margin-top: 10px;
      width: 100%;
      height: 7px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(252, 165, 165, 0.35);
    }
    .scarcity-meter__fill {
      height: 100%;
      width: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #ef4444, #dc2626);
      box-shadow: 0 0 14px rgba(239, 68, 68, 0.55);
    }
    @media (max-width: 768px) {
      .scarcity-value { padding: 4px 10px; gap: 4px; }
      .scarcity-number { font-size: 1.16rem; }
      .scarcity-denominator { font-size: 0.78rem; }
      .scarcity-unit { font-size: 0.68rem; }
    }
    /* Gate d'identification (pas de token trouvé) */
    .page.is-locked .checkout-wrap,
    .page.is-locked .checkout-note,
    .page.is-locked .scarcity-card,
    .page.is-expired .scarcity-card,
    .page.is-locked .offer-countdown { display: none; }
    .gate-overlay {
      display: none;
      margin: 40px auto 0;
      max-width: 460px;
      padding: 34px 26px;
      border-radius: 18px;
      border: 1px solid rgba(96, 165, 250, 0.3);
      background: rgba(15, 23, 42, 0.9);
      box-shadow: 0 24px 70px rgba(2, 6, 23, 0.45);
      text-align: center;
    }
    .gate-overlay.is-visible { display: block; }
    .gate-overlay h2 { font-size: 21px; font-weight: 900; margin-bottom: 8px; }
    .gate-overlay p { color: rgba(255, 255, 255, 0.72); font-size: 14.5px; line-height: 1.55; margin-bottom: 18px; }
    .gate-form { display: flex; flex-direction: column; gap: 10px; }
    .gate-input {
      height: 48px;
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(2, 6, 23, 0.6);
      color: #fff;
      font-size: 15px;
      font-family: inherit;
      padding: 0 14px;
      outline: none;
    }
    .gate-input:focus { border-color: rgba(96, 165, 250, 0.7); }
    .gate-btn {
      height: 48px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      color: #fff;
      font-size: 15px;
      font-weight: 800;
      font-family: inherit;
      cursor: pointer;
      transition: transform 0.12s ease;
    }
    .gate-btn:active { transform: scale(0.98); }
    .gate-btn[disabled] { opacity: 0.6; cursor: wait; }
    .gate-error {
      display: none;
      margin-top: 12px;
      font-size: 13.5px;
      line-height: 1.5;
      color: #fca5a5;
    }
    .gate-error.on { display: block; }
    .gate-error a { color: #93c5fd; }
    /* Offre expirée */
    .expired-overlay {
      display: none;
      text-align: center;
      margin-top: 40px;
      padding: 40px 24px;
      border-radius: 18px;
      border: 1px solid rgba(148, 163, 184, 0.25);
      background: rgba(15, 23, 42, 0.85);
    }
    .expired-overlay.is-visible { display: block; }
    .expired-overlay .icon { font-size: 40px; margin-bottom: 12px; }
    .expired-overlay h2 { font-size: 24px; font-weight: 900; margin-bottom: 8px; }
    .expired-overlay p { color: rgba(255, 255, 255, 0.72); line-height: 1.55; max-width: 480px; margin: 0 auto; }
    .is-expired .checkout-wrap, .is-expired .offer-countdown { display: none; }
    /* Toast notifications d'achat (identique /invitation) */
    .purchase-toast {
      position: fixed;
      left: 20px;
      bottom: 20px;
      z-index: 9999;
      opacity: 0;
      transform: translateY(20px);
      pointer-events: none;
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .purchase-toast.show { opacity: 1; transform: translateY(0); }
    .purchase-toast__content {
      display: flex;
      align-items: center;
      gap: 10px;
      max-width: 360px;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid rgba(59, 130, 246, 0.3);
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.95));
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(59, 130, 246, 0.2);
      backdrop-filter: blur(10px);
    }
    .purchase-toast__thumb-wrap { position: relative; width: 58px; height: 58px; flex-shrink: 0; }
    .purchase-toast__thumb {
      width: 58px; height: 58px; border-radius: 9px; object-fit: cover; display: block;
      border: 1px solid rgba(59, 130, 246, 0.4);
      box-shadow: 0 4px 16px rgba(2, 6, 23, 0.35);
    }
    .purchase-toast__thumb-flag {
      position: absolute; right: -4px; bottom: -4px; font-size: 14px; line-height: 1;
      filter: drop-shadow(0 2px 6px rgba(2, 6, 23, 0.5));
    }
    .purchase-toast__text { margin: 0; font-size: 14px; line-height: 1.35; color: #fff; }
    .purchase-toast__name { color: #60a5fa !important; font-weight: 900 !important; text-shadow: 0 0 10px rgba(96, 165, 250, 0.35); }
    .purchase-toast__action { color: rgba(255, 255, 255, 0.72); }
    .purchase-toast__course { display: block; margin-top: 2px; color: #ffffff !important; font-weight: 400 !important; }
    @media (max-width: 1023px) {
      .purchase-toast { left: 10px; right: 10px; top: 10px; bottom: auto; transform: translateY(-20px); }
      .purchase-toast__content { max-width: 100%; }
      .page { padding-top: 32px; }
    }
  </style>
</head>
<body>
  <div class="page is-locked" id="page">
    <header class="hero">
      <div class="hero-badge">Offre réservée aux participants de la masterclass</div>
      <h1>Ta place dans <span class="accent">Esprit Subconscient 2.0</span> t'attend.</h1>
      <p class="sub">Complète ton inscription ci-dessous : ton accès s'ouvre immédiatement, et ta première leçon t'attend demain matin.</p>
      <div class="offer-countdown" id="offer-countdown">
        <p class="offer-countdown-title">L'offre expire dans :</p>
        <div class="offer-countdown-grid">
          <div class="offer-countdown-box"><span id="offer-days" class="offer-countdown-value">--</span><span class="offer-countdown-label">Jours</span></div>
          <div class="offer-countdown-box"><span id="offer-hours" class="offer-countdown-value">--</span><span class="offer-countdown-label">Heures</span></div>
          <div class="offer-countdown-box"><span id="offer-minutes" class="offer-countdown-value">--</span><span class="offer-countdown-label">Minutes</span></div>
          <div class="offer-countdown-box"><span id="offer-seconds" class="offer-countdown-value">--</span><span class="offer-countdown-label">Secondes</span></div>
        </div>
      </div>
      <div class="scarcity-card" id="scarcity-card" aria-live="polite">
        <p class="scarcity-kicker">Nombre de places limitées</p>
        <div class="scarcity-phase1-total">
          <span class="scarcity-soldout-stamp">Sold out</span>
          <div class="scarcity-soldout-line">
            <span class="scarcity-soldout-count">30<span class="scarcity-soldout-slash">/30</span> places vendues</span>
            <span class="scarcity-soldout-text">parties en quelques heures</span>
          </div>
        </div>
        <div class="scarcity-phase2-note">
          <span class="scarcity-phase2-pulse"></span>
          <span class="scarcity-phase2-text"><strong>10 places rouvertes</strong> exceptionnellement</span>
        </div>
        <div class="scarcity-main">
          <p class="scarcity-label">Places restantes</p>
          <div class="scarcity-value">
            <span class="scarcity-number" id="current-places">30</span>
            <span class="scarcity-denominator">/ 30</span>
            <span class="scarcity-unit">places</span>
          </div>
        </div>
        <div class="scarcity-meter" aria-hidden="true">
          <div class="scarcity-meter__fill"></div>
        </div>
      </div>
    </header>

    <section class="checkout-wrap">
      <spiffy-checkout url="https://sonnycourt.spiffy.co/checkout/esprit-subconscient-2-0-2"></spiffy-checkout>
    </section>
    <p class="checkout-note">Paiement sécurisé · Garantie satisfaction 30 jours</p>

    <div class="gate-overlay" id="gate-overlay">
      <h2>Retrouvons ton invitation</h2>
      <p>Cette offre est réservée aux participants de la masterclass. Entre l'email utilisé lors de ton inscription pour retrouver ton accès et ton temps restant.</p>
      <form class="gate-form" id="gate-form">
        <input type="email" class="gate-input" id="gate-email" placeholder="ton@email.com" autocomplete="email" required />
        <button type="submit" class="gate-btn" id="gate-btn">Accéder à mon offre</button>
      </form>
      <p class="gate-error" id="gate-error"></p>
    </div>

    <div class="expired-overlay" id="expired-overlay">
      <div class="icon">⏳</div>
      <h2>L'offre n'est plus disponible</h2>
      <p>Ta fenêtre d'inscription est terminée. Si tu as des questions, contacte le support&nbsp;: support@sonnycourt.com</p>
    </div>
  </div>

  <div id="purchase-toast" class="purchase-toast" aria-live="polite">
    <div class="purchase-toast__content">
      <div class="purchase-toast__thumb-wrap">
        <img class="purchase-toast__thumb" src="/media/pages/es2-square-sonny.webp" alt="" aria-hidden="true" />
        <span id="purchase-toast-flag" class="purchase-toast__thumb-flag">🇫🇷</span>
      </div>
      <p class="purchase-toast__text" id="purchase-toast-text"><span class="purchase-toast__name">Sophie</span> <span class="purchase-toast__action">vient de rejoindre</span><br /><span class="purchase-toast__course">Esprit Subconscient 2.0</span></p>
    </div>
  </div>

  <script>
    import { startScarcityEngine, getCurrentWindow, SCARCITY_WINDOW_START_AFTER_SESSION_MS } from '../lib/scarcity-engine';

    document.addEventListener('DOMContentLoaded', async function () {
      const params = new URLSearchParams(window.location.search);
      const isPreview = params.get('preview') === 'true' || params.get('preview') === 'dev';
      const TOKEN_KEY = 'masterclass_es2_token';

      // Token : URL -> localStorage -> cookie. S'il existe quelque part, on ne
      // demande rien au visiteur ; sinon, gate d'identification par email.
      function readCookieToken() {
        const m = document.cookie.match(/(?:^|;\s*)masterclass_es2_token=([^;]+)/);
        return m ? decodeURIComponent(m[1]).trim() : '';
      }
      const urlToken = (params.get('t') || params.get('token') || '').trim();
      let token = urlToken;
      if (!token) {
        try { token = (localStorage.getItem(TOKEN_KEY) || '').trim(); } catch (e) { /* noop */ }
      }
      if (!token) token = readCookieToken();
      if (token) {
        try { localStorage.setItem(TOKEN_KEY, token); } catch (e) { /* noop */ }
      }

      const pageEl = document.getElementById('page');
      const gateEl = document.getElementById('gate-overlay');
      function unlockPage() {
        pageEl.classList.remove('is-locked');
        gateEl.classList.remove('is-visible');
      }
      function showGate() {
        pageEl.classList.add('is-locked');
        gateEl.classList.add('is-visible');
      }

      const countdownEl = document.getElementById('offer-countdown');
      const pad2 = (n) => String(n).padStart(2, '0');
      let offerExpiryMs = null;
      let sessionStartsAtMs = null;
      let countdownInterval = null;

      function renderCountdown() {
        if (!Number.isFinite(offerExpiryMs)) return;
        const diff = Math.max(0, offerExpiryMs - Date.now());
        const total = Math.floor(diff / 1000);
        const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = pad2(v); };
        set('offer-days', Math.floor(total / 86400));
        set('offer-hours', Math.floor((total % 86400) / 3600));
        set('offer-minutes', Math.floor((total % 3600) / 60));
        set('offer-seconds', total % 60);
        if (diff <= 0) lockExpired();
      }

      function lockExpired() {
        if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
        document.getElementById('page').classList.add('is-expired');
        const overlay = document.getElementById('expired-overlay');
        if (overlay) overlay.classList.add('is-visible');
      }

      // --- Gate + récupération de l'expiration réelle du lead (source serveur) ---
      if (isPreview) {
        // Aperçu interne : pas de token requis, countdown sur la fenêtre courante.
        const win = getCurrentWindow(Date.now());
        offerExpiryMs = win.endMs;
        sessionStartsAtMs = win.startMs - SCARCITY_WINDOW_START_AFTER_SESSION_MS;
        unlockPage();
      } else if (token) {
        try {
          const res = await fetch('/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token));
          if (res.ok) {
            const data = await res.json();
            const exp = new Date(data.offreExpiresAt || data.offre_expires_at || '').getTime();
            const ses = new Date(data.sessionStartsAt || data.session_date || '').getTime();
            if (Number.isFinite(exp)) offerExpiryMs = exp;
            if (Number.isFinite(ses)) sessionStartsAtMs = ses;
            unlockPage();
          } else if (res.status === 404 || res.status === 400) {
            // Token inconnu en base : on nettoie et on demande l'email.
            try { localStorage.removeItem(TOKEN_KEY); } catch (e) { /* noop */ }
            showGate();
          } else {
            // Erreur serveur passagère : on ne bloque pas un acheteur.
            unlockPage();
          }
        } catch (e) {
          // Réseau KO : on ne bloque pas un acheteur, countdown absent.
          unlockPage();
        }
      } else {
        showGate();
      }

      // --- Gate : retrouver le token via l'email d'inscription masterclass ---
      const gateForm = document.getElementById('gate-form');
      const gateBtn = document.getElementById('gate-btn');
      const gateErr = document.getElementById('gate-error');
      if (gateForm) {
        gateForm.addEventListener('submit', async function (ev) {
          ev.preventDefault();
          const email = (document.getElementById('gate-email').value || '').trim().toLowerCase();
          if (!email) return;
          gateErr.classList.remove('on');
          gateBtn.disabled = true;
          const prevLabel = gateBtn.textContent;
          gateBtn.textContent = 'Recherche…';
          try {
            const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            });
            const data = await res.json().catch(function () { return {}; });
            if (res.ok && data.reason === 'already_registered' && data.token) {
              try { localStorage.setItem(TOKEN_KEY, data.token); } catch (e) { /* noop */ }
              window.location.replace('/invitation-es2/?t=' + encodeURIComponent(data.token));
              return;
            }
            if (res.ok && data.eligible === true) {
              gateErr.innerHTML = 'Aucune inscription trouvée avec cet email. Utilise l\'email de ton inscription à la masterclass, ou <a href="/masterclass/">inscris-toi ici</a>.';
            } else if (res.ok && data.reason === 'excluded') {
              gateErr.innerHTML = 'Un problème avec ton accès ? Écris-nous : <a href="mailto:support@sonnycourt.com">support@sonnycourt.com</a>';
            } else {
              gateErr.textContent = 'Erreur de connexion, réessaie dans un instant.';
            }
            gateErr.classList.add('on');
          } catch (e) {
            gateErr.textContent = 'Erreur réseau, vérifie ta connexion et réessaie.';
            gateErr.classList.add('on');
          }
          gateBtn.disabled = false;
          gateBtn.textContent = prevLabel;
        });
      }

      if (Number.isFinite(offerExpiryMs)) {
        if (offerExpiryMs - Date.now() <= 0) {
          lockExpired();
        } else {
          countdownEl.classList.add('is-visible');
          renderCountdown();
          countdownInterval = setInterval(renderCountdown, 1000);
        }
      }

      // --- Notifications d'achat (même moteur que /invitation) ---
      const toast = document.getElementById('purchase-toast');
      const toastFlag = document.getElementById('purchase-toast-flag');
      const toastText = document.getElementById('purchase-toast-text');
      if (toast && toastFlag && toastText
          && !pageEl.classList.contains('is-expired')
          && !pageEl.classList.contains('is-locked')) {
        let hideTimer = null;
        let queueGapTimer = null;
        const toastQueue = [];
        let toastBusy = false;
        function flushToastQueue() {
          if (toastBusy) return;
          const next = toastQueue.shift();
          if (!next) return;
          toastBusy = true;
          const actionText = next.mode === 'replay'
            ? `a rejoint il y a ${next.detail || 'quelques instants'}`
            : 'vient de rejoindre';
          toastFlag.textContent = next.purchase.flag;
          toastText.innerHTML = `<span class="purchase-toast__name">${next.purchase.name}</span> <span class="purchase-toast__action">${actionText}</span><br /><span class="purchase-toast__course">Esprit Subconscient 2.0</span>`;
          toast.classList.add('show');
          if (hideTimer) clearTimeout(hideTimer);
          if (queueGapTimer) clearTimeout(queueGapTimer);
          hideTimer = setTimeout(function () {
            toast.classList.remove('show');
            queueGapTimer = setTimeout(function () {
              toastBusy = false;
              flushToastQueue();
            }, 1000);
          }, 4000);
        }

        const fallbackWin = getCurrentWindow(Date.now());
        const windowStartMs = Number.isFinite(sessionStartsAtMs)
          ? sessionStartsAtMs + SCARCITY_WINDOW_START_AFTER_SESSION_MS
          : fallbackWin.startMs;
        const windowEndMs = Number.isFinite(offerExpiryMs) ? offerExpiryMs : fallbackWin.endMs;

        // Widget places : mêmes visuels et mêmes phases que /invitation.
        const scarcityCard = document.getElementById('scarcity-card');
        function updatePhaseUi(phase, seats) {
          document.querySelectorAll('.scarcity-number').forEach(function (el) {
            el.textContent = String(seats);
          });
          const isPhase2 = phase === 'phase2';
          document.querySelectorAll('.scarcity-phase1-total').forEach(function (el) {
            el.classList.toggle('is-visible', isPhase2);
          });
          document.querySelectorAll('.scarcity-phase2-note').forEach(function (el) {
            el.classList.toggle('is-visible', isPhase2);
          });
          document.querySelectorAll('.scarcity-denominator').forEach(function (el) {
            el.classList.add('is-visible');
            el.textContent = `/ ${isPhase2 ? 10 : 30}`;
          });
          const denominator = isPhase2 ? 10 : 30;
          const pct = (Math.max(0, Math.min(denominator, seats)) / denominator) * 100;
          document.querySelectorAll('.scarcity-meter__fill').forEach(function (el) {
            el.style.width = `${pct}%`;
          });
        }

        startScarcityEngine({
          now: () => Date.now(),
          isActive: () => !document.getElementById('page').classList.contains('is-expired'),
          windowStartMs,
          windowEndMs,
          enableReplay: true,
          onSeatsLeft: function (seatsLeft, _soldCount, phase) {
            const seats = Math.max(0, Math.min(30, Number(seatsLeft) || 0));
            if (scarcityCard) scarcityCard.classList.add('is-visible');
            updatePhaseUi(phase, seats);
          },
          onNotification: function (purchase, mode, detail) {
            toastQueue.push({ purchase, mode, detail });
            if (!toastBusy) flushToastQueue();
          },
        });
      }
    });
  </script>
</body>
</html>
