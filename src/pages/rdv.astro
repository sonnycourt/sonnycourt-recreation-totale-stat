---
import GAConsentMode from '../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light only">
    <title>Réserve ton appel — Sonny Court</title>
    <meta name="description" content="Choisis le créneau qui t'arrange pour ton appel personnel suite au webinaire.">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"></noscript>

    <style is:global>
        :root { color-scheme: light only; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f8fafc;
            color: #0f172a;
            line-height: 1.55;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
        }
        .rv-wrap { max-width: 560px; margin: 0 auto; padding: 28px 18px 140px; }
        .rv-brand { font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: .12em; color: #2563eb; margin-bottom: 18px; }
        .rv-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 18px; padding: 24px 22px; box-shadow: 0 2px 12px rgba(15,23,42,.05); }
        h1 { font-size: clamp(1.35rem, 5vw, 1.7rem); font-weight: 900; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 10px; }
        .rv-sub { font-size: 15px; color: #475569; }
        .rv-sub b { color: #0f172a; }

        .rv-spinner { width: 34px; height: 34px; border: 3px solid #e2e8f0; border-top-color: #2563eb; border-radius: 50%; margin: 60px auto; animation: rvspin .8s linear infinite; }
        @keyframes rvspin { to { transform: rotate(360deg); } }

        .rv-current { display: flex; gap: 10px; align-items: flex-start; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 12px; padding: 12px 14px; margin: 16px 0 4px; font-size: 14px; color: #1e40af; }
        .rv-current b { color: #1d4ed8; }

        .rv-tz { font-size: 12.5px; color: #94a3b8; margin-top: 12px; }

        .rv-day { margin-top: 22px; }
        .rv-day-t { font-size: 13px; font-weight: 800; color: #0f172a; margin-bottom: 10px; }
        .rv-day-t::first-letter { text-transform: uppercase; }
        .rv-slots { display: grid; grid-template-columns: repeat(auto-fill, minmax(96px, 1fr)); gap: 8px; }
        .rv-slot { border: 1.5px solid #e2e8f0; background: #fff; border-radius: 10px; padding: 10px 4px; font: inherit; font-size: 14px; font-weight: 700; color: #334155; cursor: pointer; text-align: center; transition: border-color .1s ease, background .1s ease; }
        .rv-slot:hover { border-color: #93c5fd; }
        .rv-slot.sel { background: #2563eb; border-color: #2563eb; color: #fff; }

        .rv-confirm { position: fixed; left: 0; right: 0; bottom: 0; padding: 14px 18px calc(14px + env(safe-area-inset-bottom)); background: rgba(248,250,252,.92); backdrop-filter: blur(8px); border-top: 1px solid #e2e8f0; transform: translateY(110%); transition: transform .18s ease; }
        .rv-confirm.on { transform: translateY(0); }
        .rv-confirm-in { max-width: 560px; margin: 0 auto; }
        .rv-confirm-btn { width: 100%; border: 0; border-radius: 12px; background: #16a34a; color: #fff; font: inherit; font-size: 16px; font-weight: 800; padding: 15px 18px; cursor: pointer; }
        .rv-confirm-btn:hover { background: #15803d; }
        .rv-confirm-btn:disabled { opacity: .6; cursor: default; }

        .rv-msg { font-size: 14px; font-weight: 700; color: #dc2626; margin-top: 12px; min-height: 18px; }

        .rv-ident-form { margin-top: 18px; display: flex; flex-direction: column; gap: 10px; }
        .rv-input { border: 1.5px solid #cbd5e1; border-radius: 12px; padding: 13px 14px; font: inherit; font-size: 16px; color: #0f172a; background: #fff; }
        .rv-input:focus { outline: none; border-color: #60a5fa; box-shadow: 0 0 0 3px rgba(59,130,246,.12); }
        .rv-ident-btn { border: 0; border-radius: 12px; background: #2563eb; color: #fff; font: inherit; font-size: 15px; font-weight: 800; padding: 13px 18px; cursor: pointer; }
        .rv-ident-btn:hover { background: #3b82f6; }
        .rv-ident-btn:disabled { opacity: .6; cursor: default; }

        .rv-done-ic { width: 58px; height: 58px; border-radius: 50%; background: #dcfce7; color: #16a34a; display: flex; align-items: center; justify-content: center; font-size: 28px; margin-bottom: 14px; }
        .rv-done-when { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 14px 16px; margin: 16px 0; font-size: 16px; font-weight: 800; color: #15803d; }
        .rv-done-when::first-letter { text-transform: uppercase; }
        .rv-done-note { font-size: 13.5px; color: #64748b; margin-top: 14px; }

        .rv-info-ic { font-size: 34px; margin-bottom: 10px; }
        [hidden] { display: none !important; }
    </style>
</head>
<body>
    <div class="rv-wrap">
        <div class="rv-brand">Sonny Court</div>

        <div id="rv-loading"><div class="rv-spinner" aria-label="Chargement"></div></div>

        <div id="rv-error" class="rv-card" hidden>
            <div class="rv-info-ic">🔗</div>
            <h1>Lien invalide</h1>
            <p class="rv-sub">Ouvre cette page depuis le lien reçu par SMS. Si le problème persiste, réponds simplement au SMS.</p>
        </div>

        <div id="rv-ident" class="rv-card" hidden>
            <div class="rv-info-ic">📞</div>
            <h1>Réserve ton appel</h1>
            <p class="rv-sub">Entre l'email que tu as utilisé pour t'inscrire au webinaire.</p>
            <form id="rv-ident-form" class="rv-ident-form">
                <input id="rv-email" class="rv-input" type="email" inputmode="email" autocapitalize="none" autocomplete="email" spellcheck="false" placeholder="Ton email d'inscription" aria-label="Email d'inscription" required>
                <button type="submit" class="rv-ident-btn" id="rv-ident-btn">Voir les créneaux</button>
            </form>
            <p class="rv-msg" id="rv-ident-msg"></p>
        </div>

        <div id="rv-info" class="rv-card" hidden>
            <div class="rv-info-ic" id="rv-info-ic">📞</div>
            <h1 id="rv-info-title"></h1>
            <p class="rv-sub" id="rv-info-sub"></p>
        </div>

        <div id="rv-book" hidden>
            <div class="rv-card">
                <h1 id="rv-title"></h1>
                <p class="rv-sub" id="rv-intro"></p>
                <div class="rv-current" id="rv-current" hidden></div>
                <div id="rv-days"></div>
                <p class="rv-tz" id="rv-tz" hidden></p>
                <p class="rv-msg" id="rv-msg"></p>
            </div>
        </div>

        <div id="rv-done" class="rv-card" hidden>
            <div class="rv-done-ic">✓</div>
            <h1 id="rv-done-title">C'est noté !</h1>
            <div class="rv-done-when" id="rv-done-when"></div>
            <p class="rv-sub" id="rv-done-sub"></p>
            <p class="rv-done-note">Un empêchement ? Reviens sur cette page pour déplacer ton rendez-vous.</p>
        </div>
    </div>

    <div class="rv-confirm" id="rv-confirm">
        <div class="rv-confirm-in">
            <button type="button" class="rv-confirm-btn" id="rv-confirm-btn"></button>
        </div>
    </div>

    <script is:inline>
    (function () {
        var EP = '/.netlify/functions/rdv-slots';
        var qs = new URLSearchParams(location.search);
        var TOKEN = (qs.get('t') || qs.get('token') || '').trim();
        var EMAIL = '';
        function identQuery() { return TOKEN ? 't=' + encodeURIComponent(TOKEN) : 'email=' + encodeURIComponent(EMAIL); }
        function identBody() { return TOKEN ? { t: TOKEN } : { email: EMAIL }; }

        var fmtDay = new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
        var fmtTime = new Intl.DateTimeFormat('fr-FR', { hour: '2-digit', minute: '2-digit' });
        var fmtFull = new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' });

        var SLOTS = {};       // id -> {id, start}
        var SELECTED = null;  // id du créneau choisi
        var LAST = null;      // dernière réponse GET

        function el(id) { return document.getElementById(id); }
        function esc(s) { return (s == null ? '' : String(s)).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }
        function show(id) {
            ['rv-loading', 'rv-error', 'rv-ident', 'rv-info', 'rv-book', 'rv-done'].forEach(function (v) { el(v).hidden = v !== id; });
            if (id !== 'rv-book') setConfirm(false);
        }
        function setConfirm(on, label) {
            var bar = el('rv-confirm');
            if (on) { el('rv-confirm-btn').textContent = label; bar.classList.add('on'); }
            else bar.classList.remove('on');
        }
        function info(icon, title, sub) {
            el('rv-info-ic').textContent = icon;
            el('rv-info-title').textContent = title;
            el('rv-info-sub').innerHTML = sub;
            show('rv-info');
        }

        function render(d) {
            LAST = d; SLOTS = {}; SELECTED = null;
            var prenom = d.prenom || '';
            if (d.mode === 'purchased') {
                info('🎉', 'Tu fais déjà partie du programme' + (prenom ? ', ' + esc(prenom) : '') + ' !', 'Pas besoin de rendez-vous : ton accès t\'attend dans tes emails. À tout de suite à l\'intérieur.');
                return;
            }
            if (d.mode !== 'ok' || !Array.isArray(d.slots) || !d.slots.length) {
                info('📞', 'Merci' + (prenom ? ' ' + esc(prenom) : '') + ' !', 'Il n\'y a plus de créneau en ligne pour le moment.' + (d.closer ? ' <b>' + esc(d.closer) + '</b> te contactera directement par téléphone.' : ' On te contactera directement par téléphone.'));
                return;
            }

            el('rv-title').textContent = 'Réserve ton appel avec ' + d.closer;
            el('rv-intro').innerHTML = 'Choisis le créneau qui t\'arrange : <b>' + esc(d.closer) + '</b> t\'appellera sur ' + (d.phone_hint ? 'ton numéro finissant par <b>&bull;&bull;' + esc(d.phone_hint) + '</b>' : 'le numéro donné à l\'inscription') + '. L\'appel dure environ 20 minutes.';

            var cur = el('rv-current');
            if (d.current) {
                cur.innerHTML = '<span>📅</span><span>Ton RDV actuel : <b>' + esc(fmtFull.format(new Date(d.current))) + '</b>.<br>Choisis un autre créneau ci-dessous pour le déplacer.</span>';
                cur.hidden = false;
            } else cur.hidden = true;

            // Groupe les créneaux par jour (fuseau du visiteur).
            var groups = [], byKey = {};
            d.slots.forEach(function (s) {
                SLOTS[s.id] = s;
                var day = fmtDay.format(new Date(s.start));
                if (!byKey[day]) { byKey[day] = []; groups.push(day); }
                byKey[day].push(s);
            });
            el('rv-days').innerHTML = groups.map(function (day) {
                return '<div class="rv-day"><div class="rv-day-t">' + esc(day) + '</div><div class="rv-slots">' +
                    byKey[day].map(function (s) {
                        return '<button type="button" class="rv-slot" data-id="' + s.id + '">' + esc(fmtTime.format(new Date(s.start))) + '</button>';
                    }).join('') + '</div></div>';
            }).join('');

            var tz = '';
            try { tz = Intl.DateTimeFormat().resolvedOptions().timeZone || ''; } catch (e) {}
            var tzEl = el('rv-tz');
            if (tz && tz !== 'Europe/Paris') { tzEl.textContent = 'Heures affichées dans ton fuseau horaire (' + tz + ').'; tzEl.hidden = false; }
            else tzEl.hidden = true;

            el('rv-msg').textContent = '';
            show('rv-book');
        }
        // Hook de debug/preview : permet de rendre la page avec des données injectées.
        window.__rdvRender = render;

        el('rv-days').addEventListener('click', function (e) {
            var b = e.target.closest('.rv-slot');
            if (!b) return;
            var id = Number(b.getAttribute('data-id'));
            SELECTED = id;
            document.querySelectorAll('.rv-slot.sel').forEach(function (x) { x.classList.remove('sel'); });
            b.classList.add('sel');
            var s = SLOTS[id];
            setConfirm(true, 'Confirmer · ' + fmtFull.format(new Date(s.start)));
        });

        el('rv-confirm-btn').addEventListener('click', async function () {
            if (!SELECTED || !SLOTS[SELECTED]) return;
            var btn = this, s = SLOTS[SELECTED];
            btn.disabled = true; btn.textContent = 'Réservation…';
            try {
                var payload = identBody(); payload.slot_id = SELECTED;
                var r = await fetch(EP, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                });
                var d = await r.json().catch(function () { return {}; });
                if (r.ok && d.ok) {
                    el('rv-done-when').textContent = fmtFull.format(new Date(d.at));
                    el('rv-done-title').textContent = 'C\'est noté' + (LAST.prenom ? ' ' + LAST.prenom : '') + ' !';
                    el('rv-done-sub').innerHTML = '<b>' + esc(LAST.closer) + '</b> t\'appellera sur ' + (LAST.phone_hint ? 'ton numéro finissant par <b>&bull;&bull;' + esc(LAST.phone_hint) + '</b>' : 'le numéro donné à l\'inscription') + '. Garde ton téléphone à portée de main.';
                    show('rv-done');
                    return;
                }
                el('rv-msg').textContent = (d && d.error) ? d.error : 'Erreur, réessaie.';
                if (r.status === 409) boot(); // créneau pris entre-temps -> on recharge la liste
            } catch (err) {
                el('rv-msg').textContent = 'Erreur réseau. Vérifie ta connexion et réessaie.';
            }
            btn.disabled = false;
        });

        async function boot() {
            if (!TOKEN && !EMAIL) { show('rv-ident'); return; }
            show('rv-loading');
            try {
                var r = await fetch(EP + '?' + identQuery());
                if (r.status === 404 || r.status === 400) {
                    if (TOKEN) { show('rv-error'); return; }
                    var d404 = await r.json().catch(function () { return {}; });
                    el('rv-ident-msg').textContent = (d404 && d404.error) || 'On ne trouve pas cet email. Utilise celui de ton inscription au webinaire.';
                    show('rv-ident');
                    return;
                }
                if (!r.ok) throw 0;
                render(await r.json());
            } catch (e) {
                info('📶', 'Petit souci de connexion', 'Impossible de charger les créneaux. Vérifie ta connexion puis recharge la page.');
            }
        }
        el('rv-ident-form').addEventListener('submit', function (e) {
            e.preventDefault();
            var v = (el('rv-email').value || '').trim().toLowerCase();
            if (!v) return;
            EMAIL = v;
            el('rv-ident-msg').textContent = '';
            boot();
        });
        boot();
    })();
    </script>
</body>
</html>
