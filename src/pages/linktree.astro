---
import GAConsentMode from '../components/GAConsentMode.astro';
const title = "Pourquoi es-tu là ? - Sonny Court";
const description = "Choisis ton chemin : manifester tes désirs, reprogrammer ton subconscient ou créer ton business en ligne.";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- GA4 Consent Mode v2 -->
    <GAConsentMode />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/media/pages/sonnycourt_share.webp", Astro.url)} />
    <meta property="og:url" content={Astro.url.href} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/media/pages/sonnycourt_share.webp", Astro.url)} />
    
    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />
    
    <title>{title}</title>
  </head>
  <body>
    <div class="linktree2-page">
      <!-- Background Effects -->
      <div class="background-effects">
        <div class="gradient-mesh"></div>
        <div class="depth-layers">
          <div class="depth-circle orb1"></div>
          <div class="depth-circle orb2"></div>
        </div>
      </div>

      <!-- Main Content -->
      <main class="main-content">
        <h1 class="question">Pourquoi es-tu là ?</h1>

        <div class="choices">
          <a href="https://sonnycourt.com/inscription-manifest/" class="choice-btn choice-manifest" data-umami-event="linktree_btn_manifest">
            <span class="choice-emoji">✨</span>
            <span class="choice-label">Manifester mes désirs</span>
          </a>

          <a href="https://sonnycourt.com/es-inscription/" class="choice-btn choice-subconscient" data-umami-event="linktree_btn_subconscient">
            <span class="choice-emoji">🧠</span>
            <span class="choice-label">Reprogrammer mon subconscient</span>
          </a>

          <a href="https://systemeviral.com/inscription/" class="choice-btn choice-business" data-umami-event="linktree_btn_business">
            <span class="choice-emoji">🚀</span>
            <span class="choice-label">Créer mon business en ligne</span>
          </a>
        </div>

        <!-- Compact Social Proof -->
        <div class="social-compact">
          <span class="social-number">4M+</span>
          <span class="social-text">abonnés sur les réseaux</span>
        </div>
      </main>
    </div>
  </body>
</html>

<style is:global>
  html {
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    margin: 0;
    padding: 0;
    background: #0a0a0a;
    overflow: hidden;
  }
</style>

<style>
  .linktree2-page {
    height: 100vh;
    height: 100dvh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Background Effects (same as /linktree) */
  .background-effects {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .gradient-mesh {
    position: fixed;
    width: 200vw;
    height: 300vh;
    top: -50vh;
    left: -50vw;
    background:
      radial-gradient(circle at 20% 30%, rgba(0, 122, 255, 0.15) 0%, transparent 60%),
      radial-gradient(circle at 80% 70%, rgba(0, 122, 255, 0.08) 0%, transparent 70%),
      radial-gradient(circle at 40% 20%, rgba(0, 122, 255, 0.05) 0%, transparent 80%),
      radial-gradient(circle at 60% 80%, rgba(0, 122, 255, 0.03) 0%, transparent 90%);
    filter: blur(60px);
    opacity: 0.7;
    animation: meshMove 40s ease-in-out infinite;
  }

  @keyframes meshMove {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(-5%, -5%) scale(1.05); }
    50% { transform: translate(5%, 5%) scale(1.1); }
    75% { transform: translate(-3%, 3%) scale(1.05); }
  }

  .depth-layers {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .depth-circle {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: orbFloat 20s ease-in-out infinite;
  }

  .orb1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 122, 255, 0.6) 0%, transparent 70%);
    top: 10%;
    left: 10%;
  }

  .orb2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(0, 81, 213, 0.5) 0%, transparent 70%);
    bottom: 10%;
    right: 10%;
    animation-delay: 10s;
  }

  @keyframes orbFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(50px, -50px) scale(1.1); }
  }

  /* Main Content */
  .main-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 480px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .question {
    font-size: clamp(1.6rem, 6vw, 2.4rem);
    font-weight: 800;
    color: #ffffff;
    text-align: center;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 36px;
  }

  /* Choice Buttons */
  .choices {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
  }

  .choice-btn {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    padding: 20px 24px;
    border-radius: 18px;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .choice-btn:active {
    transform: scale(0.97);
  }

  .choice-emoji {
    font-size: 1.8rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .choice-label {
    font-size: clamp(1rem, 3.5vw, 1.15rem);
    font-weight: 600;
    line-height: 1.3;
  }

  /* Manifest button */
  .choice-manifest {
    background: rgba(139, 92, 246, 0.12);
    border-color: rgba(139, 92, 246, 0.3);
    box-shadow: 0 4px 24px rgba(139, 92, 246, 0.1);
  }

  .choice-manifest .choice-label {
    color: #c4b5fd;
  }

  .choice-manifest:hover {
    background: rgba(139, 92, 246, 0.2);
    border-color: rgba(139, 92, 246, 0.5);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(139, 92, 246, 0.2);
  }

  /* Subconscient button */
  .choice-subconscient {
    background: rgba(0, 122, 255, 0.12);
    border-color: rgba(0, 122, 255, 0.3);
    box-shadow: 0 4px 24px rgba(0, 122, 255, 0.1);
  }

  .choice-subconscient .choice-label {
    color: #93c5fd;
  }

  .choice-subconscient:hover {
    background: rgba(0, 122, 255, 0.2);
    border-color: rgba(0, 122, 255, 0.5);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(0, 122, 255, 0.2);
  }

  /* Business button */
  .choice-business {
    background: rgba(52, 199, 89, 0.12);
    border-color: rgba(52, 199, 89, 0.3);
    box-shadow: 0 4px 24px rgba(52, 199, 89, 0.1);
  }

  .choice-business .choice-label {
    color: #86efac;
  }

  .choice-business:hover {
    background: rgba(52, 199, 89, 0.2);
    border-color: rgba(52, 199, 89, 0.5);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(52, 199, 89, 0.2);
  }

  /* Compact Social Proof */
  .social-compact {
    display: flex;
    align-items: baseline;
    gap: 8px;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .social-compact:hover {
    opacity: 1;
  }

  .social-number {
    font-size: 1.1rem;
    font-weight: 800;
    background: linear-gradient(135deg, #007AFF 0%, #0051D5 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .social-text {
    color: #8E8E93;
    font-size: 0.8rem;
    font-weight: 500;
  }

  /* Mobile (small screens) */
  @media (max-height: 680px) {
    .question {
      margin-bottom: 24px;
      font-size: clamp(1.4rem, 5vw, 2rem);
    }

    .choices {
      gap: 12px;
      margin-bottom: 28px;
    }

    .choice-btn {
      padding: 16px 20px;
      border-radius: 14px;
    }

    .choice-emoji {
      font-size: 1.5rem;
    }
  }

  @media (max-height: 560px) {
    .question {
      margin-bottom: 16px;
      font-size: 1.3rem;
    }

    .choices {
      gap: 10px;
      margin-bottom: 20px;
    }

    .choice-btn {
      padding: 14px 18px;
      border-radius: 12px;
    }

    .choice-emoji {
      font-size: 1.3rem;
    }

    .choice-label {
      font-size: 0.95rem;
    }
  }
</style>
