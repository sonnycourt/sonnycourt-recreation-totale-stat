        function statusBadge(l){var s=statusOf(l);if(hasRdv(l))return stPill(s)+'<span class="cc-cbtag cc-rdvtag">&#128197; RDV '+fmt(l.rdv_at)+'</span>';var cb=(s==='A rappeler'&&l.next_callback_at)?'<span class="cc-cbtag">&#128197; '+fmt(l.next_callback_at)+'</span>':'';return stPill(s)+cb;}
        function callsCell(log){if(!log||!log.length)return '<span class="cc-calls"><small>aucun appel</small></span>';var last=log[log.length-1];return '<span class="cc-calls">'+log.length+' appel'+(log.length>1?'s':'')+'<br><small>dernier '+fmt(last.at)+'</small></span>';}
        function histHtml(log){if(!log||!log.length)return '<div class="cc-hist-empty">Aucune tentative notee.</div>';return log.map(function(e,i){var rap=(CALLBACK_OUTCOMES.indexOf(e.outcome)!==-1&&e.callback)?' <span class="rap">&rarr; rappel '+fmt(e.callback)+'</span>':'';return '<div class="cc-h"><time>'+fmt(e.at)+'</time><em>'+esc(e.outcome||'—')+rap+'</em><button type="button" class="cc-hdel" data-idx="'+i+'" title="Supprimer">&times;</button></div>';}).reverse().join('');}
        function opts(arr,val){return '<option value="">&mdash;</option>'+arr.map(function(s){return '<option'+(val===s?' selected':'')+'>'+s+'</option>';}).join('');}

        function detailHtml(l){
            var m=l.watch_max_minutes||0;
            var ctaTxt=(l.visited_sales?' &middot; <b>a vu la page de vente</b>':((l.saw_offer||m>=81)?' &middot; <b>a vu l\'offre</b>':''))+(l.checkout_clicked?' &middot; <b style="color:#7c3aed">a cliqué s\'inscrire (page de vente)'+(l.purchased?'':' &#128722; panier abandonné')+'</b>':'');
