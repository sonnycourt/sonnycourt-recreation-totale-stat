                OFFERS.map(function(o){var on=(l.proposed_offers||[]).indexOf(o.k)!==-1;return '<label class="cc-offer"><input type="checkbox" class="cc-offer-cb" data-offer="'+o.k+'"'+(on?' checked':'')+'> '+esc(o.t)+'</label>';}).join('')+
              '</div>'+
              '<div class="cc-fields">'+
                '<div class="cc-f"><label>Remarque</label><textarea class="cc-ta cc-notes" placeholder="Notes libres...">'+esc(l.call_notes||'')+'</textarea></div>'+
              '</div>'+
              '<div class="cc-saved"></div></div>';
        }
        function minutesCell(l){var m=l.watch_max_minutes||0;
            var offer=(l.saw_offer||m>=81)?'<span class="cc-cta">a vu l\'offre</span>':'';
