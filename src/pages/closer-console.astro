        function ynPill(on,hot){return on?'<span class="cc-yn yes'+(hot?' cart':'')+'">Oui</span>':'<span class="cc-yn no">Non</span>';}
        function srcBadge(l){if(l.traffic_source==='meta_ad')return '<span class="cc-src cc-src-meta">Meta</span>';if(l.traffic_source==='tiktok_ad')return '<span class="cc-src cc-src-tt">TikTok</span>';return '<span class="cc-src cc-src-orga">Orga</span>';}
        var REAL_CONTACT={'À rappeler':1,'En réflexion':1,'Dit oui (verbal)':1,'Pas intéressé':1,'Joint':1,'Rappel demande':1,'A dit OUI':1,'Refus':1};
        function contactBeforeBuy(l){var log=l.call_log;if(!Array.isArray(log))return false;var pa=l.purchased_at?new Date(l.purchased_at).getTime():null;for(var i=0;i<log.length;i++){var e=log[i];if(!e||!REAL_CONTACT[e.outcome]||!e.at)continue;var t=new Date(e.at).getTime();if(isNaN(t))continue;if(pa==null||t<pa)return true;}return false;}
