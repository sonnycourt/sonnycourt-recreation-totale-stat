            color: #94a3b8;
        }

        .closer-gate-consent {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-top: 16px;
            text-align: left;
            cursor: pointer;
        }

        .closer-gate-consent input {
            margin-top: 2px;
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            accent-color: var(--primary);
            cursor: pointer;
        }

        .closer-gate-consent span {
            font-size: 0.82rem;
            line-height: 1.45;
            color: var(--ink-soft);
        }

        .closer-gate-error {
            min-height: 1.2em;
            margin: 10px 0 0;
            font-size: 0.88rem;
            font-weight: 600;
            color: #dc2626;
        }

        .closer-gate-btn {
            width: 100%;
            margin-top: 16px;
            padding: 15px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-family: inherit;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.02em;
