            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: clamp(20px, 3vw, 26px);
        }

        .audience-head img {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            border: 3px solid #fff;
            box-shadow:
                0 0 0 2px rgba(59, 130, 246, 0.35),
                0 6px 16px rgba(37, 99, 235, 0.20);
        }

        .audience-name {
            display: block;
            font-size: 1.05rem;
            font-weight: 800;
            letter-spacing: -0.01em;
            color: var(--ink);
        }

        .audience-role {
            display: block;
            margin-top: 2px;
