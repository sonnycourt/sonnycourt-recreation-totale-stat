        function renderChips(){chipsEl.innerHTML=CHIPS.map(function(c){var n=(c.k==='all')?LEADS.length:(c.k==='rdv')?LEADS.filter(hasRdv).length:(c.k==='achete'?LEADS.filter(function(l){return l.purchased;}).length:LEADS.filter(function(l){return !l.purchased&&(l.call_status||'A appeler')===c.k;}).length);return '<button class="cc-chip'+(FILTER===c.k?' on':'')+'" data-f="'+c.k+'">'+c.t+'<small>'+n+'</small></button>';}).join('');}
        function passF(l){if(FILTER==='all')return true;if(FILTER==='rdv')return hasRdv(l);if(FILTER==='achete')return !!l.purchased;if(l.purchased)return false;return (l.call_status||'A appeler')===FILTER;}
        function heat(l){if(l.checkout_clicked&&!l.purchased)return 2;if(l.visited_sales)return 1;return 0;}
        function srcKey(l){return l.traffic_source==='meta_ad'?'meta':(l.traffic_source==='tiktok_ad'?'tiktok':'orga');}
        // Alterne les sources (Meta/Orga/TikTok) au sein d'un groupe de même chaleur,
        // chaque source gardant ses meilleures minutes d'abord.
        function interleaveSources(group){
            var by={};
            group.forEach(function(l){var k=srcKey(l);(by[k]=by[k]||[]).push(l);});
            var keys=Object.keys(by);
            keys.forEach(function(k){by[k].sort(function(a,b){return (b.watch_max_minutes||0)-(a.watch_max_minutes||0);});});
            keys.sort(function(a,b){return (by[b][0].watch_max_minutes||0)-(by[a][0].watch_max_minutes||0);});
            var out=[],i=0;
            while(keys.length){
                if(i>=keys.length)i=0;
                out.push(by[keys[i]].shift());
                if(!by[keys[i]].length)keys.splice(i,1);else i++;
            }
            return out;
        }
        function renderList(){
            var arr=LEADS.filter(passF).slice();
