---
import GAConsentMode from '../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light only">
    <title>Console closer — Mes leads</title>
    <meta name="description" content="Recrutement de closers freelance high-ticket. Leads ultra-chauds, 100% au résultat, commission croissante. La machine vend déjà — il lui manque une voix au téléphone.">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"></noscript>

    <style>
        :root {
            color-scheme: light only;
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --primary-light: #60a5fa;
            --ink: #0f172a;
            --ink-soft: #334155;
            --muted: #64748b;
            --line: #e2e8f0;
            --surface: #ffffff;
            --surface-tint: #f1f5f9;
            --bg: #f8fafc;
            --accent-soft: #eff6ff;
            --green: #16a34a;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .wrap {
            max-width: 760px;
            margin: 0 auto;
            padding: 0 22px;
        }

        /* === Section rhythm === */
        section {
            padding: clamp(48px, 8vw, 88px) 0;
            border-bottom: 1px solid var(--line);
        }

        section:last-of-type {
            border-bottom: none;
        }

        .eyebrow {
            display: inline-block;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--primary-dark);
            margin-bottom: 16px;
        }

        h1, h2 {
            line-height: 1.18;
            letter-spacing: -0.02em;
            color: var(--ink);
        }

        h1 {
            font-size: clamp(1.9rem, 5.2vw, 3rem);
            font-weight: 900;
        }

        h2 {
            font-size: clamp(1.5rem, 4vw, 2.1rem);
            font-weight: 800;
            margin-bottom: 22px;
        }

        p {
            font-size: clamp(1rem, 2.2vw, 1.12rem);
            color: var(--ink-soft);
        }

        p + p {
            margin-top: 16px;
        }

        .lead {
            font-size: clamp(1.05rem, 2.4vw, 1.22rem);
        }

        strong {
            color: var(--ink);
            font-weight: 700;
        }

        /* === Hero === */
        .hero {
            background:
                radial-gradient(ellipse 70% 60% at 80% 0%, rgba(59, 130, 246, 0.09) 0%, transparent 60%),
                linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
            padding-top: clamp(64px, 10vw, 110px);
        }

        .hero h1 {
            margin-bottom: 26px;
        }

        .hero h1 .turn {
            color: var(--primary-dark);
        }

        /* === Stat highlight (section 2) === */
        .stat-pop {
            display: block;
            font-size: clamp(2.6rem, 9vw, 4.4rem);
            font-weight: 900;
            letter-spacing: -0.03em;
            line-height: 1;
            color: var(--primary-dark);
            margin-bottom: 6px;
        }

        /* === Checklist (section 3) === */
        .check-list {
            list-style: none;
            margin: 22px 0 0;
            display: grid;
            gap: 14px;
        }

        .check-list li {
            display: grid;
            grid-template-columns: 26px 1fr;
            gap: 12px;
            align-items: start;
            font-size: clamp(1rem, 2.2vw, 1.1rem);
            color: var(--ink-soft);
        }

        .check-list .ic {
            width: 24px;
            height: 24px;
            border-radius: 7px;
            background: var(--accent-soft);
            color: var(--primary-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 2px;
        }

        .check-list .ic svg {
            width: 15px;
            height: 15px;
        }

        /* === Tables === */
        .table-card {
            margin-top: 26px;
            border: 1px solid var(--line);
            border-radius: 16px;
            overflow: hidden;
            background: var(--surface);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-variant-numeric: tabular-nums;
        }

        thead th {
            background: var(--surface-tint);
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            padding: 14px 18px;
        }

        thead th:not(:first-child) {
            text-align: center;
        }

        tbody td {
            padding: 14px 18px;
            font-size: clamp(0.95rem, 2vw, 1.05rem);
            color: var(--ink-soft);
            border-top: 1px solid var(--line);
        }

        tbody td:first-child {
            font-weight: 600;
            color: var(--ink);
        }

        tbody td:not(:first-child) {
            text-align: center;
            font-weight: 600;
        }

        .table-note {
            margin-top: 16px;
            font-size: 0.95rem;
            color: var(--muted);
        }

        /* Tiers table highlight */
        .tiers tbody tr.tier-top td {
            background: var(--accent-soft);
            color: var(--primary-dark);
            font-weight: 800;
        }

        .tiers tbody td:last-child {
            font-weight: 700;
            color: var(--primary-dark);
        }

        /* Ligne aspirationnelle "closer d'exception" */
        .tiers tbody tr.tier-elite td {
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.14), rgba(37, 99, 235, 0.05));
            border-top: 2px solid rgba(37, 99, 235, 0.4);
            color: var(--primary-dark);
            font-style: italic;
            font-weight: 800;
            letter-spacing: 0.01em;
        }

        .tiers tbody tr.tier-elite td:first-child {
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .tiers tbody tr.tier-elite td:first-child::before {
            content: '★';
            font-style: normal;
            color: var(--primary);
        }

        /* === Deal callout === */
        .deal-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            color: var(--green);
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 7px 14px;
            border-radius: 999px;
            font-size: 0.9rem;
            margin-bottom: 18px;
        }

        /* === Risk note (section deal) === */
        .risk-note {
            margin-top: 22px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: var(--surface);
            padding: clamp(20px, 3vw, 28px);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .risk-note h3 {
            font-size: 1.05rem;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 10px;
        }

        .risk-note p {
            margin: 0;
            font-size: clamp(0.92rem, 1.9vw, 1rem);
            line-height: 1.65;
            color: var(--ink-soft);
        }

        .risk-note strong {
            font-weight: 800;
            color: var(--primary-dark);
            background: var(--accent-soft);
            padding: 1px 6px;
            border-radius: 6px;
        }

        /* === Funnel links (preuve tangible) === */
        .funnel-links {
            display: grid;
            gap: 12px;
            margin-top: 24px;
        }

        .funnel-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            border: 1px solid var(--line);
            border-radius: 14px;
            background: var(--surface);
            text-decoration: none;
            color: var(--ink);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
            transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
        }

        .funnel-link:hover {
            border-color: var(--primary-light);
            box-shadow: 0 8px 22px rgba(37, 99, 235, 0.10);
            transform: translateY(-1px);
        }

        .funnel-link .fl-ic {
            width: 42px;
            height: 42px;
            border-radius: 11px;
            background: var(--accent-soft);
            color: var(--primary-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .funnel-link .fl-ic svg { width: 20px; height: 20px; }

        .funnel-link .fl-text { flex: 1; min-width: 0; }

        .funnel-link .fl-title {
            display: block;
            font-weight: 700;
            font-size: 0.98rem;
            color: var(--ink);
        }

        .funnel-link .fl-sub {
            display: block;
            margin-top: 2px;
            font-size: 0.82rem;
            color: var(--muted);
            line-height: 1.4;
        }

        .funnel-link .fl-arrow {
            color: var(--muted);
            flex-shrink: 0;
            display: flex;
        }

        .funnel-link .fl-arrow svg { width: 18px; height: 18px; }

        .funnel-link.is-placeholder {
            border-style: dashed;
            background: #fcfdfe;
        }

        .funnel-link.is-placeholder .fl-ic {
            background: var(--surface-tint);
            color: var(--muted);
        }

        .funnel-link.is-placeholder .fl-title { color: var(--muted); }

        /* === Calculator === */
        .calc {
            margin-top: 26px;
        }

        .calc-controls {
            display: grid;
            gap: 22px;
            padding: clamp(20px, 3vw, 28px);
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 18px;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        @media (min-width: 680px) {
            .calc-controls {
                grid-template-columns: 1fr 1fr;
                gap: 24px 30px;
            }
        }

        .calc-field-head {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 12px;
        }

        .calc-field label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--ink-soft);
            line-height: 1.3;
        }

        .calc-field-val {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--primary-dark);
            font-variant-numeric: tabular-nums;
            white-space: nowrap;
        }

        .calc-field input[type="range"] {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 6px;
            border-radius: 999px;
            background: #e2e8f0;
            outline: none;
            cursor: pointer;
        }

        .calc-field input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid var(--primary);
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.4);
            cursor: pointer;
        }

        .calc-field input[type="range"]::-moz-range-thumb {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid var(--primary);
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.4);
            cursor: pointer;
        }

        .calc-field input[type="range"]:focus-visible {
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.25);
        }

        .calc-field-help {
            margin-top: 8px;
            font-size: 0.78rem;
            color: var(--muted);
        }

        .calc-kpis {
            margin-top: 18px;
            display: grid;
            gap: 14px;
            grid-template-columns: 1fr;
        }

        @media (min-width: 680px) {
            .calc-kpis {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .kpi {
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 20px 18px;
            background: var(--surface);
            text-align: center;
        }

        .kpi--accent {
            background: linear-gradient(165deg, #eff6ff, #ffffff);
            border-color: #bfdbfe;
        }

        .kpi-val {
            display: block;
            font-size: clamp(1.5rem, 4.5vw, 2rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            line-height: 1.1;
            color: var(--ink);
            font-variant-numeric: tabular-nums;
        }

        .kpi--accent .kpi-val {
            color: var(--primary-dark);
        }

        .kpi-label {
            display: block;
            margin-top: 6px;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--ink-soft);
        }

        .kpi-sub {
            display: block;
            margin-top: 3px;
            font-size: 0.72rem;
            color: var(--muted);
        }

        .calc-chart {
            margin-top: 18px;
            border: 1px solid var(--line);
            border-radius: 18px;
            padding: 20px clamp(8px, 2vw, 18px);
            background: var(--surface);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .calc-chart-head {
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 0 0 6px 10px;
        }

        .chart-host {
            position: relative;
        }

        .chart-host svg {
            width: 100%;
            height: auto;
            display: block;
        }

        .calc-markers {
            margin-top: 16px;
            display: grid;
            gap: 10px;
            grid-template-columns: 1fr;
        }

        @media (min-width: 680px) {
            .calc-markers {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .marker {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px 16px;
            background: var(--surface);
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .marker--accent {
            background: var(--accent-soft);
            border-color: #bfdbfe;
        }

        .marker-k {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--muted);
        }

        .marker-v {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--ink);
            font-variant-numeric: tabular-nums;
        }

        .marker--accent .marker-v {
            color: var(--primary-dark);
        }

        .calc-explainer {
            margin-top: 18px;
            font-size: 0.95rem;
            line-height: 1.65;
            color: var(--muted);
        }

        /* === Profile blocks (section 8) === */
        .fit-grid {
            margin-top: 22px;
            display: grid;
            gap: 18px;
        }

        @media (min-width: 640px) {
            .fit-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .fit-card {
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 22px;
            background: var(--surface);
        }

        .fit-card h3 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .fit-card.yes h3 { color: var(--green); }
        .fit-card.no h3 { color: #dc2626; }

        .fit-card ul {
            list-style: none;
            display: grid;
            gap: 10px;
        }

        .fit-card li {
            font-size: 0.98rem;
            color: var(--ink-soft);
            padding-left: 22px;
            position: relative;
        }

        .fit-card li::before {
            position: absolute;
            left: 0;
            top: 0;
            font-weight: 700;
        }

        .fit-card.yes li::before { content: '✓'; color: var(--green); }
        .fit-card.no li::before { content: '✕'; color: #dc2626; }

        /* === Availability callout (section 7) === */
        .op-availability {
            margin-top: 18px;
            padding: 16px 20px;
            border-radius: 14px;
            background: var(--accent-soft);
            border: 1px solid #bfdbfe;
            font-size: clamp(0.95rem, 2vw, 1.02rem);
            line-height: 1.55;
            color: var(--ink-soft);
        }

        .op-availability strong {
            color: var(--primary-dark);
        }

        /* === Expectations (section 8 bis) === */
        .expect-grid {
            margin-top: 22px;
            display: grid;
            gap: 18px;
        }

        @media (min-width: 640px) {
            .expect-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .expect-card {
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 24px;
            background: var(--surface);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .expect-tag {
            display: inline-block;
            margin-bottom: 12px;
            padding: 4px 11px;
            border-radius: 999px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.09em;
            text-transform: uppercase;
        }

        .expect-tag--value {
            background: var(--accent-soft);
            border-color: #bfdbfe;
            color: var(--primary-dark);
        }

        .expect-card h3 {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 10px;
        }

        .expect-card p {
            margin: 0;
            font-size: 0.98rem;
            line-height: 1.6;
            color: var(--ink-soft);
        }

        /* === Final CTA === */
        .closing {
            background:
                radial-gradient(ellipse 80% 70% at 50% 100%, rgba(59, 130, 246, 0.1) 0%, transparent 65%),
                linear-gradient(180deg, var(--bg) 0%, #eef4ff 100%);
            text-align: center;
        }

        .cta-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 30px;
            padding: 17px 42px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-family: inherit;
            font-size: 1.05rem;
            font-weight: 800;
            letter-spacing: 0.02em;
            text-decoration: none;
            cursor: pointer;
            box-shadow: 0 12px 30px rgba(37, 99, 235, 0.32);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 38px rgba(37, 99, 235, 0.42);
        }

        .closing .micro {
            margin-top: 16px;
            font-size: 0.9rem;
            color: var(--muted);
        }

        .cta-date {
            margin: 0 auto 4px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.92rem;
            font-weight: 700;
            color: var(--primary-dark);
        }

        .cta-date .dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: var(--primary);
            flex-shrink: 0;
        }

        /* === Top banner (première mission) === */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 11px 18px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-size: clamp(0.82rem, 2.4vw, 0.95rem);
            font-weight: 600;
            line-height: 1.35;
            text-align: center;
            box-shadow: 0 2px 14px rgba(37, 99, 235, 0.28);
        }

        .topbar strong {
            color: #fff;
            font-weight: 800;
        }

        .topbar .live-dot {
            width: 9px;
            height: 9px;
            border-radius: 999px;
            background: #fff;
            flex-shrink: 0;
            box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
            animation: topbarPulse 1.6s ease-in-out infinite;
        }

        @keyframes topbarPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.55); }
            50% { box-shadow: 0 0 0 7px rgba(255, 255, 255, 0); }
        }

        /* === Projection block (trajectoire de croissance) === */
        .projection {
            margin-top: 26px;
            border: 1px dashed var(--primary-light);
            border-radius: 18px;
            background: linear-gradient(165deg, #eff6ff, #ffffff);
            padding: clamp(22px, 3.5vw, 34px);
        }

        .projection-tag {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 14px;
            padding: 5px 13px;
            border-radius: 999px;
            background: rgba(37, 99, 235, 0.1);
            border: 1px solid rgba(37, 99, 235, 0.25);
            color: var(--primary-dark);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .projection-arc {
            display: flex;
            align-items: center;
            gap: clamp(10px, 3vw, 22px);
            margin: 4px 0 18px;
            flex-wrap: wrap;
        }

        .projection-now,
        .projection-goal {
            display: flex;
            flex-direction: column;
        }

        .projection-num {
            font-size: clamp(1.6rem, 6vw, 2.6rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            line-height: 1;
        }

        .projection-now .projection-num { color: var(--ink-soft); }
        .projection-goal .projection-num { color: var(--primary-dark); }

        .projection-sub {
            margin-top: 5px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--muted);
        }

        .projection-arrow {
            flex: 1;
            min-width: 40px;
            height: 3px;
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(37, 99, 235, 0.25), var(--primary));
            position: relative;
        }

        .projection-arrow::after {
            content: '';
            position: absolute;
            right: -2px;
            top: 50%;
            transform: translateY(-50%);
