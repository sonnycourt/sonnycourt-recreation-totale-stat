    <script is:inline>
    (function () {
        var EP='/.netlify/functions/closer-console';
        var OUTCOMES=['Pas de réponse','Répondeur','Numéro invalide','À rappeler','En réflexion','Dit oui (verbal)','Pas intéressé'];
        var CALLBACK_OUTCOMES=['À rappeler','Rappel demande'];
        var CHIPS=[{k:'all',t:'Tous'},{k:'A appeler',t:'A appeler'},{k:'A rappeler',t:'Rappels'},{k:'En reflexion',t:'En reflexion'},{k:'Dit oui (verbal)',t:'Dits oui'},{k:'achete',t:'Achats'},{k:'Refuse',t:'Refuses'},{k:'Injoignable',t:'Injoignables'}];
        var cc=document.getElementById('cc'), listEl=document.getElementById('cc-list'), chipsEl=document.getElementById('cc-chips');
        var sessionEl=document.getElementById('cc-session');
        var meEl=document.getElementById('cc-me');
        var DATA={}, LEADS=[], FILTER='all';

        // ===== Leads de test locaux : pour s'entraîner, aucune écriture réseau =====
        var TEST_OUTCOME_STATUS={'Pas de réponse':null,'Répondeur':null,'Numéro invalide':'Injoignable','À rappeler':'A rappeler','En réflexion':'En reflexion','Dit oui (verbal)':'Dit oui (verbal)','Pas intéressé':'Refuse','Pas de reponse':null,'Messagerie':null,'Joint':'En reflexion','Rappel demande':'A rappeler','A dit OUI':'Dit oui (verbal)','Refus':'Refuse','Faux numero':'Injoignable'};
        function testDerive(log){if(!Array.isArray(log)||!log.length)return{call_status:null,next_callback_at:null};var last=log[log.length-1];var st=TEST_OUTCOME_STATUS.hasOwnProperty(last.outcome)?TEST_OUTCOME_STATUS[last.outcome]:null;var cb=(CALLBACK_OUTCOMES.indexOf(last.outcome)!==-1&&last.callback)?last.callback:null;return{call_status:st,next_callback_at:cb};}
        function isTestLead(t){return typeof t==='string'&&t.indexOf('test-')===0;}
        var TEST_SEQ=0;
        function addTestLead(name,tel){
            TEST_SEQ++;
            var iso=new Date().toISOString();
            var lead={token:'test-'+Date.now()+'-'+TEST_SEQ,prenom:(name&&name.trim())||('Lead test '+TEST_SEQ),email:'test-local@exemple.com',telephone:(tel&&tel.trim())||'',pays:'France',watch_max_minutes:90,saw_offer:true,clicked_cta:true,purchased:false,purchased_at:null,session_date:iso,call_status:null,next_callback_at:null,call_notes:'',call_transcript:'',call_log:[],_test:true};
            ALL_LEADS.push(lead);
            SESSION_SEL=sDate(iso);   // bascule sur la session du lead de test pour qu'il soit visible
            FILTER='all';
            buildSessions();applySession();
        }
        var ALL_LEADS=[], SESSION_SEL='', SESSIONS=[];
        var dfDay=new Intl.DateTimeFormat('fr-FR',{day:'numeric',month:'short',year:'numeric'});
        function sDate(d){return d?String(d).slice(0,10):'';}
        function frDay(d){try{return dfDay.format(new Date(d+'T12:00:00'));}catch(e){return d;}}

        function esc(s){return (s==null?'':String(s)).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
        var PAYS_FLAGS={'France':'🇫🇷','Belgique':'🇧🇪','Suisse':'🇨🇭','Luxembourg':'🇱🇺','Monaco':'🇲🇨','Canada':'🇨🇦'};
        function paysFlag(p){return PAYS_FLAGS[(p||'').trim()]||'🌍';}
        function p2(n){return (n<10?'0':'')+n;}
        function fmt(iso){var d=new Date(iso);if(isNaN(d.getTime()))return '';return p2(d.getDate())+'/'+p2(d.getMonth()+1)+' '+p2(d.getHours())+':'+p2(d.getMinutes());}
        function nowLocal(){var d=new Date();return d.getFullYear()+'-'+p2(d.getMonth()+1)+'-'+p2(d.getDate())+'T'+p2(d.getHours())+':'+p2(d.getMinutes());}
        function plusH(h){var d=new Date(Date.now()+h*3600*1000);return d.getFullYear()+'-'+p2(d.getMonth()+1)+'-'+p2(d.getDate())+'T'+p2(d.getHours())+':'+p2(d.getMinutes());}
        function statusOf(l){return l.purchased?'Achete':(l.call_status||'A appeler');}
        function stCls(s){return {'A appeler':'st-app','A rappeler':'st-rap','En reflexion':'st-ref','Dit oui (verbal)':'st-oui','Injoignable':'st-inj','Refuse':'st-ref2','Achete':'st-ach'}[s]||'st-app';}
        function prio(l){if(l.purchased)return 100;var s=l.call_status||'A appeler';return {'A rappeler':1,'A appeler':2,'En reflexion':3,'Dit oui (verbal)':4,'Injoignable':8,'Refuse':9}[s]||2;}
        function stPill(s){return '<span class="st '+stCls(s)+'">'+esc(s)+'</span>';}
        function statusBadge(l){var s=statusOf(l);var cb=(s==='A rappeler'&&l.next_callback_at)?'<span class="cc-cbtag">&#128197; '+fmt(l.next_callback_at)+'</span>':'';return stPill(s)+cb;}
        function callsCell(log){if(!log||!log.length)return '<span class="cc-calls"><small>aucun appel</small></span>';var last=log[log.length-1];return '<span class="cc-calls">'+log.length+' appel'+(log.length>1?'s':'')+'<br><small>dernier '+fmt(last.at)+'</small></span>';}
        function histHtml(log){if(!log||!log.length)return '<div class="cc-hist-empty">Aucune tentative notee.</div>';return log.map(function(e,i){var rap=(CALLBACK_OUTCOMES.indexOf(e.outcome)!==-1&&e.callback)?' <span class="rap">&rarr; rappel '+fmt(e.callback)+'</span>':'';return '<div class="cc-h"><time>'+fmt(e.at)+'</time><em>'+esc(e.outcome||'—')+rap+'</em><button type="button" class="cc-hdel" data-idx="'+i+'" title="Supprimer">&times;</button></div>';}).reverse().join('');}
        function opts(arr,val){return '<option value="">&mdash;</option>'+arr.map(function(s){return '<option'+(val===s?' selected':'')+'>'+s+'</option>';}).join('');}

        function detailHtml(l){
            var m=l.watch_max_minutes||0;
            var ctaTxt=l.clicked_cta?' &middot; <b>a cliqué le CTA</b>':((l.saw_offer||m>=81)?' &middot; <b>a vu l\'offre</b>':'');
            return '<div class="cc-det-in">'+
              '<div class="cc-recap">'+
                '<span>&#9993; '+(l.email?'<a href="mailto:'+esc(l.email)+'">'+esc(l.email)+'</a>':'&mdash;')+'</span>'+
                '<span>'+paysFlag(l.pays)+' <b>'+esc(l.pays||'—')+'</b></span>'+
                '<span>&#9202; <b>'+m+' min</b>'+ctaTxt+'</span>'+
                '<span>'+(function(){var a=attribution(l);if(a==='valide')return '<b style="color:#15803d">Vente closer (à recréditer)</b>';if(a==='seul')return '<b style="color:#b45309">Acheté seul — non crédité</b>';return 'Pas encore acheteur';})()+'</span>'+
              '</div>'+
              '<div class="cc-curst">Statut actuel '+stPill(statusOf(l))+' <span style="color:#94a3b8">(determine par le dernier appel)</span></div>'+
              '<div class="cc-callbar"><button type="button" class="cc-callbtn cc-copytel" data-tel="'+esc(l.telephone||'')+'">&#128203; Copier le numéro '+esc(l.telephone||'')+'</button>'+
              '<button type="button" class="cc-lognew">+ Noter la tentative d\'appel</button></div>'+
              '<div class="cc-logform" hidden>'+
                '<div class="cc-logrow">'+
                  '<div class="cc-f"><label>Date / heure de l\'appel</label><input type="datetime-local" class="cc-in cc-at"></div>'+
                  '<div class="cc-f"><label>Resultat de l\'appel</label><select class="cc-sel cc-outcome">'+opts(OUTCOMES,'')+'</select></div>'+
                '</div>'+
                '<div class="cc-cbwrap" hidden><div class="cc-f"><label>&#128197; Rappeler le</label><input type="datetime-local" class="cc-in cc-cb"></div></div>'+
                '<div class="cc-logbtns"><button type="button" class="cc-logvalid">Valider la tentative</button><button type="button" class="cc-logcancel">Annuler</button></div>'+
              '</div>'+
              '<div class="cc-hist"><div class="cc-hist-t">Historique des appels</div>'+histHtml(l.call_log)+'</div>'+
              '<div class="cc-fields">'+
                '<div class="cc-f"><label>Notes</label><textarea class="cc-ta cc-notes" placeholder="Notes libres...">'+esc(l.call_notes||'')+'</textarea></div>'+
              '</div>'+
              '<div class="cc-saved"></div></div>';
        }
        function minutesCell(l){var m=l.watch_max_minutes||0;
            var cta=l.clicked_cta?'<span class="cc-cta cc-cta-hot">CTA cliqué</span>':((l.saw_offer||m>=81)?'<span class="cc-cta">a vu l\'offre</span>':'');
            return '<div class="cc-minw"><span class="cc-min'+(m>=81?' hot':'')+'">'+m+' min</span>'+cta+'</div>';}
        var REAL_CONTACT={'À rappeler':1,'En réflexion':1,'Dit oui (verbal)':1,'Pas intéressé':1,'Joint':1,'Rappel demande':1,'A dit OUI':1,'Refus':1};
        function contactBeforeBuy(l){var log=l.call_log;if(!Array.isArray(log))return false;var pa=l.purchased_at?new Date(l.purchased_at).getTime():null;for(var i=0;i<log.length;i++){var e=log[i];if(!e||!REAL_CONTACT[e.outcome]||!e.at)continue;var t=new Date(e.at).getTime();if(isNaN(t))continue;if(pa==null||t<pa)return true;}return false;}
        function attribution(l){if(!l.purchased)return null;return contactBeforeBuy(l)?'valide':'seul';}
        function boughtCell(l){var a=attribution(l);if(a==='valide')return '<span class="cc-buy yes">&#10003; Vente closer</span>';if(a==='seul')return '<span class="cc-buy seul">Acheté seul</span>';return '<span class="cc-buy no">Non</span>';}
        function rowHtml(l){return '<tr class="cc-r'+(attribution(l)==='valide'?' bought':'')+'" data-token="'+esc(l.token)+'">'+
              '<td><div class="cc-nm">'+esc(l.prenom||'Sans nom')+'</div>'+
                 '<div class="cc-sub">'+(l.email?'<a class="cc-mail" href="mailto:'+esc(l.email)+'" onclick="event.stopPropagation()">'+esc(l.email)+'</a>':'<span class="cc-noinfo">sans email</span>')+'</div>'+
                 '<div class="cc-sub2">'+paysFlag(l.pays)+' '+esc(l.pays||'—')+'</div></td>'+
              '<td><a class="cc-tel" href="tel:'+esc(l.telephone||'')+'" onclick="event.stopPropagation()">'+esc(l.telephone||'aucun')+'</a></td>'+
              '<td>'+minutesCell(l)+'</td>'+
              '<td class="cc-stcell">'+statusBadge(l)+'</td>'+
              '<td class="cc-callscell">'+callsCell(l.call_log)+'</td>'+
              '<td class="cc-buycell">'+boughtCell(l)+'</td>'+
              '<td style="text-align:right"><span class="cc-chev">&#9656;</span></td></tr>'+
              '<tr class="cc-det" data-detail="'+esc(l.token)+'" hidden><td colspan="7"></td></tr>';}

        function renderChips(){chipsEl.innerHTML=CHIPS.map(function(c){var n=(c.k==='all')?LEADS.length:(c.k==='achete'?LEADS.filter(function(l){return l.purchased;}).length:LEADS.filter(function(l){return !l.purchased&&(l.call_status||'A appeler')===c.k;}).length);return '<button class="cc-chip'+(FILTER===c.k?' on':'')+'" data-f="'+c.k+'">'+c.t+'<small>'+n+'</small></button>';}).join('');}
        function passF(l){if(FILTER==='all')return true;if(FILTER==='achete')return !!l.purchased;if(l.purchased)return false;return (l.call_status||'A appeler')===FILTER;}
        function renderList(){var arr=LEADS.filter(passF).slice().sort(function(a,b){var pa=prio(a),pb=prio(b);if(pa!==pb)return pa-pb;if(pa===1)return new Date(a.next_callback_at||0)-new Date(b.next_callback_at||0);return (b.watch_max_minutes||0)-(a.watch_max_minutes||0);});if(!arr.length){listEl.innerHTML='<div class="cc-empty">Aucun lead dans ce filtre.</div>';return;}listEl.innerHTML='<div class="cc-scroll"><table class="cc-tbl"><thead><tr><th>Lead</th><th>Telephone</th><th>Minutes vues</th><th>Statut</th><th>Appels</th><th>Acheteur</th><th></th></tr></thead><tbody>'+arr.map(rowHtml).join('')+'</tbody></table></div>';}
        function render(leads){ALL_LEADS=leads||[];buildSessions();applySession();}
        function buildSessions(){
            var counts={};
            ALL_LEADS.forEach(function(l){var d=sDate(l.session_date);if(d)counts[d]=(counts[d]||0)+1;});
            SESSIONS=Object.keys(counts).sort(function(a,b){return a<b?1:-1;});
            if(!SESSIONS.length){sessionEl.hidden=true;SESSION_SEL='';return;}
            sessionEl.hidden=false;
            if(!SESSION_SEL||SESSIONS.indexOf(SESSION_SEL)===-1)SESSION_SEL=SESSIONS[0];
            sessionEl.innerHTML=SESSIONS.map(function(d){return '<option value="'+d+'"'+(d===SESSION_SEL?' selected':'')+'>'+frDay(d)+' · '+counts[d]+' leads</option>';}).join('');
        }
        function applySession(){
            DATA={};
            LEADS=SESSION_SEL?ALL_LEADS.filter(function(l){return sDate(l.session_date)===SESSION_SEL;}):ALL_LEADS.slice();
            LEADS.forEach(function(l){DATA[l.token]=l;});
            renderChips();renderList();
        }
        sessionEl.addEventListener('change',function(){SESSION_SEL=this.value;applySession();});

        async function load(){try{var r=await fetch(EP,{credentials:'same-origin'});if(!r.ok){listEl.innerHTML='<div class="cc-empty">Connecte-toi pour voir tes leads.</div>';return;}var d=await r.json();renderMe(d.me||null);render(d.leads||[]);}catch(e){listEl.innerHTML='<div class="cc-empty">Erreur reseau.</div>';}}
        function meRow(label,val,kind){
            if(!val)return'';
            if(kind==='tel'){
                return'<div class="cc-me-row"><span class="cc-me-val">'+esc(val)+'</span></div>';
            }
            var sub=label?'<small>'+esc(label)+'</small>':'';
            return'<div class="cc-me-row"><span class="cc-me-val">'+sub+'<a href="'+esc(val)+'" target="_blank" rel="noopener noreferrer" style="color:#fff;text-decoration:none;">'+esc(val)+'</a></span>'+
                '<button type="button" class="cc-me-cp" data-copy="'+esc(val)+'">&#128203; Copier</button></div>';
        }
        function renderMe(me){
            if(!me){meEl.hidden=true;meEl.innerHTML='';return;}
            var tels=meRow('',me.phone_1,'tel')+meRow('',me.phone_2,'tel');
            var liens=meRow('Tarif complet (prospect)',me.checkout_full_url,'link')+meRow('Lien -5% (closing)',me.checkout_discount_url,'link');
            if(!tels&&!liens){meEl.hidden=true;meEl.innerHTML='';return;}
            meEl.innerHTML='<div class="cc-me-grid">'+
                '<div class="cc-me-block"><div class="cc-me-k">&#128222; Mes numéros</div>'+(tels||'<div class="cc-me-empty">Aucun numéro configuré.</div>')+'</div>'+
                '<div class="cc-me-block"><div class="cc-me-k">&#128279; Mes liens checkout</div>'+(liens||'<div class="cc-me-empty">Aucun lien configuré.</div>')+'</div>'+
            '</div>';
            meEl.hidden=false;
        }
        function saved(det,msg){var s=det.querySelector('.cc-saved');if(s){s.textContent=msg||'Enregistre';setTimeout(function(){s.textContent='';},1600);}}
        async function postJSON(p){if(isTestLead(p.token))return testRespond(p);return fetch(EP,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});}
        function testRespond(p){
            var l=DATA[p.token];
            if(l){
                if(p.action==='log'){if(!Array.isArray(l.call_log))l.call_log=[];var e={at:p.at||new Date().toISOString(),outcome:p.outcome};if(p.callback)e.callback=p.callback;l.call_log.push(e);}
                else if(p.action==='log-delete'){if(Array.isArray(l.call_log))l.call_log.splice(p.index,1);}
                else{if(typeof p.call_notes==='string')l.call_notes=p.call_notes;if(typeof p.call_transcript==='string')l.call_transcript=p.call_transcript;}
                var d=testDerive(l.call_log);l.call_status=d.call_status;l.next_callback_at=d.next_callback_at;
            }
            var body={ok:true,call_log:l?l.call_log:[],call_status:l?l.call_status:null,next_callback_at:l?l.next_callback_at:null};
            return Promise.resolve({ok:true,json:function(){return Promise.resolve(body);}});
        }
        function updateRow(token){var l=DATA[token];var row=listEl.querySelector('.cc-r[data-token="'+CSS.escape(token)+'"]');if(!row)return;row.querySelector('.cc-stcell').innerHTML=statusBadge(l);row.querySelector('.cc-callscell').innerHTML=callsCell(l.call_log);row.classList.toggle('bought',!!l.purchased);}
        function syncDetail(det,token){var l=DATA[token];det.querySelector('.cc-hist').innerHTML='<div class="cc-hist-t">Historique des appels</div>'+histHtml(l.call_log);var cs=det.querySelector('.cc-curst');if(cs)cs.innerHTML='Statut actuel '+stPill(statusOf(l))+' <span style="color:#94a3b8">(determine par le dernier appel)</span>';}

        chipsEl.addEventListener('click',function(e){var b=e.target.closest('.cc-chip');if(!b)return;FILTER=b.getAttribute('data-f');renderChips();renderList();});

        function ccFallbackCopy(text){var ta=document.createElement('textarea');ta.value=text;ta.style.position='fixed';ta.style.opacity='0';document.body.appendChild(ta);ta.select();try{document.execCommand('copy');}catch(e){}document.body.removeChild(ta);}
        function ccCopy(text,btn,doneLabel){var orig=btn.innerHTML;var ok=function(){btn.classList.add('copied');btn.innerHTML=doneLabel||'&#10003; Copié';setTimeout(function(){btn.classList.remove('copied');btn.innerHTML=orig;},1500);};try{if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(text).then(ok,function(){ccFallbackCopy(text);ok();});}else{ccFallbackCopy(text);ok();}}catch(_){ccFallbackCopy(text);ok();}}
        meEl.addEventListener('click',function(e){var b=e.target.closest('.cc-me-cp');if(!b)return;ccCopy(b.getAttribute('data-copy')||'',b);});
        listEl.addEventListener('click', async function(e){
            var det=e.target.closest('.cc-det');
            var copyBtn=e.target.closest('.cc-copytel');
            if(copyBtn){
                var tel=copyBtn.getAttribute('data-tel')||'';
                var orig=copyBtn.innerHTML;
                var ok=function(){copyBtn.classList.add('copied');copyBtn.innerHTML='&#10003; Numéro copié';setTimeout(function(){copyBtn.classList.remove('copied');copyBtn.innerHTML=orig;},1500);};
                try{ if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(tel).then(ok,function(){ccFallbackCopy(tel);ok();});}else{ccFallbackCopy(tel);ok();} }catch(_){ccFallbackCopy(tel);ok();}
                return;
            }
            if(e.target.closest('.cc-lognew')){det.querySelector('.cc-logform').hidden=false;det.querySelector('.cc-at').value=nowLocal();return;}
            if(e.target.closest('.cc-logcancel')){det.querySelector('.cc-logform').hidden=true;return;}
            if(e.target.closest('.cc-logvalid')){
                var token=det.getAttribute('data-detail');var btn=e.target.closest('.cc-logvalid');
                var at=det.querySelector('.cc-at').value, outcome=det.querySelector('.cc-outcome').value;
                if(!outcome){alert('Choisis le resultat de l\'appel.');return;}
                var payload={token:token,action:'log',outcome:outcome,at:at?new Date(at).toISOString():undefined};
                if(CALLBACK_OUTCOMES.indexOf(outcome)!==-1){var cbv=det.querySelector('.cc-cb').value;payload.callback=cbv?new Date(cbv).toISOString():undefined;}
                btn.disabled=true;btn.textContent='...';
                try{var r=await postJSON(payload);var d=await r.json();if(r.ok){var l=DATA[token];l.call_log=d.call_log;l.call_status=d.call_status;l.next_callback_at=d.next_callback_at;syncDetail(det,token);det.querySelector('.cc-logform').hidden=true;updateRow(token);renderChips();saved(det,'Tentative notee');}}catch(err){}
                btn.disabled=false;btn.textContent='Valider la tentative';return;
            }
            var del=e.target.closest('.cc-hdel');
            if(del){var token=det.getAttribute('data-detail');var idx=parseInt(del.getAttribute('data-idx'),10);try{var r=await postJSON({token:token,action:'log-delete',index:idx});var d=await r.json();if(r.ok){var l=DATA[token];l.call_log=d.call_log;l.call_status=d.call_status;l.next_callback_at=d.next_callback_at;syncDetail(det,token);updateRow(token);renderChips();saved(det,'Supprime');}}catch(e2){}return;}
            if(det)return;
            var row=e.target.closest('.cc-r');if(!row)return;var token=row.getAttribute('data-token');var dr=listEl.querySelector('.cc-det[data-detail="'+CSS.escape(token)+'"]');
            if(row.classList.contains('open')){row.classList.remove('open');dr.hidden=true;dr.querySelector('td').innerHTML='';}
            else{row.classList.add('open');dr.hidden=false;dr.querySelector('td').innerHTML=detailHtml(DATA[token]);}
        });

        listEl.addEventListener('change',function(e){if(e.target.classList.contains('cc-outcome')){var det=e.target.closest('.cc-det');var w=det.querySelector('.cc-cbwrap');var show=CALLBACK_OUTCOMES.indexOf(e.target.value)!==-1;w.hidden=!show;if(show&&!det.querySelector('.cc-cb').value)det.querySelector('.cc-cb').value=plusH(2);}});
        listEl.addEventListener('focusout',function(e){if(e.target.classList.contains('cc-notes'))autosave(e.target,{call_notes:e.target.value});});
        async function autosave(el,fields){var det=el.closest('.cc-det');if(!det)return;var token=det.getAttribute('data-detail');var l=DATA[token];if(fields.call_notes!==undefined)l.call_notes=fields.call_notes;if(fields.call_transcript!==undefined)l.call_transcript=fields.call_transcript;fields.token=token;try{var r=await postJSON(fields);if(r.ok)saved(det);}catch(e){}}

        document.getElementById('cc-refresh').addEventListener('click', load);
        var testAddBtn=document.getElementById('cc-testadd-btn');
        var testAddBox=document.getElementById('cc-testadd');
        function setTestAdd(open){testAddBox.hidden=!open;testAddBtn.classList.toggle('is-on',open);testAddBtn.innerHTML=open?'&#10005; Fermer':'&#43; Lead test';if(open)document.getElementById('cc-tl-name').focus();}
        testAddBtn.addEventListener('click',function(){setTestAdd(testAddBox.hidden);});
        document.getElementById('cc-testadd-close').addEventListener('click',function(){setTestAdd(false);});
        document.getElementById('cc-tl-add').addEventListener('click',function(){
            addTestLead(document.getElementById('cc-tl-name').value, document.getElementById('cc-tl-tel').value);
            document.getElementById('cc-tl-name').value='';
            document.getElementById('cc-tl-tel').value='';
        });
        window.initCloserConsole=function(){cc.hidden=false;load();};
    })();
    </script>

</body>
</html>
