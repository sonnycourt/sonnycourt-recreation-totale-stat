                (hasRdv(l)?'<span>&#128197; <b style="color:#6d28d9">RDV réservé par le lead : '+fmt(l.rdv_at)+'</b>'+((l.rdv_phone&&l.rdv_phone!==l.telephone)?' &middot; <b style="color:#6d28d9">appeler le '+esc(l.rdv_phone)+'</b>':'')+'</span>':'')+
                '<span>'+(function(){var a=attribution(l);if(a==='valide')return '<b style="color:#15803d">Vente closer (à recréditer)</b>';if(a==='seul')return '<b style="color:#b45309">Acheté seul — non crédité</b>';return 'Pas encore acheteur';})()+'</span>'+
