        function p2(n){return (n<10?'0':'')+n;}
        function fmt(iso){var d=new Date(iso);if(isNaN(d.getTime()))return '';return p2(d.getDate())+'/'+p2(d.getMonth()+1)+' '+p2(d.getHours())+':'+p2(d.getMinutes());}
        function nowLocal(){var d=new Date();return d.getFullYear()+'-'+p2(d.getMonth()+1)+'-'+p2(d.getDate())+'T'+p2(d.getHours())+':'+p2(d.getMinutes());}
        function plusH(h){var d=new Date(Date.now()+h*3600*1000);return d.getFullYear()+'-'+p2(d.getMonth()+1)+'-'+p2(d.getDate())+'T'+p2(d.getHours())+':'+p2(d.getMinutes());}
        function isUrl(s){return /^https?:\/\//i.test((s||'').trim());}
        function statusOf(l){return l.purchased?'Achete':(l.call_status||'A appeler');}
        function stCls(s){return {'A appeler':'st-app','A rappeler':'st-rap','En reflexion':'st-ref','Dit oui (verbal)':'st-oui','Injoignable':'st-inj','Refuse':'st-ref2','Achete':'st-ach'}[s]||'st-app';}
        function prio(l){if(l.purchased)return 100;var s=l.call_status||'A appeler';return {'A rappeler':1,'A appeler':2,'En reflexion':3,'Dit oui (verbal)':4,'Injoignable':8,'Refuse':9}[s]||2;}
        function stPill(s){return '<span class="st '+stCls(s)+'">'+esc(s)+'</span>';}
        function statusBadge(l){var s=statusOf(l);var cb=(s==='A rappeler'&&l.next_callback_at)?'<span class="cc-cbtag">&#128197; '+fmt(l.next_callback_at)+'</span>':'';return stPill(s)+cb;}
        function callsCell(log){if(!log||!log.length)return '<span class="cc-calls"><small>aucun appel</small></span>';var last=log[log.length-1];return '<span class="cc-calls">'+log.length+' appel'+(log.length>1?'s':'')+'<br><small>dernier '+fmt(last.at)+'</small></span>';}
        function histHtml(log){if(!log||!log.length)return '<div class="cc-hist-empty">Aucune tentative notee.</div>';return log.map(function(e,i){var rap=(e.outcome==='Rappel demande'&&e.callback)?' <span class="rap">&rarr; rappel '+fmt(e.callback)+'</span>':'';return '<div class="cc-h"><time>'+fmt(e.at)+'</time><em>'+esc(e.outcome||'—')+rap+'</em><button type="button" class="cc-hdel" data-idx="'+i+'" title="Supprimer">&times;</button></div>';}).reverse().join('');}
        function opts(arr,val){return '<option value="">&mdash;</option>'+arr.map(function(s){return '<option'+(val===s?' selected':'')+'>'+s+'</option>';}).join('');}

        function detailHtml(l){
            var rec=isUrl(l.call_transcript)?'<a class="cc-reclink" href="'+esc(l.call_transcript)+'" target="_blank" rel="noopener">Ouvrir &#8599;</a>':'';
            return '<div class="cc-det-in">'+
              '<div class="cc-curst">Statut actuel '+stPill(statusOf(l))+' <span style="color:#94a3b8">(determine par le dernier appel)</span></div>'+
              '<div class="cc-callbar"><a class="cc-callbtn" href="tel:'+esc(l.telephone||'')+'">&#128222; Appeler '+esc(l.telephone||'')+'</a>'+
              '<button type="button" class="cc-lognew">+ Noter la tentative d\'appel</button></div>'+
              '<div class="cc-logform" hidden>'+
                '<div class="cc-logrow">'+
                  '<div class="cc-f"><label>Date / heure de l\'appel</label><input type="datetime-local" class="cc-in cc-at"></div>'+
                  '<div class="cc-f"><label>Resultat de l\'appel</label><select class="cc-sel cc-outcome">'+opts(OUTCOMES,'')+'</select></div>'+
                '</div>'+
                '<div class="cc-cbwrap" hidden><div class="cc-f"><label>&#128197; Rappeler le</label><input type="datetime-local" class="cc-in cc-cb"></div></div>'+
                '<div class="cc-logbtns"><button type="button" class="cc-logvalid">Valider la tentative</button><button type="button" class="cc-logcancel">Annuler</button></div>'+
              '</div>'+
              '<div class="cc-hist"><div class="cc-hist-t">Historique des appels</div>'+histHtml(l.call_log)+'</div>'+
              '<div class="cc-fields">'+
                '<div class="cc-f"><label>Notes</label><textarea class="cc-ta cc-notes" placeholder="Notes libres...">'+esc(l.call_notes||'')+'</textarea></div>'+
                '<div class="cc-f"><label>Transcript ou lien enregistrement '+rec+'</label><textarea class="cc-ta cc-trans" placeholder="Transcript OU lien https:// audio/video...">'+esc(l.call_transcript||'')+'</textarea></div>'+
              '</div>'+
              '<div class="cc-saved"></div></div>';
        }
        function rowHtml(l){return '<tr class="cc-r'+(l.purchased?' bought':'')+'" data-token="'+esc(l.token)+'">'+
              '<td><div class="cc-nm">'+esc(l.prenom||'Sans nom')+'</div><div class="cc-sub">'+esc(l.pays||'')+' &middot; '+(l.watch_max_minutes||0)+' min vus</div></td>'+
              '<td><a class="cc-tel" href="tel:'+esc(l.telephone||'')+'" onclick="event.stopPropagation()">'+esc(l.telephone||'aucun')+'</a></td>'+
              '<td class="cc-stcell">'+statusBadge(l)+'</td>'+
              '<td class="cc-callscell">'+callsCell(l.call_log)+'</td>'+
              '<td style="text-align:right"><span class="cc-chev">&#9656;</span></td></tr>'+
              '<tr class="cc-det" data-detail="'+esc(l.token)+'" hidden><td colspan="5"></td></tr>';}

        function renderChips(){chipsEl.innerHTML=CHIPS.map(function(c){var n=(c.k==='all')?LEADS.length:(c.k==='achete'?LEADS.filter(function(l){return l.purchased;}).length:LEADS.filter(function(l){return !l.purchased&&(l.call_status||'A appeler')===c.k;}).length);return '<button class="cc-chip'+(FILTER===c.k?' on':'')+'" data-f="'+c.k+'">'+c.t+'<small>'+n+'</small></button>';}).join('');}
        function passF(l){if(FILTER==='all')return true;if(FILTER==='achete')return !!l.purchased;if(l.purchased)return false;return (l.call_status||'A appeler')===FILTER;}
        function renderList(){var arr=LEADS.filter(passF).slice().sort(function(a,b){var pa=prio(a),pb=prio(b);if(pa!==pb)return pa-pb;if(pa===1)return new Date(a.next_callback_at||0)-new Date(b.next_callback_at||0);return (b.watch_max_minutes||0)-(a.watch_max_minutes||0);});if(!arr.length){listEl.innerHTML='<div class="cc-empty">Aucun lead dans ce filtre.</div>';return;}listEl.innerHTML='<div class="cc-scroll"><table class="cc-tbl"><thead><tr><th>Lead</th><th>Telephone</th><th>Statut</th><th>Appels</th><th></th></tr></thead><tbody>'+arr.map(rowHtml).join('')+'</tbody></table></div>';}
        function render(leads){ALL_LEADS=leads||[];buildSessions();applySession();}
        function buildSessions(){
            var counts={};
            ALL_LEADS.forEach(function(l){var d=sDate(l.session_date);if(d)counts[d]=(counts[d]||0)+1;});
            SESSIONS=Object.keys(counts).sort(function(a,b){return a<b?1:-1;});
            if(!SESSIONS.length){sessionEl.hidden=true;SESSION_SEL='';return;}
            sessionEl.hidden=false;
            if(!SESSION_SEL||SESSIONS.indexOf(SESSION_SEL)===-1)SESSION_SEL=SESSIONS[0];
            sessionEl.innerHTML=SESSIONS.map(function(d){return '<option value="'+d+'"'+(d===SESSION_SEL?' selected':'')+'>'+frDay(d)+' · '+counts[d]+' leads</option>';}).join('');
        }
        function applySession(){
            DATA={};
            LEADS=SESSION_SEL?ALL_LEADS.filter(function(l){return sDate(l.session_date)===SESSION_SEL;}):ALL_LEADS.slice();
            LEADS.forEach(function(l){DATA[l.token]=l;});
            renderChips();renderList();
        }
        sessionEl.addEventListener('change',function(){SESSION_SEL=this.value;applySession();});

        async function load(){try{var r=await fetch(EP,{credentials:'same-origin'});if(!r.ok){listEl.innerHTML='<div class="cc-empty">Connecte-toi pour voir tes leads.</div>';return;}var d=await r.json();render(d.leads||[]);}catch(e){listEl.innerHTML='<div class="cc-empty">Erreur reseau.</div>';}}
        function saved(det,msg){var s=det.querySelector('.cc-saved');if(s){s.textContent=msg||'Enregistre';setTimeout(function(){s.textContent='';},1600);}}
        async function postJSON(p){return fetch(EP,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});}
        function updateRow(token){var l=DATA[token];var row=listEl.querySelector('.cc-r[data-token="'+CSS.escape(token)+'"]');if(!row)return;row.querySelector('.cc-stcell').innerHTML=statusBadge(l);row.querySelector('.cc-callscell').innerHTML=callsCell(l.call_log);row.classList.toggle('bought',!!l.purchased);}
        function syncDetail(det,token){var l=DATA[token];det.querySelector('.cc-hist').innerHTML='<div class="cc-hist-t">Historique des appels</div>'+histHtml(l.call_log);var cs=det.querySelector('.cc-curst');if(cs)cs.innerHTML='Statut actuel '+stPill(statusOf(l))+' <span style="color:#94a3b8">(determine par le dernier appel)</span>';}

        chipsEl.addEventListener('click',function(e){var b=e.target.closest('.cc-chip');if(!b)return;FILTER=b.getAttribute('data-f');renderChips();renderList();});

        listEl.addEventListener('click', async function(e){
            var det=e.target.closest('.cc-det');
            if(e.target.closest('.cc-lognew')){det.querySelector('.cc-logform').hidden=false;det.querySelector('.cc-at').value=nowLocal();return;}
            if(e.target.closest('.cc-logcancel')){det.querySelector('.cc-logform').hidden=true;return;}
            if(e.target.closest('.cc-logvalid')){
                var token=det.getAttribute('data-detail');var btn=e.target.closest('.cc-logvalid');
                var at=det.querySelector('.cc-at').value, outcome=det.querySelector('.cc-outcome').value;
                if(!outcome){alert('Choisis le resultat de l\'appel.');return;}
                var payload={token:token,action:'log',outcome:outcome,at:at?new Date(at).toISOString():undefined};
                if(outcome==='Rappel demande'){var cbv=det.querySelector('.cc-cb').value;payload.callback=cbv?new Date(cbv).toISOString():undefined;}
                btn.disabled=true;btn.textContent='...';
                try{var r=await postJSON(payload);var d=await r.json();if(r.ok){var l=DATA[token];l.call_log=d.call_log;l.call_status=d.call_status;l.next_callback_at=d.next_callback_at;syncDetail(det,token);det.querySelector('.cc-logform').hidden=true;updateRow(token);renderChips();saved(det,'Tentative notee');}}catch(err){}
                btn.disabled=false;btn.textContent='Valider la tentative';return;
            }
            var del=e.target.closest('.cc-hdel');
            if(del){var token=det.getAttribute('data-detail');var idx=parseInt(del.getAttribute('data-idx'),10);try{var r=await postJSON({token:token,action:'log-delete',index:idx});var d=await r.json();if(r.ok){var l=DATA[token];l.call_log=d.call_log;l.call_status=d.call_status;l.next_callback_at=d.next_callback_at;syncDetail(det,token);updateRow(token);renderChips();saved(det,'Supprime');}}catch(e2){}return;}
            if(det)return;
            var row=e.target.closest('.cc-r');if(!row)return;var token=row.getAttribute('data-token');var dr=listEl.querySelector('.cc-det[data-detail="'+CSS.escape(token)+'"]');
            if(row.classList.contains('open')){row.classList.remove('open');dr.hidden=true;dr.querySelector('td').innerHTML='';}
            else{row.classList.add('open');dr.hidden=false;dr.querySelector('td').innerHTML=detailHtml(DATA[token]);}
        });

        listEl.addEventListener('change',function(e){if(e.target.classList.contains('cc-outcome')){var det=e.target.closest('.cc-det');var w=det.querySelector('.cc-cbwrap');var show=e.target.value==='Rappel demande';w.hidden=!show;if(show&&!det.querySelector('.cc-cb').value)det.querySelector('.cc-cb').value=plusH(2);}});
        listEl.addEventListener('focusout',function(e){if(e.target.classList.contains('cc-notes'))autosave(e.target,{call_notes:e.target.value});if(e.target.classList.contains('cc-trans'))autosave(e.target,{call_transcript:e.target.value});});
        async function autosave(el,fields){var det=el.closest('.cc-det');if(!det)return;var token=det.getAttribute('data-detail');var l=DATA[token];if(fields.call_notes!==undefined)l.call_notes=fields.call_notes;if(fields.call_transcript!==undefined)l.call_transcript=fields.call_transcript;fields.token=token;try{var r=await postJSON(fields);if(r.ok)saved(det);}catch(e){}}

        document.getElementById('cc-refresh').addEventListener('click', load);
        window.initCloserConsole=function(){cc.hidden=false;load();};
    })();
    </script>

</body>
</html>
