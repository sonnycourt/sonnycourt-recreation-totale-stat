                var d=await r.json();
                DISPO_DAYS=d.days||[];
                if(d.deadline){document.getElementById('cc-dispo-deadline').innerHTML='Coche les créneaux où tu peux appeler, <b>avant vendredi '+fmt(d.deadline).replace(' ',' à ')+'</b>. Les leads les plus chauds réservent directement un RDV dedans : il apparaît ensuite dans ta liste de leads.';}
                dispoRender();
            }catch(e){dispoGrid.innerHTML='<div class="cc-empty">Erreur de chargement. Clique sur Rafraichir pour réessayer.</div>';}
        }
        window.__ccDispoPreview=function(days){DISPO_DAYS=days||[];dispoRender();};
        function dispoFind(start){for(var i=0;i<DISPO_DAYS.length;i++){var ss=DISPO_DAYS[i].slots||[];for(var j=0;j<ss.length;j++){if(ss[j].start===start)return ss[j];}}return null;}
        dispoGrid.addEventListener('click',async function(e){
            var b=e.target.closest('.cc-dslot');
            if(!b||b.classList.contains('booked'))return;
            var start=b.getAttribute('data-start');var s=dispoFind(start);if(!s)return;
            var wantOn=s.state!=='open';
            s.state=wantOn?'open':'off';dispoRender();
            try{
                var r=await fetch(DISPO_EP,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'},body:JSON.stringify({start:start,on:wantOn})});
                if(!r.ok){var d=await r.json().catch(function(){return{};});if(d&&d.state==='booked'){dispoLoad();return;}throw 0;}
            }catch(err){s.state=wantOn?'off':'open';dispoRender();}
        });
        function showDispo(){cc.classList.add('view-dispo');navDispo.classList.add('is-active');navConsole.classList.remove('is-active');if(!dispoLoaded){dispoLoaded=true;dispoLoad();}}
        function showLeads(){cc.classList.remove('view-dispo');navDispo.classList.remove('is-active');navConsole.classList.add('is-active');}
        navDispo.addEventListener('click',showDispo);
        navConsole.addEventListener('click',function(e){e.preventDefault();showLeads();});
        document.getElementById('cc-dispo-refresh').addEventListener('click',dispoLoad);

        // ---- Assistant IA (doc + downsell, contenu live côté serveur) ----
        var AI_EP='/.netlify/functions/closer-assistant';
        var aiPanel=document.getElementById('cc-ai');
        var aiMsgs=document.getElementById('cc-ai-msgs');
        var aiIn=document.getElementById('cc-ai-in');
        var aiSend=document.getElementById('cc-ai-send');
        var AI_HIST=[], aiBusy=false;
        function aiRender(role,text,extraCls){
            var d=document.createElement('div');
            d.className='cc-ai-m '+(role==='user'?'me':'bot')+(extraCls?' '+extraCls:'');
            d.innerHTML=esc(text).replace(/\*\*([^*\n]+)\*\*/g,'<b>$1</b>').replace(/\n/g,'<br>');
            aiMsgs.appendChild(d);aiMsgs.scrollTop=aiMsgs.scrollHeight;return d;
        }
        window.__ccAiPreview=aiRender;
        document.getElementById('cc-ai-fab').addEventListener('click',function(){
            var opening=aiPanel.hidden;aiPanel.hidden=!opening;if(opening)aiIn.focus();
        });
        document.getElementById('cc-ai-close').addEventListener('click',function(){aiPanel.hidden=true;});
        document.getElementById('cc-ai-form').addEventListener('submit',async function(e){
            e.preventDefault();
            if(aiBusy)return;
            var q=(aiIn.value||'').trim();
            if(!q)return;
            aiIn.value='';
            AI_HIST.push({role:'user',content:q});
            aiRender('user',q);
            var typing=aiRender('bot','•••','typing');
            aiBusy=true;aiSend.disabled=true;
            try{
                var r=await fetch(AI_EP,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'},body:JSON.stringify({messages:AI_HIST})});
                var d=await r.json().catch(function(){return{};});
                typing.remove();
                if(r.ok&&d.reply){AI_HIST.push({role:'assistant',content:d.reply});aiRender('bot',d.reply);}
                else{aiRender('bot','⚠ '+((d&&d.error)||'Erreur, réessaie.'),'err');}
            }catch(err){typing.remove();aiRender('bot','⚠ Erreur réseau, réessaie.','err');}
            aiBusy=false;aiSend.disabled=false;aiIn.focus();
        });

        window.initCloserConsole=function(){
            cc.hidden=false;load();
            // 1ère visite sur cet appareil -> ouvre la vidéo automatiquement
            try{if(!localStorage.getItem('cc_welcome_seen')){localStorage.setItem('cc_welcome_seen','1');openWelcome();}}catch(e){}
        };
    })();
    </script>

</body>
</html>
