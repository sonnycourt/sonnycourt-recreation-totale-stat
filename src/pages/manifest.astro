---
import BlackFridayBanner from '../components/BlackFridayBanner.astro';
import GAConsentMode from '../components/GAConsentMode.astro';
import PromoBanner from '../components/PromoBanner.astro';
import { promo } from '../config/promo';
---

<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MANIFEST - Transforme ta réalité en 3 mois</title>
    <meta name="description" content="Formation Manifestation : Découvre comment manifester tes souhaits les plus profonds grâce à la puissance de ton subconscient.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="MANIFEST - Transforme ta réalité en 3 mois" />
    <meta property="og:description" content="Formation Manifestation : Découvre comment manifester tes souhaits les plus profonds grâce à la puissance de ton subconscient." />
    <meta property="og:image" content={new URL("/media/pages/sonnycourt_share.webp", Astro.url)} />
    <meta property="og:url" content={Astro.url.href} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="MANIFEST - Transforme ta réalité en 3 mois" />
    <meta name="twitter:description" content="Formation Manifestation : Découvre comment manifester tes souhaits les plus profonds grâce à la puissance de ton subconscient." />
    <meta name="twitter:image" content={new URL("/media/pages/sonnycourt_share.webp", Astro.url)} />
    
    <!-- GA4 Consent Mode v2 -->
    <GAConsentMode />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;700;900&display=swap" rel="stylesheet">

    <!-- Start of Async ProveSource Code -->
    <script>!function(o,i){window.provesrc&&window.console&&console.error&&console.error("ProveSource is included twice in this page."),window.provesrc={dq:[],display:function(){this.dq.push(arguments)}},o._provesrcAsyncInit=function(){window.provesrc.init({apiKey:"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2NvdW50SWQiOiI1ZWIxNDZlZWI2MTA2YzIxNzYzNDFiM2YiLCJpYXQiOjE1ODg2NzYzMzR9.qpFyCznmnc15rh4QVR5ziDpOwO_TnrsIr5Yc4-KXxRc",v:"0.0.4"})};var r=i.createElement("script");r.type="text/javascript",r.async=!0,r["ch"+"ar"+"set"]="UTF-8",r.src="https://cdn.provesrc.com/provesrc.js";var e=i.getElementsByTagName("script")[0];e.parentNode.insertBefore(r,e)}(window,document);</script>
    <!-- End of Async ProveSource Code -->

    <!-- Spiffy Checkout Integration -->
    <script>
    "use strict";!function(i,t){var f=t.spiffy=t.spiffy||[];if(!f.init){
    if(f.invoked)return void(t.console&&console.error&&console.warn("Spiffy Elements included twice."))
    ;f.invoked=!0,f.methods=["identify","config","debug","off","on"],f.factory=function(i){
    return function(){var t=Array.prototype.slice.call(arguments);return t.unshift(i),f.push(t),f}},
    f.methods.forEach(function(i){spiffy[i]=f.factory(i)}),f.load=function(t,f){if(!spiffy.ACCOUNT){
    spiffy.ACCOUNT=t,spiffy.DOMAIN=f;var e=i.createElement("script");e.type="text/javascript",
    e.async=!0,e.crossorigin="anonymous",e.src="https://js.static.spiffy.co/spiffy.js?a="+t
    ;var n=i.getElementsByTagName("script")[0];n.parentNode.insertBefore(e,n)}}}}(document,window),
    spiffy.SNIPPET_VERSION="1.1.0";
    spiffy.config({
        hideSidebar: false,
    })
    spiffy.load("sonnycourt");
    </script>
    <!-- End Spiffy Integration -->
</head>
<body>
    <PromoBanner />
    <div id="promo-config" data-deadline={promo.deadline} data-badge={promo.badgeText} data-active={promo.active.toString()} style="display:none;"></div>
    {/* BlackFriday Banner désactivé - Réactiver l'année prochaine en changeant show={false} en show={true} */}
    <BlackFridayBanner show={false} discount={70} />
    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-badge">FORMATION NIVEAU 2</div>
                <p class="hero-subtitle">⚡ PLUS DE <span id="counter-number">2000</span> PERSONNES ONT DÉJÀ TRANSFORMÉ LEUR VIE</p>
                <h1 class="hero-title">MANIFEST</h1>
                <p class="hero-description">3 mois pour Manifester la Richesse, l'Amour et la Liberté</p>

                <div class="hero-cover-container">
                    <div class="premium-frame">
                        <div class="frame-border"></div>
                        <div class="glare-effect"></div>
                        <img src="https://i1.wp.com/sonnycourt.com/wp-content/uploads/2025/07/Sonny-Court-Manifest-Formation.webp"
                             alt="Formation MANIFEST - Sonny Court"
                             class="hero-cover-image">
                        <div class="subtle-overlay"></div>
                    </div>
                </div>

                <p class="hero-tagline">Découvre les techniques de manifestation oubliées pour transformer tes rêves en réalité</p>

                <a href="https://sonnycourt.spiffy.co/checkout/manifest#pop" class="cta-button-final">Commencer la formation</a>
                <p class="hero-guarantee">✓ Garantie satisfaction 30 jours</p>
            </div>
        </div>
    </section>

    <!-- Scarcity Section -->
    <section class="scarcity-section">
        <div class="container">
            <h2 class="guarantee-title scarcity-title"><span class="scarcity-emoji">🚨</span> <span class="scarcity-text">DERNIÈRES PLACES DISPONIBLES !</span></h2>
            <div class="scarcity-container">
                <!-- URGENT Places Counter -->
                <div class="urgent-counter" id="urgent-counter">
                    <div class="scarcity-badge" id="scarcityBadge">
                        <span class="badge-icon"></span>
                        <span class="badge-text">OFFRE -50%</span>
                    </div>
                    <div class="counter-header">
                        <div class="urgency-text">PLACES DISPONIBLES</div>
                    </div>

                    <div class="counter-display">
                        <div class="counter-number">
                            <span id="current-places">27</span>
                            <span class="counter-slash">/</span>
                            <span class="counter-total">100</span>
                        </div>
                        <div class="counter-label">RESTANTES</div>
                    </div>

                    <div class="urgency-meter">
                        <div class="meter-container">
                            <div class="meter-fill" id="meter-fill"></div>
                        </div>
                    </div>

                    <div class="warning-message" id="warning-message">
                        <div class="warning-text">
                            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-triangle-alert-icon lucide-triangle-alert" style="color: #ef4444; flex-shrink: 0;"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                                <span style="color: #ef4444;">Ce compteur est réel. Une fois les 100 places réservées, cette offre ne sera plus accessible.</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CTA Section - Clear Action -->
                <div class="cta-section">
                    <a href="https://sonnycourt.spiffy.co/checkout/manifest#pop"
                       class="cta-button-final scarcity-cta-button"
                       id="scarcity-cta-link">
                        <span id="cta-text">🔥 RÉSERVER MA PLACE AVANT QU'IL NE SOIT TROP TARD</span>
                        <span class="cta-arrow" id="cta-arrow">→</span>
                    </a>

                </div>

                    <!-- Sold Out State - Very Clear -->
                    <div class="sold-out-state" id="sold-out-state" style="display: none;">
                        <div class="sold-out-content">
                            <div class="sold-out-title">COMPLET !</div>
                            <div class="sold-out-description">
                                Toutes les places ont été réservées.<br>
                                Revenez demain à 9h pour de nouvelles places !
                            </div>
                        </div>
                    </div>
            </div>

                <!-- Background Elements -->
                <div class="scarcity-bg-elements">
                    <div class="bg-element bg-element-1"></div>
                    <div class="bg-element bg-element-2"></div>
                    <div class="bg-element bg-element-3"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <div class="container">
            <div class="feature-card fade-in">
                <span class="feature-number">01</span>
                <div class="feature-content">
                    <h3><span>Élimine tes pensées limitantes</span> rapidement</h3>
                    <p>Imagine-toi enfin libéré des doutes qui te bloquent depuis des années...</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/manifest pv media/Manifest-etape-1.webp" alt="Étape 1 - Contrôle mental">
                </div>
            </div>

            <div class="feature-card fade-in">
                <span class="feature-number">02</span>
                <div class="feature-content">
                    <h3><span>12 exercices mentaux guidés</span> qui reprogramment ton subconscient</h3>
                    <p>Écoute 10 minutes par jour et vois tes désirs devenir réalité...</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/manifest pv media/Manifest-etape-2.webp" alt="Étape 2 - Méditation guidée">
                </div>
            </div>

            <div class="feature-card fade-in">
                <span class="feature-number">03</span>
                <div class="feature-content">
                    <h3><span>Manifeste tes premiers résultats</span> en 30 jours maximum</h3>
                    <p>Deviens le créateur conscient de ta nouvelle réalité d'abondance...</p>
                </div>
                <div class="feature-image">
                    <img src="/media/pages/manifest pv media/Manifest-etape-3.webp" alt="Étape 3 - Transformation personnelle">
                </div>
            </div>
        </div>
    </section>

    <!-- Wisdom Section - Premium Design -->
    <section class="wisdom-section">
        <!-- Particules mystiques d'arrière-plan -->
        <div class="wisdom-particles">
            <div class="wisdom-particle particle-1"></div>
            <div class="wisdom-particle particle-2"></div>
            <div class="wisdom-particle particle-3"></div>
            <div class="wisdom-particle particle-4"></div>
        </div>

        <div class="container">
            <!-- Header élégant -->
            <div class="wisdom-header">
                <h2 class="guarantee-title">Pourquoi Ces Grands Maîtres Croient en Toi</h2>
                <p class="wisdom-subtitle">Les mêmes principes que tu vas maîtriser dans MANIFEST</p>
            </div>

            <!-- Citations en layout premium -->
            <div class="wisdom-gallery">
                <!-- Citation 1 - Bob Proctor -->
                <div class="wisdom-card fade-in">
                    <div class="wisdom-card-inner">
                        <div class="wisdom-quote-wrapper">
                            <blockquote class="wisdom-quote">
                                <p class="wisdom-quote-text">Si tu peux voir quelque chose dans ton esprit, tu peux le tenir dans ta main.</p>
                            </blockquote>
                        </div>

                        <div class="wisdom-author">
                            <div class="wisdom-author-image">
                                <img src="/media/pages/manifest pv media/sonnycourt_photo_profil_of_bob_proctor_b2df4414-3b29-4bc5-b478-865d81027ae9-modified-1.webp" alt="Bob Proctor">
                                <div class="wisdom-author-glow"></div>
                            </div>
                            <div class="wisdom-author-info">
                                <h4 class="wisdom-author-name">Bob Proctor</h4>
                                <p class="wisdom-author-title">Auteur & Conférencier</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Citation 2 - Bouddha -->
                <div class="wisdom-card fade-in">
                    <div class="wisdom-card-inner">
                        <div class="wisdom-quote-wrapper">
                            <blockquote class="wisdom-quote">
                                <p class="wisdom-quote-text">Ce que nous sommes aujourd'hui vient de nos pensées d'hier, et nos pensées actuelles bâtissent notre vie de demain.</p>
                            </blockquote>
                        </div>

                        <div class="wisdom-author">
                            <div class="wisdom-author-image">
                                <img src="/media/pages/manifest pv media/sonnycourt_photo_profil_of_buddha_statue_gold_from_front_a8d5d62b-63e8-4272-9c51-1a1c4a04eae8-modified-1.webp" alt="Bouddha">
                                <div class="wisdom-author-glow"></div>
                            </div>
                            <div class="wisdom-author-info">
                                <h4 class="wisdom-author-name">Bouddha</h4>
                                <p class="wisdom-author-title">Éveillé Spirituel</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Citation 3 - Carl Jung -->
                <div class="wisdom-card fade-in">
                    <div class="wisdom-card-inner">
                        <div class="wisdom-quote-wrapper">
                            <blockquote class="wisdom-quote">
                                <p class="wisdom-quote-text">Celui qui regarde à l'extérieur rêve ; celui qui regarde à l'intérieur s'éveille.</p>
                            </blockquote>
                        </div>

                        <div class="wisdom-author">
                            <div class="wisdom-author-image">
                                <img src="/media/pages/manifest pv media/sonnycourt_photo_profil_of_carl_jung_realistic_confident_eyes_0ca5c982-e78d-459e-a0ba-668fa0280409-modified-1.webp" alt="Carl Jung">
                                <div class="wisdom-author-glow"></div>
                            </div>
                            <div class="wisdom-author-info">
                                <h4 class="wisdom-author-name">Carl Jung</h4>
                                <p class="wisdom-author-title">Psychanalyste</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Citation 4 - William James -->
                <div class="wisdom-card fade-in">
                    <div class="wisdom-card-inner">
                        <div class="wisdom-quote-wrapper">
                            <blockquote class="wisdom-quote">
                                <p class="wisdom-quote-text">La plus grande révolution de notre génération est la découverte que les êtres humains peuvent changer leur vie en changeant leur esprit.</p>
                            </blockquote>
                        </div>

                        <div class="wisdom-author">
                            <div class="wisdom-author-image">
                                <img src="/media/pages/manifest pv media/grewtrehgrew-modified-1.webp" alt="William James">
                                <div class="wisdom-author-glow"></div>
                            </div>
                            <div class="wisdom-author-info">
                                <h4 class="wisdom-author-name">William James</h4>
                                <p class="wisdom-author-title">Philosophe & Psychologue</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Citation 5 - Wayne Dyer -->
                <div class="wisdom-card fade-in">
                    <div class="wisdom-card-inner">
                        <div class="wisdom-quote-wrapper">
                            <blockquote class="wisdom-quote">
                                <p class="wisdom-quote-text">Lorsque tu changes la façon dont tu regardes les choses, les choses que tu regardes changent.</p>
                            </blockquote>
                        </div>

                        <div class="wisdom-author">
                            <div class="wisdom-author-image">
                                <img src="/media/pages/manifest pv media/sonnycourt_photo_profil_of_Wayne_Dyer_happy_facial_expression_b_a2ba65c1-a032-4984-8cda-32d5147a807d-modified-1.webp" alt="Wayne Dyer">
                                <div class="wisdom-author-glow"></div>
                            </div>
                            <div class="wisdom-author-info">
                                <h4 class="wisdom-author-name">Wayne Dyer</h4>
                                <p class="wisdom-author-title">Auteur & Motivational Speaker</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Citation 6 - Aristote -->
                <div class="wisdom-card fade-in">
                    <div class="wisdom-card-inner">
                        <div class="wisdom-quote-wrapper">
                            <blockquote class="wisdom-quote">
                                <p class="wisdom-quote-text">Ceux qui ne peuvent pas changer leur esprit ne peuvent rien changer.</p>
                            </blockquote>
                        </div>

                        <div class="wisdom-author">
                            <div class="wisdom-author-image">
                                <img src="/media/pages/manifest pv media/1-modified-2-1.webp" alt="Aristote">
                                <div class="wisdom-author-glow"></div>
                            </div>
                            <div class="wisdom-author-info">
                                <h4 class="wisdom-author-name">Aristote</h4>
                                <p class="wisdom-author-title">Philosophe Antique</p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Call to reflection -->
            <div class="wisdom-reflection">
                <div class="reflection-content">
                    <h3 class="reflection-title">Ces citations prouvent que toute transformation commence par un changement intérieur</h3>
                    <p class="reflection-text">Ces grands visionnaires ont tous utilisé les mêmes lois universelles que tu vas découvrir dans la formation MANIFEST. Leur succès n'était pas un hasard... c'était une méthode.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Story Section -->
    <section class="story-section">
        <div class="container">
            <div class="story-content">
                <h2 class="guarantee-title">C'est lorsqu'on pense avoir tout compris qu'on se rend compte qu'on a peut être tout faux...</h2>

                <!-- Phase 1: Le problème -->
                <div class="story-phase">
                    <h3 class="story-subtitle">🔍 <span class="emoji-text">La quête désespérée</span></h3>
                    <div class="story-highlight">
                        <p>Comme toi, j'ai passé des années à chercher les vraies réponses...</p>
                    </div>
                    <p class="story-text">
                        J'étais expert en loi d'attraction, j'avais lu tous les livres, testé toutes les méthodes... mais je stagnais. Je sentais qu'il y avait quelque chose de plus profond, mais je ne savais pas quoi.
                    </p>
                </div>

                <!-- Phase 2: La découverte -->
                <div class="story-phase">
                    <h3 class="story-subtitle">💡 <span class="emoji-text">La découverte révolutionnaire</span></h3>
                    <p class="story-text">
                        C'est alors que j'ai découvert d'anciennes pratiques et substances utilisées depuis des millénaires par certaines cultures pour explorer les profondeurs de la conscience. Ça m'a ouvert des portes de perception que je n'aurais jamais imaginées. J'ai vu la loi d'attraction sous un angle complètement nouveau.
                    </p>
                </div>

                <!-- Phase 3: L'illumination -->
                <div class="story-phase">
                    <h3 class="story-subtitle">✨ <span class="emoji-text">L'illumination</span></h3>
                    <p class="story-text">
                        Chacune de ces expériences m'apportait des compréhensions concrètes impossibles à trouver dans les livres. J'ai découvert de nouvelles dimensions de la loi d'attraction que personne n'avait jamais formulées.
                    </p>
                    <div class="story-highlight">
                        <p>J'étais convaincu qu'il était possible d'atteindre ces états de conscience naturellement.</p>
                    </div>
                </div>

                <!-- Phase 4: La réalisation -->
                <div class="story-phase">
                    <h3 class="story-subtitle">🎯 <span class="emoji-text">La réalisation cruciale</span></h3>
                    <p class="story-text">
                        Après le succès de ma première formation "Esprit Subconscient", j'ai réalisé qu'il manquait quelque chose d'essentiel : un système pratique pour appliquer concrètement ces connaissances chaque jour.
                    </p>
                </div>

                <!-- Phase 5: La naissance de MANIFEST -->
                <div class="story-phase">
                    <h3 class="story-subtitle">🚀 <span class="emoji-text">La naissance de MANIFEST</span></h3>
                    <div class="story-highlight">
                        <p>Comme l'a dit Goethe : « Savoir n'est pas suffisant, nous devons appliquer. »</p>
                    </div>
                    <p class="story-text">
                        C'est ainsi qu'est née <strong>MANIFEST</strong> : un camp d'entraînement de 90 jours où la théorie rencontre la pratique concrète.
                    </p>

                    <div class="story-features">
                        <p><strong>Chaque leçon = 2 parties :</strong></p>
                        <p>• <strong>Théorie</strong> : Déclics transformateurs</p>
                        <p>• <strong>Pratique</strong> : Exercice mental guidé étape par étape</p>
                    </div>

                    <div class="story-highlight">
                        <p>Tu mérites de tirer le meilleur de toi-même et de ce que la vie a à t'offrir.</p>
                    </div>
                </div>

                <!-- Phase 6: Les résultats prouvés -->
                <div class="story-phase">
                    <h3 class="story-subtitle">📈 <span class="emoji-text">Les résultats parlent d'eux-mêmes</span></h3>

                    <div class="testimonial-highlight">
                        <p><strong>Malika :</strong> 90 jours → Quitte son emploi et reçoit un financement inespéré pour développer son entreprise</p>
                    </div>

                    <div class="testimonial-highlight">
                        <p><strong>Leticia :</strong> 66 jours → Atteint le plus haut chiffre d'affaires avec son entreprise et lie des liens avec de nouveaux partenaires</p>
                    </div>

                    <div class="testimonial-highlight">
                        <p><strong>Mon frère Ludovic :</strong> 21 jours → Après 3 ans de célibat → nouvelle relation amoureuse</p>
                    </div>

                    <div class="testimonial-highlight">
                        <p><strong>Mon amie :</strong> 1 jour → Se sentait invisible → "plus de compliments qu'en 6 mois"</p>
                    </div>

                    <div class="story-highlight">
                        <p><strong>Et ce n'est qu'une infime partie des retours incroyables que nous avons reçus.</strong></p>
                        <p><strong>Continue à lire pour en savoir plus...</strong></p>
                    </div>
                </div>

                <!-- Phase 7: L'appel à l'action -->
                <div class="story-phase">
                    <h3 class="story-subtitle">⚡ <span class="emoji-text">C'est à ton tour maintenant</span></h3>
                    <div class="story-highlight">
                        <p>Cette formation n'améliore pas seulement ton charisme ; elle a le pouvoir de résoudre n'importe lequel de tes problèmes.</p>
                    </div>

                    <div class="story-highlight">
                        <p>La question n'est pas "si ça marche", mais "quand vas-tu enfin décider de changer ta vie ?"</p>
                    </div>

                    <p class="story-text">
                        Cette formation n'attend que toi. Chaque jour que tu attends, c'est une opportunité qui passe... Je sais exactement ce que ça fait de regretter de ne pas avoir agi plus tôt.
                    </p>

                    <div class="story-highlight">
                        <p>Ton avenir commence MAINTENANT.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Reviews Section -->
    <section class="reviews-section">
        <div class="container">
            <div class="reviews-header">
                <h2 class="guarantee-title">Ce que disent nos membres</h2>
                <p class="reviews-subtitle">Des transformations réelles, des vies changées</p>
            </div>


            <div class="reviews-widget">
                <!-- Elfsight Testimonials Slider | MANIFEST (sur Manifest + Pack Transformation) -->
                <script src="https://elfsightcdn.com/platform.js" async></script>
                <div class="elfsight-app-2af569cb-eeca-4673-b866-0f34bc463e6e" data-elfsight-app-lazy></div>
            </div>
        </div>
    </section>

