                    console.log('❌ Pas l\'heure nocturne');
                }
                if (lastNightReset === today) {
                    console.log('❌ Reset nocturne déjà fait aujourd\'hui');
                }
            }

            console.log('📊 État final :');
            console.log(`   Places: ${scarcitySystem.currentSeats}/5`);
            console.log(`   Boutons: ${scarcitySystem.currentSeats === 0 ? 'DÉSACTIVÉS' : 'ACTIVÉS'}`);
            console.log(`   Design: IDENTIQUE à l'état normal`);
            console.log(`   Couleurs: mêmes dégradés bleus`);
            console.log(`   Tous les boutons: "COMPLET - REVIENS DEMAIN"`);
            console.log(`   Message urgence: "MINCE ! Tu arrives trop TARD -->"`);
            console.log(`   Logique: STABLE basée sur l'heure actuelle`);
            console.log(`   Zéro: garanti de 23h à 6h`);

            console.log('🎨 === FIN TEST - SYSTÈME STABLE ===');
        };

        // Animation du compteur de personnes
        function animateCounter() {
            const counterElement = document.getElementById('counter-number');
            if (!counterElement) return;

            const targetNumber = 2847;
            const duration = 3000; // 3 secondes
            const startTime = performance.now();
            const startNumber = 2000;

            function updateCounter(currentTime) {
                const elapsedTime = currentTime - startTime;
                const progress = Math.min(elapsedTime / duration, 1);

                // Fonction d'easing pour un effet plus naturel
                const easeOutCubic = 1 - Math.pow(1 - progress, 3);
                const currentNumber = Math.floor(startNumber + (targetNumber - startNumber) * easeOutCubic);

                counterElement.textContent = currentNumber.toLocaleString();

                if (progress < 1) {
                    requestAnimationFrame(updateCounter);
                }
            }

            // Délai de 1 seconde avant de commencer l'animation
            setTimeout(() => {
                requestAnimationFrame(updateCounter);
            }, 1000);
        }

        // Lancer l'animation au chargement de la page
        animateCounter();

        // Timer compte à rebours jusqu'à minuit
        function startCountdownTimer() {
            const timerElement = document.getElementById('countdown-timer');

            function updateTimer() {
                // Vérifier s'il y a encore des places disponibles
                const currentPlaces = document.getElementById('current-places');
                const placesCount = currentPlaces ? parseInt(currentPlaces.textContent) || 0 : 0;

                // Si plus de places, afficher un message différent
                if (placesCount === 0) {
                    timerElement.textContent = 'REVENU DEMAIN';
                    timerElement.style.color = '#666';
                    timerElement.style.animation = 'none';
                    return;
                }

                const now = new Date();
                const midnight = new Date(now);
                midnight.setHours(24, 0, 0, 0); // Minuit

                const timeLeft = midnight - now;

                if (timeLeft <= 0) {
                    timerElement.textContent = '00:00:00';
                    return;
                }

                const hours = Math.floor(timeLeft / (1000 * 60 * 60));
                const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((timeLeft % (1000 * 60)) / 1000);

                const formattedTime = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                timerElement.textContent = formattedTime;

                // Restaurer le style normal si on revient à des places disponibles
                timerElement.style.color = '';
                timerElement.style.animation = '';
            }

            // Mettre à jour immédiatement
            updateTimer();

            // Mettre à jour chaque seconde
            setInterval(updateTimer, 1000);
        }

        // Lancer le timer au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            startCountdownTimer();
        });
    </script>

    <!-- Script pour le lecteur vidéo personnalisé -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const video = document.getElementById('manifestMainVideo');
            const playPauseBtn = document.getElementById('playPauseBtn');
            const playButton = document.getElementById('playButton');
            const playOverlay = document.getElementById('playOverlay');
            const progressBar = document.getElementById('progressBar');
            const progressFilled = document.getElementById('progressFilled');
            const currentTimeEl = document.getElementById('currentTime');
            const durationEl = document.getElementById('duration');
            const fullscreenBtn = document.getElementById('fullscreenBtn');
            const videoControls = document.getElementById('videoControls');
            const videoWrapper = document.querySelector('.video-wrapper');

            if (!video) return;

            // Format time
            function formatTime(seconds) {
                const m = Math.floor(seconds / 60);
                const s = Math.floor(seconds % 60);
                return `${m}:${String(s).padStart(2, '0')}`;
            }

            // Update duration
            video.addEventListener('loadedmetadata', () => {
                durationEl.textContent = formatTime(video.duration);
            });

            // Update progress
            video.addEventListener('timeupdate', () => {
                const percent = (video.currentTime / video.duration) * 100;
                progressFilled.style.width = percent + '%';
                currentTimeEl.textContent = formatTime(video.currentTime);
            });

            // Play/Pause
            function togglePlay() {
                if (video.paused) {
                    video.play();
                    playOverlay.classList.add('hidden');
                    playPauseBtn.querySelector('.play-icon').style.display = 'none';
                    playPauseBtn.querySelector('.pause-icon').style.display = 'block';
                } else {
                    video.pause();
                    playOverlay.classList.remove('hidden');
                    playPauseBtn.querySelector('.play-icon').style.display = 'block';
                    playPauseBtn.querySelector('.pause-icon').style.display = 'none';
                }
            }

            playButton?.addEventListener('click', togglePlay);
            playPauseBtn?.addEventListener('click', togglePlay);
            video?.addEventListener('click', togglePlay);

            // Progress bar click
            progressBar?.addEventListener('click', (e) => {
                const rect = progressBar.getBoundingClientRect();
                const percent = (e.clientX - rect.left) / rect.width;
                video.currentTime = percent * video.duration;
            });

            // Fullscreen
            fullscreenBtn?.addEventListener('click', () => {
                if (document.fullscreenElement) {
                    document.exitFullscreen();
                } else {
                    videoWrapper?.requestFullscreen();
                }
            });

            // Show/hide controls on hover
            let controlsTimeout;
            videoWrapper?.addEventListener('mouseenter', () => {
                clearTimeout(controlsTimeout);
                videoControls?.classList.add('show');
            });

            videoWrapper?.addEventListener('mouseleave', () => {
                controlsTimeout = setTimeout(() => {
                    if (!video.paused) {
                        videoControls?.classList.remove('show');
                    }
                }, 2000);
            });

            // Keep controls visible when paused
            video.addEventListener('pause', () => {
                videoControls?.classList.add('show');
            });

            // Protection
            document.addEventListener('contextmenu', (e) => {
                if (e.target === video) e.preventDefault();
            });
        });
    </script>

