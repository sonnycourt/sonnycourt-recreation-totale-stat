            position: relative;
            z-index: 2;
            overflow: hidden;
        }

        .wisdom-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image:
                radial-gradient(circle at 25% 25%, rgba(139, 92, 246, 0.02) 0%, transparent 30%),
                radial-gradient(circle at 75% 75%, rgba(255, 215, 0, 0.01) 0%, transparent 30%);
            pointer-events: none;
        }

        /* Particules mystiques d'arrière-plan */
        .wisdom-particles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .wisdom-particle {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(139, 92, 246, 0.05) 50%, transparent 100%);
            animation: wisdomFloat 12s ease-in-out infinite;
        }

        .wisdom-particle.particle-1 {
            width: 20px;
            height: 20px;
            top: 15%;
            left: 10%;
            animation-delay: 0s;
        }

        .wisdom-particle.particle-2 {
            width: 15px;
            height: 15px;
            top: 70%;
            right: 15%;
            animation-delay: 4s;
        }

        .wisdom-particle.particle-3 {
            width: 25px;
            height: 25px;
            bottom: 20%;
            left: 20%;
            animation-delay: 8s;
        }

        .wisdom-particle.particle-4 {
            width: 12px;
            height: 12px;
            top: 40%;
            right: 25%;
            animation-delay: 2s;
        }

        @keyframes wisdomFloat {
            0%, 100% {
                transform: translate(0px, 0px) scale(0.8);
                opacity: 0.3;
            }
            25% {
                transform: translate(20px, -15px) scale(1.1);
                opacity: 0.6;
            }
            50% {
                transform: translate(-10px, -25px) scale(1.2);
                opacity: 0.4;
            }
            75% {
                transform: translate(15px, -10px) scale(0.9);
                opacity: 0.5;
            }
        }

        /* Header élégant */
        .wisdom-header {
            text-align: center;
            margin-bottom: 100px;
            position: relative;
        }


        .wisdom-main-title {
            margin: 0;
            background: linear-gradient(135deg, var(--primary-purple) 0%, #A78BFA 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            font-weight: 800;
            text-shadow: 0 0 40px rgba(139, 92, 246, 0.2);
        }

        .wisdom-subtitle {
            font-size: 1.2rem;
            color: var(--text-secondary);
            font-style: italic;
            margin-bottom: 60px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }


        /* Galerie de citations premium */
        .wisdom-gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 50px;
            margin-bottom: 100px;
        }

        .wisdom-card {
            background:
                linear-gradient(135deg, rgba(20, 20, 20, 0.95) 0%, rgba(30, 30, 30, 0.9) 100%),
                rgba(139, 92, 246, 0.03);
            border: 1px solid rgba(139, 92, 246, 0.2);
            border-radius: 24px;
            padding: 50px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(15px);
            transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow:
                0 20px 40px rgba(0, 0, 0, 0.3),
                0 0 60px rgba(139, 92, 246, 0.1);
        }

        .wisdom-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(139, 92, 246, 0.05),
                transparent
            );
            transition: left 1s ease;
        }

        .wisdom-card:hover::before {
            left: 100%;
        }

        .wisdom-card:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: rgba(139, 92, 246, 0.4);
            box-shadow:
                0 30px 60px rgba(0, 0, 0, 0.4),
                0 0 100px rgba(139, 92, 246, 0.2);
        }

        .wisdom-card-inner {
            position: relative;
            z-index: 2;
        }

        .wisdom-quote-wrapper {
            margin-bottom: 40px;
        }


        .wisdom-quote {
            margin: 0;
        }

        .wisdom-quote-text {
            font-size: 1.3rem;
            line-height: 1.6;
            color: var(--text-primary);
            font-style: italic;
            margin: 0;
            position: relative;
        }


        .wisdom-author {
            display: flex;
            align-items: center;
            gap: 20px;
            padding-top: 30px;
            border-top: 1px solid rgba(139, 92, 246, 0.2);
        }

        .wisdom-author-image {
            position: relative;
            flex-shrink: 0;
        }

        .wisdom-author-image img {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            border: 3px solid rgba(139, 92, 246, 0.3);
            object-fit: cover;
            transition: all 0.4s ease;
        }

        .wisdom-author-glow {
            position: absolute;
            top: -5px;
            left: -5px;
            right: -5px;
            bottom: -5px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(139, 92, 246, 0.2) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .wisdom-card:hover .wisdom-author-glow {
            opacity: 1;
        }

        .wisdom-card:hover .wisdom-author-image img {
            border-color: rgba(139, 92, 246, 0.6);
            transform: scale(1.05);
        }

        .wisdom-author-info h4 {
            margin: 0 0 5px 0;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary-purple);
        }

        .wisdom-author-info p {
            margin: 0;
            font-size: 0.9rem;
            color: var(--text-secondary);
            opacity: 0.8;
        }


        /* Section de réflexion */
        .wisdom-reflection {
            background:
                linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(139, 92, 246, 0.04) 100%),
                rgba(20, 20, 20, 0.9);
            border-radius: 32px;
            padding: 40px 30px;
            text-align: center;
            position: relative;
            backdrop-filter: blur(20px);
            border: 1px solid rgba(139, 92, 246, 0.2);
            box-shadow:
                0 25px 50px rgba(0, 0, 0, 0.3),
                0 0 80px rgba(139, 92, 246, 0.1);
        }

        .reflection-content {
            max-width: 600px;
            margin: 0 auto;
        }

        .reflection-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 20px;
            background: linear-gradient(135deg, var(--primary-purple) 0%, #A78BFA 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .reflection-text {
            font-size: 1.1rem;
            line-height: 1.7;
            color: var(--text-secondary);
            margin: 0;
            font-style: italic;
        }

        /* Animations */
        @keyframes wisdomIconPulse {
            0%, 100% {
                transform: scale(1);
                filter:
                    drop-shadow(0 0 20px rgba(139, 92, 246, 0.5))
                    drop-shadow(0 0 40px rgba(139, 92, 246, 0.3));
            }
            50% {
                transform: scale(1.05);
                filter:
                    drop-shadow(0 0 25px rgba(139, 92, 246, 0.7))
                    drop-shadow(0 0 50px rgba(139, 92, 246, 0.5));
            }
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .wisdom-section {
                padding: 100px 0;
            }

            .wisdom-gallery {
                grid-template-columns: 1fr;
                gap: 40px;
                margin-bottom: 80px;
            }

            .wisdom-card {
                padding: 40px 30px;
            }


            .wisdom-quote-text {
            font-size: 1.1rem;
        }

            .wisdom-quote-text::before,
            .wisdom-quote-text::after {
                display: none;
            }

            .wisdom-author {
                flex-direction: column;
            text-align: center;
                gap: 15px;
            }

            .wisdom-reflection {
                padding: 50px 30px;
            }

            .reflection-title {
                font-size: 1.8rem;
            }
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            text-align: center;
            margin-bottom: 80px;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Reviews Section */
        .reviews-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--darker-bg) 0%, var(--dark-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .reviews-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .reviews-subtitle {
            font-size: 1.3rem;
            color: var(--text-secondary);
            margin-top: 15px;
            font-style: italic;
            opacity: 0.8;
        }


        .reviews-widget {
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        /* Method Section */
        .method-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--card-bg) 0%, var(--dark-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .method-header {
            text-align: center;
            margin-bottom: 60px;
            position: relative;
        }

        .method-main-title {
            margin: 0;
            background: linear-gradient(135deg, var(--primary-purple), #A78BFA);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            font-weight: 800;
        }

        .method-subtitle {
            font-size: 1.3rem;
            color: var(--text-secondary);
            max-width: 700px;
            margin: 0 auto 30px;
            line-height: 1.6;
            font-weight: 400;
        }

        .method-content {
            display: flex;
            flex-direction: column;
            gap: 60px;
        }

        .method-video-container {
            position: relative;
        }

        .method-video-frame {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            box-shadow:
                0 25px 50px rgba(0, 0, 0, 0.4),
                0 0 80px rgba(139, 92, 246, 0.2);
            transition: all 0.4s ease;
        }

        .method-video-frame:hover {
            transform: translateY(-10px);
            box-shadow:
                0 35px 70px rgba(0, 0, 0, 0.5),
                0 0 100px rgba(139, 92, 246, 0.3);
        }

        .method-video-glow {
            position: absolute;
            top: -15px;
            left: -15px;
            right: -15px;
            bottom: -15px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(139, 92, 246, 0.1));
            border-radius: 35px;
            z-index: -1;
            opacity: 0.8;
        }

        .method-keypoints {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .method-keypoint {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            padding: 25px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(20, 20, 20, 0.8));
            border: 1px solid rgba(139, 92, 246, 0.2);
            border-radius: 16px;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .method-keypoint:hover {
            transform: translateX(10px);
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.12), rgba(20, 20, 20, 0.9));
            border-color: rgba(139, 92, 246, 0.4);
            box-shadow: 0 10px 30px rgba(139, 92, 246, 0.15);
        }

        .keypoint-icon {
                font-size: 2rem;
            color: var(--primary-purple);
            flex-shrink: 0;
            margin-top: 2px;
        }

        .keypoint-content h4 {
            margin: 0 0 10px 0;
            color: var(--text-primary);
            font-size: 1.2rem;
            font-weight: 600;
        }

        .keypoint-content p {
            margin: 0;
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .method-cta {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(20, 20, 20, 0.9));
            border: 2px solid rgba(139, 92, 246, 0.3);
            border-radius: 24px;
            padding: 50px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .method-cta::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.1), transparent);
            transition: left 0.5s;
        }

        .method-cta:hover::before {
            left: 100%;
        }

        .method-cta-title {
                font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 15px;
            background: linear-gradient(135deg, var(--primary-purple), #A78BFA);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .method-cta-text {
            font-size: 1.1rem;
            color: var(--text-secondary);
            margin-bottom: 30px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .method-benefits-preview {
            display: flex;
            justify-content: center;
                gap: 30px;
            flex-wrap: wrap;
        }

        .benefit-preview-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        .benefit-check {
            color: var(--primary-purple);
            font-weight: 700;
            font-size: 1.1rem;
        }

        .method-cta-button {
            margin-top: 40px;
                text-align: center;
        }

        .method-guarantee {
            margin: 15px 0 0 0;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            font-weight: 500;
            text-align: center;
            letter-spacing: 0.5px;
        }

        .method-guarantee::first-letter {
            color: var(--primary-purple);
            font-weight: 700;
        }

        /* Video Section */
        .video-section {
            padding: 120px 0;
            background: var(--card-bg);
            position: relative;
            z-index: 2;
        }

        .video-container {
            max-width: 900px;
            margin: 0 auto;
            background: var(--darker-bg);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-color);
        }

        .video-wrapper {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            background: #000;
        }

        .custom-video-player {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            cursor: pointer;
            -webkit-user-select: none;
            -moz-user-select: none;
            user-select: none;
        }

        /* Masquer les contrôles natifs */
        .custom-video-player::-webkit-media-controls {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-panel {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-play-button {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-timeline {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-current-time-display {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-time-remaining-display {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-mute-button {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-volume-slider {
            display: none !important;
        }
        .custom-video-player::-webkit-media-controls-fullscreen-button {
            display: none !important;
        }

        /* Contrôles personnalisés */
        .custom-video-controls {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
            padding: 20px;
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: 10;
        }

        .video-wrapper:hover .custom-video-controls,
        .custom-video-controls.show {
            opacity: 1;
        }

        /* Barre de progression */
        .video-progress-container {
            margin-bottom: 12px;
        }

        .video-progress-bar {
            width: 100%;
            height: 6px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 3px;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .video-progress-filled {
            height: 100%;
            background: linear-gradient(90deg, #8B5CF6 0%, #A78BFA 100%);
            border-radius: 3px;
            width: 0%;
            transition: width 0.1s linear;
        }

        .video-progress-bar:hover .video-progress-filled {
            background: linear-gradient(90deg, #A78BFA 0%, #C4B5FD 100%);
        }

        /* Contrôles du bas */
        .video-controls-bottom {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .video-control-btn {
            background: rgba(139, 92, 246, 0.3);
            border: 1px solid rgba(139, 92, 246, 0.5);
            border-radius: 8px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: white;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .video-control-btn:hover {
            background: rgba(139, 92, 246, 0.5);
            border-color: rgba(139, 92, 246, 0.7);
            transform: scale(1.1);
        }

        .video-time {
            color: white;
            font-size: 14px;
            font-weight: 500;
            flex: 1;
        }

        .time-separator {
            margin: 0 4px;
            opacity: 0.6;
        }

        .video-controls-right {
            display: flex;
            gap: 8px;
        }

        /* Overlay play button */
        .video-play-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 5;
            transition: opacity 0.3s ease;
            cursor: pointer;
        }

        .video-play-overlay.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .video-play-button {
            background: none;
            border: none;
            cursor: pointer;
            transition: transform 0.3s ease;
        }

        .video-play-button:hover {
            transform: scale(1.1);
        }

        /* Story Section */
        .story-section {
            padding: 120px 0;
            position: relative;
            z-index: 2;
        }

        .story-content {
            max-width: 800px;
            margin: 0 auto;
        }

        .story-content .guarantee-title {
            margin-bottom: 40px;
        }

        .story-highlight {
            background: var(--card-bg);
            border-left: 4px solid var(--primary-purple);
            padding: 30px;
            margin: 40px 0;
            border-radius: 12px;
        }

        .story-highlight p {
            font-size: 1.2rem;
            color: var(--text-primary);
            margin: 0;
        }

        .story-text {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.9;
            margin-bottom: 30px;
        }

        .story-text strong {
            color: var(--primary-purple);
            font-weight: 600;
        }

        /* Nouveaux styles pour la structure améliorée */
        .story-phase {
            margin-bottom: 60px;
            padding: 40px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 16px;
            border: 1px solid rgba(139, 92, 246, 0.1);
            transition: all 0.3s ease;
        }

        .story-phase:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(139, 92, 246, 0.2);
            transform: translateY(-2px);
        }

        .story-subtitle {
            font-size: 1.4rem;
            color: var(--primary-purple);
            margin-bottom: 20px;
            font-weight: 700;
                text-align: center;
            }

        .story-subtitle .emoji-text {
            background: linear-gradient(135deg, #8B5CF6 0%, #A855F7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .story-features {
            background: rgba(139, 92, 246, 0.05);
            border-radius: 12px;
            padding: 25px;
            margin: 25px 0;
            border-left: 4px solid var(--primary-purple);
        }

        .story-features p {
            margin: 8px 0;
            color: var(--text-secondary);
                font-size: 1rem;
            }

        .testimonial-highlight {
            background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(22, 163, 74, 0.05) 100%);
            border: 1px solid rgba(34, 197, 94, 0.2);
            border-radius: 12px;
            padding: 20px 25px;
            margin: 15px 0;
            position: relative;
        }

        .testimonial-highlight::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
            border-radius: 12px 0 0 12px;
        }

        .testimonial-highlight p {
            margin: 0;
            color: var(--text-primary);
            font-size: 1.1rem;
            font-weight: 600;
        }

        /* Learning Section */
        .learning-section {
            padding: 120px 0;
            background:
                radial-gradient(circle at 20% 30%, rgba(139, 92, 246, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(139, 92, 246, 0.06) 0%, transparent 50%),
                var(--darker-bg);
            position: relative;
            z-index: 2;
            overflow: hidden;
        }

        .learning-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image:
                radial-gradient(circle at 25% 25%, rgba(139, 92, 246, 0.03) 0%, transparent 25%),
                radial-gradient(circle at 75% 75%, rgba(139, 92, 246, 0.03) 0%, transparent 25%);
            pointer-events: none;
        }

        .learning-header {
            text-align: center;
            margin-bottom: 80px;
            position: relative;
        }

        .learning-subtitle {
            font-size: 1.3rem;
            color: var(--text-secondary);
            margin-top: 20px;
            font-style: italic;
            opacity: 0.8;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }

        .learning-mystic-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
            position: relative;
        }

        .learning-mystic-item {
            background:
                linear-gradient(135deg, rgba(20, 20, 20, 0.9) 0%, rgba(30, 30, 30, 0.8) 100%),
                rgba(139, 92, 246, 0.05);
            border: 1px solid rgba(139, 92, 246, 0.2);
            border-radius: 20px;
            padding: 50px 30px;
            display: block;
            text-align: center;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .learning-mystic-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, transparent 30%, rgba(139, 92, 246, 0.1) 50%, transparent 70%);
            opacity: 0;
            transition: opacity 0.6s ease;
            pointer-events: none;
        }

        .learning-mystic-item:hover::before {
            opacity: 1;
        }

        .learning-mystic-item:hover {
            transform: translateY(-10px) scale(1.02);
            border-color: rgba(139, 92, 246, 0.5);
            box-shadow:
                0 20px 60px rgba(139, 92, 246, 0.3),
                0 0 80px rgba(139, 92, 246, 0.1),
                inset 0 0 20px rgba(139, 92, 246, 0.05);
        }


        .mystic-content {
            text-align: center;
        }

        .mystic-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #A78BFA;
            margin-bottom: 15px;
        }

        .mystic-description {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.6;
            margin: 0;
        }

        @keyframes mysticGlow {
            0% {
                filter: drop-shadow(0 0 10px rgba(139, 92, 246, 0.5));
                transform: scale(1);
            }
            100% {
                filter: drop-shadow(0 0 20px rgba(139, 92, 246, 0.8));
                transform: scale(1.1);
            }
        }

        @keyframes crystalPulse {
            0%, 100% {
                opacity: 0.3;
                transform: translate(-50%, -50%) scale(1);
            }
            50% {
                opacity: 0.6;
                transform: translate(-50%, -50%) scale(1.2);
            }
        }

        @media (max-width: 768px) {
            .learning-mystic-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }

            .learning-mystic-item {
                padding: 30px 20px;
            }

        }

        /* Video Reviews Section */
        .video-reviews-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--darker-bg) 0%, var(--dark-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .video-reviews-section .section-subtitle {
            text-align: center;
            color: var(--text-secondary);
            font-size: 1.2rem;
            margin-bottom: 60px;
            font-style: italic;
        }

        .video-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 40px;
            margin-top: 60px;
        }

        .video-card {
            background: var(--card-bg);
            border: 2px solid var(--primary-purple);
            border-radius: 24px;
            padding: 20px;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 400px;
            position: relative;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .video-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(139, 92, 246, 0.3);
            border-color: var(--primary-gold);
        }

        .review-video {
            width: 100%;
            max-width: 280px;
            height: 400px;
            object-fit: cover;
            border-radius: 16px;
            background: var(--dark-bg);
            outline: none;
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.3);
        }

        /* Custom video controls styling */
        .review-video::-webkit-media-controls-panel {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.9), rgba(255, 215, 0, 0.1));
            border-radius: 12px;
            backdrop-filter: blur(10px);
        }

        /* Hide video controls when not playing */
        .video-card:not(.playing):not(.controls-visible) .review-video::-webkit-media-controls-panel {
            display: none !important;
        }

        /* Show controls when paused but not at start */
        .video-card.paused .review-video::-webkit-media-controls-panel {
            display: flex !important;
        }

        /* Hide controls for Firefox when not playing */
        .video-card:not(.playing):not(.controls-visible) .review-video::-moz-range-track,
        .video-card:not(.playing):not(.controls-visible) .review-video::-moz-range-thumb {
            display: none !important;
        }

        /* Show controls for Firefox when paused but not at start */
        .video-card.paused .review-video::-moz-range-track,
        .video-card.paused .review-video::-moz-range-thumb {
            display: block !important;
        }

        .review-video::-webkit-media-controls-play-button {
            background-color: var(--primary-gold);
            border-radius: 50%;
            width: 40px;
            height: 40px;
        }

        .review-video::-webkit-media-controls-timeline {
            background-color: rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            height: 6px;
        }

        .review-video::-webkit-media-controls-current-time-display,
        .review-video::-webkit-media-controls-time-remaining-display {
            color: var(--primary-gold);
            font-weight: 600;
            font-size: 12px;
        }

        .review-video::-webkit-media-controls-volume-slider {
            background-color: rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            height: 4px;
        }

        /* Firefox specific styling */
        .review-video::-moz-range-track {
            background-color: rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            height: 6px;
        }

        .review-video::-moz-range-thumb {
            background-color: var(--primary-gold);
            border-radius: 50%;
            width: 16px;
            height: 16px;
            border: none;
        }

        /* Hide fullscreen and download buttons */
        .review-video::-webkit-media-controls-fullscreen-button,
        .review-video::-webkit-media-controls-download-button {
            display: none !important;
        }

        /* Loading state for videos */
        .review-video[poster=""] {
            background: linear-gradient(135deg, var(--dark-bg) 0%, var(--darker-bg) 100%);
            position: relative;
        }

        .review-video[poster=""]::before {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 40px;
            height: 40px;
            border: 3px solid rgba(139, 92, 246, 0.3);
            border-top: 3px solid var(--primary-gold);
            border-radius: 50%;
            animation: videoLoading 1s linear infinite;
            z-index: 1;
        }

        @keyframes videoLoading {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }

        /* Focus state for accessibility */
        .review-video:focus {
            outline: 2px solid var(--primary-gold);
            outline-offset: 4px;
        }

        /* Custom Play Button */
        .custom-play-button {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 80px;
            height: 80px;
            background: none;
            border: none;
            cursor: pointer;
            z-index: 15;
            transition: all 0.3s ease;
            opacity: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .custom-play-button:hover {
            transform: translate(-50%, -50%) scale(1.1);
        }

        .custom-play-button:active {
            transform: translate(-50%, -50%) scale(0.95);
        }

        .custom-play-button svg {
            width: 100%;
            height: 100%;
            filter: drop-shadow(0 4px 8px rgba(139, 92, 246, 0.3));
        }

        /* Hide/show play and pause icons */
        .custom-play-button .play-icon,
        .custom-play-button .pause-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            transition: opacity 0.3s ease;
        }

        /* Hide pause icon by default */
        .custom-play-button .pause-icon {
            display: none;
        }

        .custom-play-button svg circle {
            transition: all 0.3s ease;
        }

        .custom-play-button:hover svg circle {
            r: 13;
            stroke-width: 3;
        }

        /* Hide custom play button when video is playing */
        .video-card.playing .custom-play-button {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        /* Show custom play button when paused (but hide at start/end) */
        .video-card.paused .custom-play-button {
            opacity: 1;
            pointer-events: auto;
        }

        /* Video overlay gradient when not playing */
        .video-card:not(.playing):not(.paused)::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg,
                rgba(139, 92, 246, 0.4) 0%,
                rgba(255, 215, 0, 0.1) 50%,
                rgba(139, 92, 246, 0.4) 100%);
            backdrop-filter: blur(2px);
            z-index: 5;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .video-card.playing::before,
        .video-card.paused::before {
            opacity: 0;
        }

        /* Bonus Section */
        .bonus-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--dark-bg) 0%, var(--darker-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .bonus-card {
            background: var(--card-bg);
            border: 2px solid var(--primary-purple);
            border-radius: 24px;
            padding: 60px;
