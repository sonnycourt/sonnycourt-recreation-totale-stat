            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .bonus-content {
            padding-top: 40px;
        }

        .bonus-title {
            font-size: 2.5rem;
            margin-bottom: 20px;
            color: var(--primary-purple);
            font-weight: 700;
        }

        .bonus-subtitle {
            font-size: 1.5rem;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .bonus-description {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.8;
        }

        .bonus-image {
            position: relative;
        }

        .bonus-image img {
            width: 100%;
