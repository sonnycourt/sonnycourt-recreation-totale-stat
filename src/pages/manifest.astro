        // Ancien système SimpleScarcity (désactivé - gardé pour référence)
        class SimpleScarcity {
            constructor() {
                this.storageKey = 'daily_seats';
                this.dailyPlaces = 4;        // 4 places disponibles sur 5 total (sentiment de rareté immédiat)
                this.releaseHour = 6;        // Reset à 6h du matin
                this.nightResetStart = 23;   // Reset nocturne commence à 23h
                this.nightResetEnd = 1;      // Reset nocturne finit à 1h

                this.init();
            }

            init() {
                this.checkDailyReset();
                this.loadSeats();
                this.updateUI();
                this.setupButtonClick();
            }

            checkDailyReset() {
                const now = new Date();

                // Vérifier le reset matinal à 6h
                const today6AM = new Date(now.getFullYear(), now.getMonth(), now.getDate(), this.releaseHour, 0, 0, 0);
                const lastMorningReset = localStorage.getItem('last_morning_reset');

                // Reset matinal à 6h
                if (now >= today6AM && lastMorningReset !== today6AM.toDateString()) {
                    this.resetSeats();
                    localStorage.setItem('last_morning_reset', today6AM.toDateString());
                    console.log('🌅 Reset matinal effectué à 6h');
                    return;
                }

                // Vérifier le reset nocturne entre 23h et 1h
                this.checkNightlyReset(now);
            }

            checkNightlyReset(now) {
                const currentHour = now.getHours();
                const currentMinute = now.getMinutes();
                const lastNightReset = localStorage.getItem('last_night_reset');
                const today = now.toDateString();

                // Si on est entre 23h et 1h du matin
                const isNightTime = (currentHour >= this.nightResetStart || currentHour <= this.nightResetEnd);

                if (isNightTime && lastNightReset !== today) {
                    // Attendre entre 10 et 60 minutes après l'entrée dans la plage nocturne
                    const randomWait = 10 + Math.random() * 50; // 10-60 minutes pour plus de variabilité
                    const lastResetTime = localStorage.getItem('last_reset_time');

                    if (lastResetTime) {
                        const timeSinceLastReset = (now - new Date(lastResetTime)) / (1000 * 60); // en minutes

                        // Si ça fait plus que le temps d'attente aléatoire
                        if (timeSinceLastReset > randomWait) {
                            // 100% de chance de déclencher le reset (mais timing aléatoire)
                            this.currentSeats = 0; // Forcer à zéro
                            this.saveSeats();
                            this.updateUI();
                            localStorage.setItem('last_night_reset', today);
                            localStorage.setItem('last_reset_time', now.toISOString());
                            console.log(`🌙 RESET NOCTURNE 100% à ${currentHour}:${currentMinute.toString().padStart(2, '0')} (après ${Math.round(timeSinceLastReset)} minutes d'attente)`);
                        }
                    } else {
                        // Premier check de la nuit - initialiser le timer
                        localStorage.setItem('last_reset_time', now.toISOString());
                        console.log(`🌙 Entrée en plage nocturne - Reset imminent dans ${Math.round(randomWait)} minutes`);
                    }
                }
            }

            // PLUS DE LOGIQUE COMPLEXE - Système stable basé sur l'heure actuelle

            // Méthode de test pour forcer un décrément
            forceDecrement() {
                if (this.currentSeats > 0) {
                    this.currentSeats--;
                    this.saveSeats();
                    this.updateUI();
                    console.log(`🔧 FORÇAGE: ${this.currentSeats} places restantes`);
                } else {
                    console.log(`❌ Impossible de décrémenter: déjà à 0`);
                }
            }

            resetSeats() {
                this.currentSeats = this.dailyPlaces;
                this.saveSeats();
                // Reset aussi le timer de décrément automatique
                localStorage.removeItem('last_auto_decrement');
            }

            loadSeats() {
                const now = new Date();
                const currentHour = now.getHours();

                // LOGIQUE STABLE ET GARANTIE basée sur l'heure actuelle
                if (currentHour >= 23 || currentHour < 6) {
                    // NUIT (23h à 6h) = ZÉRO places garanti
                    this.currentSeats = 0;
                    console.log(`🌙 ${currentHour}h: Mode NUIT - 0/5 places (garanti)`);
                } else if (currentHour >= 19) {
                    // 19h-22h59 = 1 place
                    this.currentSeats = 1;
                    console.log(`🌆 ${currentHour}h: 1/5 places`);
                } else if (currentHour >= 16) {
                    // 16h-18h59 = 2 places
                    this.currentSeats = 2;
                    console.log(`🌇 ${currentHour}h: 2/5 places`);
                } else if (currentHour >= 11) {
                    // 11h-15h59 = 3 places
                    this.currentSeats = 3;
                    console.log(`☀️ ${currentHour}h: 3/5 places`);
                } else {
                    // 6h-10h59 = 4 places (reset matinal)
                    this.currentSeats = 4;
                    console.log(`🌅 ${currentHour}h: 4/5 places (reset matinal)`);
                }

                // Sauvegarder pour cohérence
                this.saveSeats();
            }

            saveSeats() {
                localStorage.setItem(this.storageKey, this.currentSeats.toString());
            }

            setupButtonClick() {
                const button = document.getElementById('scarcity-cta-link');
                if (button) {
                    button.addEventListener('click', (e) => {
                        if (this.currentSeats > 0) {
