            disableAllButtons() {
                // Désactiver tous les boutons de la page et changer leur texte
                const allButtons = document.querySelectorAll('button, a[href], input[type="submit"], .cta-button');
                allButtons.forEach(button => {
                    if (!button.classList.contains('reminder-btn')) { // Garder le bouton reminder actif
                        // Sauvegarder le texte original si pas déjà fait
                        if (!button.dataset.originalText) {
                            button.dataset.originalText = button.textContent || button.innerText || '';
                        }

                        // Changer le texte pour "COMPLET - REVIENS DEMAIN"
                        if (button.tagName === 'A' || button.classList.contains('cta-button')) {
                            button.textContent = 'COMPLET - REVIENS DEMAIN';
                        } else if (button.tagName === 'BUTTON' || button.tagName === 'INPUT') {
                            if (button.type === 'submit') {
                                button.value = 'COMPLET - REVIENS DEMAIN';
                            } else {
                                button.textContent = 'COMPLET - REVIENS DEMAIN';
                            }
                        }

                        // Désactiver le bouton
                        button.style.pointerEvents = 'none';
                        button.style.opacity = '0.8';
                        button.style.cursor = 'not-allowed';
                    }
                });
                console.log('🔒 Tous les boutons désactivés et texte changé - Places épuisées');
            }

            enableAllButtons() {
                // Réactiver tous les boutons de la page et restaurer leur texte original
                const allButtons = document.querySelectorAll('button, a[href], input[type="submit"], .cta-button');
                allButtons.forEach(button => {
                    // Restaurer le texte original si sauvegardé
                    if (button.dataset.originalText) {
                        if (button.tagName === 'INPUT' && button.type === 'submit') {
                            button.value = button.dataset.originalText;
                        } else {
                            button.textContent = button.dataset.originalText;
                        }
                        // Supprimer la sauvegarde après restauration
                        delete button.dataset.originalText;
                    }

                    // Réactiver le bouton
                    button.style.pointerEvents = 'auto';
                    button.style.opacity = '1';
                    button.style.cursor = 'pointer';
                });
                console.log('✅ Tous les boutons réactivés et texte restauré - Places disponibles');
            }

