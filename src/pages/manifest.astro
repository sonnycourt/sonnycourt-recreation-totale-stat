        // ===== NOUVEAU SYSTÈME DE PLACES AVEC TOKEN (REMPLACE SimpleScarcity) =====
        
        // Tableau de paliers pour le calcul des places (même que dans check-places-manifest.js)
        const paliers = [
            { heure: 0, places: 27 },
            { heure: 24, places: 20 },
            { heure: 48, places: 14 },
            { heure: 72, places: 10 },
            { heure: 96, places: 7 },
            { heure: 120, places: 5 },
            { heure: 144, places: 3 },
            { heure: 156, places: 2 },
            { heure: 162, places: 1 },
            { heure: 168, places: 0 }
        ];

        // Fonction pour calculer les places restantes avec interpolation linéaire (côté client pour preview)
        function calculatePlacesRemainingClient(startTime) {
            const now = Math.floor(Date.now() / 1000);
            const elapsedSeconds = now - startTime;
            const elapsedHours = elapsedSeconds / 3600;

            if (elapsedHours >= 168) {
                return 0;
            }

            let palierInf = paliers[0];
            let palierSup = paliers[paliers.length - 1];

            for (let i = 0; i < paliers.length - 1; i++) {
                if (elapsedHours >= paliers[i].heure && elapsedHours < paliers[i + 1].heure) {
                    palierInf = paliers[i];
                    palierSup = paliers[i + 1];
                    break;
                }
            }

            if (elapsedHours === palierInf.heure) {
                return palierInf.places;
            }

            const deltaHeures = palierSup.heure - palierInf.heure;
            const deltaPlaces = palierSup.places - palierInf.places;
            const progression = (elapsedHours - palierInf.heure) / deltaHeures;
            const placesInterpolees = palierInf.places + (deltaPlaces * progression);

            return Math.floor(placesInterpolees);
        }

        // Système de places avec token
        class ManifestPlacesSystem {
            constructor() {
                this.placesRemaining = 27;
                this.token = null;
                this.startTime = null;
                this.init();
            }

            async init() {
                const urlParams = new URLSearchParams(window.location.search);
                const previewMode = urlParams.get('preview');
                const isPreview = previewMode === 'true';
                const isPreviewExpired = previewMode === 'expired';

                // Mode preview expired : simuler places = 0
                if (isPreviewExpired) {
                    console.log('🔍 Mode preview expired activé - simulation places = 0');
                    this.placesRemaining = 0;
                    this.updateUI();
                    this.disableSpiffyButtons();
                    return;
                }

                // Mode preview : afficher 20 places (fixe)
                if (isPreview) {
                    console.log('🔍 Mode preview activé - affichage 20 places');
                    this.placesRemaining = 20;
                    this.updateUI();
                    return;
                }

                // Mode preview stvalentin : paliers de 5 à 0 places du 14 fév 16h au 15 fév 23h59
                if (previewMode === 'stvalentin') {
                    const stvalPaliers = [
                        { time: new Date('2026-02-14T16:00:00').getTime(), places: 5 },
                        { time: new Date('2026-02-14T22:00:00').getTime(), places: 4 },
                        { time: new Date('2026-02-15T13:00:00').getTime(), places: 3 },
                        { time: new Date('2026-02-15T18:00:00').getTime(), places: 2 },
                        { time: new Date('2026-02-15T22:00:00').getTime(), places: 1 },
                        { time: new Date('2026-02-15T23:59:00').getTime(), places: 0 }
                    ];

                    const calcStvalPlaces = () => {
                        const now = Date.now();
                        if (now < stvalPaliers[0].time) return 5;
                        for (let i = stvalPaliers.length - 1; i >= 0; i--) {
                            if (now >= stvalPaliers[i].time) return stvalPaliers[i].places;
                        }
                        return 0;
                    };

                    this.placesRemaining = calcStvalPlaces();
                    console.log('🔍 Mode preview stvalentin activé -', this.placesRemaining, 'places');
                    this.updateUI();
                    if (this.placesRemaining === 0) this.disableSpiffyButtons();

                    // Mettre à jour toutes les minutes
                    setInterval(() => {
                        this.placesRemaining = calcStvalPlaces();
                        this.updateUI();
                        if (this.placesRemaining === 0) this.disableSpiffyButtons();
                    }, 60000);

                    return;
                }

                // Mode preview promo : places descendent de 5 à 0 jusqu'à la deadline config
                if (previewMode === 'promo') {
                    const promoConfig = document.getElementById('promo-config');
                    const promoDeadline = promoConfig ? new Date(promoConfig.dataset.deadline).getTime() : 0;
                    const promoBadge = promoConfig ? promoConfig.dataset.badge : '';
                    const promoActive = promoConfig ? promoConfig.dataset.active === 'true' : false;

                    if (!promoActive || !promoDeadline || Date.now() >= promoDeadline) {
                        window.location.href = '/fin-promo/';
                        return;
                    }

                    const promoStart = Date.now();
                    const promoDuration = promoDeadline - promoStart;
                    const promoMaxPlaces = 5;

                    const calcPromoPlaces = () => {
                        const now = Date.now();
                        if (now >= promoDeadline) return 0;
                        const remaining = promoDeadline - now;
                        const ratio = remaining / Math.max(promoDuration, 1);
                        return Math.max(0, Math.ceil(ratio * promoMaxPlaces));
                    };

                    this.placesRemaining = calcPromoPlaces();
                    console.log('🔍 Mode preview promo activé -', this.placesRemaining, 'places');
                    this.updateUI();
                    if (this.placesRemaining === 0) this.disableSpiffyButtons();

                    // Mettre à jour le badge
                    if (promoBadge) {
                        const badgeEl = document.querySelector('.seasonal-badge-text');
                        if (badgeEl) badgeEl.textContent = promoBadge;
                        const badgeIcon = document.querySelector('.seasonal-badge-icon');
                        if (badgeIcon) {
                            const emoji = promoConfig.dataset.badge?.split(' ')[0] || '⚡';
                            badgeIcon.innerHTML = `<span style="font-size:18px;">${emoji}</span>`;
                        }
                    }

                    setInterval(() => {
                        this.placesRemaining = calcPromoPlaces();
                        this.updateUI();
                        if (this.placesRemaining === 0) this.disableSpiffyButtons();
                    }, 60000);

                    return;
                }

                // Mode normal : vérification du token requise
                const tokenFromUrl = urlParams.get('token');
                const storedToken = localStorage.getItem('manifest_token');
                this.token = tokenFromUrl || storedToken;

                if (!this.token) {
                    console.log('⚠️ Pas de token - redirection vers inscription');
                    window.location.href = '/inscription-manifest/';
                    return;
                }

                // Stocker le token dans localStorage
                if (this.token) {
                    localStorage.setItem('manifest_token', this.token);
                }

                // Vérifier le token et charger les places
                await this.checkTokenAndLoadPlaces();
            }

            async checkTokenAndLoadPlaces() {
                try {
                    const response = await fetch(`/.netlify/functions/check-places-manifest?token=${encodeURIComponent(this.token || '')}`);
                    const data = await response.json();

                    if (!data.valid) {
                        if (data.expired) {
                            console.log('⏰ Token expiré - places = 0');
                            this.placesRemaining = 0;
                            this.updateUI();
                            this.disableSpiffyButtons();
                        } else {
                            alert('Lien invalide. Veuillez utiliser le lien que vous avez reçu par email.');
                            window.location.href = '/inscription-manifest/';
                        }
                        return;
                    }

                    this.placesRemaining = data.placesRemaining;
                    this.startTime = data.startTime;
                    this.updateUI();

                    // Synchroniser toutes les minutes
                    setInterval(async () => {
                        try {
                            const syncResponse = await fetch(`/.netlify/functions/check-places-manifest?token=${encodeURIComponent(this.token || '')}`);
                            const syncData = await syncResponse.json();
                            if (syncData.valid && syncData.placesRemaining !== undefined) {
                                this.placesRemaining = syncData.placesRemaining;
                                this.updateUI();
                                if (this.placesRemaining === 0) {
                                    this.disableSpiffyButtons();
                                }
                            } else if (!syncData.valid && syncData.expired) {
                                this.placesRemaining = 0;
                                this.updateUI();
                                this.disableSpiffyButtons();
                            }
                        } catch (error) {
                            console.error('Erreur de synchronisation:', error);
                        }
                    }, 60000); // Toutes les minutes

                } catch (error) {
                    console.error('Erreur lors de la vérification:', error);
                    alert('Erreur de connexion. La page se charge sans le système de places.');
                }
            }

            disableSpiffyButtons() {
                const spiffyButtons = document.querySelectorAll('.scarcity-cta-button, .cta-button-final, a[href*="spiffy.co"]');
                spiffyButtons.forEach((button) => {
                    button.classList.add('disabled', 'sold-out');
                    button.style.pointerEvents = 'none';
                    button.style.opacity = '0.6';
                    button.style.cursor = 'not-allowed';
                    button.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        return false;
                    });
                });
            }

            updateUI() {
                const currentPlacesEl = document.getElementById('current-places');
                const ctaLink = document.getElementById('scarcity-cta-link');
                const ctaText = document.getElementById('cta-text');
                const soldOutState = document.getElementById('sold-out-state');
                const ctaSection = document.querySelector('.cta-section');
                const urgentCounter = document.getElementById('urgent-counter');
                const warningMessage = document.getElementById('warning-message');
                const meterFill = document.getElementById('meter-fill');

                // Update counter display
                if (currentPlacesEl) {
                    currentPlacesEl.textContent = this.placesRemaining;
                }

                // Update progress meter (affichage 100 places, mais logique réelle 27)
                if (meterFill) {
                    const percentage = (this.placesRemaining / 100) * 100;
                    meterFill.style.width = `${percentage}%`;
                }

                // Update warning message intensity
                if (warningMessage) {
                    if (this.placesRemaining <= 1) {
                        warningMessage.classList.add('critical');
                    } else if (this.placesRemaining <= 3) {
                        warningMessage.classList.add('high');
                    } else {
                        warningMessage.classList.remove('critical', 'high');
                    }
                }

                if (this.placesRemaining === 0) {
                    // SOLD OUT STATE
                    this.disableSpiffyButtons();

                    if (urgentCounter) {
                        urgentCounter.classList.add('sold-out');
                    }
