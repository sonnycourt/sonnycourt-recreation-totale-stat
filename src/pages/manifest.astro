    <script>
        (function() {
            const viewersCountEl = document.getElementById('liveViewersCount');
            const placesEl = document.getElementById('current-places');
            
            if (!viewersCountEl) return;

            // Base range: 7-28, ajusté selon les places restantes
            function calculateViewersRange() {
                const places = placesEl ? parseInt(placesEl.textContent) || 27 : 27;
                
                // Plus il reste peu de places, plus il y a de viewers (tension)
                if (places <= 5) {
                    return { min: 22, max: 28 }; // Très haute tension
                } else if (places <= 10) {
                    return { min: 18, max: 26 }; // Haute tension
                } else if (places <= 15) {
                    return { min: 14, max: 23 }; // Tension moyenne
                } else if (places <= 20) {
                    return { min: 11, max: 20 }; // Tension modérée
                } else {
                    return { min: 7, max: 17 }; // Normal
                }
            }

            let currentViewers = 0;
            
            function initViewers() {
                const range = calculateViewersRange();
                currentViewers = Math.floor(Math.random() * (range.max - range.min + 1)) + range.min;
                viewersCountEl.textContent = currentViewers;
            }

            function updateViewers() {
                const range = calculateViewersRange();
                
                // Micro-variation: +1, -1, ou 0 (avec tendance à rester dans le range)
                const variation = Math.random();
                let change = 0;
                
                if (variation < 0.35) {
                    change = -1;
                } else if (variation < 0.7) {
                    change = 1;
                }
                // 30% chance de rester stable
                
                let newViewers = currentViewers + change;
                
                // Garder dans le range
                if (newViewers < range.min) newViewers = range.min + 1;
                if (newViewers > range.max) newViewers = range.max - 1;
                
                currentViewers = newViewers;
                viewersCountEl.textContent = currentViewers;
            }

            // Initialiser après un petit délai
            setTimeout(() => {
                initViewers();
                
                // Micro-variations toutes les 4-8 secondes
                setInterval(() => {
                    updateViewers();
                }, 4000 + Math.random() * 4000);
                
            }, 2500);

            // Observer les changements du compteur de places
            if (placesEl) {
                const placesObserver = new MutationObserver(() => {
                    // Recalculer le range quand les places changent
                    const range = calculateViewersRange();
                    if (currentViewers < range.min) {
                        currentViewers = range.min + Math.floor(Math.random() * 3);
                        viewersCountEl.textContent = currentViewers;
                    }
                });
                
                placesObserver.observe(placesEl, { childList: true, characterData: true, subtree: true });
            }
        })();
    </script>
