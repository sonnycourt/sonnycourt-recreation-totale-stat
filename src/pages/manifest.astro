        @keyframes shieldPulse {
            0%, 100% {
                transform: scale(1);
                filter:
                    drop-shadow(0 0 20px rgba(139, 92, 246, 0.6))
                    drop-shadow(0 0 40px rgba(139, 92, 246, 0.4));
            }
            50% {
                transform: scale(1.05);
                filter:
                    drop-shadow(0 0 25px rgba(139, 92, 246, 0.8))
                    drop-shadow(0 0 50px rgba(139, 92, 246, 0.6));
            }
        }

        @keyframes shieldGlowPulse {
            0%, 100% {
                opacity: 0.3;
                transform: scale(1);
            }
            50% {
                opacity: 0.6;
                transform: scale(1.1);
            }
        }

        @keyframes trustPulse {
            0%, 100% {
                transform: scale(1);
                filter:
                    drop-shadow(0 0 15px rgba(139, 92, 246, 0.5))
                    drop-shadow(0 0 30px rgba(139, 92, 246, 0.3));
            }
            50% {
                transform: scale(1.02);
                filter:
                    drop-shadow(0 0 20px rgba(139, 92, 246, 0.7))
                    drop-shadow(0 0 40px rgba(139, 92, 246, 0.5));
            }
        }

        @keyframes trustGlowPulse {
            0%, 100% {
