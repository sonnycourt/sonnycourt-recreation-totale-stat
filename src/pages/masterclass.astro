        function applyMasterclassPhoneStyles() {
            const root = document.getElementById('step2-phone-container');
            if (!root) return;
            const input = root.querySelector('#phone');
            if (input) {
                input.style.setProperty('width', '100%', 'important');
                input.style.setProperty('height', '56px', 'important');
