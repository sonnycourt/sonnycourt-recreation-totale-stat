    <script>
        // @ts-nocheck
        /** Aligné sur netlify/functions/lib/webinaire-session-paris.mjs (cutoff jeudi 19h Paris). Routes : /masterclass. */
        /** TEMP — supprimer tout le bloc mot de passe avant lancement public */
        const MASTERCLASS_ACCESS_SESSION = 'masterclass_access';
        const MASTERCLASS_TEMP_PASSWORD = 'masterclass';

        const TOKEN_KEY = 'masterclass_es2_token';
        const LEGACY_TOKEN_KEY = 'webinaire_es2_token';
        const COOKIE_MAX = 365 * 24 * 60 * 60;
        const STEP2_SUBMIT_LABEL = 'Confirmer mon inscription';

        const state = {
            name: '',
            email: '',
            phone: '',
            country: ''
        };

        let iti = null;

        function pad(value) {
            return String(value).padStart(2, '0');
        }

        function getCookie(name) {
            const esc = name.replace(/[$()*+.?[\\\]^{|}]/g, '\\$&');
            const m = document.cookie.match(new RegExp('(?:^|; )' + esc + '=([^;]*)'));
            return m ? decodeURIComponent(m[1]) : '';
        }

        function setTokenEverywhere(token) {
            localStorage.setItem(TOKEN_KEY, token);
            document.cookie = `${TOKEN_KEY}=${encodeURIComponent(token)}; path=/; max-age=${COOKIE_MAX}; SameSite=Lax`;
        }

        function clearToken() {
            localStorage.removeItem(TOKEN_KEY);
            localStorage.removeItem(LEGACY_TOKEN_KEY);
            document.cookie = `${TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
            document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
        }

        function getStoredToken() {
            let t = (localStorage.getItem(TOKEN_KEY) || getCookie(TOKEN_KEY) || '').trim();
            if (t) return t;
            const legacy = (localStorage.getItem(LEGACY_TOKEN_KEY) || getCookie(LEGACY_TOKEN_KEY) || '').trim();
            if (legacy) {
                setTokenEverywhere(legacy);
                localStorage.removeItem(LEGACY_TOKEN_KEY);
                document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
                return legacy;
            }
            return '';
        }

        function parseParisParts(date) {
            const formatter = new Intl.DateTimeFormat('fr-FR', {
                timeZone: 'Europe/Paris',
                year: 'numeric',
                month: 'numeric',
                day: 'numeric',
                weekday: 'short',
                hour: 'numeric',
                minute: 'numeric',
                second: 'numeric',
                hourCycle: 'h23'
            });
            const parts = formatter.formatToParts(date);
            const value = (type) => Number(parts.find((p) => p.type === type)?.value || 0);
            const weekRaw = parts.find((p) => p.type === 'weekday')?.value || '';
            return {
                year: value('year'),
                month: value('month'),
                day: value('day'),
                hour: value('hour'),
                minute: value('minute'),
                second: value('second'),
                weekdayText: weekRaw.toLowerCase()
            };
        }

        function getParisWeekdayNumber(parts) {
            const dayMap = { lun: 1, mar: 2, mer: 3, jeu: 4, ven: 5, sam: 6, dim: 7 };
            for (const key of Object.keys(dayMap)) {
                if (parts.weekdayText.startsWith(key)) return dayMap[key];
            }
            return 1;
        }

        function addDaysParisCalendar(year, month, day, deltaDays) {
            const d = new Date(Date.UTC(year, month - 1, day + deltaDays, 12, 0, 0));
            const p = parseParisParts(d);
            return { year: p.year, month: p.month, day: p.day };
        }

        function findParisInstantUtc(parisYear, parisMonth, parisDay, parisHour) {
            let candidate = new Date(Date.UTC(parisYear, parisMonth - 1, parisDay, parisHour - 1, 0, 0));
            for (let i = 0; i < 4000; i++) {
                const p = parseParisParts(candidate);
                if (p.year === parisYear && p.month === parisMonth && p.day === parisDay && p.hour === parisHour) {
                    return candidate;
                }
                candidate = new Date(candidate.getTime() + 60 * 1000);
            }
            return null;
        }

        function getMarketingThursdayDateParts(now) {
            const parisNow = parseParisParts(now);
            const dow = getParisWeekdayNumber(parisNow);
            const daysFromMonday = dow - 1;
            const mon = addDaysParisCalendar(parisNow.year, parisNow.month, parisNow.day, -daysFromMonday);
            const thu = addDaysParisCalendar(mon.year, mon.month, mon.day, 3);
            const thu19 = findParisInstantUtc(thu.year, thu.month, thu.day, 19);
            if (!thu19) return thu;
            if (now.getTime() < thu19.getTime()) return thu;
            return addDaysParisCalendar(thu.year, thu.month, thu.day, 7);
        }

        function getMarketingCountdownTargetUtc(now) {
            const thu = getMarketingThursdayDateParts(now);
            const t20 = findParisInstantUtc(thu.year, thu.month, thu.day, 20);
            if (!t20) return null;
            if (now.getTime() < t20.getTime()) return t20;
            const nextThu = addDaysParisCalendar(thu.year, thu.month, thu.day, 7);
            return findParisInstantUtc(nextThu.year, nextThu.month, nextThu.day, 20);
        }

        function formatParisDateNoTime(date) {
            const fmt = new Intl.DateTimeFormat('fr-FR', {
                timeZone: 'Europe/Paris',
                weekday: 'long',
                day: 'numeric',
                month: 'long',
                year: 'numeric'
            });
            const text = fmt.format(date);
            return text.charAt(0).toUpperCase() + text.slice(1);
        }

        /** Créneau d’inscription : aligné sur getRegistrationSessionInstantUtc (serveur). */
        function getOptinMasterclassSessionUtc(now) {
            const thu = getMarketingThursdayDateParts(now);
            return findParisInstantUtc(thu.year, thu.month, thu.day, 20);
        }

        function updatePopupSessionBubble() {
            const el = document.getElementById('popup-session-date');
            if (!el) return;
            const inst = getOptinMasterclassSessionUtc(new Date());
            if (!inst) return;
            el.textContent = formatParisDateNoTime(inst) + ' à 20h';
        }

        function updateCountdown() {
            updatePopupSessionBubble();
            const target = getMarketingCountdownTargetUtc(new Date());
            if (!target) return;

            const nowMs = Date.now();
            const diff = Math.max(0, target.getTime() - nowMs);
            const totalSeconds = Math.floor(diff / 1000);
            const days = Math.floor(totalSeconds / 86400);
            const hours = Math.floor((totalSeconds % 86400) / 3600);
            const minutes = Math.floor((totalSeconds % 3600) / 60);
            const seconds = totalSeconds % 60;
            document.getElementById('days').textContent = pad(days);
            document.getElementById('hours').textContent = pad(hours);
            document.getElementById('minutes').textContent = pad(minutes);
            document.getElementById('seconds').textContent = pad(seconds);
            document.getElementById('next-session-label').textContent =
                formatParisDateNoTime(target) + ' à 20h (heure de Paris)';
        }

        function normalizeReg(payload) {
            return {
                statut: payload.statut || 'inscrit',
                sessionStartsAt: payload.sessionStartsAt || payload.session_date,
                sessionEndsAt: payload.sessionEndsAt || payload.session_ends_at,
                offreExpiresAt: payload.offreExpiresAt || payload.offre_expires_at,
                token: payload.token
            };
        }

        function decideRoute(reg, token) {
            const now = Date.now();
            const sd = new Date(reg.sessionStartsAt).getTime();
            const oe = new Date(reg.offreExpiresAt).getTime();
            const st = reg.statut;

            if (st === 'acheteur') return { type: 'block', variant: 'acheteur' };
            if (st === 'no-show' || st === 'non-acheteur') return { type: 'block', variant: 'closed' };
            if (st === 'inscrit') {
                if (now < sd) {
                    return { type: 'redirect', url: '/masterclass/confirmation?t=' + encodeURIComponent(token) };
                }
                if (now >= sd && now < oe) {
                    return { type: 'redirect', url: '/masterclass/session?t=' + encodeURIComponent(token) };
                }
                return { type: 'block', variant: 'closed' };
            }
            if (st === 'present') {
                if (now < oe) {
                    return { type: 'redirect', url: '/masterclass/session?t=' + encodeURIComponent(token) };
                }
                return { type: 'block', variant: 'closed' };
            }
            return { type: 'main' };
        }

        function applyRoute(route) {
            if (route.type === 'redirect') {
                window.location.replace(route.url);
                return 'redirect';
            }
            if (route.type === 'block') {
                showBlocked(route.variant);
                return 'block';
            }
            showMain();
            return 'main';
        }

        function showMain() {
            const gl = document.getElementById('gate-loading');
            if (gl) gl.classList.add('is-hidden');
            document.getElementById('gate-blocked').classList.remove('is-visible');
            document.getElementById('page-main').classList.add('is-visible');
        }

        function showBlocked(variant) {
            document.getElementById('gate-loading').classList.add('is-hidden');
            document.getElementById('page-main').classList.remove('is-visible');
            const gb = document.getElementById('gate-blocked');
            gb.classList.add('is-visible');
            gb.querySelectorAll('[data-block-variant]').forEach(function (el) {
                el.style.display = el.getAttribute('data-block-variant') === variant ? 'block' : 'none';
            });
        }

        /** @returns {Promise<boolean>} true si la page opt-in doit s’initialiser */
        async function runEntryGate() {
            const url = new URL(window.location.href);
            if (url.searchParams.get('preview') === 'true') {
                showMain();
                return true;
            }
            const token = getStoredToken();
            if (!token) {
                showMain();
                return true;
            }
            try {
                const res = await fetch(
                    '/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token),
                );
                if (res.status === 404) {
                    clearToken();
                    showMain();
                    return true;
                }
                if (!res.ok) {
                    showMain();
                    return true;
                }
                const data = await res.json();
                if (!data.valid) {
                    clearToken();
                    showMain();
                    return true;
                }
                const reg = normalizeReg(Object.assign({}, data, { token }));
                const outcome = applyRoute(decideRoute(reg, token));
                if (outcome === 'redirect') return false;
                if (outcome === 'block') return false;
                return true;
            } catch (e) {
                showMain();
                return true;
            }
        }

        function routeFromEligibilityPayload(body, token) {
            const reg = normalizeReg(
                Object.assign({}, body, {
                    token: token || body.token,
                }),
            );
            return decideRoute(reg, reg.token);
        }

        function openPopup() {
            updatePopupSessionBubble();
            document.getElementById('custom-popup').style.display = 'block';
            document.body.style.overflow = 'hidden';
