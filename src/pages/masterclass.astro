        function initPhoneInput() {
            const wrap = document.getElementById('step2-phone-container');
            if (!wrap || typeof intlTelInput === 'undefined') {
                return;
            }
            wrap.innerHTML = '';
            const input = document.createElement('input');
            input.type = 'tel';
            input.id = 'phone';
            input.setAttribute('autocomplete', 'tel');
            input.placeholder = 'Ton numéro';
            wrap.appendChild(input);
            injectMasterclassPhoneDropdownStyles();
            iti = intlTelInput(input, {
                initialCountry: 'auto',
                geoIpLookup: function (callback) {
                    fetch('https://ipapi.co/json/')
                        .then((res) => res.json())
                        .then((data) => callback((data.country_code || 'fr').toLowerCase()))
                        .catch(() => callback('fr'));
                },
                preferredCountries: ['fr', 'be', 'ch', 'ca', 'ma', 'sn'],
                separateDialCode: true,
                dropdownContainer: document.body,
                utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@18.5.3/build/js/utils.js',
            });
            input.addEventListener('countrychange', function () {
                setTimeout(applyMasterclassPhoneStyles, 0);
            });
            if (iti.promise && typeof iti.promise.then === 'function') {
                iti.promise.then(applyMasterclassPhoneStyles);
            }
            setTimeout(applyMasterclassPhoneStyles, 80);
            setTimeout(applyMasterclassPhoneStyles, 350);
        }

        function setCommitRowError(on) {
            const row = document.getElementById('commit-row-label');
            if (row) row.classList.toggle('commit-row--error', Boolean(on));
        }

        /** Pays FR pour l’API (aligné ancienne liste) — dérivé du pays choisi sur le champ tel (IP + drapeau). */
        function countryIsoToPaysFr(iso2) {
            const code = (iso2 || '').toLowerCase();
            const map = {
                fr: 'France',
                be: 'Belgique',
                ch: 'Suisse',
                ca: 'Canada',
                ma: 'Maroc',
                sn: 'Sénégal',
                ci: "Côte d'Ivoire",
                dz: 'Algérie',
                tn: 'Tunisie',
                re: 'France',
                gp: 'France',
                mq: 'France',
                gf: 'France',
                pf: 'France',
                yt: 'France',
                nc: 'France',
                bl: 'France',
                mf: 'France',
                pm: 'France',
                wf: 'France',
                lu: 'Luxembourg',
                mc: 'Monaco',
            };
            return map[code] || 'Autre';
        }

        function validateStep1() {
            const msg = document.getElementById('step1-message');
            msg.textContent = '';
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!name || !email) {
                alert('Merci de remplir prénom et email.');
                return false;
            }
            if (!emailRegex.test(email)) {
                alert('Merci de saisir un email valide.');
                return false;
            }
            state.name = name;
            state.email = email.toLowerCase();
            return true;
        }

        function validateContactStep() {
            const rawPhone = document.getElementById('phone').value.trim();
            let phone = rawPhone;

            if (iti) {
                try {
                    phone = iti.getNumber();
                } catch (error) {
                    phone = rawPhone;
                }
            }

            if (!phone) {
                alert('Merci de saisir ton numéro de téléphone.');
                return false;
            }

            let pays = 'Autre';
            if (iti) {
                try {
                    const d = iti.getSelectedCountryData();
                    if (d && d.iso2) pays = countryIsoToPaysFr(d.iso2);
                } catch (e) {
                    /* ignore */
                }
            }

            state.phone = phone;
            state.country = pays;
            return true;
        }

        function validateCommitStep() {
            const msg = document.getElementById('step3-message');
            const commit = document.getElementById('commit-present');
            msg.textContent = '';
            setCommitRowError(false);
            if (!commit || !commit.checked) {
                setCommitRowError(true);
                msg.textContent = 'Merci de cocher la case pour confirmer ta présence jeudi à 20h.';
                commit?.focus();
                return false;
            }
            return true;
        }

        async function submitRegistration() {
            const formStatus = document.getElementById('form-status');
            const submitBtn = document.getElementById('step3-submit');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Inscription...';
            formStatus.textContent = '';

            try {
                const response = await fetch('/.netlify/functions/register-webinaire', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: state.email,
                        prenom: state.name,
                        creneau: '20h',
                        telephone: state.phone,
                        pays: state.country,
                    }),
                });

                const result = await response.json();

                if (response.status === 409 && result.token) {
                    setTokenEverywhere(result.token);
                    closePopup();
                    applyRoute(routeFromEligibilityPayload(result, result.token));
                    return;
                }

                if (response.status === 403 && result.reason === 'excluded') {
                    formStatus.textContent =
                        'Tu n\u2019es pas \u00e9ligible pour suivre cette masterclass.';
                    submitBtn.disabled = false;
                    submitBtn.textContent = STEP3_SUBMIT_LABEL;
                    return;
                }

                if (!response.ok || !result?.success || !result?.token) {
                    throw new Error(result?.error || 'Erreur inconnue');
                }

                setTokenEverywhere(result.token);
                window.location.href = '/masterclass/confirmation?t=' + encodeURIComponent(result.token);
            } catch (error) {
                formStatus.textContent = 'Une erreur est survenue. Merci de réessayer.';
                submitBtn.disabled = false;
                submitBtn.textContent = STEP3_SUBMIT_LABEL;
            }
        }

        async function saveStep1Lead() {
            const response = await fetch('/.netlify/functions/register-webinaire', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    email: state.email,
                    prenom: state.name,
                    creneau: '20h',
                }),
            });
            const result = await response.json();
            if (response.status === 403 && result.reason === 'excluded') {
                return { ok: false, excluded: true };
            }
            if (!response.ok || !result?.success || !result?.token) {
                return { ok: false };
            }
            setTokenEverywhere(result.token);
            return { ok: true, token: result.token };
        }

        function formatProofCount(n) {
            const rounded = Math.floor(n);
            const grouped = rounded.toLocaleString('fr-FR');
            return '+' + grouped.replace(/\u202f/g, ' ');
        }

        function initProofSectionCountUp() {
            const section = document.querySelector('.proof-section');
            const elSubs = document.getElementById('proof-count-subs');
            const elStudents = document.getElementById('proof-count-students');
            if (!section || !elSubs || !elStudents) return;

            const targetSubs = Number(elSubs.dataset.target);
            const targetStudents = Number(elStudents.dataset.target);
            if (!Number.isFinite(targetSubs) || !Number.isFinite(targetStudents)) return;

            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                section.classList.add('proof-section--visible');
                elSubs.textContent = formatProofCount(targetSubs);
                elStudents.textContent = formatProofCount(targetStudents);
                return;
            }

            let started = false;

            function easeOutCubic(t) {
                return 1 - Math.pow(1 - t, 3);
            }

            function tick(durationMs) {
                const start = performance.now();
                function frame(now) {
                    const raw = Math.min(1, (now - start) / durationMs);
                    const e = easeOutCubic(raw);
                    elSubs.textContent = formatProofCount(targetSubs * e);
                    elStudents.textContent = formatProofCount(targetStudents * e);
                    if (raw < 1) {
                        requestAnimationFrame(frame);
                    } else {
                        elSubs.textContent = formatProofCount(targetSubs);
                        elStudents.textContent = formatProofCount(targetStudents);
                    }
                }
                requestAnimationFrame(frame);
            }

            function start() {
                if (started) return;
                started = true;
                section.classList.add('proof-section--visible');
                tick(2000);
            }

            if (!('IntersectionObserver' in window)) {
                start();
                return;
            }

            const io = new IntersectionObserver(
                (entries) => {
                    for (let i = 0; i < entries.length; i++) {
                        if (entries[i].isIntersecting) {
                            start();
                            io.disconnect();
                            return;
                        }
                    }
                },
                { threshold: 0.2, rootMargin: '0px 0px -8% 0px' }
            );
            io.observe(section);
        }

        function initMainInteractions() {
            refreshCountdownTarget();
            updateCountdown();
            startCountdownTicker();
            document.addEventListener('visibilitychange', function () {
                if (document.hidden) {
                    stopCountdownTicker();
                } else {
                    refreshCountdownTarget();
                    updateCountdown();
                    startCountdownTicker();
                }
            });
            initProofSectionCountUp();

            var _preGif = new Image();
            _preGif.src = '/media/pages/blue butterfly animation 2.gif';

            document.querySelectorAll('.popup-trigger').forEach((btn) => {
                btn.addEventListener('click', function () {
                    showPreOptinOverlayThenOpenPopup();
                });
            });

            document.getElementById('commit-present').addEventListener('change', function () {
                if (this.checked) setCommitRowError(false);
            });

            document.getElementById('popup-close-btn').addEventListener('click', closePopup);
            document.getElementById('custom-popup').addEventListener('click', function (event) {
                if (event.target === this) closePopup();
            });
            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') closePopup();
            });

            document.getElementById('step1-button').addEventListener('click', async function () {
                const msg = document.getElementById('step1-message');
                msg.textContent = '';
                if (!validateStep1()) return;
                const btn = this;
                btn.disabled = true;
                try {
                    const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: state.email }),
                    });
                    const body = await res.json();
                    if (!res.ok) {
                        msg.textContent = 'Vérification impossible. Réessaie dans un instant.';
                        return;
                    }
                    if (body.eligible === false && body.reason === 'excluded') {
                        msg.textContent =
                            'Tu n\u2019es pas \u00e9ligible pour suivre cette masterclass.';
                        return;
                    }
                    if (body.eligible === false && body.reason === 'already_registered') {
                        var sessionDate = body.session_date ? new Date(body.session_date).getTime() : 0;
                        var offreExpires = body.offre_expires_at ? new Date(body.offre_expires_at).getTime() : 0;
                        var now = Date.now();
                        var sessionPassed = sessionDate > 0 && now >= (offreExpires || sessionDate);

                        if (sessionPassed) {
                            msg.textContent =
                                'Tu es d\u00e9j\u00e0 inscrit(e) \u00e0 une session pr\u00e9c\u00e9dente. Tu ne peux pas te r\u00e9inscrire.';
                            return;
                        }
                        if (body.token) {
                            setTokenEverywhere(body.token);
                            closePopup();
                            applyRoute(routeFromEligibilityPayload(body, body.token));
                            return;
                        }
                        msg.textContent =
                            'Tu es d\u00e9j\u00e0 inscrit(e). Tu ne peux pas te r\u00e9inscrire.';
                        return;
                    }
                    goToContactStep();
                    // UX: on passe immédiatement à l'étape 2 et on fait la capture en arrière-plan.
                    saveStep1Lead()
                        .then(function (capture) {
                            if (capture && capture.ok && capture.token) {
                                state._preCapturedToken = capture.token;
                            }
                        })
                        .catch(function () {});
                } catch (e) {
                    msg.textContent = 'Vérification impossible. Réessaie dans un instant.';
                } finally {
                    btn.disabled = false;
                }
            });

            document.getElementById('step2-next').addEventListener('click', function () {
                if (!validateContactStep()) return;
                goToCommitStep();
            });

            document.getElementById('step3-submit').addEventListener('click', function () {
                if (!validateCommitStep()) return;
                submitRegistration();
            });
        }

        async function bootstrapAfterAccessGate() {
            const shouldInit = await runEntryGate();
            if (shouldInit) {
                initMainInteractions();
            }
        }

        function hasMasterclassSessionAccess() {
            try {
                return sessionStorage.getItem(MASTERCLASS_ACCESS_SESSION) === 'true';
            } catch (e) {
                return false;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const pwdGate = document.getElementById('masterclass-password-gate');
            const pwdInput = document.getElementById('masterclass-pwd-input');
            const pwdBtn = document.getElementById('masterclass-pwd-submit');
            const pwdErr = document.getElementById('masterclass-pwd-error');
            const url = new URL(window.location.href);
            const previewBypass = url.searchParams.get('preview') === 'dev';

            function unlockAndStart() {
                pwdGate.classList.add('is-hidden');
                bootstrapAfterAccessGate();
            }

            if (previewBypass || hasMasterclassSessionAccess()) {
                pwdGate.classList.add('is-hidden');
                bootstrapAfterAccessGate();
                return;
            }

            pwdInput.focus();

            function tryPassword() {
                pwdErr.textContent = '';
                const v = (pwdInput.value || '').trim();
                if (v === MASTERCLASS_TEMP_PASSWORD) {
                    try {
                        sessionStorage.setItem(MASTERCLASS_ACCESS_SESSION, 'true');
                    } catch (e) {
                        /* ignore */
                    }
                    unlockAndStart();
                    return;
                }
                pwdErr.textContent = 'Mot de passe incorrect.';
                pwdInput.value = '';
                pwdInput.focus();
            }

            pwdBtn.addEventListener('click', tryPassword);
            pwdInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') tryPassword();
            });
        });
    </script>
</body>
</html>
