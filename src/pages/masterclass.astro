                </label>
                <p id="step3-message" class="form-error" role="alert"></p>
                <button id="step3-submit" class="submit-btn" type="button">Confirmer mon inscription</button>
                <p id="form-status" class="success-copy"></p>
            </div>
        </div>
    </div>

    <script>
        // @ts-nocheck
        /** Aligné sur netlify/functions/lib/webinaire-session-paris.mjs (cutoff jeudi 19h Paris). Routes : /masterclass. */
        /** TEMP — supprimer tout le bloc mot de passe avant lancement public */
        const MASTERCLASS_ACCESS_SESSION = 'masterclass_access';
        const MASTERCLASS_TEMP_PASSWORD = 'masterclass';

        const TOKEN_KEY = 'masterclass_es2_token';
        const LEGACY_TOKEN_KEY = 'webinaire_es2_token';
        const COOKIE_MAX = 365 * 24 * 60 * 60;
        const STEP3_SUBMIT_LABEL = 'Confirmer mon inscription';
        const PRE_OPTIN_DELAY_MS = 4000;
        const PRE_OPTIN_FADE_MS = 300;
        const PRE_OPTIN_SUCCESS_MS = 1420;

        const state = {
            name: '',
            email: '',
            phone: '',
            country: ''
        };

        let iti = null;
        let preOptinOverlayBusy = false;

        function pad(value) {
            return String(value).padStart(2, '0');
        }

        function getCookie(name) {
            const esc = name.replace(/[$()*+.?[\\\]^{|}]/g, '\\$&');
            const m = document.cookie.match(new RegExp('(?:^|; )' + esc + '=([^;]*)'));
            return m ? decodeURIComponent(m[1]) : '';
        }

        function setTokenEverywhere(token) {
            localStorage.setItem(TOKEN_KEY, token);
            document.cookie = `${TOKEN_KEY}=${encodeURIComponent(token)}; path=/; max-age=${COOKIE_MAX}; SameSite=Lax`;
        }

        function clearToken() {
            localStorage.removeItem(TOKEN_KEY);
            localStorage.removeItem(LEGACY_TOKEN_KEY);
            document.cookie = `${TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
            document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
        }

        function getStoredToken() {
            let t = (localStorage.getItem(TOKEN_KEY) || getCookie(TOKEN_KEY) || '').trim();
            if (t) return t;
            const legacy = (localStorage.getItem(LEGACY_TOKEN_KEY) || getCookie(LEGACY_TOKEN_KEY) || '').trim();
            if (legacy) {
                setTokenEverywhere(legacy);
                localStorage.removeItem(LEGACY_TOKEN_KEY);
                document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
                return legacy;
            }
            return '';
        }

        function parseParisParts(date) {
            const formatter = new Intl.DateTimeFormat('fr-FR', {
                timeZone: 'Europe/Paris',
                year: 'numeric',
                month: 'numeric',
                day: 'numeric',
                weekday: 'short',
                hour: 'numeric',
                minute: 'numeric',
                second: 'numeric',
                hourCycle: 'h23'
            });
            const parts = formatter.formatToParts(date);
            const value = (type) => Number(parts.find((p) => p.type === type)?.value || 0);
            const weekRaw = parts.find((p) => p.type === 'weekday')?.value || '';
            return {
                year: value('year'),
                month: value('month'),
                day: value('day'),
                hour: value('hour'),
                minute: value('minute'),
                second: value('second'),
                weekdayText: weekRaw.toLowerCase()
            };
        }

        function getParisWeekdayNumber(parts) {
            const dayMap = { lun: 1, mar: 2, mer: 3, jeu: 4, ven: 5, sam: 6, dim: 7 };
            for (const key of Object.keys(dayMap)) {
                if (parts.weekdayText.startsWith(key)) return dayMap[key];
            }
            return 1;
        }

        function addDaysParisCalendar(year, month, day, deltaDays) {
            const d = new Date(Date.UTC(year, month - 1, day + deltaDays, 12, 0, 0));
            const p = parseParisParts(d);
            return { year: p.year, month: p.month, day: p.day };
        }

        function findParisInstantUtc(parisYear, parisMonth, parisDay, parisHour) {
            // Calcul direct de l’offset UTC ↔ Paris (converge en 1–2 itérations,
            // gère DST naturellement). Remplace l’ancienne boucle minute-par-minute
            // qui pouvait itérer jusqu’à 4000 fois et saturait le thread principal.
            const targetWallMs = Date.UTC(parisYear, parisMonth - 1, parisDay, parisHour, 0, 0);
            let utcGuess = targetWallMs;
            for (let i = 0; i < 3; i++) {
                const p = parseParisParts(new Date(utcGuess));
                if (p.year === parisYear && p.month === parisMonth && p.day === parisDay && p.hour === parisHour) {
                    return new Date(utcGuess);
                }
                const parisWallMs = Date.UTC(p.year, p.month - 1, p.day, p.hour, p.minute, p.second);
                const offsetMs = parisWallMs - utcGuess;
                utcGuess = targetWallMs - offsetMs;
            }
            const p = parseParisParts(new Date(utcGuess));
            if (p.year === parisYear && p.month === parisMonth && p.day === parisDay && p.hour === parisHour) {
                return new Date(utcGuess);
            }
            return null;
        }

        function getMarketingThursdayDateParts(now) {
            const parisNow = parseParisParts(now);
            const dow = getParisWeekdayNumber(parisNow);
            const daysFromMonday = dow - 1;
            const mon = addDaysParisCalendar(parisNow.year, parisNow.month, parisNow.day, -daysFromMonday);
            const thu = addDaysParisCalendar(mon.year, mon.month, mon.day, 3);
            const thu19 = findParisInstantUtc(thu.year, thu.month, thu.day, 19);
            if (!thu19) return thu;
            if (now.getTime() < thu19.getTime()) return thu;
            return addDaysParisCalendar(thu.year, thu.month, thu.day, 7);
        }

        function getMarketingCountdownTargetUtc(now) {
            const thu = getMarketingThursdayDateParts(now);
            const t20 = findParisInstantUtc(thu.year, thu.month, thu.day, 20);
            if (!t20) return null;
            if (now.getTime() < t20.getTime()) return t20;
            const nextThu = addDaysParisCalendar(thu.year, thu.month, thu.day, 7);
            return findParisInstantUtc(nextThu.year, nextThu.month, nextThu.day, 20);
        }

        /**
         * Fallback robuste pour navigateurs qui gèrent mal certains formats Intl.
         * On calcule le prochain jeudi 20h (heure de Paris) via une projection locale.
         */
        function getFallbackParisThursday20Utc(now) {
            const parisProjected = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Paris' }));
            const offsetMs = now.getTime() - parisProjected.getTime();
            const day = parisProjected.getDay(); // 0=dimanche ... 4=jeudi
            let deltaToThu = (4 - day + 7) % 7;
            const thu20 = new Date(parisProjected);
            thu20.setDate(thu20.getDate() + deltaToThu);
            thu20.setHours(20, 0, 0, 0);
            if (parisProjected.getTime() >= thu20.getTime()) {
                thu20.setDate(thu20.getDate() + 7);
            }
            return new Date(thu20.getTime() + offsetMs);
        }

        function getMarketingCountdownTargetUtcSafe(now) {
            const primary = getMarketingCountdownTargetUtc(now);
            if (primary) return primary;
            return getFallbackParisThursday20Utc(now);
        }

        function formatParisDateNoTime(date) {
            const fmt = new Intl.DateTimeFormat('fr-FR', {
                timeZone: 'Europe/Paris',
                weekday: 'long',
                day: 'numeric',
                month: 'long',
                year: 'numeric'
            });
            const text = fmt.format(date);
            return text.charAt(0).toUpperCase() + text.slice(1);
        }

        /** Créneau d’inscription : aligné sur getRegistrationSessionInstantUtc (serveur). */
        function getOptinMasterclassSessionUtc(now) {
            const thu = getMarketingThursdayDateParts(now);
            return findParisInstantUtc(thu.year, thu.month, thu.day, 20);
        }

        function updatePopupSessionBubble() {
            const el = document.getElementById('popup-session-date');
            if (!el) return;
            const now = new Date();
            const inst = getOptinMasterclassSessionUtc(now) || getFallbackParisThursday20Utc(now);
            if (!inst) return;
            el.textContent = formatParisDateNoTime(inst) + ' à 20h';
        }

        // --- Countdown: cible pré-calculée, recalcul uniquement au rollover ---
        // Évite d’appeler Intl.DateTimeFormat + formatToParts chaque seconde
        // (principale cause de lag Safari/Firefox sur le main thread).
        let __countdownTargetMs = null;
        let __countdownTicker = null;

        function refreshCountdownTarget() {
            const t = getMarketingCountdownTargetUtcSafe(new Date());
            __countdownTargetMs = t ? t.getTime() : null;
            const labelEl = document.getElementById('next-session-label');
            if (labelEl && t) {
                labelEl.textContent = formatParisDateNoTime(t) + ' à 20h (heure de Paris)';
            }
            updatePopupSessionBubble();
        }

        function updateCountdown() {
            if (__countdownTargetMs === null) {
                refreshCountdownTarget();
                if (__countdownTargetMs === null) return;
            }
            let diff = __countdownTargetMs - Date.now();
            if (diff <= 0) {
                refreshCountdownTarget();
                if (__countdownTargetMs === null) return;
                diff = Math.max(0, __countdownTargetMs - Date.now());
            }
            const totalSeconds = Math.floor(diff / 1000);
            const days = Math.floor(totalSeconds / 86400);
            const hours = Math.floor((totalSeconds % 86400) / 3600);
            const minutes = Math.floor((totalSeconds % 3600) / 60);
            const seconds = totalSeconds % 60;
            const dEl = document.getElementById('days');
            const hEl = document.getElementById('hours');
            const mEl = document.getElementById('minutes');
            const sEl = document.getElementById('seconds');
            if (dEl) dEl.textContent = pad(days);
            if (hEl) hEl.textContent = pad(hours);
            if (mEl) mEl.textContent = pad(minutes);
            if (sEl) sEl.textContent = pad(seconds);
        }

        function startCountdownTicker() {
            if (__countdownTicker) return;
            __countdownTicker = setInterval(updateCountdown, 1000);
        }

        function stopCountdownTicker() {
            if (__countdownTicker) {
                clearInterval(__countdownTicker);
                __countdownTicker = null;
            }
        }

        function normalizeReg(payload) {
            return {
                statut: payload.statut || 'inscrit',
                sessionStartsAt: payload.sessionStartsAt || payload.session_date,
                sessionEndsAt: payload.sessionEndsAt || payload.session_ends_at,
                offreExpiresAt: payload.offreExpiresAt || payload.offre_expires_at,
                token: payload.token
            };
        }

        function decideRoute(reg, token) {
            const now = Date.now();
            const sd = new Date(reg.sessionStartsAt).getTime();
            const oe = new Date(reg.offreExpiresAt).getTime();
            if (!Number.isFinite(sd) || !Number.isFinite(oe)) return { type: 'main' };
            if (now < sd) {
                return { type: 'redirect', url: '/masterclass/confirmation?t=' + encodeURIComponent(token) };
            }
            if (now >= sd && now < oe) {
                return { type: 'redirect', url: '/masterclass/replay?t=' + encodeURIComponent(token) };
            }
            return { type: 'block', variant: 'closed' };
        }

        function applyRoute(route) {
            if (route.type === 'redirect') {
                window.location.replace(route.url);
                return 'redirect';
            }
            if (route.type === 'block') {
                showBlocked(route.variant);
                return 'block';
            }
            showMain();
            return 'main';
        }

        function showMain() {
            const gl = document.getElementById('gate-loading');
            if (gl) gl.classList.add('is-hidden');
            document.getElementById('gate-blocked').classList.remove('is-visible');
            document.getElementById('page-main').classList.add('is-visible');
        }

        function showBlocked(variant) {
            document.getElementById('gate-loading').classList.add('is-hidden');
            document.getElementById('page-main').classList.remove('is-visible');
            const gb = document.getElementById('gate-blocked');
            gb.classList.add('is-visible');
            gb.querySelectorAll('[data-block-variant]').forEach(function (el) {
                el.style.display = el.getAttribute('data-block-variant') === variant ? 'block' : 'none';
            });
        }

        /** @returns {Promise<boolean>} true si la page opt-in doit s’initialiser */
        async function runEntryGate() {
            const url = new URL(window.location.href);
            if (url.searchParams.get('preview') === 'dev') {
                showMain();
                return true;
            }
            const token = getStoredToken();
            if (!token) {
                showMain();
                return true;
            }
            try {
                const res = await fetch(
                    '/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token),
                );
                if (res.status === 404) {
                    clearToken();
                    showMain();
                    return true;
                }
                if (!res.ok) {
                    showMain();
                    return true;
                }
                const data = await res.json();
                if (!data.valid) {
                    clearToken();
                    showMain();
                    return true;
                }
                const reg = normalizeReg(Object.assign({}, data, { token }));
                const outcome = applyRoute(decideRoute(reg, token));
                if (outcome === 'redirect') return false;
                if (outcome === 'block') return false;
                return true;
            } catch (e) {
                showMain();
                return true;
            }
        }

        function routeFromEligibilityPayload(body, token) {
            const reg = normalizeReg(
                Object.assign({}, body, {
                    token: token || body.token,
                }),
            );
            return decideRoute(reg, reg.token);
        }

        function openPopup() {
            updatePopupSessionBubble();
            document.getElementById('custom-popup').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closePopup() {
            document.getElementById('custom-popup').style.display = 'none';
            document.body.style.overflow = '';
        }

        function showPreOptinOverlayThenOpenPopup() {
            if (preOptinOverlayBusy) return;
            const overlay = document.getElementById('pre-optin-overlay');
            if (!overlay) {
                openPopup();
                return;
            }
            preOptinOverlayBusy = true;
            overlay.setAttribute('aria-hidden', 'false');
            overlay.classList.remove('is-fading');
            overlay.classList.add('is-visible');
            const success = document.getElementById('pre-optin-success');
            if (success) success.classList.remove('is-visible');
            document.body.style.overflow = 'hidden';

            setTimeout(function () {
                if (success) success.classList.add('is-visible');
                playValidationTone();
                setTimeout(function () {
                    // Ouvre d'abord le popup, puis fond l'overlay par-dessus
                    // pour éviter tout flash visuel de la page.
                    openPopup();
                    requestAnimationFrame(function () {
                        overlay.classList.add('is-fading');
                        setTimeout(function () {
                            overlay.classList.remove('is-visible', 'is-fading');
                            overlay.setAttribute('aria-hidden', 'true');
                            if (success) success.classList.remove('is-visible');
                            preOptinOverlayBusy = false;
                        }, PRE_OPTIN_FADE_MS);
                    });
                }, PRE_OPTIN_SUCCESS_MS);
            }, PRE_OPTIN_DELAY_MS);
        }

        function playValidationTone() {
            try {
                const AudioCtx = window.AudioContext || window.webkitAudioContext;
                if (!AudioCtx) return;
                const ctx = new AudioCtx();
                const now = ctx.currentTime;

                const osc1 = ctx.createOscillator();
                const osc2 = ctx.createOscillator();
                const gain = ctx.createGain();

                osc1.type = 'sine';
                osc2.type = 'triangle';
                osc1.frequency.setValueAtTime(880, now);
                osc2.frequency.setValueAtTime(1320, now + 0.06);

                gain.gain.setValueAtTime(0.0001, now);
                gain.gain.exponentialRampToValueAtTime(0.08, now + 0.03);
                gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.24);

                osc1.connect(gain);
                osc2.connect(gain);
                gain.connect(ctx.destination);

                osc1.start(now);
                osc2.start(now + 0.06);
                osc1.stop(now + 0.24);
                osc2.stop(now + 0.24);

                osc2.onended = function () {
                    ctx.close().catch(() => {});
                };
            } catch (e) {
                /* ignore audio errors */
            }
        }

