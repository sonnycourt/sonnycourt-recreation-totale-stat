        /** Pays FR pour l’API (aligné ancienne liste) — dérivé du pays choisi sur le champ tel (IP + drapeau). */
        function countryIsoToPaysFr(iso2) {
            const code = (iso2 || '').toLowerCase();
            const map = {
                fr: 'France',
                be: 'Belgique',
                ch: 'Suisse',
                ca: 'Canada',
                ma: 'Maroc',
                sn: 'Sénégal',
                ci: "Côte d'Ivoire",
                dz: 'Algérie',
                tn: 'Tunisie',
                re: 'France',
                gp: 'France',
                mq: 'France',
                gf: 'France',
                pf: 'France',
                yt: 'France',
                nc: 'France',
                bl: 'France',
                mf: 'France',
                pm: 'France',
                wf: 'France',
                lu: 'Luxembourg',
                mc: 'Monaco',
            };
            return map[code] || 'Autre';
        }

        function validateStep1() {
            const msg = document.getElementById('step1-message');
            msg.textContent = '';
            setCommitRowError(false);
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!name || !email) {
                alert('Merci de remplir prénom et email.');
                return false;
            }
            if (!emailRegex.test(email)) {
                alert('Merci de saisir un email valide.');
                return false;
            }
            const commit = document.getElementById('commit-present');
            if (!commit || !commit.checked) {
                setCommitRowError(true);
                msg.textContent = 'Merci de cocher la case pour confirmer ta présence jeudi à 20h.';
                commit.focus();
                return false;
            }
            state.name = name;
            state.email = email.toLowerCase();
            return true;
        }

        function validateContactStep() {
            const rawPhone = document.getElementById('phone').value.trim();
            let phone = rawPhone;

            if (iti) {
                try {
                    phone = iti.getNumber();
                } catch (error) {
                    phone = rawPhone;
                }
            }

            if (!phone) {
                alert('Merci de saisir ton numéro de téléphone.');
                return false;
            }

            let pays = 'Autre';
            if (iti) {
                try {
                    const d = iti.getSelectedCountryData();
                    if (d && d.iso2) pays = countryIsoToPaysFr(d.iso2);
                } catch (e) {
                    /* ignore */
                }
            }

            state.phone = phone;
            state.country = pays;
            return true;
        }

        async function submitRegistration() {
            const formStatus = document.getElementById('form-status');
            const submitBtn = document.getElementById('step2-submit');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Inscription...';
            formStatus.textContent = '';

            try {
                const response = await fetch('/.netlify/functions/register-webinaire', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: state.email,
                        prenom: state.name,
                        creneau: '20h',
                        telephone: state.phone,
                        pays: state.country,
                    }),
                });

                const result = await response.json();

                if (response.status === 409 && result.token) {
                    setTokenEverywhere(result.token);
                    closePopup();
                    applyRoute(routeFromEligibilityPayload(result, result.token));
                    return;
                }

                if (response.status === 403 && result.reason === 'excluded') {
                    formStatus.textContent =
                        'Tu as déjà accès à une de nos formations. Consulte tes emails pour y accéder.';
                    submitBtn.disabled = false;
                    submitBtn.textContent = STEP2_SUBMIT_LABEL;
                    return;
                }

                if (!response.ok || !result?.success || !result?.token) {
                    throw new Error(result?.error || 'Erreur inconnue');
                }

                setTokenEverywhere(result.token);
                window.location.href = '/masterclass/confirmation?t=' + encodeURIComponent(result.token);
            } catch (error) {
                formStatus.textContent = 'Une erreur est survenue. Merci de réessayer.';
                submitBtn.disabled = false;
                submitBtn.textContent = STEP2_SUBMIT_LABEL;
            }
        }

        function initMainInteractions() {
            updateCountdown();
            setInterval(updateCountdown, 1000);

            document.querySelectorAll('.popup-trigger').forEach((btn) => {
                btn.addEventListener('click', function () {
                    openPopup();
                });
            });

            document.getElementById('commit-present').addEventListener('change', function () {
                if (this.checked) setCommitRowError(false);
            });

            document.getElementById('popup-close-btn').addEventListener('click', closePopup);
            document.getElementById('custom-popup').addEventListener('click', function (event) {
                if (event.target === this) closePopup();
            });
            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') closePopup();
            });

            document.getElementById('step1-button').addEventListener('click', async function () {
                const msg = document.getElementById('step1-message');
                msg.textContent = '';
                if (!validateStep1()) return;
                const btn = this;
                btn.disabled = true;
                try {
                    const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: state.email }),
                    });
                    const body = await res.json();
                    if (!res.ok) {
                        msg.textContent = 'Vérification impossible. Réessaie dans un instant.';
                        return;
                    }
                    if (body.eligible === false && body.reason === 'excluded') {
                        msg.textContent =
                            'Tu as déjà accès à une de nos formations. Consulte tes emails pour y accéder.';
                        return;
                    }
                    if (body.eligible === false && body.reason === 'already_registered' && body.token) {
                        setTokenEverywhere(body.token);
                        const route = routeFromEligibilityPayload(body, body.token);
                        if (route.type === 'redirect') {
                            window.location.replace(route.url);
                            return;
                        }
                        if (route.type === 'block') {
                            closePopup();
                            applyRoute(route);
                            return;
                        }
                        goToContactStep();
                        return;
                    }
                    goToContactStep();
                } catch (e) {
                    msg.textContent = 'Vérification impossible. Réessaie dans un instant.';
                } finally {
                    btn.disabled = false;
                }
            });

            document.getElementById('step2-submit').addEventListener('click', function () {
                if (!validateContactStep()) return;
                submitRegistration();
            });
        }

        async function bootstrapAfterAccessGate() {
            const shouldInit = await runEntryGate();
            if (shouldInit) {
                initMainInteractions();
            }
        }

        function hasMasterclassSessionAccess() {
            try {
                return sessionStorage.getItem(MASTERCLASS_ACCESS_SESSION) === 'true';
            } catch (e) {
                return false;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const pwdGate = document.getElementById('masterclass-password-gate');
            const pwdInput = document.getElementById('masterclass-pwd-input');
            const pwdBtn = document.getElementById('masterclass-pwd-submit');
            const pwdErr = document.getElementById('masterclass-pwd-error');
            const url = new URL(window.location.href);
            const previewBypass = url.searchParams.get('preview') === 'true';

            function unlockAndStart() {
                pwdGate.classList.add('is-hidden');
                bootstrapAfterAccessGate();
            }

            if (previewBypass || hasMasterclassSessionAccess()) {
                pwdGate.classList.add('is-hidden');
                bootstrapAfterAccessGate();
                return;
            }

            pwdInput.focus();

            function tryPassword() {
                pwdErr.textContent = '';
                const v = (pwdInput.value || '').trim();
                if (v === MASTERCLASS_TEMP_PASSWORD) {
                    try {
                        sessionStorage.setItem(MASTERCLASS_ACCESS_SESSION, 'true');
                    } catch (e) {
                        /* ignore */
                    }
                    unlockAndStart();
                    return;
                }
                pwdErr.textContent = 'Mot de passe incorrect.';
                pwdInput.value = '';
                pwdInput.focus();
            }

            pwdBtn.addEventListener('click', tryPassword);
            pwdInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') tryPassword();
            });
        });
    </script>
</body>
</html>
