        function initPhoneInput() {
            const wrap = document.getElementById('step2-phone-container');
            if (!wrap || typeof intlTelInput === 'undefined') {
                return;
            }
            wrap.innerHTML = '';
            const input = document.createElement('input');
            input.type = 'tel';
            input.id = 'phone';
            input.setAttribute('autocomplete', 'tel');
            input.placeholder = 'Ton numéro';
            wrap.appendChild(input);
            injectMasterclassPhoneDropdownStyles();
            iti = intlTelInput(input, {
                initialCountry: 'auto',
                geoIpLookup: function (callback) {
                    fetch('https://ipapi.co/json/')
                        .then((res) => res.json())
                        .then((data) => callback((data.country_code || 'fr').toLowerCase()))
                        .catch(() => callback('fr'));
                },
                preferredCountries: ['fr', 'be', 'ch', 'ca', 'ma', 'sn'],
                separateDialCode: true,
                dropdownContainer: document.body,
                utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@18.5.3/build/js/utils.js',
            });
            input.addEventListener('countrychange', function () {
                setTimeout(applyMasterclassPhoneStyles, 0);
            });
            if (iti.promise && typeof iti.promise.then === 'function') {
                iti.promise.then(applyMasterclassPhoneStyles);
            }
            setTimeout(applyMasterclassPhoneStyles, 80);
            setTimeout(applyMasterclassPhoneStyles, 350);
        }

