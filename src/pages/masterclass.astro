---
import GAConsentMode from '../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Masterclass Esprit Subconscient 2.0 - Réserve ta place</title>
    <meta name="description" content="Masterclass gratuite : reprogramme ton subconscient et manifeste la vie de tes rêves. Réserve ta place au prochain webinaire.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
    <link rel="preload" as="image" href="/media/pages/blue%20butterfly%20animation%202.gif" type="image/gif">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@18.5.3/build/css/intlTelInput.css">
    <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.5.3/build/js/intlTelInput.min.js" defer></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #3b82f6;
            --primary-light: #60a5fa;
            --primary-dark: #2563eb;
            --accent: #93c5fd;
            --bg-dark: #0a0a1a;
            --text-white: #ffffff;
            --text-muted: rgba(255, 255, 255, 0.72);
            --border: rgba(59, 130, 246, 0.35);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: var(--text-white);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .bg-gradient {
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 100%, rgba(37, 99, 235, 0.2) 0%, transparent 50%),
                linear-gradient(180deg, #0a0a1a 0%, #1a1a3a 50%, #0a0a1a 100%);
            z-index: -1;
        }

        .gate-loading {
            position: fixed;
            inset: 0;
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 16px;
            background: linear-gradient(180deg, #0a1628 0%, #0a0a1a 100%);
        }

        .gate-loading.is-hidden {
            display: none;
        }

        .gate-spinner {
            width: 44px;
            height: 44px;
            border: 3px solid rgba(59, 130, 246, 0.25);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: gateSpin 0.85s linear infinite;
        }

        @keyframes gateSpin {
            to { transform: rotate(360deg); }
        }

        .gate-loading p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .pre-optin-overlay {
            position: fixed;
            inset: 0;
            z-index: 10020;
            display: none;
            opacity: 0;
            align-items: center;
            justify-content: flex-start;
            flex-direction: column;
            padding: 36px 16px 16px;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.24) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 100%, rgba(37, 99, 235, 0.18) 0%, transparent 50%),
                linear-gradient(180deg, #071227 0%, #0a0a1a 55%, #050510 100%);
            transition: opacity 0.3s ease;
        }

        .pre-optin-overlay.is-visible {
            display: flex;
            opacity: 1;
            align-items: center;
        }

        .pre-optin-overlay.is-fading {
            opacity: 0;
        }

        .pre-optin-overlay__inner {
            text-align: center;
            width: min(100%, 320px);
            height: clamp(150px, 24vw, 220px);
            padding: 0;
            border-radius: 18px;
            border: 1px solid rgba(96, 165, 250, 0.34);
            background: rgba(10, 20, 42, 0.42);
            overflow: hidden;
            box-shadow:
                0 28px 84px rgba(0, 0, 0, 0.52),
                0 0 48px rgba(59, 130, 246, 0.18);
        }

        .pre-optin-overlay__butterfly {
            width: 100%;
            height: 100%;
            display: block;
            margin: 0;
            object-fit: cover;
        }

        .pre-optin-overlay__text {
            margin: 14px auto 0;
            text-align: center;
            font-size: clamp(1.08rem, 2.3vw, 1.32rem);
            font-weight: 700;
            letter-spacing: 0.03em;
            color: #dbeafe;
            text-shadow: 0 0 16px rgba(96, 165, 250, 0.35);
            animation: preOptinPulse 1.4s ease-in-out infinite;
        }

        .pre-optin-overlay__success {
            margin: 12px auto 0;
            width: fit-content;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            border-radius: 999px;
            border: 1px solid rgba(96, 165, 250, 0.55);
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.24) 0%, rgba(37, 99, 235, 0.2) 100%);
            color: #bfdbfe;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            opacity: 0;
            transform: translateY(4px);
            transition: opacity 0.2s ease, transform 0.2s ease;
            pointer-events: none;
        }

        .pre-optin-overlay__success.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        .pre-optin-overlay__success svg {
            width: 16px;
            height: 16px;
            color: #60a5fa;
        }

        @keyframes preOptinPulse {
            0%, 100% {
                opacity: 0.72;
                transform: translateY(0);
            }
            50% {
                opacity: 1;
                transform: translateY(-1px);
            }
        }

        #gate-blocked {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background: linear-gradient(180deg, #0a1628 0%, #0a0a1a 100%);
        }

        #gate-blocked.is-visible {
            display: flex;
        }

        .gate-blocked-inner {
            max-width: 520px;
            text-align: center;
        }

        .gate-blocked-inner h1 {
            font-size: clamp(1.4rem, 4vw, 2rem);
            margin-bottom: 14px;
            color: #fff;
            line-height: 1.25;
        }

        .gate-blocked-inner p {
            color: var(--text-muted);
            line-height: 1.65;
        }

        #page-main {
            display: none;
        }

        #page-main.is-visible {
            display: block;
        }

        /* TEMP PRÉ-LANCEMENT — retirer avant mise en public */
        #masterclass-password-gate {
            position: fixed;
            inset: 0;
            z-index: 10001;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.22) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 100%, rgba(37, 99, 235, 0.15) 0%, transparent 50%),
                linear-gradient(180deg, #0a1628 0%, #0a0a1a 50%, #06060f 100%);
        }

        #masterclass-password-gate.is-hidden {
            display: none;
        }

        .masterclass-pwd-box {
            width: 100%;
            max-width: 380px;
            padding: 28px 22px;
            border-radius: 16px;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.04);
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
        }

        .masterclass-pwd-box h2 {
            font-size: 1.15rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 8px;
            text-align: center;
        }

        .masterclass-pwd-box .masterclass-pwd-hint {
            font-size: 0.82rem;
            color: var(--text-muted);
            text-align: center;
            margin-bottom: 20px;
        }

        .masterclass-pwd-box input {
            width: 100%;
            padding: 14px 16px;
            margin-bottom: 12px;
            border-radius: 10px;
            border: 2px solid var(--border);
            background: rgba(255, 255, 255, 0.06);
            color: #fff;
            font-size: 16px;
        }

        .masterclass-pwd-box input::placeholder {
            color: rgba(255, 255, 255, 0.35);
        }

        .masterclass-pwd-box input:focus {
            outline: none;
            border-color: rgba(59, 130, 246, 0.65);
        }

        #masterclass-pwd-submit {
            width: 100%;
            border: none;
            border-radius: 10px;
            padding: 14px;
            font-size: 0.95rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #fff;
            cursor: pointer;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.35);
        }

        #masterclass-pwd-submit:hover {
            filter: brightness(1.06);
        }

        #masterclass-pwd-error {
            min-height: 1.2em;
            font-size: 0.85rem;
            color: #fca5a5;
            text-align: center;
            margin-bottom: 8px;
        }

        .form-error {
            color: #fca5a5;
            font-size: 0.85rem;
            margin: -4px 0 10px;
            min-height: 1.2em;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 20px 48px;
        }

        .hero {
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            gap: 44px;
            align-items: center;
            margin-bottom: 40px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(59, 130, 246, 0.2);
            border: 1px solid var(--border);
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }

        .badge::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: #ef4444;
            box-shadow: 0 0 0 rgba(239, 68, 68, 0.6);
            animation: liveDotPulse 1.3s ease-in-out infinite;
            flex-shrink: 0;
        }

        @keyframes liveDotPulse {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.55);
            }
            50% {
                opacity: 0.45;
                transform: scale(0.84);
                box-shadow: 0 0 0 8px rgba(239, 68, 68, 0);
            }
        }

        h1 {
            font-size: clamp(2rem, 4vw, 3.1rem);
            line-height: 1.2;
            font-weight: 800;
            margin-bottom: 18px;
            background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero h1 {
            text-transform: uppercase;
            letter-spacing: 0.035em;
        }

        .subheadline {
            font-size: clamp(1rem, 1.9vw, 1.2rem);
            line-height: 1.65;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        .next-session {
            margin-bottom: 16px;
            color: var(--accent);
            font-weight: 600;
        }

        .sessions-visual {
            display: grid;
            grid-template-columns: repeat(2, minmax(120px, 1fr));
            gap: 10px;
            max-width: 360px;
            margin-bottom: 18px;
        }

        .sessions-visual--one {
            grid-template-columns: 1fr;
            max-width: 200px;
        }

        .session-bubble {
            background: rgba(59, 130, 246, 0.2);
            border: 1px solid rgba(59, 130, 246, 0.45);
            border-radius: 12px;
            padding: 10px 10px;
            text-align: center;
            transition: all 0.25s ease;
        }

        .session-day {
            display: block;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-muted);
            margin-bottom: 2px;
        }

        .session-hour {
            display: block;
            font-size: 1.05rem;
            font-weight: 700;
            color: #fff;
        }

        .session-bubble.active {
            border-color: rgba(59, 130, 246, 0.45);
            background: rgba(59, 130, 246, 0.2);
            box-shadow: none;
        }

        .countdown {
            display: grid;
            grid-template-columns: repeat(4, minmax(64px, 1fr));
            gap: 10px;
            margin-bottom: 24px;
            max-width: 500px;
        }

        .count-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 8px;
            text-align: center;
        }

        .count-value {
            display: block;
            font-size: clamp(1.25rem, 3vw, 1.8rem);
            font-weight: 700;
            color: #fff;
        }

        .count-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .cta-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 16px 30px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.7px;
            cursor: pointer;
            text-transform: uppercase;
            box-shadow: 0 10px 35px rgba(59, 130, 246, 0.45);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 40px rgba(59, 130, 246, 0.6);
        }

        .image-wrapper {
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--border);
            box-shadow: 0 25px 80px rgba(59, 130, 246, 0.25);
            background: rgba(255, 255, 255, 0.03);
            aspect-ratio: 3 / 2;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            text-align: center;
            padding: 0;
        }

        /* === Sections below hero === */
        .section {
            margin-top: clamp(24px, 4vw, 40px);
            position: relative;
        }

        .section-title {
            font-size: clamp(1.25rem, 2.5vw, 1.6rem);
            font-weight: 700;
            color: #fff;
            margin: 0 0 clamp(18px, 3vw, 28px);
            line-height: 1.25;
        }

        .section-title .title-accent {
            color: #fff;
        }

        /* --- Gift section --- */
        .gift-section {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: clamp(20px, 3vw, 36px);
            align-items: center;
            background:
                radial-gradient(ellipse 80% 60% at 20% 30%, rgba(59, 130, 246, 0.06) 0%, transparent 70%),
                linear-gradient(165deg, rgba(255, 255, 255, 0.05), rgba(15, 23, 42, 0.5));
            border: 1px solid rgba(96, 165, 250, 0.15);
            border-radius: 20px;
            padding: clamp(24px, 3.5vw, 40px);
            position: relative;
            overflow: hidden;
        }

        .gift-section::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent 5%, rgba(96, 165, 250, 0.4) 50%, transparent 95%);
            border-radius: 20px 20px 0 0;
        }

        .gift-image-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .gift-image {
            width: auto;
            height: auto;
            max-width: clamp(132px, 24vw, 200px);
            max-height: clamp(180px, 34vw, 270px);
            object-fit: contain;
            display: block;
            border-radius: 0;
            filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.3))
                drop-shadow(0 2px 6px rgba(0, 0, 0, 0.15));
        }

        .gift-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
            padding: 5px 12px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(147, 197, 253, 0.95);
            background: rgba(59, 130, 246, 0.12);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 999px;
        }

        .gift-badge svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }

        .gift-heading {
            margin: 0 0 16px;
        }

        .gift-heading-main {
            display: block;
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.4rem, 3vw, 1.9rem);
            font-weight: 900;
            font-style: italic;
            color: #fff;
            line-height: 1.2;
            letter-spacing: -0.01em;
            margin-bottom: 4px;
        }

        .gift-heading-sub {
            display: block;
            font-family: 'Inter', sans-serif;
            font-size: clamp(0.88rem, 1.6vw, 1.05rem);
            font-weight: 400;
            color: rgba(255, 255, 255, 0.55);
            line-height: 1.5;
        }

        .gift-heading-sub strong {
            color: #fff;
            font-weight: 700;
            border-bottom: 2px solid rgba(96, 165, 250, 0.5);
            padding-bottom: 1px;
        }

        .gift-text {
            margin: 0;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.7;
            font-size: clamp(0.88rem, 1.6vw, 0.98rem);
        }

        .gift-text + .gift-text {
            margin-top: clamp(12px, 2vw, 16px);
        }

        /* --- Discover section --- */
        .discover-section {
            background:
                radial-gradient(ellipse 70% 50% at 80% 20%, rgba(59, 130, 246, 0.05) 0%, transparent 70%),
                linear-gradient(165deg, rgba(255, 255, 255, 0.04), rgba(15, 23, 42, 0.4));
            border: 1px solid rgba(96, 165, 250, 0.12);
            border-radius: 20px;
            padding: clamp(28px, 4vw, 44px) clamp(24px, 3.5vw, 40px);
        }

        .discover-list {
            list-style: none;
            display: grid;
            gap: 0;
        }

        .discover-item {
            display: grid;
            grid-template-columns: 32px 1fr;
            gap: 14px;
            align-items: start;
            padding: clamp(14px, 2vw, 18px) 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .discover-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .discover-item:first-child {
            padding-top: 0;
        }

        .discover-icon {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            background: rgba(59, 130, 246, 0.1);
            color: #60a5fa;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .discover-icon svg {
            width: 16px;
            height: 16px;
        }

        .discover-text {
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.6;
            font-size: clamp(0.88rem, 1.6vw, 0.98rem);
        }

        /* --- Social proof section --- */
        .proof-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: clamp(14px, 2.5vw, 20px);
        }

        .proof-section .proof-card {
            opacity: 0.45;
            transform: translateY(14px);
            transition: opacity 0.55s ease, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .proof-section.proof-section--visible .proof-card {
            opacity: 1;
            transform: translateY(0);
        }

        .proof-section.proof-section--visible .proof-card:nth-child(2) {
            transition-delay: 0.07s;
        }

        .proof-card {
            background:
                linear-gradient(165deg, rgba(255, 255, 255, 0.05), rgba(15, 23, 42, 0.5));
            border: 1px solid rgba(96, 165, 250, 0.12);
            border-radius: 16px;
            padding: clamp(22px, 3vw, 32px) clamp(18px, 2.5vw, 28px);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .proof-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(96, 165, 250, 0.3), transparent);
        }

        .proof-number {
            display: block;
            font-size: clamp(1.6rem, 3.5vw, 2.2rem);
            font-weight: 800;
            background: linear-gradient(135deg, #60a5fa, #93c5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.1;
            margin-bottom: 6px;
            font-variant-numeric: tabular-nums;
            min-height: 1.15em;
        }

        .proof-label {
            font-size: clamp(0.75rem, 1.3vw, 0.88rem);
            color: rgba(255, 255, 255, 0.6);
            font-weight: 500;
            line-height: 1.4;
        }

        /* --- Final CTA --- */
        .final-cta {
            margin-top: clamp(28px, 4vw, 44px);
            text-align: center;
            padding: clamp(28px, 4vw, 44px) clamp(20px, 3vw, 36px);
            background:
                radial-gradient(ellipse 60% 50% at 50% 40%, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
            border-radius: 20px;
            border: 1px solid rgba(96, 165, 250, 0.1);
        }

        .final-cta-text {
            font-size: clamp(0.9rem, 1.6vw, 1.05rem);
            color: rgba(255, 255, 255, 0.6);
            margin: 0 0 18px;
            font-weight: 500;
        }

        .final-cta .cta-button {
            margin: 0 auto;
        }

        .custom-popup {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(9px);
            z-index: 9999;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        .popup-content {
            position: relative;
            max-width: 500px;
            width: calc(100% - 30px);
            margin: 40px auto;
            background: linear-gradient(135deg, #1a1a3a 0%, #0a0a1a 100%);
            border: 2px solid var(--border);
            border-radius: 20px;
            padding: 28px 22px;
        }

        .popup-close {
            position: absolute;
            top: 10px;
            right: 14px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            font-size: 28px;
            cursor: pointer;
        }

        .popup-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .popup-title {
            font-size: 1.35rem;
            margin-bottom: 0;
        }

        .popup-form-lead {
