                '.iti__country-list::-webkit-scrollbar-thumb {' +
                'background: linear-gradient(180deg, #3b82f6, #60a5fa); border-radius: 5px;' +
                '}' +
                '.iti__country {' +
                'padding: 14px 18px !important; color: #fff !important; background: transparent !important;' +
                'border-bottom: 1px solid rgba(59, 130, 246, 0.28) !important;' +
                '}' +
                '.iti__country:hover, .iti__country.iti__highlight {' +
