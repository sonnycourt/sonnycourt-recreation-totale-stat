---
import GAConsentMode from '../components/GAConsentMode.astro';
// true uniquement avec `astro dev` (localhost), false dans le build de prod.
const IS_DEV = import.meta.env.DEV;
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light only">
    <title>Documentation closer — Session du 2 juillet</title>
    <meta name="description" content="Recrutement de closers freelance high-ticket. Leads ultra-chauds, 100% au résultat, commission croissante. La machine vend déjà — il lui manque une voix au téléphone.">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"></noscript>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            color-scheme: light only;
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --primary-light: #60a5fa;
            --ink: #0f172a;
            --ink-soft: #334155;
            --muted: #64748b;
            --line: #e2e8f0;
            --surface: #ffffff;
            --surface-tint: #f1f5f9;
            --bg: #f8fafc;
            --accent-soft: #eff6ff;
            --green: #16a34a;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .wrap {
            max-width: 760px;
            margin: 0 auto;
            padding: 0 22px;
        }

        /* === Section rhythm === */
        section {
            padding: clamp(48px, 8vw, 88px) 0;
            border-bottom: 1px solid var(--line);
        }

        section:last-of-type {
            border-bottom: none;
        }

        .eyebrow {
            display: inline-block;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--primary-dark);
            margin-bottom: 16px;
        }

        h1, h2 {
            line-height: 1.18;
            letter-spacing: -0.02em;
            color: var(--ink);
        }

        h1 {
            font-size: clamp(1.9rem, 5.2vw, 3rem);
            font-weight: 900;
        }

        h2 {
            font-size: clamp(1.5rem, 4vw, 2.1rem);
            font-weight: 800;
            margin-bottom: 22px;
        }

        h3 {
            font-size: clamp(1.1rem, 2.6vw, 1.3rem);
            font-weight: 800;
            margin: 26px 0 12px;
        }

        /* Parcours du prospect (mini-frise) */
        .journey {
            display: flex; gap: 4px; margin-top: 22px; overflow-x: auto;
            padding: 6px 2px 10px; -webkit-overflow-scrolling: touch;
        }
        .journey-step {
            flex: 1 0 116px; display: flex; flex-direction: column; align-items: center;
            text-align: center; position: relative; padding-top: 4px;
        }
        .journey-step::before {
            content: ''; position: absolute; top: 28px; right: 50%; width: 100%; height: 2px;
            background: var(--line); z-index: 0;
        }
        .journey-step:first-child::before { display: none; }
        .journey-step .js-dot {
            width: 48px; height: 48px; border-radius: 50%; background: var(--accent-soft);
            color: var(--primary-dark); display: flex; align-items: center; justify-content: center;
            border: 2px solid var(--line); position: relative; z-index: 1;
        }
        .journey-step .js-dot svg { width: 22px; height: 22px; }
        .journey-step .js-label { margin-top: 9px; font-size: 0.8rem; font-weight: 700; color: var(--ink); line-height: 1.25; }
        .journey-step .js-sub { font-size: 0.72rem; color: var(--muted); margin-top: 2px; }
        .journey-step.is-closer .js-dot {
            background: var(--primary-dark); color: #fff; border-color: var(--primary-dark);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.35); transform: scale(1.12);
        }
        .journey-step.is-closer .js-label { color: var(--primary-dark); }
        .journey-step .js-badge {
            display: inline-block; margin-top: 5px; font-size: 0.62rem; font-weight: 800;
            letter-spacing: 0.04em; text-transform: uppercase; color: #fff;
            background: var(--primary-dark); border-radius: 999px; padding: 2px 8px;
        }
        /* Bifurcation après l'offre */
        .journey-fork-label {
            display: flex; align-items: center; gap: 8px; margin: 16px 0 10px;
            font-size: 0.82rem; font-weight: 700; color: var(--muted);
        }
        .journey-fork-label::before, .journey-fork-label::after {
            content: ''; flex: 1; height: 1px; background: var(--line);
        }
        .journey-fork { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        @media (max-width: 560px) { .journey-fork { grid-template-columns: 1fr; } }
        .fork-card {
            display: flex; gap: 12px; align-items: flex-start; padding: 15px 16px;
            border-radius: 14px; border: 1px solid var(--line); background: var(--surface);
        }
        .fork-card .fk-ic {
            width: 40px; height: 40px; border-radius: 11px; display: flex; align-items: center;
            justify-content: center; flex-shrink: 0;
        }
        .fork-card .fk-ic svg { width: 20px; height: 20px; }
        .fork-card .fk-title { display: block; font-weight: 800; font-size: 0.95rem; color: var(--ink); }
        .fork-card .fk-sub { display: block; font-size: 0.82rem; color: var(--muted); margin-top: 3px; line-height: 1.4; }
        .fork-card.is-self { background: #f0fdf4; border-color: #bbf7d0; }
        .fork-card.is-self .fk-ic { background: #dcfce7; color: #15803d; }
        .fork-card.is-closer { background: var(--accent-soft); border-color: var(--primary-light); }
        .fork-card.is-closer .fk-ic { background: var(--primary-dark); color: #fff; }
        .fork-badge {
            display: inline-block; margin-left: 7px; font-size: 0.6rem; font-weight: 800;
            letter-spacing: 0.04em; text-transform: uppercase; color: #fff;
            background: var(--primary-dark); border-radius: 999px; padding: 2px 7px; vertical-align: middle;
        }
        .fork-badge.is-green { background: #15803d; }
        .fork-card.is-warn { background: #fffbeb; border-color: #fde68a; }
        .fork-card.is-warn .fk-ic { background: #fef3c7; color: #b45309; }
        /* Sous-issues d'une carte (cas B) */
        .fork-outcomes { margin-top: 9px; display: flex; flex-direction: column; gap: 7px; }
        .fork-outcomes .fo {
            display: flex; gap: 8px; align-items: flex-start; font-size: 0.8rem;
            color: var(--ink-soft); line-height: 1.4;
        }
        .fork-outcomes .fo svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; }
        .fork-outcomes .fo b { color: var(--ink); }
        .fo.is-win svg { color: #15803d; }
        .fo.is-win .fo-bonus { color: #15803d; font-weight: 800; }
        .fo.is-leave svg { color: var(--muted); }
        .fork-card .fo-note {
            display: block; margin-top: 9px; font-size: 0.72rem; color: var(--muted);
            font-style: italic; line-height: 1.45;
        }
        /* Objections (les faits) */
        .obj-list { display: flex; flex-direction: column; gap: 12px; margin-top: 8px; }
        .obj-item {
            border: 1px solid var(--line); border-left: 3px solid var(--primary-light);
            border-radius: 12px; padding: 14px 16px; background: var(--surface);
        }
        .obj-item .obj-q { font-weight: 800; color: var(--ink); font-size: 1rem; }
        .obj-item .obj-a { color: var(--ink-soft); font-size: 0.92rem; margin-top: 5px; line-height: 1.55; }
        /* La vision — manifeste */
        .vision {
            background: radial-gradient(130% 150% at 0% 0%, #1e293b 0%, #0f172a 58%);
            color: #cbd5e1; border-radius: 22px; padding: clamp(26px, 5vw, 48px);
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
        }
        .vision .vision-eyebrow {
            display: inline-block; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.12em;
            text-transform: uppercase; color: #60a5fa; margin-bottom: 12px;
        }
        .vision h2 { color: #ffffff; margin-bottom: 14px; }
        .vision h3 {
            color: #ffffff; margin: 32px 0 10px; font-size: clamp(1.08rem, 2.4vw, 1.3rem);
        }
        .vision p { color: #cbd5e1; }
        .vision p strong { color: #ffffff; }
        .vision .vision-intro {
            font-size: clamp(1.02rem, 2.3vw, 1.18rem); color: #f8fafc; font-weight: 600;
            border-left: 3px solid #60a5fa; padding-left: 16px; margin: 2px 0 4px; line-height: 1.55;
        }
        .vision .vision-kicker {
            margin-top: 28px; padding-top: 22px; border-top: 1px solid rgba(148, 163, 184, 0.25);
            font-size: clamp(1.04rem, 2.4vw, 1.2rem); font-weight: 700; color: #ffffff; line-height: 1.55;
        }
        .aftersale-note {
            margin-top: 14px; font-size: 0.82rem; color: var(--muted); font-style: italic;
            border-left: 3px solid var(--line); padding-left: 12px; line-height: 1.5;
        }
        /* Timeline verticale (voyage intérieur) */
        .vtimeline { margin: 18px 0 6px; }
        .vstep { display: flex; gap: 16px; position: relative; padding-bottom: 22px; }
        .vstep:last-child { padding-bottom: 0; }
        .vstep::before {
            content: ''; position: absolute; left: 18px; top: 40px; bottom: -2px; width: 3px;
            border-radius: 999px; background: var(--line);
        }
        .vstep:last-child::before { display: none; }
        .vstep .vs-dot {
            width: 40px; height: 40px; border-radius: 50%; background: var(--accent-soft);
            color: var(--primary-dark); display: flex; align-items: center; justify-content: center;
            border: 2px solid var(--line); flex-shrink: 0; font-weight: 800; font-size: 0.95rem; z-index: 1;
        }
        .vstep .vs-body { padding-top: 7px; }
        .vstep .vs-label { font-weight: 800; color: var(--ink); font-size: 0.98rem; }
        .vstep .vs-text { color: var(--ink-soft); font-size: 0.92rem; margin-top: 3px; line-height: 1.5; }
        /* Le lead qui se chauffe : dégradé continu froid (bleu) -> chaud (rouge).
           Chaque bulle se fond dans la suivante, et le fil de liaison aussi. */
        .vtimeline .vstep .vs-dot { color: #fff; border: none; }
        .vtimeline .vstep:nth-child(1) .vs-dot { background: linear-gradient(180deg, #93c5fd, #60a5fa); }
        .vtimeline .vstep:nth-child(2) .vs-dot { background: linear-gradient(180deg, #60a5fa, #a78bfa); }
        .vtimeline .vstep:nth-child(3) .vs-dot { background: linear-gradient(180deg, #a78bfa, #f472b6); }
        .vtimeline .vstep:nth-child(4) .vs-dot { background: linear-gradient(180deg, #f472b6, #fb923c); }
        .vtimeline .vstep:nth-child(5) .vs-dot {
            background: linear-gradient(180deg, #fb923c, #ef4444);
            box-shadow: 0 8px 18px rgba(239, 68, 68, 0.35);
        }
        .vtimeline .vstep:nth-child(1)::before { background: linear-gradient(180deg, #60a5fa, #a78bfa); }
        .vtimeline .vstep:nth-child(2)::before { background: linear-gradient(180deg, #a78bfa, #f472b6); }
        .vtimeline .vstep:nth-child(3)::before { background: linear-gradient(180deg, #f472b6, #fb923c); }
        .vtimeline .vstep:nth-child(4)::before { background: linear-gradient(180deg, #fb923c, #ef4444); }
        .vstep.is-peak .vs-label { color: #dc2626; }
        .vtimeline-cap {
            display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
            font-size: 0.78rem; color: var(--muted); margin: 2px 0 14px;
        }
        .vtimeline-cap .bar {
            height: 6px; flex: 0 0 130px; border-radius: 999px;
            background: linear-gradient(90deg, #60a5fa, #a78bfa, #f472b6, #fb923c, #ef4444);
        }

        p {
            font-size: clamp(1rem, 2.2vw, 1.12rem);
            color: var(--ink-soft);
        }

        p + p {
            margin-top: 16px;
        }

        .lead {
            font-size: clamp(1.05rem, 2.4vw, 1.22rem);
        }

        strong {
            color: var(--ink);
            font-weight: 700;
        }

        /* === Hero === */
        .hero {
            background:
                radial-gradient(ellipse 70% 60% at 80% 0%, rgba(59, 130, 246, 0.09) 0%, transparent 60%),
                linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
            padding-top: clamp(64px, 10vw, 110px);
        }

        .hero h1 {
            margin-bottom: 26px;
        }

        .hero h1 .turn {
            color: var(--primary-dark);
        }

        /* === Stat highlight (section 2) === */
        .stat-pop {
            display: block;
            font-size: clamp(2.6rem, 9vw, 4.4rem);
            font-weight: 900;
            letter-spacing: -0.03em;
            line-height: 1;
            color: var(--primary-dark);
            margin-bottom: 6px;
        }

        /* === Checklist (section 3) === */
        .check-list {
            list-style: none;
            margin: 22px 0 0;
            display: grid;
            gap: 14px;
        }

        .check-list li {
            display: grid;
            grid-template-columns: 26px 1fr;
            gap: 12px;
            align-items: start;
            font-size: clamp(1rem, 2.2vw, 1.1rem);
            color: var(--ink-soft);
        }

        .check-list .ic {
            width: 24px;
            height: 24px;
            border-radius: 7px;
            background: var(--accent-soft);
            color: var(--primary-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 2px;
        }

        .check-list .ic svg {
            width: 15px;
            height: 15px;
        }

        /* === Tables === */
        .table-card {
            margin-top: 26px;
            border: 1px solid var(--line);
            border-radius: 16px;
            overflow: hidden;
            background: var(--surface);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-variant-numeric: tabular-nums;
        }

        thead th {
            background: var(--surface-tint);
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            padding: 14px 18px;
        }

        thead th:not(:first-child) {
            text-align: center;
        }

        tbody td {
            padding: 14px 18px;
            font-size: clamp(0.95rem, 2vw, 1.05rem);
            color: var(--ink-soft);
            border-top: 1px solid var(--line);
        }

        tbody td:first-child {
            font-weight: 600;
            color: var(--ink);
        }

        tbody td:not(:first-child) {
            text-align: center;
            font-weight: 600;
        }

        .table-note {
            margin-top: 16px;
            font-size: 0.95rem;
            color: var(--muted);
        }

        /* Tiers table highlight */
        .tiers tbody tr.tier-top td {
            background: var(--accent-soft);
            color: var(--primary-dark);
            font-weight: 800;
        }

        .tiers tbody td:last-child {
            font-weight: 700;
            color: var(--primary-dark);
        }

        /* Ligne aspirationnelle "closer d'exception" */
        .tiers tbody tr.tier-elite td {
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.14), rgba(37, 99, 235, 0.05));
            border-top: 2px solid rgba(37, 99, 235, 0.4);
            color: var(--primary-dark);
            font-style: italic;
            font-weight: 800;
            letter-spacing: 0.01em;
        }

        .tiers tbody tr.tier-elite td:first-child {
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .tiers tbody tr.tier-elite td:first-child::before {
            content: '★';
            font-style: normal;
            color: var(--primary);
        }

        /* === Deal callout === */
        .deal-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            color: var(--green);
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 7px 14px;
            border-radius: 999px;
            font-size: 0.9rem;
            margin-bottom: 18px;
        }

        /* === Risk note (section deal) === */
        .risk-note {
            margin-top: 22px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: var(--surface);
            padding: clamp(20px, 3vw, 28px);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .risk-note h3 {
            font-size: 1.05rem;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 10px;
        }

        .risk-note p {
            margin: 0;
            font-size: clamp(0.92rem, 1.9vw, 1rem);
            line-height: 1.65;
            color: var(--ink-soft);
        }

        .risk-note strong {
            font-weight: 800;
            color: var(--primary-dark);
            background: var(--accent-soft);
            padding: 1px 6px;
            border-radius: 6px;
        }

        /* === Funnel links (preuve tangible) === */
        .funnel-links {
            display: grid;
            gap: 12px;
            margin-top: 24px;
        }

        .funnel-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            border: 1px solid var(--line);
            border-radius: 14px;
            background: var(--surface);
            text-decoration: none;
            color: var(--ink);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
            transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
        }

        .funnel-link:hover {
            border-color: var(--primary-light);
            box-shadow: 0 8px 22px rgba(37, 99, 235, 0.10);
            transform: translateY(-1px);
        }

        .funnel-link .fl-ic {
            width: 42px;
            height: 42px;
            border-radius: 11px;
            background: var(--accent-soft);
            color: var(--primary-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .funnel-link .fl-ic svg { width: 20px; height: 20px; }

        .funnel-link .fl-text { flex: 1; min-width: 0; }

        .funnel-link .fl-title {
            display: block;
            font-weight: 700;
            font-size: 0.98rem;
            color: var(--ink);
        }

        .funnel-link .fl-sub {
            display: block;
            margin-top: 2px;
            font-size: 0.82rem;
            color: var(--muted);
            line-height: 1.4;
        }

        .funnel-link .fl-arrow {
            color: var(--muted);
            flex-shrink: 0;
            display: flex;
        }

        .funnel-link .fl-arrow svg { width: 18px; height: 18px; }
        /* Sous-élément (importance seconde, rattaché à la carte au-dessus) */
        .funnel-link.is-sub {
            margin-left: 38px; padding: 12px 16px; background: #f8fafc; border-style: dashed;
            position: relative;
        }
        .funnel-link.is-sub::before {
            content: ''; position: absolute; left: -22px; top: -10px; width: 14px; height: 28px;
            border-left: 2px solid var(--line); border-bottom: 2px solid var(--line);
            border-bottom-left-radius: 8px;
        }
        .funnel-link.is-sub .fl-ic { width: 34px; height: 34px; }
        .funnel-link.is-sub .fl-ic svg { width: 17px; height: 17px; }
        .funnel-link.is-sub .fl-title { font-size: 0.9rem; }
        .funnel-link.is-sub .fl-sub { font-size: 0.78rem; }

        .funnel-link.is-placeholder {
            border-style: dashed;
            background: #fcfdfe;
        }

        .funnel-link.is-placeholder .fl-ic {
            background: var(--surface-tint);
            color: var(--muted);
        }

        .funnel-link.is-placeholder .fl-title { color: var(--muted); }

        /* === Calculator === */
        .calc {
            margin-top: 26px;
        }

        .calc-controls {
            display: grid;
            gap: 22px;
            padding: clamp(20px, 3vw, 28px);
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 18px;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        @media (min-width: 680px) {
            .calc-controls {
                grid-template-columns: 1fr 1fr;
                gap: 24px 30px;
            }
        }

        .calc-field-head {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 12px;
        }

        .calc-field label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--ink-soft);
            line-height: 1.3;
        }

        .calc-field-val {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--primary-dark);
            font-variant-numeric: tabular-nums;
            white-space: nowrap;
        }

        .calc-field input[type="range"] {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 6px;
            border-radius: 999px;
            background: #e2e8f0;
            outline: none;
            cursor: pointer;
        }

        .calc-field input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid var(--primary);
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.4);
            cursor: pointer;
        }

        .calc-field input[type="range"]::-moz-range-thumb {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: #fff;
            border: 3px solid var(--primary);
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.4);
            cursor: pointer;
        }

        .calc-field input[type="range"]:focus-visible {
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.25);
        }

        .calc-field-help {
            margin-top: 8px;
            font-size: 0.78rem;
            color: var(--muted);
        }

        .calc-kpis {
            margin-top: 18px;
            display: grid;
            gap: 14px;
            grid-template-columns: 1fr;
        }

        @media (min-width: 680px) {
            .calc-kpis {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .kpi {
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 20px 18px;
            background: var(--surface);
            text-align: center;
        }

        .kpi--accent {
            background: linear-gradient(165deg, #eff6ff, #ffffff);
            border-color: #bfdbfe;
        }

        .kpi-val {
            display: block;
            font-size: clamp(1.5rem, 4.5vw, 2rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            line-height: 1.1;
            color: var(--ink);
            font-variant-numeric: tabular-nums;
        }

        .kpi--accent .kpi-val {
            color: var(--primary-dark);
        }

        .kpi-label {
            display: block;
            margin-top: 6px;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--ink-soft);
        }

        .kpi-sub {
            display: block;
            margin-top: 3px;
            font-size: 0.72rem;
            color: var(--muted);
        }

        .calc-chart {
            margin-top: 18px;
            border: 1px solid var(--line);
            border-radius: 18px;
            padding: 20px clamp(8px, 2vw, 18px);
            background: var(--surface);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .calc-chart-head {
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 0 0 6px 10px;
        }

        .chart-host {
            position: relative;
        }

        .chart-host svg {
            width: 100%;
            height: auto;
            display: block;
        }

        .calc-markers {
            margin-top: 16px;
            display: grid;
            gap: 10px;
            grid-template-columns: 1fr;
        }

        @media (min-width: 680px) {
            .calc-markers {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .marker {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px 16px;
            background: var(--surface);
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .marker--accent {
            background: var(--accent-soft);
            border-color: #bfdbfe;
        }

        .marker-k {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--muted);
        }

        .marker-v {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--ink);
            font-variant-numeric: tabular-nums;
        }

        .marker--accent .marker-v {
            color: var(--primary-dark);
        }

        .calc-explainer {
            margin-top: 18px;
            font-size: 0.95rem;
            line-height: 1.65;
            color: var(--muted);
        }

        /* === Profile blocks (section 8) === */
        .fit-grid {
            margin-top: 22px;
            display: grid;
            gap: 18px;
        }

        @media (min-width: 640px) {
            .fit-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .fit-card {
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 22px;
            background: var(--surface);
        }

        .fit-card h3 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .fit-card.yes h3 { color: var(--green); }
        .fit-card.no h3 { color: #dc2626; }

        .fit-card ul {
            list-style: none;
            display: grid;
            gap: 10px;
        }

        .fit-card li {
            font-size: 0.98rem;
            color: var(--ink-soft);
            padding-left: 22px;
            position: relative;
        }

        .fit-card li::before {
            position: absolute;
            left: 0;
            top: 0;
            font-weight: 700;
        }

        .fit-card.yes li::before { content: '✓'; color: var(--green); }
        .fit-card.no li::before { content: '✕'; color: #dc2626; }

        /* === Availability callout (section 7) === */
        .op-availability {
            margin-top: 18px;
            padding: 16px 20px;
            border-radius: 14px;
            background: var(--accent-soft);
            border: 1px solid #bfdbfe;
            font-size: clamp(0.95rem, 2vw, 1.02rem);
            line-height: 1.55;
            color: var(--ink-soft);
        }

        .op-availability strong {
            color: var(--primary-dark);
        }

        /* === Expectations (section 8 bis) === */
        .expect-grid {
            margin-top: 22px;
            display: grid;
            gap: 18px;
        }

        @media (min-width: 640px) {
            .expect-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .expect-card {
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 24px;
            background: var(--surface);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .expect-tag {
            display: inline-block;
            margin-bottom: 12px;
            padding: 4px 11px;
            border-radius: 999px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.09em;
            text-transform: uppercase;
        }

        .expect-tag--value {
            background: var(--accent-soft);
            border-color: #bfdbfe;
            color: var(--primary-dark);
        }

        .expect-card h3 {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 10px;
        }

        .expect-card p {
            margin: 0;
            font-size: 0.98rem;
            line-height: 1.6;
            color: var(--ink-soft);
        }

        /* === Final CTA === */
        .closing {
            background:
                radial-gradient(ellipse 80% 70% at 50% 100%, rgba(59, 130, 246, 0.1) 0%, transparent 65%),
                linear-gradient(180deg, var(--bg) 0%, #eef4ff 100%);
            text-align: center;
        }

        .cta-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 30px;
            padding: 17px 42px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-family: inherit;
            font-size: 1.05rem;
            font-weight: 800;
            letter-spacing: 0.02em;
            text-decoration: none;
            cursor: pointer;
            box-shadow: 0 12px 30px rgba(37, 99, 235, 0.32);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 38px rgba(37, 99, 235, 0.42);
        }

        .closing .micro {
            margin-top: 16px;
            font-size: 0.9rem;
            color: var(--muted);
        }

        .cta-date {
            margin: 0 auto 4px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.92rem;
            font-weight: 700;
            color: var(--primary-dark);
        }

        .cta-date .dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: var(--primary);
            flex-shrink: 0;
        }

        /* === Top banner (première mission) === */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 11px 18px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-size: clamp(0.82rem, 2.4vw, 0.95rem);
            font-weight: 600;
            line-height: 1.35;
            text-align: center;
            box-shadow: 0 2px 14px rgba(37, 99, 235, 0.28);
        }

        .topbar strong {
            color: #fff;
            font-weight: 800;
        }

        .topbar .live-dot {
            width: 9px;
            height: 9px;
            border-radius: 999px;
            background: #fff;
            flex-shrink: 0;
            box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
            animation: topbarPulse 1.6s ease-in-out infinite;
        }

        @keyframes topbarPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.55); }
            50% { box-shadow: 0 0 0 7px rgba(255, 255, 255, 0); }
        }

        /* === Projection block (trajectoire de croissance) === */
        .projection {
            margin-top: 26px;
            border: 1px dashed var(--primary-light);
            border-radius: 18px;
            background: linear-gradient(165deg, #eff6ff, #ffffff);
            padding: clamp(22px, 3.5vw, 34px);
        }

        .projection-tag {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 14px;
            padding: 5px 13px;
            border-radius: 999px;
            background: rgba(37, 99, 235, 0.1);
            border: 1px solid rgba(37, 99, 235, 0.25);
            color: var(--primary-dark);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .projection-arc {
            display: flex;
            align-items: center;
            gap: clamp(10px, 3vw, 22px);
            margin: 4px 0 18px;
            flex-wrap: wrap;
        }

        .projection-now,
        .projection-goal {
            display: flex;
            flex-direction: column;
        }

        .projection-num {
            font-size: clamp(1.6rem, 6vw, 2.6rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            line-height: 1;
        }

        .projection-now .projection-num { color: var(--ink-soft); }
        .projection-goal .projection-num { color: var(--primary-dark); }

        .projection-sub {
            margin-top: 5px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--muted);
        }

        .projection-arrow {
            flex: 1;
            min-width: 40px;
            height: 3px;
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(37, 99, 235, 0.25), var(--primary));
            position: relative;
        }

        .projection-arrow::after {
            content: '';
            position: absolute;
            right: -2px;
            top: 50%;
            transform: translateY(-50%);
            border-left: 9px solid var(--primary);
            border-top: 6px solid transparent;
            border-bottom: 6px solid transparent;
        }

        .projection p {
            margin: 0;
            font-size: clamp(0.95rem, 2vw, 1.05rem);
            color: var(--ink-soft);
            line-height: 1.65;
        }

        /* === Audience / sérieux block === */
        .audience {
            margin-top: 22px;
            border: 1px solid var(--line);
            border-radius: 18px;
            background: var(--surface);
            padding: clamp(24px, 3.5vw, 38px);
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        }

        .audience-head {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: clamp(20px, 3vw, 26px);
        }

        .audience-head img {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            border: 3px solid #fff;
            box-shadow:
                0 0 0 2px rgba(59, 130, 246, 0.35),
                0 6px 16px rgba(37, 99, 235, 0.20);
        }

        .audience-name {
            display: block;
            font-size: 1.05rem;
            font-weight: 800;
            letter-spacing: -0.01em;
            color: var(--ink);
        }

        .audience-role {
            display: block;
            margin-top: 2px;
            font-size: 0.85rem;
            color: var(--muted);
        }

        /* Barre de stats : 3 colonnes égales, pleine largeur, séparateurs */
        .audience-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-top: 1px solid var(--line);
            border-bottom: 1px solid var(--line);
            margin-bottom: clamp(20px, 3vw, 26px);
        }

        .audience-stat {
            padding: clamp(16px, 2.5vw, 20px) clamp(10px, 1.6vw, 16px);
            text-align: center;
        }

        .audience-stat + .audience-stat {
            border-left: 1px solid var(--line);
        }

        .audience-num {
            display: block;
            font-size: clamp(1.4rem, 4.2vw, 2rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            line-height: 1;
            color: var(--ink);
            margin-bottom: 7px;
            white-space: nowrap;
        }

        .audience-stat.is-key .audience-num {
            color: var(--primary-dark);
        }

        .audience-cap {
            display: block;
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--muted);
            line-height: 1.4;
        }

        .audience p {
            margin: 0;
            font-size: clamp(0.95rem, 2vw, 1.05rem);
            line-height: 1.7;
            color: var(--ink-soft);
        }

        .audience p + p {
            margin-top: 12px;
        }

        .audience-socials {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: clamp(16px, 2.5vw, 20px);
            padding-top: clamp(14px, 2vw, 18px);
            border-top: 1px solid var(--line);
        }

        .audience-socials-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--muted);
            margin-right: 2px;
        }

        .audience-socials a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid var(--line);
            color: var(--ink-soft);
            background: #fff;
            transition: color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
        }

        .audience-socials a:hover {
            color: var(--primary-dark);
            border-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .audience-socials a svg {
            width: 18px;
            height: 18px;
        }

        @media (max-width: 560px) {
            .audience-stats {
                grid-template-columns: 1fr;
            }

            .audience-stat {
                text-align: left;
                padding: 15px 0;
                display: flex;
                align-items: baseline;
                gap: 10px;
            }

            .audience-stat + .audience-stat {
                border-left: none;
                border-top: 1px solid var(--line);
            }

            .audience-num {
                margin-bottom: 0;
                min-width: 84px;
            }
        }

        /* === Gate d'accès (mot de passe closer) === */
        .closer-gate {
            position: fixed;
            inset: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background:
                radial-gradient(ellipse 70% 60% at 80% 0%, rgba(59, 130, 246, 0.10) 0%, transparent 60%),
                linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
        }

        .closer-gate.is-hidden {
            display: none;
        }

        .closer-gate-card {
            width: 100%;
            max-width: 400px;
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 20px;
            padding: clamp(28px, 5vw, 40px);
            box-shadow: 0 20px 60px rgba(15, 23, 42, 0.10);
            text-align: center;
        }

        .closer-gate-logo {
            width: 48px;
            height: 48px;
            margin: 0 auto 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: var(--accent-soft);
            color: var(--primary-dark);
        }

        .closer-gate-logo svg {
            width: 24px;
            height: 24px;
        }

        .closer-gate-card h1 {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--ink);
            letter-spacing: -0.01em;
            margin-bottom: 8px;
        }

        .closer-gate-hint {
            font-size: 0.95rem;
            color: var(--muted);
            line-height: 1.5;
            margin-bottom: 22px;
        }

        .closer-gate-form {
            display: none;
        }

        .closer-gate-form.is-ready {
            display: block;
        }

        .closer-gate-input {
            width: 100%;
            padding: 14px 16px;
            text-align: center;
            font-family: inherit;
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--ink);
            border: 2px solid var(--line);
            border-radius: 12px;
            background: #fff;
        }

        .closer-gate-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.18);
        }

        .closer-gate-input::placeholder {
            letter-spacing: normal;
            text-transform: none;
            font-weight: 500;
            color: #94a3b8;
        }

        .closer-gate-consent {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-top: 16px;
            text-align: left;
            cursor: pointer;
        }

        .closer-gate-consent input {
            margin-top: 2px;
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            accent-color: var(--primary);
            cursor: pointer;
        }

        .closer-gate-consent span {
            font-size: 0.82rem;
            line-height: 1.45;
            color: var(--ink-soft);
        }

        .closer-gate-error {
            min-height: 1.2em;
            margin: 10px 0 0;
            font-size: 0.88rem;
            font-weight: 600;
            color: #dc2626;
        }

        .closer-gate-btn {
            width: 100%;
            margin-top: 16px;
            padding: 15px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-family: inherit;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.02em;
            cursor: pointer;
            box-shadow: 0 10px 26px rgba(37, 99, 235, 0.30);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .closer-gate-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 32px rgba(37, 99, 235, 0.4);
        }

        .closer-gate-btn:disabled {
            opacity: 0.6;
            cursor: default;
            transform: none;
        }

        .closer-gate-spinner {
            width: 38px;
            height: 38px;
            margin: 8px auto 0;
            border: 3px solid rgba(59, 130, 246, 0.25);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: closerSpin 0.8s linear infinite;
        }

        .closer-gate-spinner.is-hidden {
            display: none;
        }

        @keyframes closerSpin {
            to { transform: rotate(360deg); }
        }
    </style>

    <!-- Styles des éléments du graphe générés en JS (non scopés) -->
    <style is:global>
        .chart-host .calc-hit.is-active {
            fill: rgba(37, 99, 235, 0.12);
        }

        .chart-host .calc-tip {
            position: absolute;
            transform: translate(-50%, calc(-100% - 12px));
            background: #0f172a;
            color: #fff;
            padding: 7px 11px;
            border-radius: 9px;
            font-size: 0.84rem;
            font-weight: 800;
            white-space: nowrap;
            pointer-events: none;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.28);
            z-index: 5;
            font-variant-numeric: tabular-nums;
            font-family: 'Inter', sans-serif;
        }

        .chart-host .calc-tip[hidden] {
            display: none;
        }

        .chart-host .calc-tip::after {
            content: '';
            position: absolute;
            left: 50%;
            top: 100%;
            transform: translateX(-50%);
            border: 6px solid transparent;
            border-top-color: #0f172a;
        }

        .chart-host .calc-tip.below {
            transform: translate(-50%, 12px);
        }

        .chart-host .calc-tip.below::after {
            top: auto;
            bottom: 100%;
            border-top-color: transparent;
            border-bottom-color: #0f172a;
        }

        .chart-host .calc-tip-m {
            display: block;
            font-size: 0.68rem;
            font-weight: 600;
            color: #93c5fd;
            margin-bottom: 1px;
        }
    </style>
</head>
<body>
    <!-- Gate d'accès (protection mot de passe) -->
    <div id="closer-gate" class="closer-gate" role="dialog" aria-modal="true" aria-labelledby="closer-gate-title">
        <div class="closer-gate-card">
            <div class="closer-gate-logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h1 id="closer-gate-title">Documentation closer · accès réservé</h1>
            <p class="closer-gate-hint">Connectez-vous avec votre email et votre mot de passe.</p>
            <div id="closer-gate-spinner" class="closer-gate-spinner" aria-hidden="true"></div>
            <form id="closer-gate-form" class="closer-gate-form">
                <input id="closer-gate-email" class="closer-gate-input" type="email" inputmode="email" autocapitalize="none" autocomplete="username" spellcheck="false" placeholder="Votre email" aria-label="Email" />
                <input id="closer-gate-pass" class="closer-gate-input" type="password" autocomplete="current-password" placeholder="Votre mot de passe" aria-label="Mot de passe" style="margin-top:10px;" />
                <label class="closer-gate-consent" for="closer-gate-consent">
                    <input type="checkbox" id="closer-gate-consent" />
                    <span>Je comprends que les informations de cette page sont confidentielles et je m'engage à ne pas les partager ni les diffuser.</span>
                </label>
                <p id="closer-gate-error" class="closer-gate-error" role="alert"></p>
                <button id="closer-gate-btn" class="closer-gate-btn" type="submit" disabled>Accéder</button>
            </form>
        </div>
    </div>

    <script is:inline define:vars={{ IS_DEV }}>
        window.__CLOSER_DOC_DEV__ = IS_DEV;
