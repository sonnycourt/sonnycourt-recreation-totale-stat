---
import '../../styles/admin-es2.css';

const tabs = [
  { id: 'overview', label: "Vue d'ensemble" },
  { id: 'funnel', label: 'Funnel' },
  { id: 'behavior', label: 'Comportement utilisateur' },
  { id: 'content', label: 'Contenu' },
  { id: 'ops', label: 'Ops / Debug' },
  { id: 'health', label: 'Santé client' },
];
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Dashboard admin — ES2</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <div id="gate" class="min-h-screen flex items-center justify-center text-slate-400 text-sm">Vérification…</div>

    <div id="app" class="hidden min-h-screen flex flex-col md:flex-row">
      <aside class="w-full md:w-56 shrink-0 border-b md:border-b-0 md:border-r border-slate-800 bg-slate-900/80 p-4 md:min-h-screen">
        <div class="mb-6 flex items-center justify-between md:block">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Admin</span>
        </div>
        <nav class="flex flex-row flex-wrap gap-1 md:flex-col md:gap-0.5" id="nav" aria-label="Sections">
          {tabs.map((t, i) => (
            <button
              type="button"
              class:list={[
                'tab-btn rounded-md px-3 py-2 text-left text-sm font-medium transition md:w-full',
                i === 0 ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200',
              ]}
              data-tab={t.id}
            >
              {t.label}
            </button>
          ))}
        </nav>
      </aside>

      <div class="flex min-h-0 flex-1 flex-col">
        <header class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-800 bg-slate-950/90 px-4 py-3 md:px-6">
          <h1 class="text-sm font-semibold text-slate-300 md:text-base" id="panel-title">{tabs[0].label}</h1>
          <div class="flex items-center gap-2">
            <button
              type="button"
              id="pwd-btn"
              class="rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-300 transition hover:border-slate-500 hover:text-white"
            >
              Mot de passe
            </button>
            <button
              type="button"
              id="logout-btn"
              class="rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-300 transition hover:border-slate-500 hover:text-white"
            >
              Se déconnecter
            </button>
          </div>
        </header>

        <main class="flex-1 p-4 md:p-8">
          {tabs.map((t, i) => (
            <section
              class:list={['tab-panel', i === 0 ? '' : 'hidden']}
              data-panel={t.id}
              role="tabpanel"
            >
              {t.id === 'ops' ? (
                <div class="space-y-4" id="ops-cockpit">
                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                      <div>
                        <p class="text-xs uppercase tracking-wider text-slate-500">Cockpit live</p>
                        <h3 class="text-sm font-semibold text-white">Surveillance diffusion ES2</h3>
                      </div>
                      <div class="flex items-center gap-2">
                        <button id="ops-refresh" type="button" class="rounded-md border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-200 hover:border-slate-500">Actualiser</button>
                        <span id="ops-updated" class="text-xs text-slate-500">—</span>
                      </div>
                    </div>
                  </div>

                  <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">En attente (live)</p>
                      <p id="ops-waiting" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">En session (live)</p>
                      <p id="ops-session" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">En replay (live)</p>
                      <p id="ops-replay" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Actifs totaux</p>
                      <p id="ops-total" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                  </div>

                  <div class="grid gap-3 xl:grid-cols-2">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-3">
                      <p class="text-xs uppercase tracking-wider text-slate-500">Santé vidéo</p>
                      <p class="text-xs text-slate-400">Source active: <span id="ops-source" class="font-semibold text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400 break-all">URL active: <span id="ops-url" class="text-slate-300">—</span></p>
                      <div class="space-y-1 text-xs text-slate-400">
                        <p>Check active: <span id="ops-check-active">—</span></p>
                        <p>Check primary: <span id="ops-check-primary">—</span></p>
                        <p>Check backup: <span id="ops-check-backup">—</span></p>
                      </div>
                      <div class="flex flex-wrap gap-2 pt-1">
                        <button id="ops-switch-primary" type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-500">Passer en Primary</button>
                        <button id="ops-switch-backup" type="button" class="rounded-md border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-200 hover:border-slate-500">Passer en Backup</button>
                        <button id="ops-clear-override" type="button" class="rounded-md border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-300 hover:border-slate-500">Reset</button>
                      </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-2">
                      <p class="text-xs uppercase tracking-wider text-slate-500">Session courante</p>
                      <p class="text-xs text-slate-400">Heure UTC: <span id="ops-now-utc" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Heure Paris: <span id="ops-now-paris" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Session: <span id="ops-session-date" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Expire: <span id="ops-expire-date" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Fenêtre live: <span id="ops-live-window" class="text-slate-200">—</span></p>
                      <div class="pt-2 text-xs text-slate-400">
                        <p>Inscrits: <span id="ops-pop-inscrit" class="text-slate-200">0</span></p>
                        <p>Présents: <span id="ops-pop-present" class="text-slate-200">0</span></p>
                        <p>Acheteurs: <span id="ops-pop-acheteur" class="text-slate-200">0</span></p>
                        <p>Non-acheteurs: <span id="ops-pop-nonacheteur" class="text-slate-200">0</span></p>
                      </div>
                    </div>
                  </div>

                  <p id="ops-error" class="hidden text-xs text-red-400"></p>
                </div>
              ) : (
                <p class="text-slate-500 text-sm">À venir</p>
              )}
            </section>
          ))}
        </main>
      </div>
    </div>

    <div
      id="pwd-modal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 px-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="pwd-modal-title"
    >
      <div class="w-full max-w-md rounded-xl border border-slate-700 bg-slate-900 p-6 shadow-xl">
        <h2 id="pwd-modal-title" class="text-base font-semibold text-white mb-1">Changer le mot de passe</h2>
        <p class="text-xs text-slate-500 mb-4">Minimum 12 caractères.</p>
        <form id="pwd-form" class="space-y-3">
          <input
            type="password"
            id="pwd-current"
            autocomplete="current-password"
            required
            class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
            placeholder="Mot de passe actuel"
          />
          <input
            type="password"
            id="pwd-new"
            autocomplete="new-password"
            required
            minlength="12"
            class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
            placeholder="Nouveau mot de passe"
          />
          <input
            type="password"
            id="pwd-confirm"
            autocomplete="new-password"
            required
            minlength="12"
            class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
            placeholder="Confirmer le nouveau"
          />
          <p id="pwd-modal-err" class="hidden text-sm text-red-400"></p>
          <p id="pwd-modal-ok" class="hidden text-sm text-emerald-400"></p>
          <div class="flex gap-2 justify-end pt-2">
            <button type="button" id="pwd-cancel" class="rounded-lg border border-slate-600 px-3 py-2 text-xs font-medium text-slate-300 hover:bg-slate-800">
              Annuler
            </button>
            <button type="submit" id="pwd-save" class="rounded-lg bg-blue-600 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-500">
              Enregistrer
            </button>
          </div>
        </form>
      </div>
    </div>

    <script define:vars={{ tabIds: tabs.map((t) => t.id), tabLabels: tabs.map((t) => t.label) }}>
      const gate = document.getElementById('gate');
      const app = document.getElementById('app');
      const titleEl = document.getElementById('panel-title');

      async function requireAuth() {
        try {
          const r = await fetch('/.netlify/functions/admin-es2-session', { credentials: 'same-origin' });
          if (!r.ok) throw new Error('unauth');
          const d = await r.json();
          if (!d.authenticated) throw new Error('unauth');
          gate.classList.add('hidden');
          app.classList.remove('hidden');
        } catch {
          window.location.replace('/es-cockpit/');
        }
      }

      const pwdModal = document.getElementById('pwd-modal');
      document.getElementById('pwd-btn').addEventListener('click', function () {
        pwdModal.classList.remove('hidden');
      });
      document.getElementById('pwd-cancel').addEventListener('click', function () {
        pwdModal.classList.add('hidden');
        document.getElementById('pwd-modal-err').classList.add('hidden');
      });
      pwdModal.addEventListener('click', function (e) {
        if (e.target === pwdModal) pwdModal.classList.add('hidden');
      });

      document.getElementById('pwd-form').addEventListener('submit', async function (e) {
        e.preventDefault();
        const errEl = document.getElementById('pwd-modal-err');
        const btn = document.getElementById('pwd-save');
        errEl.classList.add('hidden');
        errEl.textContent = '';
        btn.disabled = true;
        try {
          const r = await fetch('/.netlify/functions/admin-es2-change-password', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              currentPassword: document.getElementById('pwd-current').value,
              newPassword: document.getElementById('pwd-new').value,
              confirm: document.getElementById('pwd-confirm').value,
            }),
          });
          const d = await r.json().catch(function () { return {}; });
          if (r.ok) {
            document.getElementById('pwd-current').value = '';
            document.getElementById('pwd-new').value = '';
            document.getElementById('pwd-confirm').value = '';
            errEl.classList.add('hidden');
            const okEl = document.getElementById('pwd-modal-ok');
            okEl.textContent = 'Mot de passe mis à jour.';
            okEl.classList.remove('hidden');
            setTimeout(function () {
              okEl.classList.add('hidden');
              pwdModal.classList.add('hidden');
            }, 1200);
            return;
          }
          errEl.textContent = d.error || 'Erreur.';
          if (r.status === 429) errEl.textContent = 'Trop de tentatives. Réessaie plus tard.';
          if (r.status === 401) errEl.textContent = d.error || 'Session expirée. Reconnecte-toi.';
          errEl.classList.remove('hidden');
        } catch {
          errEl.textContent = 'Erreur réseau.';
          errEl.classList.remove('hidden');
        } finally {
          btn.disabled = false;
        }
      });

      document.getElementById('logout-btn').addEventListener('click', async function () {
        try {
          await fetch('/.netlify/functions/admin-es2-logout', { method: 'POST', credentials: 'same-origin' });
        } catch {
          /* ignore */
        }
        window.location.replace('/es-cockpit/');
      });

      document.querySelectorAll('.tab-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const id = btn.getAttribute('data-tab');
          document.querySelectorAll('.tab-btn').forEach(function (b) {
            b.classList.remove('bg-slate-800', 'text-white');
            b.classList.add('text-slate-400');
          });
          btn.classList.add('bg-slate-800', 'text-white');
          btn.classList.remove('text-slate-400');
          document.querySelectorAll('.tab-panel').forEach(function (p) {
            p.classList.toggle('hidden', p.getAttribute('data-panel') !== id);
          });
          const idx = tabIds.indexOf(id);
          if (idx >= 0) titleEl.textContent = tabLabels[idx];
          if (id === 'ops') startOpsPolling();
        });
      });

      let opsPollingTimer = null;
      let opsBusy = false;

      function statusText(check) {
        if (!check) return '—';
        if (check.ok) return `OK (${check.status || '200'})`;
        if (check.status) return `KO (${check.status})`;
        return `KO (${check.error || 'error'})`;
      }

      async function refreshOpsStatus() {
        if (opsBusy) return;
        const root = document.getElementById('ops-cockpit');
        if (!root) return;
        if (root.closest('.hidden')) return;
        opsBusy = true;
        const errEl = document.getElementById('ops-error');
        if (errEl) {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
        try {
          const r = await fetch('/.netlify/functions/admin-es2-cockpit-status', { credentials: 'same-origin' });
          const d = await r.json().catch(function () { return {}; });
          if (!r.ok) throw new Error(d.error || 'Erreur cockpit');

          document.getElementById('ops-waiting').textContent = String(d?.presence?.waiting || 0);
          document.getElementById('ops-session').textContent = String(d?.presence?.session || 0);
          document.getElementById('ops-replay').textContent = String(d?.presence?.replay || 0);
          document.getElementById('ops-total').textContent = String(d?.presence?.activeTotal || 0);

          document.getElementById('ops-source').textContent = d?.video?.activeSource || '—';
          document.getElementById('ops-url').textContent = d?.video?.activeUrl || '—';
          document.getElementById('ops-check-active').textContent = statusText(d?.video?.checks?.active);
          document.getElementById('ops-check-primary').textContent = statusText(d?.video?.checks?.primary);
          document.getElementById('ops-check-backup').textContent = statusText(d?.video?.checks?.backup);

          document.getElementById('ops-now-utc').textContent = d?.now?.utcIso || '—';
          document.getElementById('ops-now-paris').textContent = d?.now?.parisIso || '—';
          document.getElementById('ops-session-date').textContent = d?.currentSession?.sessionDateIso || '—';
          document.getElementById('ops-expire-date').textContent = d?.currentSession?.offerExpiresIso || '—';
          document.getElementById('ops-live-window').textContent = d?.currentSession?.isLiveWindow ? 'Oui' : 'Non';

          document.getElementById('ops-pop-inscrit').textContent = String(d?.sessionPopulation?.inscrit || 0);
          document.getElementById('ops-pop-present').textContent = String(d?.sessionPopulation?.present || 0);
          document.getElementById('ops-pop-acheteur').textContent = String(d?.sessionPopulation?.acheteur || 0);
          document.getElementById('ops-pop-nonacheteur').textContent = String(d?.sessionPopulation?.non_acheteur || 0);

          document.getElementById('ops-updated').textContent = `MAJ ${new Date().toLocaleTimeString('fr-FR')}`;
        } catch (e) {
          if (errEl) {
            errEl.textContent = e?.message || 'Erreur cockpit';
            errEl.classList.remove('hidden');
          }
        } finally {
          opsBusy = false;
        }
      }

      function startOpsPolling() {
        if (opsPollingTimer) return;
        refreshOpsStatus();
        opsPollingTimer = setInterval(refreshOpsStatus, 7000);
      }

      async function sendOpsControl(action) {
        const errEl = document.getElementById('ops-error');
        if (errEl) {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
        try {
          const r = await fetch('/.netlify/functions/admin-es2-cockpit-control', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action }),
          });
          const d = await r.json().catch(function () { return {}; });
          if (!r.ok) throw new Error(d.error || 'Action impossible');
          await refreshOpsStatus();
        } catch (e) {
          if (errEl) {
            errEl.textContent = e?.message || 'Erreur action';
            errEl.classList.remove('hidden');
          }
        }
      }

      const opsRefreshBtn = document.getElementById('ops-refresh');
      if (opsRefreshBtn) {
        opsRefreshBtn.addEventListener('click', refreshOpsStatus);
      }
      const opsPrimaryBtn = document.getElementById('ops-switch-primary');
      if (opsPrimaryBtn) opsPrimaryBtn.addEventListener('click', function () { sendOpsControl('switch_primary'); });
      const opsBackupBtn = document.getElementById('ops-switch-backup');
      if (opsBackupBtn) opsBackupBtn.addEventListener('click', function () { sendOpsControl('switch_backup'); });
      const opsResetBtn = document.getElementById('ops-clear-override');
      if (opsResetBtn) opsResetBtn.addEventListener('click', function () { sendOpsControl('clear_override'); });

      requireAuth();
    </script>
  </body>
</html>
