---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Offre terminée - Sonny Court" description="Cette offre promotionnelle est terminée." showHeader={true} showFooter={true}>
  <div class="fin-promo-page">
    <div class="fin-promo-card">
      <div class="fin-promo-icon">⏰</div>
      <h1>Cette offre est terminée</h1>
      <p class="fin-promo-text">
        La promotion à laquelle tu essayes d'accéder a expiré.<br>
        Mais pas de panique — d'autres offres arrivent régulièrement.
      </p>
      <div class="fin-promo-actions">
        <a href="/formations/" class="fin-promo-btn primary">Voir nos formations</a>
        <a href="/" class="fin-promo-btn secondary">Retour à l'accueil</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .fin-promo-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .fin-promo-card {
    text-align: center;
    max-width: 520px;
    padding: 48px 32px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
  }

  .fin-promo-icon {
    font-size: 56px;
    margin-bottom: 24px;
  }

  h1 {
    font-size: 28px;
    font-weight: 700;
    color: #fafafa;
    margin-bottom: 16px;
  }

  .fin-promo-text {
    font-size: 16px;
    line-height: 1.7;
    color: #a1a1aa;
    margin-bottom: 32px;
  }

  .fin-promo-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .fin-promo-btn {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.2s ease;
    width: 100%;
    max-width: 280px;
    text-align: center;
  }

  .fin-promo-btn.primary {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    color: #ffffff;
    box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
  }

  .fin-promo-btn.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(139, 92, 246, 0.5);
  }

  .fin-promo-btn.secondary {
    background: transparent;
    color: #a1a1aa;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .fin-promo-btn.secondary:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.2);
  }
</style>
