---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Offre terminée - Sonny Court" description="Cette offre promotionnelle est terminée." showHeader={true} showFooter={true}>
  <div class="fin-promo-page">
    <div class="fin-promo-card">
      <div class="fin-promo-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h1>Cette offre est terminée</h1>
      <p class="fin-promo-text">
        La promotion à laquelle tu essayes d'accéder a expiré.
      </p>
      <div class="fin-promo-actions">
        <a href="/formations/" class="fin-promo-btn primary">Voir nos formations</a>
        <a href="/" class="fin-promo-btn secondary">Retour à l'accueil</a>
      </div>
      <div class="fin-promo-support">
        <p>Besoin d'aide ?</p>
        <a href="mailto:info@sonnycourt.com" class="fin-promo-email">info@sonnycourt.com</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .fin-promo-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .fin-promo-card {
    text-align: center;
    max-width: 520px;
    padding: 48px 32px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
  }

  .fin-promo-icon {
    margin-bottom: 24px;
    color: #a1a1aa;
  }

  h1 {
    font-size: 28px;
    font-weight: 700;
    color: #fafafa;
    margin-bottom: 16px;
  }

  .fin-promo-text {
    font-size: 16px;
    line-height: 1.7;
    color: #a1a1aa;
    margin-bottom: 32px;
  }

  .fin-promo-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    margin-bottom: 32px;
  }

  .fin-promo-btn {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.2s ease;
    width: 100%;
    max-width: 280px;
    text-align: center;
  }

  .fin-promo-btn.primary {
    background: linear-gradient(135deg, #007AFF 0%, #0051D5 100%);
    color: #ffffff;
    box-shadow: 0 4px 20px rgba(0, 122, 255, 0.3);
  }

  .fin-promo-btn.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 122, 255, 0.4);
  }

  .fin-promo-btn.secondary {
    background: transparent;
    color: #a1a1aa;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .fin-promo-btn.secondary:hover {
    color: #fafafa;
    border-color: rgba(255, 255, 255, 0.2);
  }

  .fin-promo-support {
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .fin-promo-support p {
    font-size: 14px;
    color: #71717a;
    margin-bottom: 8px;
  }

  .fin-promo-email {
    color: #007AFF;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    transition: color 0.2s ease;
  }

  .fin-promo-email:hover {
    color: #3395ff;
  }
</style>
