        function getNowMs() {
            if (!Number.isFinite(simulatedNowMs)) return Date.now();
            if (!Number.isFinite(simulatedAnchorRealMs)) return simulatedNowMs;
            return simulatedNowMs + (Date.now() - simulatedAnchorRealMs);
        }

        function pad(n) { return String(n).padStart(2, '0'); }
