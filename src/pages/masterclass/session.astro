---
import GAConsentMode from '../../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Replay — Webinaire Esprit Subconscient 2.0</title>
    <meta name="description" content="Accède au replay de la masterclass Esprit Subconscient 2.0.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --accent: #93c5fd;
            --bg-dark: #0a0a1a;
            --text-muted: rgba(255, 255, 255, 0.72);
            --border: rgba(59, 130, 246, 0.35);
        }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }
        .bg-gradient {
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 100%, rgba(37, 99, 235, 0.2) 0%, transparent 50%),
                linear-gradient(180deg, #0a0a1a 0%, #1a1a3a 50%, #0a0a1a 100%);
            z-index: -1;
        }
        .gate-loading {
            position: fixed;
            inset: 0;
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 16px;
            background: linear-gradient(180deg, #0a1628 0%, #0a0a1a 100%);
        }
        .spinner {
            width: 44px;
            height: 44px;
            border: 3px solid rgba(59, 130, 246, 0.25);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.85s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .gate-loading p { color: var(--text-muted); font-size: 0.95rem; }
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 28px 18px 48px;
            display: none;
        }
        .container.is-visible { display: block; }
        .badge {
            display: inline-flex;
            padding: 8px 16px;
            background: rgba(59, 130, 246, 0.2);
            border: 1px solid var(--border);
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }
        h1 {
            font-size: clamp(1.6rem, 4vw, 2.2rem);
            line-height: 1.2;
            margin-bottom: 12px;
            background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .subtitle { color: var(--text-muted); line-height: 1.55; margin-bottom: 22px; }
        .video-box {
            position: relative;
            width: 100%;
            aspect-ratio: 16 / 9;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border);
            background: rgba(0, 0, 0, 0.35);
            margin-bottom: 20px;
        }
        .video-box iframe {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }
        .video-placeholder {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            text-align: center;
            padding: 20px;
            font-size: 0.95rem;
        }
        .blocked {
            display: none;
            max-width: 560px;
            margin: 0 auto;
            padding: 48px 20px;
            text-align: center;
        }
        .blocked.is-visible { display: block; }
        .blocked h1 { -webkit-text-fill-color: #fff; color: #fff; }
        .blocked p { color: var(--text-muted); margin-top: 12px; line-height: 1.6; }
        .btn {
            display: inline-flex;
            margin-top: 22px;
            padding: 14px 22px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            font-weight: 700;
            text-decoration: none;
            border: none;
            cursor: pointer;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>
    <div class="bg-gradient"></div>
    <div id="gate-loading" class="gate-loading" aria-live="polite">
        <div class="spinner" aria-hidden="true"></div>
        <p>Chargement…</p>
    </div>

    <div id="blocked" class="blocked">
        <h1 id="blocked-title">Accès indisponible</h1>
        <p id="blocked-text"></p>
        <a class="btn" href="/masterclass">Retour</a>
    </div>

    <div id="main" class="container">
        <div class="badge">Replay masterclass</div>
        <h1 id="headline">Ta session replay</h1>
        <p id="sub" class="subtitle">Merci d’avoir réservé ta place. Profite du replay ci-dessous.</p>
        <div class="video-box">
            <div id="video-placeholder" class="video-placeholder">
                Colle ici l’URL de la vidéo (Wistia / Vimeo / YouTube) — à brancher dans le code ou via config.
            </div>
            <iframe id="video-frame" title="Replay webinaire" style="display:none;"></iframe>
        </div>
    </div>

    <script>
        // @ts-nocheck
        const TOKEN_KEY = 'masterclass_es2_token';
        const LEGACY_TOKEN_KEY = 'webinaire_es2_token';
        const COOKIE_MAX = 365 * 24 * 60 * 60;

        function getCookie(name) {
            const esc = name.replace(/[$()*+.?[\\\]^{|}]/g, '\\$&');
            const m = document.cookie.match(new RegExp('(?:^|; )' + esc + '=([^;]*)'));
            return m ? decodeURIComponent(m[1]) : '';
        }

        function setTokenEverywhere(token) {
            localStorage.setItem(TOKEN_KEY, token);
            document.cookie = `${TOKEN_KEY}=${encodeURIComponent(token)}; path=/; max-age=${COOKIE_MAX}; SameSite=Lax`;
            localStorage.removeItem(LEGACY_TOKEN_KEY);
            document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
        }

        function getStoredTokenWithLegacy() {
            let t = (localStorage.getItem(TOKEN_KEY) || getCookie(TOKEN_KEY) || '').trim();
            if (t) return t;
            const legacy = (localStorage.getItem(LEGACY_TOKEN_KEY) || getCookie(LEGACY_TOKEN_KEY) || '').trim();
            if (legacy) {
                setTokenEverywhere(legacy);
                return legacy;
            }
            return '';
        }

        function normalizeReg(data, token) {
            return {
                statut: data.statut || 'inscrit',
                sessionStartsAt: data.sessionStartsAt || data.session_date,
                offreExpiresAt: data.offreExpiresAt || data.offre_expires_at,
                prenom: data.prenom || '',
                token,
            };
        }

        function accessState(reg) {
            const now = Date.now();
            const sd = new Date(reg.sessionStartsAt).getTime();
            const oe = new Date(reg.offreExpiresAt).getTime();
            const st = reg.statut;
            if (st === 'acheteur') return 'acheteur';
            if (st === 'no-show' || st === 'non-acheteur') return 'closed';
            if (now < sd) return 'before';
            if (now >= oe) return 'closed';
            return 'ok';
        }

        function showLoading(show) {
            document.getElementById('gate-loading').style.display = show ? 'flex' : 'none';
        }

        function showBlocked(title, text) {
            showLoading(false);
            document.getElementById('main').classList.remove('is-visible');
            const b = document.getElementById('blocked');
            document.getElementById('blocked-title').textContent = title;
            document.getElementById('blocked-text').textContent = text;
            b.classList.add('is-visible');
        }

        function showMain(reg) {
            showLoading(false);
            document.getElementById('blocked').classList.remove('is-visible');
            const main = document.getElementById('main');
            main.classList.add('is-visible');
            if (reg.prenom) {
                document.getElementById('headline').textContent = `${reg.prenom}, voici ton replay`;
            }
        }

        document.addEventListener('DOMContentLoaded', async function () {
            const params = new URLSearchParams(window.location.search);
            let token = (params.get('t') || '').trim();
            if (!token) {
                token = getStoredTokenWithLegacy();
            }
            if (!token) {
                showLoading(false);
                showBlocked('Lien manquant', 'Utilise le lien reçu par email pour accéder au replay.');
                return;
            }

            try {
                const res = await fetch(
                    '/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token),
                );
                if (!res.ok) {
                    showBlocked('Lien invalide', 'Ce lien ne correspond plus à une inscription valide.');
                    return;
                }
                const data = await res.json();
                if (!data.valid) {
                    showBlocked('Lien invalide', 'Ce lien ne correspond plus à une inscription valide.');
                    return;
                }
                const reg = normalizeReg(data, token);
                const a = accessState(reg);
                if (a === 'acheteur') {
                    showBlocked(
                        'Tu es déjà membre !',
                        'Tu es déjà membre d’Esprit Subconscient 2.0 ! Consulte tes emails pour accéder à ton espace.',
                    );
                    return;
                }
                if (a === 'closed') {
                    showBlocked(
                        'Cette masterclass n’est plus accessible.',
                        '',
                    );
                    return;
                }
                if (a === 'before') {
                    window.location.replace('/masterclass/confirmation?t=' + encodeURIComponent(token));
                    return;
                }

                await fetch('/.netlify/functions/update-webinaire-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token, statut: 'present' }),
                });

                setTokenEverywhere(token);

                showMain(reg);
            } catch (e) {
                showBlocked('Erreur', 'Impossible de charger ta session. Réessaie plus tard.');
            }
        });
    </script>
</body>
</html>
