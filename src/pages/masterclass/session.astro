---
import GAConsentMode from '../../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Session — Masterclass Esprit Subconscient 2.0</title>
    <meta name="description" content="Regarde la masterclass Esprit Subconscient 2.0.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --accent: #93c5fd;
            --bg-dark: #0a0a1a;
            --text-muted: rgba(255, 255, 255, 0.72);
            --border: rgba(59, 130, 246, 0.35);
        }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }
        .bg-gradient {
            position: fixed;
            inset: 0;
            z-index: -1;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 100%, rgba(37, 99, 235, 0.2) 0%, transparent 50%),
                linear-gradient(180deg, #0a0a1a 0%, #1a1a3a 50%, #0a0a1a 100%);
        }
        .gate-loading {
            position: fixed;
            inset: 0;
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 16px;
            background: linear-gradient(180deg, #0a1628 0%, #0a0a1a 100%);
        }
        .spinner {
            width: 44px;
            height: 44px;
            border: 3px solid rgba(59, 130, 246, 0.25);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.85s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        .screen {
            display: none;
            max-width: 1040px;
            margin: 0 auto;
            padding: 26px 16px 42px;
        }
        .screen.is-visible { display: block; }

        .badge {
            display: inline-flex;
            padding: 8px 16px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(59, 130, 246, 0.16);
            color: var(--accent);
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.9px;
            margin-bottom: 14px;
        }
        h1 {
            font-size: clamp(1.55rem, 4vw, 2.25rem);
            line-height: 1.2;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .subtitle {
            color: var(--text-muted);
            line-height: 1.55;
            margin-bottom: 18px;
            max-width: 760px;
        }
        .blocked {
            text-align: center;
            max-width: 620px;
            margin: 0 auto;
            padding-top: 48px;
        }
        .blocked h1 { -webkit-text-fill-color: #fff; color: #fff; }
        .blocked p { color: var(--text-muted); margin-top: 10px; line-height: 1.6; }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 20px;
            border: none;
            border-radius: 12px;
            padding: 14px 20px;
            font-size: 0.95rem;
            font-weight: 700;
            text-decoration: none;
            color: #fff;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            box-shadow: 0 12px 30px rgba(59, 130, 246, 0.32);
        }

        .video-shell {
            width: 100%;
            aspect-ratio: 16 / 9;
            border-radius: 16px;
            border: 1px solid var(--border);
            overflow: hidden;
            background: #05070f;
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.42);
            margin-bottom: 20px;
        }
        #masterclass-video {
            width: 100%;
            height: 100%;
            display: block;
            background: #000;
        }
        .video-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: var(--text-muted);
            padding: 20px;
            line-height: 1.5;
            background: radial-gradient(circle at 50% 30%, rgba(59,130,246,0.08), transparent 60%);
        }
        .offer-zone {
            min-height: 132px;
        }
        .offer-zone.hidden { visibility: hidden; pointer-events: none; }
        .offer-zone.visible { visibility: visible; }
        .offer-cta {
            width: 100%;
            max-width: 520px;
            border: none;
            border-radius: 14px;
            padding: 16px 20px;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.02em;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            box-shadow: 0 14px 34px rgba(59, 130, 246, 0.38);
        }
        .offer-zone.visible .offer-cta { animation: ctaIn 0.35s ease both; }
        @keyframes ctaIn {
            from { opacity: 0; transform: translateY(6px) scale(0.985); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        .offer-countdown-title {
            margin-top: 14px;
            margin-bottom: 10px;
            color: var(--accent);
            font-size: 0.92rem;
            font-weight: 700;
            letter-spacing: 0.03em;
        }
        .countdown {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 8px;
            max-width: 520px;
        }
        .count-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 10px 6px;
            text-align: center;
        }
        .count-value {
            display: block;
            font-size: clamp(1.08rem, 3vw, 1.45rem);
            font-weight: 700;
            color: #fff;
        }
        .count-label {
            font-size: 0.68rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.55px;
        }
        .wait-note {
            color: var(--text-muted);
            margin-bottom: 14px;
            line-height: 1.55;
        }
        @media (max-width: 640px) {
            .screen { padding: 20px 14px 34px; }
            .offer-cta { width: 100%; }
            .countdown { max-width: 100%; }
        }
    </style>
</head>
<body>
    <div class="bg-gradient"></div>

    <div id="gate-loading" class="gate-loading" aria-live="polite">
        <div class="spinner" aria-hidden="true"></div>
        <p>Chargement de la session…</p>
    </div>

    <section id="screen-blocked" class="screen blocked" aria-live="polite">
        <div class="badge">Session fermée</div>
        <h1 id="blocked-title">Cette masterclass n'est plus accessible.</h1>
        <p id="blocked-text"></p>
        <a class="btn" href="/masterclass">Retour à la masterclass</a>
    </section>

    <section id="screen-before" class="screen" aria-live="polite">
        <div class="badge">Session pas encore ouverte</div>
        <h1>La masterclass commence dans...</h1>
        <p class="wait-note">Tu vas être redirigé vers ta page de confirmation.</p>
        <div class="countdown">
            <div class="count-card"><span id="before-days" class="count-value">00</span><span class="count-label">Jours</span></div>
            <div class="count-card"><span id="before-hours" class="count-value">00</span><span class="count-label">Heures</span></div>
            <div class="count-card"><span id="before-minutes" class="count-value">00</span><span class="count-label">Minutes</span></div>
            <div class="count-card"><span id="before-seconds" class="count-value">00</span><span class="count-label">Secondes</span></div>
        </div>
    </section>

    <section id="screen-main" class="screen">
        <div class="badge">Masterclass en direct / replay</div>
        <h1>Masterclass Esprit Subconscient 2.0</h1>
        <p class="subtitle">Reprogramme ton subconscient et manifeste la vie de tes rêves</p>

        <div class="video-shell">
            <video id="masterclass-video" controls controlslist="nodownload noplaybackrate" preload="metadata" playsinline></video>
            <div id="video-placeholder" class="video-placeholder" style="display:none;">
                URL Bunny Stream à brancher dans <code style="margin-left:6px;opacity:0.9;">VIDEO_SOURCE_URL</code>.
            </div>
        </div>

        <div id="offer-zone" class="offer-zone hidden">
            <a id="offer-cta" class="offer-cta" href="#">Découvrir Esprit Subconscient 2.0</a>
            <p class="offer-countdown-title">L'offre expire dans :</p>
            <div class="countdown">
                <div class="count-card"><span id="offer-days" class="count-value">00</span><span class="count-label">Jours</span></div>
                <div class="count-card"><span id="offer-hours" class="count-value">00</span><span class="count-label">Heures</span></div>
                <div class="count-card"><span id="offer-minutes" class="count-value">00</span><span class="count-label">Minutes</span></div>
                <div class="count-card"><span id="offer-seconds" class="count-value">00</span><span class="count-label">Secondes</span></div>
            </div>
        </div>
    </section>

    <script>
        // @ts-nocheck
        const TOKEN_KEY = 'masterclass_es2_token';
        const LEGACY_TOKEN_KEY = 'webinaire_es2_token';
        const COOKIE_MAX = 365 * 24 * 60 * 60;
        const CTA_APPEAR_SECONDS = 2100; // 35 min
        const VIDEO_SOURCE_URL = ''; // TODO: URL Bunny Stream (source vidéo)
        const CTA_STATE_PREFIX = 'masterclass_es2_cta_visible_';
        const REDIRECT_TO_CONFIRMATION_MS = 2200;

        function pad(n) { return String(n).padStart(2, '0'); }
        function getCookie(name) {
            const esc = name.replace(/[$()*+.?[\\\]^{|}]/g, '\\$&');
            const m = document.cookie.match(new RegExp('(?:^|; )' + esc + '=([^;]*)'));
            return m ? decodeURIComponent(m[1]) : '';
        }
        function setTokenEverywhere(token) {
            localStorage.setItem(TOKEN_KEY, token);
            document.cookie = `${TOKEN_KEY}=${encodeURIComponent(token)}; path=/; max-age=${COOKIE_MAX}; SameSite=Lax`;
            localStorage.removeItem(LEGACY_TOKEN_KEY);
            document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
        }
        function getStoredTokenWithLegacy() {
            let t = (localStorage.getItem(TOKEN_KEY) || getCookie(TOKEN_KEY) || '').trim();
            if (t) return t;
            const legacy = (localStorage.getItem(LEGACY_TOKEN_KEY) || getCookie(LEGACY_TOKEN_KEY) || '').trim();
            if (legacy) {
                setTokenEverywhere(legacy);
                return legacy;
            }
            return '';
        }
        function showLoading(on) {
            document.getElementById('gate-loading').style.display = on ? 'flex' : 'none';
        }
        function showScreen(id) {
            ['screen-blocked', 'screen-before', 'screen-main'].forEach((x) => {
                document.getElementById(x).classList.toggle('is-visible', x === id);
            });
            showLoading(false);
        }
        function showBlocked(title, text) {
            document.getElementById('blocked-title').textContent = title;
            document.getElementById('blocked-text').textContent = text || '';
            showScreen('screen-blocked');
        }
        function normalizeReg(data, token) {
            return {
                token,
                statut: data.statut || 'inscrit',
                prenom: data.prenom || '',
                sessionStartsAt: data.sessionStartsAt || data.session_date,
                offreExpiresAt: data.offreExpiresAt || data.offre_expires_at,
            };
        }
        function updateCountdown(targetMs, ids) {
            const diff = Math.max(0, targetMs - Date.now());
            const total = Math.floor(diff / 1000);
            document.getElementById(ids.days).textContent = pad(Math.floor(total / 86400));
            document.getElementById(ids.hours).textContent = pad(Math.floor((total % 86400) / 3600));
            document.getElementById(ids.minutes).textContent = pad(Math.floor((total % 3600) / 60));
            document.getElementById(ids.seconds).textContent = pad(total % 60);
        }
        function showOfferZone(token) {
            const zone = document.getElementById('offer-zone');
            if (!zone.classList.contains('visible')) {
                zone.classList.remove('hidden');
                zone.classList.add('visible');
            }
            try { localStorage.setItem(CTA_STATE_PREFIX + token, '1'); } catch {}
        }
        function shouldShowOfferImmediately(reg) {
            try {
                if (localStorage.getItem(CTA_STATE_PREFIX + reg.token) === '1') return true;
            } catch {}
            return reg.statut === 'present';
        }

        function mountVideoAndOffer(reg) {
            const offerHref = '/es2?t=' + encodeURIComponent(reg.token);
            document.getElementById('offer-cta').href = offerHref;

            const expiryMs = new Date(reg.offreExpiresAt).getTime();
            const offerIds = { days: 'offer-days', hours: 'offer-hours', minutes: 'offer-minutes', seconds: 'offer-seconds' };
            const tick = () => {
                updateCountdown(expiryMs, offerIds);
                if (Date.now() >= expiryMs) {
                    showBlocked("Cette masterclass n'est plus accessible.", '');
                }
            };
            setInterval(tick, 1000);

            const video = document.getElementById('masterclass-video');
            const placeholder = document.getElementById('video-placeholder');

            let maxWatched = 0;
            video.addEventListener('timeupdate', function () {
                if (video.currentTime > maxWatched) maxWatched = video.currentTime;
                if (video.currentTime >= CTA_APPEAR_SECONDS) showOfferZone(reg.token);
            });
            video.addEventListener('seeking', function () {
                if (video.currentTime > maxWatched + 1) {
                    video.currentTime = maxWatched;
                }
            });

            if (shouldShowOfferImmediately(reg)) showOfferZone(reg.token);
            tick();

            if (!VIDEO_SOURCE_URL) {
                video.style.display = 'none';
                placeholder.style.display = 'flex';
                return;
            }
            video.src = VIDEO_SOURCE_URL;
        }

        function runBeforeSession(reg) {
            const targetMs = new Date(reg.sessionStartsAt).getTime();
            const ids = { days: 'before-days', hours: 'before-hours', minutes: 'before-minutes', seconds: 'before-seconds' };
            const redirectUrl = '/masterclass/confirmation?t=' + encodeURIComponent(reg.token);
            showScreen('screen-before');
            updateCountdown(targetMs, ids);
            const t = setInterval(() => updateCountdown(targetMs, ids), 1000);
            setTimeout(() => {
                clearInterval(t);
                window.location.replace(redirectUrl);
            }, REDIRECT_TO_CONFIRMATION_MS);
        }

        async function maybeMarkPresent(reg) {
            if (reg.statut !== 'inscrit') return;
            try {
                await fetch('/.netlify/functions/update-webinaire-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: reg.token, statut: 'present' }),
                });
            } catch {}
        }

        document.addEventListener('DOMContentLoaded', async function () {
            const params = new URLSearchParams(window.location.search);
            const preview = params.get('preview') === 'true' || params.get('preview') === '1';

            if (preview) {
                const now = new Date();
                const offerMs = now.getTime() + 48 * 60 * 60 * 1000;
                const previewReg = {
                    token: 'preview-session',
                    statut: 'present',
                    prenom: 'Preview',
                    sessionStartsAt: new Date(now.getTime() - 2 * 60 * 60 * 1000).toISOString(),
                    offreExpiresAt: new Date(offerMs).toISOString(),
                };
                showScreen('screen-main');
                mountVideoAndOffer(previewReg);
                return;
            }

            let token = (params.get('t') || '').trim();
            if (!token) token = getStoredTokenWithLegacy();
            if (!token) {
                window.location.replace('/masterclass');
                return;
            }

            try {
                const res = await fetch('/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token));
                if (!res.ok) {
                    window.location.replace('/masterclass');
                    return;
                }
                const data = await res.json();
                if (!data.valid || !data.sessionStartsAt || !data.offreExpiresAt) {
                    window.location.replace('/masterclass');
                    return;
                }
                setTokenEverywhere(token);
                const reg = normalizeReg(data, token);

                const now = Date.now();
                const sessionMs = new Date(reg.sessionStartsAt).getTime();
                const offerMs = new Date(reg.offreExpiresAt).getTime();

                if (!Number.isFinite(sessionMs) || !Number.isFinite(offerMs)) {
                    showBlocked('Erreur', 'Dates de session invalides.');
                    return;
                }

                if (reg.statut === 'no-show' || reg.statut === 'non-acheteur') {
                    showBlocked("Cette masterclass n'est plus accessible.", '');
                    return;
                }
                if (reg.statut === 'acheteur') {
                    showBlocked(
                        "Tu es déjà membre d'Esprit Subconscient 2.0 !",
                        'Consulte tes emails pour accéder à ton espace.'
                    );
                    return;
                }
                if (now >= offerMs) {
                    showBlocked("Cette masterclass n'est plus accessible.", '');
                    return;
                }
                if (reg.statut === 'inscrit' && now < sessionMs) {
                    runBeforeSession(reg);
                    return;
                }

                showScreen('screen-main');
                await maybeMarkPresent(reg);
                mountVideoAndOffer(reg);
            } catch (e) {
                showBlocked('Erreur', 'Impossible de charger la session pour le moment.');
            }
        });
    </script>
</body>
</html>
