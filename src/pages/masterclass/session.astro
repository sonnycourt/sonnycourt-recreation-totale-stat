---
import GAConsentMode from '../../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Session - Masterclass Esprit Subconscient 2.0</title>
    <meta name="description" content="Regarde la masterclass Esprit Subconscient 2.0.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
    <GAConsentMode />
    <style>
        html { opacity: 0; }
        html.ready { opacity: 1; transition: opacity 0.15s ease; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --accent: #93c5fd;
            --bg-dark: #0a0a1a;
            --text-muted: rgba(255, 255, 255, 0.72);
            --border: rgba(59, 130, 246, 0.35);
        }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }
        .bg-gradient {
            position: fixed;
            inset: 0;
            z-index: -1;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 100%, rgba(37, 99, 235, 0.2) 0%, transparent 50%),
                linear-gradient(180deg, #0a0a1a 0%, #1a1a3a 50%, #0a0a1a 100%);
        }
        .gate-loading {
            position: fixed;
            inset: 0;
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 16px;
            background: linear-gradient(180deg, #0a1628 0%, #0a0a1a 100%);
        }
        .spinner {
            width: 44px;
            height: 44px;
            border: 3px solid rgba(59, 130, 246, 0.25);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.85s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        .dev-time-banner {
            display: none;
            padding: 10px;
            border-radius: 12px;
            border: 1px solid rgba(96, 165, 250, 0.45);
            background: rgba(15, 23, 42, 0.92);
            box-shadow: 0 12px 30px rgba(2, 6, 23, 0.45);
        }
        .dev-time-banner.is-visible {
            display: block;
            position: fixed;
            top: 10px;
            right: 10px;
            left: auto;
            z-index: 460000;
            width: min(380px, calc(100vw - 24px));
            max-height: min(520px, 78vh);
            overflow-x: hidden;
            overflow-y: auto;
            margin: 0;
            -webkit-overflow-scrolling: touch;
        }
        .dev-time-title {
            font-size: 0.78rem;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
            margin-bottom: 8px;
        }
        .dev-time-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
        }
        .dev-time-input {
            height: 36px;
            border-radius: 8px;
            border: 1px solid rgba(59, 130, 246, 0.45);
            background: rgba(255, 255, 255, 0.06);
            color: #fff;
            padding: 0 10px;
            font-size: 0.9rem;
        }
        .dev-time-btn {
            height: 34px;
            border-radius: 8px;
            border: 1px solid rgba(59, 130, 246, 0.35);
            background: rgba(59, 130, 246, 0.16);
            color: #dbeafe;
            padding: 0 10px;
            font-size: 0.82rem;
            font-weight: 600;
            cursor: pointer;
        }
        .dev-time-btn.is-active {
            border-color: rgba(147, 197, 253, 0.9);
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.38), rgba(37, 99, 235, 0.34));
            color: #fff;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.35), 0 10px 20px rgba(2, 6, 23, 0.35);
        }
        .dev-time-now {
            margin-left: auto;
            font-size: 0.78rem;
            color: var(--text-muted);
        }
        .dev-section {
            margin-bottom: 10px;
        }
        .dev-label {
            display: block;
            font-size: 0.74rem;
            color: #93c5fd;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 5px;
        }
        .dev-summary {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 18px;
            padding: 8px 10px;
            border-radius: 8px;
            background: rgba(59, 130, 246, 0.08);
            border: 1px solid rgba(59, 130, 246, 0.2);
            font-size: 0.76rem;
            color: #dbeafe;
        }
        .dev-summary span { white-space: nowrap; }
        .dev-summary .dev-state-val {
            font-weight: 700;
            color: #60a5fa;
        }

        .screen {
            display: none;
            max-width: 1040px;
            margin: 0 auto;
            padding: 26px 16px 42px;
        }
        .screen.is-visible { display: block; }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(59, 130, 246, 0.16);
            color: var(--accent);
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.9px;
            margin-bottom: 14px;
        }
        .badge::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: #ef4444;
            box-shadow: 0 0 0 rgba(239, 68, 68, 0.6);
            animation: liveDotPulse 1.3s ease-in-out infinite;
            flex-shrink: 0;
        }
        @keyframes liveDotPulse {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.55);
            }
            50% {
                opacity: 0.45;
                transform: scale(0.84);
                box-shadow: 0 0 0 8px rgba(239, 68, 68, 0);
            }
        }
        .screen-main-header {
            text-align: center;
            margin-bottom: 8px;
        }
        h1 {
            font-size: clamp(1.55rem, 4vw, 2.25rem);
            line-height: 1.2;
            font-weight: 800;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .subtitle {
            color: var(--text-muted);
            line-height: 1.55;
            margin-bottom: 18px;
            max-width: 760px;
            margin-left: auto;
            margin-right: auto;
        }
        .screen-main-header {
            text-align: center;
        }
        .blocked {
            text-align: center;
            max-width: 620px;
            margin: 0 auto;
            padding-top: 48px;
        }
        .blocked h1 { -webkit-text-fill-color: #fff; color: #fff; }
        .blocked p { color: var(--text-muted); margin-top: 10px; line-height: 1.6; }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 20px;
            border: none;
            border-radius: 12px;
            padding: 14px 20px;
            font-size: 0.95rem;
            font-weight: 700;
            text-decoration: none;
            color: #fff;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            box-shadow: 0 12px 30px rgba(59, 130, 246, 0.32);
        }

        .pre-live-countdown {
            margin-bottom: 10px;
            max-width: 640px;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
        }
        .pre-live-countdown .countdown {
            margin-left: auto;
            margin-right: auto;
        }
        .pre-live-countdown .countdown-title {
            font-size: 0.86rem;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }
        .video-shell {
            width: 100%;
            aspect-ratio: 16 / 9;
            border-radius: 16px;
            border: 1px solid var(--border);
            overflow: hidden;
            background: #05070f;
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.42);
            margin-bottom: 20px;
        }
        .video-container {
            position: relative;
            width: 100%;
            height: 100%;
            background: #000;
        }
        #masterclass-video {
            width: 100%;
            height: 100%;
            display: block;
            background: #000;
        }
        .video-waiting {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 12px;
            text-align: center;
            color: var(--text-muted);
            padding: 20px;
            line-height: 1.5;
            background:
                linear-gradient(180deg, rgba(2, 6, 18, 0.35) 0%, rgba(2, 6, 18, 0.6) 100%),
                url('/media/pages/ES20-banner.webp') center/cover no-repeat;
            z-index: 4;
        }
        .video-waiting.is-hidden {
            display: none;
        }
        .waiting-title {
            font-size: clamp(1rem, 2.2vw, 1.18rem);
            font-weight: 700;
            color: #dbeafe;
            text-shadow: 0 2px 20px rgba(2, 6, 23, 0.5);
        }
        .waiting-title.is-ended {
            color: #fecaca;
            font-size: clamp(1.08rem, 2.5vw, 1.32rem);
            letter-spacing: 0.01em;
            text-shadow: 0 6px 26px rgba(127, 29, 29, 0.55);
            background: rgba(127, 29, 29, 0.28);
            border: 1px solid rgba(239, 68, 68, 0.38);
            border-radius: 12px;
            padding: 10px 14px;
        }
        .play-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 6;
            transition: opacity 0.25s ease;
        }
        .play-overlay.hidden {
            opacity: 0;
            pointer-events: none;
        }
        .play-button {
            border: 1px solid rgba(147, 197, 253, 0.55);
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.95), rgba(37, 99, 235, 0.92));
            border-radius: 16px;
            padding: 14px 24px;
            cursor: pointer;
            transition: transform 0.2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 16px 36px rgba(37, 99, 235, 0.45);
        }
        .play-button:hover { transform: translateY(-1px); }
        .play-button__label {
            font-size: 1rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: 0.01em;
            text-shadow: 0 1px 12px rgba(2, 6, 23, 0.35);
        }
        .video-controls {
            position: absolute;
            left: 10px;
            right: 10px;
            bottom: 10px;
            z-index: 7;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            padding: 8px 10px;
            border-radius: 10px;
            background: rgba(6, 12, 24, 0.72);
            border: 1px solid rgba(59, 130, 246, 0.28);
            backdrop-filter: blur(6px);
            opacity: 0;
            transition: opacity 0.2s ease;
        }
        .video-container:hover .video-controls,
        .video-controls.is-visible {
            opacity: 1;
        }
        @media (max-width: 1023px) {
            .video-container.is-joined .video-controls {
                opacity: 1;
            }
        }
        @media (max-width: 1023px) and (orientation: landscape) {
            .video-container.is-joined .video-controls.mobile-autohide-hidden {
                opacity: 0;
                pointer-events: none;
            }
        }
        /* Verrou strict: aucun contrôle visible avant le "join" explicite */
        .video-container:not(.is-joined) .video-controls {
            display: none !important;
        }
        .controls-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .control-btn {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            border: 1px solid rgba(59, 130, 246, 0.35);
            background: rgba(59, 130, 246, 0.15);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        .control-btn svg { width: 18px; height: 18px; }
        .volume-range {
            width: 84px;
            accent-color: var(--primary);
        }
        .rotate-hint {
            position: absolute;
            inset: 0;
            z-index: 20;
            display: none;
            pointer-events: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
            background: rgba(0, 0, 0, 0.45);
            backdrop-filter: blur(6px);
        }
        .rotate-hint__inner {
            max-width: 420px;
            border-radius: 14px;
            border: 1px solid rgba(59, 130, 246, 0.35);
            background: rgba(6, 12, 24, 0.72);
            padding: 14px 16px;
            text-align: center;
            color: #dbeafe;
            font-weight: 700;
            font-size: 13px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
        }
        /* Sur mobile/iPad: recommandation en portrait uniquement */
        @media (orientation: portrait) and (max-width: 1023px) {
            .rotate-hint {
                display: flex;
            }
        }

        .fullscreen-floating {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 18;
            display: none;
            width: 38px;
            height: 38px;
            border-radius: 10px;
            border: 1px solid rgba(59, 130, 246, 0.35);
            background: rgba(59, 130, 246, 0.15);
            color: #fff;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(6px);
        }
        .fullscreen-floating svg { width: 18px; height: 18px; }
        /* Desktop uniquement */
        @media (min-width: 1024px) {
            .fullscreen-floating {
                display: inline-flex;
            }
        }
        .fullscreen-floating.hidden {
            display: none !important;
        }
        .video-container:not(.is-joined) .fullscreen-floating {
            display: none !important;
        }
        /* ── Heart Column ── */
        .player-row {
            display: flex;
            align-items: stretch;
            gap: 10px;
        }
        .player-row .video-shell {
            flex: 1;
            min-width: 0;
            margin-bottom: 0;
        }
        .heart-column {
            position: relative;
            flex-shrink: 0;
            width: 50px;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s ease;
        }
        .heart-column.is-visible {
            opacity: 1;
            pointer-events: auto;
        }
        .heart-column__btn {
            position: absolute;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1.5px solid rgba(59, 130, 246, 0.4);
            background: rgba(59, 130, 246, 0.15);
            font-size: 20px;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.1s ease;
        }
        .heart-column__btn:active { transform: translateX(-50%) scale(0.88); }
        .heart-column__track {
            position: absolute;
            bottom: 58px;
            left: 0;
            right: 0;
            top: 0;
            overflow: hidden;
        }
        @keyframes floatUp {
            0%   { transform: translateY(0) scale(1);      opacity: 1;  }
            50%  { transform: translateY(-120px) scale(1.1); opacity: 0.6; }
            100% { transform: translateY(-260px) scale(0.8); opacity: 0;  }
        }
        @media (max-width: 767px) {
            .player-row { display: block; }
            .player-row .video-shell { margin-bottom: 20px; }
            .heart-column {
                position: fixed;
                bottom: 20px;
                right: 12px;
                width: 44px;
                height: 200px;
                z-index: 200;
            }
        }

        .purchase-toast {
            position: fixed;
            left: 20px;
            bottom: 20px;
            z-index: 9999;
            opacity: 0;
            transform: translateY(20px);
            pointer-events: none;
            transition: opacity 0.4s ease, transform 0.4s ease;
        }
        .purchase-toast.show {
            opacity: 1;
            transform: translateY(0);
        }
        .purchase-toast__content {
            display: flex;
            align-items: center;
            gap: 10px;
            max-width: 360px;
            padding: 14px 16px;
            border-radius: 14px;
            border: 1px solid rgba(59, 130, 246, 0.3);
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.95));
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(59, 130, 246, 0.2);
            backdrop-filter: blur(10px);
        }
        .purchase-toast__thumb-wrap {
            position: relative;
            width: 58px;
            height: 58px;
            flex-shrink: 0;
        }
        .purchase-toast__thumb {
            width: 58px;
            height: 58px;
            border-radius: 9px;
            object-fit: cover;
            display: block;
            border: 1px solid rgba(59, 130, 246, 0.4);
            box-shadow: 0 4px 16px rgba(2, 6, 23, 0.35);
        }
        .purchase-toast__thumb-flag {
            position: absolute;
            right: -4px;
            bottom: -4px;
            font-size: 14px;
            line-height: 1;
            filter: drop-shadow(0 2px 6px rgba(2, 6, 23, 0.5));
        }
        .purchase-toast__text {
            margin: 0;
            font-size: 14px;
            line-height: 1.35;
            color: #fff;
        }
        .purchase-toast__name {
            color: #60a5fa !important;
            font-weight: 900 !important;
            text-shadow: 0 0 10px rgba(96, 165, 250, 0.35);
        }
        .purchase-toast__action {
            color: rgba(255, 255, 255, 0.72);
        }
        .purchase-toast__course {
            display: block;
            margin-top: 2px;
            color: #ffffff !important;
            font-weight: 400 !important;
        }

        .offer-zone {
            min-height: 132px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding-top: 38px;
        }
        .offer-zone.hidden {
            display: none;
        }
        .diagnostic-guide-zone {
            display: none;
            margin-top: 22px;
            margin-bottom: 12px;
            text-align: center;
        }
        .diagnostic-guide-zone.visible {
            display: block;
            animation: ctaFadeIn 0.35s ease forwards;
        }
        .diagnostic-guide-btn {
            width: 100%;
            max-width: 520px;
            border-radius: 12px;
            border: 1px solid rgba(96, 165, 250, 0.45);
            background: rgba(59, 130, 246, 0.16);
            color: #dbeafe;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.93rem;
            padding: 13px 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 10px 24px rgba(2, 6, 23, 0.28);
        }
        .diagnostic-guide-btn:hover {
            background: rgba(59, 130, 246, 0.24);
            border-color: rgba(147, 197, 253, 0.65);
            color: #fff;
        }
        .diagnostic-guide-note {
            margin-top: 8px;
            font-size: 0.78rem;
            color: rgba(226, 232, 240, 0.68);
        }
        .offer-zone.visible {
            display: flex;
            opacity: 1;
            transform: translateY(0);
            animation: ctaFadeIn 0.4s ease forwards;
        }
        @keyframes ctaFadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .offer-cta {
            width: 100%;
            max-width: 520px;
            margin-top: 12px;
            border: none;
            border-radius: 14px;
            padding: 16px 20px;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.02em;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            box-shadow: 0 14px 34px rgba(59, 130, 246, 0.38);
            transition: all 0.25s ease;
        }
        .offer-cta:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 40px rgba(59, 130, 246, 0.45);
        }
        .offer-expired-state {
            width: 100%;
            max-width: 520px;
            margin-top: 12px;
            border-radius: 14px;
            border: 1px solid rgba(248, 113, 113, 0.45);
            background: linear-gradient(135deg, rgba(127, 29, 29, 0.38), rgba(69, 10, 10, 0.45));
            padding: 16px 16px 14px;
            text-align: center;
        }
        .offer-expired-title {
            margin: 0;
            color: #fff1f2;
            font-size: 1rem;
            font-weight: 800;
        }
        .offer-expired-copy {
            margin: 8px 0 12px;
            color: #fecdd3;
            font-size: 0.9rem;
            line-height: 1.4;
        }
        .offer-expired-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 40px;
            padding: 0 14px;
            border-radius: 10px;
            border: 1px solid rgba(251, 113, 133, 0.55);
            color: #fff;
            background: rgba(225, 29, 72, 0.32);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 800;
        }

        .mc-gate-overlay {
            position: fixed;
            inset: 0;
            z-index: 200000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 18px;
            background: rgba(2, 6, 23, 0.92);
            backdrop-filter: blur(10px);
        }
        .mc-gate-overlay.is-visible {
            display: flex;
        }
        html.mc-page-lock,
        html.mc-page-lock body {
            overflow: hidden;
            height: 100%;
        }
        .mc-gate-overlay__panel {
            width: min(560px, 100%);
            border-radius: 16px;
            border: 1px solid rgba(96, 165, 250, 0.45);
