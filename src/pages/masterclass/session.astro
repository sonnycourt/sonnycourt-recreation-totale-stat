    <script>
        // @ts-nocheck
        const TOKEN_KEY = 'masterclass_es2_token';
        const LEGACY_TOKEN_KEY = 'webinaire_es2_token';
        const COOKIE_MAX = 365 * 24 * 60 * 60;
        const GUIDE_RELEASE_LEAD_MS = 60 * 60 * 1000; // bouton guide visible 60 min avant session_date
        const LIVE_VIDEO_LEAD_MS = 15 * 60 * 1000; // la vidéo commence 15 min avant session_date (19h45)
        const LATE_DIRECT_CUTOFF_MS = 30 * 60 * 1000; // +30 min après début live = trop tard pour le direct
        const CTA_APPEAR_SECONDS = 1800; // minute 30
        const VIDEO_DURATION_FALLBACK_SECONDS = 2700; // fallback si metadata indisponible
        let ACTIVE_VIDEO_DURATION_SECONDS = VIDEO_DURATION_FALLBACK_SECONDS;
        const VIDEO_SOURCE_URL_PRIMARY = 'https://sonnycourt-videos-public.b-cdn.net/Webinaire%20-%20V1%20(Pour%20Partage%20Et%20Timing).mp4';
        let ACTIVE_VIDEO_SOURCE_URL = VIDEO_SOURCE_URL_PRIMARY;
        const LIVE_GRACE_HIDE_COUNTDOWN_MS = 3 * 60 * 1000; // 20h03
        const LIVE_JOIN_LABEL = 'Rejoindre la masterclass en cours';
        const REPLAY_LABEL = 'Lancer la vidéo';
        let simulatedNowMs = null;
        let simulatedAnchorRealMs = null;

        function getNowMs() {
            if (!Number.isFinite(simulatedNowMs)) return Date.now();
            if (!Number.isFinite(simulatedAnchorRealMs)) return simulatedNowMs;
            return simulatedNowMs + (Date.now() - simulatedAnchorRealMs);
        }

        function pad(n) { return String(n).padStart(2, '0'); }
        function getVideoDurationSeconds() {
            return ACTIVE_VIDEO_DURATION_SECONDS || VIDEO_DURATION_FALLBACK_SECONDS;
        }
        function getCookie(name) {
            const esc = name.replace(/[$()*+.?[\\\]^{|}]/g, '\\$&');
            const m = document.cookie.match(new RegExp('(?:^|; )' + esc + '=([^;]*)'));
            return m ? decodeURIComponent(m[1]) : '';
        }
        async function fetchActiveVideoSourceConfig() {
            try {
                const res = await fetch('/.netlify/functions/webinaire-video-config');
                if (!res.ok) return;
                const data = await res.json();
                if (data && data.activeUrl) {
                    ACTIVE_VIDEO_SOURCE_URL = String(data.activeUrl);
                }
            } catch {
                /* ignore */
            }
        }
        function setTokenEverywhere(token) {
            localStorage.setItem(TOKEN_KEY, token);
            document.cookie = `${TOKEN_KEY}=${encodeURIComponent(token)}; path=/; max-age=${COOKIE_MAX}; SameSite=Lax`;
            localStorage.removeItem(LEGACY_TOKEN_KEY);
            document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
        }
        function getStoredTokenWithLegacy() {
            let t = (localStorage.getItem(TOKEN_KEY) || getCookie(TOKEN_KEY) || '').trim();
            if (t) return t;
            const legacy = (localStorage.getItem(LEGACY_TOKEN_KEY) || getCookie(LEGACY_TOKEN_KEY) || '').trim();
            if (legacy) {
                setTokenEverywhere(legacy);
                return legacy;
            }
            return '';
        }
        function showLoading(on) {
            document.getElementById('gate-loading').style.display = on ? 'flex' : 'none';
        }
        function showScreen(id) {
            ['screen-blocked', 'screen-before', 'screen-main', 'screen-recovery'].forEach((x) => {
                document.getElementById(x).classList.toggle('is-visible', x === id);
            });
            showLoading(false);
        }
        function showBlocked(title, text) {
            document.getElementById('blocked-title').textContent = title;
            document.getElementById('blocked-text').textContent = text || '';
            showScreen('screen-blocked');
        }
        function normalizeReg(data, token) {
            return {
                token,
                statut: data.statut || 'inscrit',
                prenom: data.prenom || '',
                sessionStartsAt: data.sessionStartsAt || data.session_date,
                offreExpiresAt: data.offreExpiresAt || data.offre_expires_at,
            };
        }
        function decideRouteFromPayload(payload, token) {
            const now = Date.now();
            const sd = new Date(payload.sessionStartsAt || payload.session_date).getTime();
            const oe = new Date(payload.offreExpiresAt || payload.offre_expires_at).getTime();
            const liveStart = sd - LIVE_VIDEO_LEAD_MS;
            const lateCutoff = liveStart + LATE_DIRECT_CUTOFF_MS;
            if (!Number.isFinite(sd) || !Number.isFinite(oe)) {
                return { type: 'block', title: 'Erreur', text: 'Dates de session invalides.' };
            }
            if (now < liveStart) {
                return { type: 'redirect', url: '/masterclass/confirmation?t=' + encodeURIComponent(token) };
            }
            if (now >= liveStart && now < lateCutoff) {
                return { type: 'redirect', url: '/masterclass/session?t=' + encodeURIComponent(token) };
            }
            if (now >= lateCutoff && now < oe) {
                return { type: 'redirect', url: '/masterclass/replay?t=' + encodeURIComponent(token) + '&reason=late' };
            }
            return { type: 'block', title: "Cette masterclass n'est plus accessible.", text: '' };
        }
        function setupRecoveryForm() {
            const submit = document.getElementById('recovery-submit');
            const input = document.getElementById('recovery-email');
            const err = document.getElementById('recovery-error');
            if (!submit || !input || !err) return;
            submit.addEventListener('click', async function () {
                err.textContent = '';
                const email = String(input.value || '').trim().toLowerCase();
                if (!email || !email.includes('@')) {
                    err.textContent = 'Merci de saisir un email valide.';
                    return;
                }
                submit.disabled = true;
                try {
                    const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email }),
                    });
                    const body = await res.json();
                    if (!res.ok) {
                        err.textContent = 'Vérification impossible. Réessaie dans un instant.';
                        return;
                    }
                    if (body.eligible === false && body.reason === 'excluded') {
                        err.textContent = "Tu n'es pas éligible pour suivre cette masterclass.";
                        return;
                    }
                    if (body.eligible === false && body.reason === 'already_registered' && body.token) {
                        setTokenEverywhere(body.token);
                        const route = decideRouteFromPayload(body, body.token);
                        if (route.type === 'redirect') {
                            window.location.replace(route.url);
                            return;
                        }
                        showBlocked(route.title, route.text || '');
                        return;
                    }
                    err.textContent = "Aucune inscription trouvée avec cet email.";
                } catch (e) {
                    err.textContent = 'Vérification impossible. Réessaie dans un instant.';
                } finally {
                    submit.disabled = false;
                }
            });
        }
        function updateCountdown(targetMs, ids) {
            const diff = Math.max(0, targetMs - getNowMs());
            const total = Math.floor(diff / 1000);
            document.getElementById(ids.days).textContent = pad(Math.floor(total / 86400));
            document.getElementById(ids.hours).textContent = pad(Math.floor((total % 86400) / 3600));
            document.getElementById(ids.minutes).textContent = pad(Math.floor((total % 3600) / 60));
            document.getElementById(ids.seconds).textContent = pad(total % 60);
        }
        async function sendPresencePing(token, stage, meta) {
            if (!token) return;
            try {
                await fetch('/.netlify/functions/webinaire-presence', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        token,
                        stage,
                        currentSecond: meta && Number.isFinite(meta.currentSecond) ? Math.floor(meta.currentSecond) : null,
                        isPlaying: Boolean(meta && meta.isPlaying),
                    }),
                });
            } catch {
                /* ignore */
            }
        }
        /* ── Heart Column ── */
        const HEART_SHOW_BEFORE_MS = 15 * 60 * 1000;

        function spawnHeart(track) {
            const h = document.createElement('span');
            var HEART_BLUES = ['#3b82f6','#60a5fa','#93c5fd','#2563eb','#a5b4fc','#bfdbfe'];
            var color = HEART_BLUES[Math.floor(Math.random() * HEART_BLUES.length)];
            h.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="' + color + '" stroke="none"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>';
            h.style.cssText = `
                position:absolute;bottom:0;left:${6 + Math.random() * 24}px;
                font-size:${12 + Math.random() * 10}px;opacity:1;pointer-events:none;
                animation:floatUp ${2 + Math.random()}s ease-out forwards;
            `;
            track.appendChild(h);
            h.addEventListener('animationend', () => h.remove());
        }

        function getSimInterval(sessionStartMs) {
            const now = getNowMs();
            const pre15 = sessionStartMs - 15 * 60 * 1000; // 19h45
            const pre5  = sessionStartMs - 5  * 60 * 1000; // 19h55
            const endMs = sessionStartMs + getVideoDurationSeconds() * 1000;
            const min15 = sessionStartMs + 15 * 60 * 1000; // 20h15
            const min30 = sessionStartMs + 30 * 60 * 1000; // 20h30

            if (now < pre15) return null;       // avant 19h45 — invisible
            if (now >= endMs) return -1;        // après fin — disparaît
            // 19h45 → 19h55 : montée lente
            if (now < pre5)  return 3000 + Math.random() * 2000;
            // 19h55 → 20h00 : montée rapide
            if (now < sessionStartMs) return 1200 + Math.random() * 800;
            // 20h00 → 20h15 : pic intense
            if (now < min15) return 600 + Math.random() * 600;
            // 20h15 → 20h30 : bon débit mais moins intense
            if (now < min30) return 1500 + Math.random() * 1000;
            // 20h30 → fin : débit modéré
            return 2500 + Math.random() * 1500;
        }

        function initHeartColumn(sessionStartMs) {
            const col   = document.getElementById('heart-column');
            const track = document.getElementById('heart-track');
            const btn   = document.getElementById('heart-btn');
            if (!col || !track || !btn) return { recalc: () => {}, destroy: () => {} };

            let timer = null;
            let burstTimers = [];

            function spawnBurst() {
                var count = 3 + Math.floor(Math.random() * 5); // 3-7 cœurs par "personne"
                for (var i = 0; i < count; i++) {
                    var t = setTimeout(function() { spawnHeart(track); }, i * (80 + Math.random() * 120));
                    burstTimers.push(t);
                }
            }

            function scheduleNext() {
                if (timer) clearTimeout(timer);
                var delay = getSimInterval(sessionStartMs);
                if (delay === null) return;
                if (delay === -1) { col.classList.remove('is-visible'); return; }
                timer = setTimeout(function() {
                    if (col.classList.contains('is-visible')) spawnBurst();
                    scheduleNext();
                }, delay);
            }

            function updateVisibility() {
                const now = getNowMs();
                const endMs = sessionStartMs + getVideoDurationSeconds() * 1000;
                if (now >= endMs) {
                    col.classList.remove('is-visible');
                    if (timer) { clearTimeout(timer); timer = null; }
                    return;
                }
                const show = now >= sessionStartMs - HEART_SHOW_BEFORE_MS;
                if (show && !col.classList.contains('is-visible')) {
                    col.classList.add('is-visible');
                    scheduleNext();
                } else if (!show && col.classList.contains('is-visible')) {
                    col.classList.remove('is-visible');
                    if (timer) { clearTimeout(timer); timer = null; }
                } else if (show) {
                    scheduleNext();
                }
            }

            btn.addEventListener('click', () => {
                spawnHeart(track);
                if (timer) clearTimeout(timer);
                timer = setTimeout(() => { spawnHeart(track); scheduleNext(); }, 300 + Math.random() * 500);
            });

            updateVisibility();
            return {
                recalc: updateVisibility,
                destroy: function () {
                    if (timer) { clearTimeout(timer); timer = null; }
                    burstTimers.forEach((t) => clearTimeout(t));
                    burstTimers = [];
                    col.classList.remove('is-visible');
                },
            };
        }

        function initPurchaseToasts(sessionStartMs) {
            const toast = document.getElementById('purchase-toast');
            const text = document.getElementById('purchase-toast-text');
            const flagEl = document.getElementById('purchase-toast-flag');
            if (!toast || !text || !flagEl) return { recalc: () => {}, destroy: () => {} };

            const prenoms = [
                'Sophie', 'Karim', 'Julie', 'Antoine', 'Fatima', 'Romain', 'Léa', 'Mehdi', 'Camille', 'Théo',
                'Nora', 'Alexandre', 'Chloé', 'Youssef', 'Marine', 'Sarah', 'Lucas', 'Inès', 'Maxime', 'Amina',
                'Thomas', 'Emma', 'Omar', 'Charlotte', 'Mathis', 'Yasmine', 'Hugo', 'Manon', 'Adam', 'Clara',
            ];
            const flags = ['🇫🇷', '🇧🇪', '🇨🇭', '🇨🇦'];
            let used = [];
            let hideTimer = null;
            let nextTimer = null;

            function pickUniqueName() {
                if (used.length >= prenoms.length) used = [];
                let idx = 0;
                do idx = Math.floor(Math.random() * prenoms.length);
                while (used.includes(idx));
                used.push(idx);
                return prenoms[idx];
            }

            function shouldRun() {
                const elapsedSec = Math.max(0, Math.floor((getNowMs() - sessionStartMs) / 1000));
                return elapsedSec >= CTA_APPEAR_SECONDS;
            }

            function hideNow() {
                toast.classList.remove('show');
                if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
            }

            function scheduleNext() {
                if (nextTimer) clearTimeout(nextTimer);
                if (!shouldRun()) return;
                const delay = 45000 + Math.random() * 45000; // 45-90s
                nextTimer = setTimeout(showOne, delay);
            }

            function showOne() {
                if (!shouldRun()) {
                    hideNow();
                    return;
                }
                const prenom = pickUniqueName();
                const flag = flags[Math.floor(Math.random() * flags.length)];
                flagEl.textContent = flag;
                text.innerHTML = `<span class="purchase-toast__name" style="color:#60a5fa;font-weight:900;">${prenom}</span> <span class="purchase-toast__action">vient de rejoindre</span><br /><span class="purchase-toast__course" style="color:#ffffff;font-weight:400;">Esprit Subconscient 2.0</span>`;
                toast.classList.add('show');
                if (hideTimer) clearTimeout(hideTimer);
                hideTimer = setTimeout(() => {
                    toast.classList.remove('show');
                    scheduleNext();
                }, 4000);
            }

            function recalc() {
                if (nextTimer) { clearTimeout(nextTimer); nextTimer = null; }
                hideNow();
                if (shouldRun()) showOne();
                else scheduleNext();
            }

            recalc();
            return {
                recalc,
                destroy: function () {
                    if (nextTimer) { clearTimeout(nextTimer); nextTimer = null; }
                    hideNow();
                },
            };
        }
        /* ──────────────────────────────── */

        function showOfferZone(token) {
            const zone = document.getElementById('offer-zone');
            if (!zone || zone.classList.contains('visible')) return;
            const cta = document.getElementById('offer-cta');
            cta.href = '/es2?t=' + encodeURIComponent(token);
            zone.classList.remove('hidden');
            void zone.offsetWidth; // reflow needed to trigger animation from display:none
            zone.classList.add('visible');
        }
        function hideOfferZone() {
            const zone = document.getElementById('offer-zone');
            if (!zone || zone.classList.contains('hidden')) return;
            zone.classList.remove('visible');
            zone.classList.add('hidden');
        }

        function mountVideoAndOffer(reg) {
            const expiryMs = new Date(reg.offreExpiresAt).getTime();
            const offerIds = { days: 'offer-days', hours: 'offer-hours', minutes: 'offer-minutes', seconds: 'offer-seconds' };
            const tick = () => {
                updateCountdown(expiryMs, offerIds);
                if (getNowMs() >= expiryMs) {
                    showBlocked("Cette masterclass n'est plus accessible.", '');
                }
            };
            const offerInterval = setInterval(tick, 1000);

            const video = document.getElementById('masterclass-video');
            const videoContainer = document.getElementById('video-container');
            const waiting = document.getElementById('video-waiting');
            const playOverlay = document.getElementById('playOverlay');
            const playBtn = document.getElementById('playButton');
            const muteBtn = document.getElementById('muteBtn');
            const volRange = document.getElementById('volumeRange');
            const fullscreenBtn = document.getElementById('fullscreenBtn');
            const preLive = document.getElementById('pre-live-countdown');
            const endedNote = document.getElementById('session-ended-note');
            const volumeIcon = document.getElementById('icon-volume');
            const muteIcon = document.getElementById('icon-mute');
            const playOverlayLabel = document.getElementById('playOverlayLabel');
            const sessionStartMs = new Date(reg.sessionStartsAt).getTime();
            const liveStartMs = sessionStartMs - LIVE_VIDEO_LEAD_MS;
            const hideCountdownMs = liveStartMs + LIVE_GRACE_HIDE_COUNTDOWN_MS;

            function formatSessionParisLabel(ms) {
                return new Intl.DateTimeFormat('fr-FR', {
                    timeZone: 'Europe/Paris',
                    weekday: 'long',
                    day: 'numeric',
                    month: 'long',
                }).format(new Date(ms));
            }

            let maxWatched = 0;
            let liveStarted = false;
            let launchInterval = null;
            let presenceInterval = null;
            let isLiveJoin = false;
            let isSessionEnded = false;
            let hasAppliedLiveOffset = false;

            function syncIcons() {
                const muted = video.muted || video.volume === 0;
                volumeIcon.style.display = muted ? 'none' : 'block';
                muteIcon.style.display = muted ? 'block' : 'none';
            }

            function disableNativeSeekAndFastForward() {
                video.playbackRate = 1;
                video.defaultPlaybackRate = 1;
                video.addEventListener('ratechange', function () {
                    if (video.playbackRate !== 1) video.playbackRate = 1;
                });
            }

            function updatePlayOverlayLabel() {
                if (!playOverlayLabel) return;
                playOverlayLabel.textContent = isLiveJoin ? LIVE_JOIN_LABEL : REPLAY_LABEL;
            }

            function applySimulatedLiveOffset() {
                if (hasAppliedLiveOffset) return;
                if (!Number.isFinite(video.duration) || video.duration <= 0) return;
                const elapsedSec = Math.max(0, Math.floor((getNowMs() - liveStartMs) / 1000));
                if (elapsedSec > 0 && elapsedSec < getVideoDurationSeconds()) {
                    isLiveJoin = true;
                    // Important: update max first so anti-seek guard doesn't snap back.
                    maxWatched = Math.max(maxWatched, elapsedSec);
                    video.currentTime = elapsedSec;
                } else {
                    isLiveJoin = false;
                }
                hasAppliedLiveOffset = true;
                updatePlayOverlayLabel();
            }

            function showEndedState() {
                isSessionEnded = true;
                liveStarted = false;
                if (preLive) preLive.style.display = 'none';
                if (endedNote) endedNote.classList.remove('is-visible');
                if (waiting) {
                    waiting.classList.remove('is-hidden');
                    const wt = waiting.querySelector('.waiting-title');
                    if (wt) {
                        wt.textContent = 'La masterclass est terminée';
                        wt.classList.add('is-ended');
                    }
                }
                playOverlay.classList.add('hidden');
                video.pause();
                video.currentTime = 0;
                updatePlayOverlayLabel();
                showOfferZone(reg.token);
            }

            function activateLiveJoinState() {
                if (isSessionEnded) return;
                liveStarted = true;
                if (endedNote) endedNote.classList.remove('is-visible');
                if (preLive) preLive.style.display = 'none';
                if (!video.paused) {
                    if (waiting) waiting.classList.add('is-hidden');
                    playOverlay.classList.add('hidden');
                } else {
                    if (waiting) {
                        waiting.classList.remove('is-hidden');
                        const wt = waiting.querySelector('.waiting-title');
                        if (wt) {
                            wt.textContent = '';
                            wt.classList.remove('is-ended');
                        }
                    }
                    playOverlay.classList.remove('hidden');
                }
                applySimulatedLiveOffset();
                syncIcons();
            }

            function refreshPreLiveCountdown() {
                const now = getNowMs();
                if (now < liveStartMs) {
                    sendPresencePing(reg.token, 'waiting', { currentSecond: 0, isPlaying: false });
                    liveStarted = false;
                    isSessionEnded = false;
                    hasAppliedLiveOffset = false;
                    if (endedNote) endedNote.classList.remove('is-visible');
                    if (preLive) preLive.style.display = 'block';
                    updateCountdown(liveStartMs, {
                        days: 'pl-days',
                        hours: 'pl-hours',
                        minutes: 'pl-minutes',
                        seconds: 'pl-seconds',
                    });
                    video.pause();
                    playOverlay.classList.add('hidden');
                    if (waiting) {
                        waiting.classList.remove('is-hidden');
                        const wt = waiting.querySelector('.waiting-title');
                        if (wt) {
                            wt.textContent = `Début de la diffusion ${formatSessionParisLabel(sessionStartMs)} à 19h45 (Paris)`;
                            wt.classList.remove('is-ended');
                        }
                    }
                    return;
                }

                if (now >= liveStartMs + getVideoDurationSeconds() * 1000) {
                    showEndedState();
                    return;
                }

                if (now >= liveStartMs && now < hideCountdownMs && preLive) {
                    preLive.style.display = 'none';
                }
                activateLiveJoinState();
                updateCtaStateByTime();
                updateDiagnosticGuideState();
                sendPresencePing(reg.token, 'session', { currentSecond: video.currentTime, isPlaying: !video.paused });
            }

            function updateCtaStateByTime() {
                const elapsedSec = Math.max(0, Math.floor((getNowMs() - liveStartMs) / 1000));
                if (elapsedSec >= CTA_APPEAR_SECONDS && !isSessionEnded) {
                    showOfferZone(reg.token);
                } else if (elapsedSec < CTA_APPEAR_SECONDS) {
                    hideOfferZone();
                }
            }
            function updateDiagnosticGuideState() {
                const zone = document.getElementById('diagnostic-guide-zone');
                if (!zone) return;
                const now = getNowMs();
                const showAt = sessionStartMs - GUIDE_RELEASE_LEAD_MS;
                const hideAt = sessionStartMs + 15 * 60 * 1000;
                const shouldShow = now >= showAt && now <= hideAt && !isSessionEnded;
                zone.classList.toggle('visible', shouldShow);
            }

            video.addEventListener('timeupdate', function () {
                if (video.currentTime > maxWatched) maxWatched = video.currentTime;
                updateCtaStateByTime();
                if (video.currentTime >= getVideoDurationSeconds()) {
                    showEndedState();
                }
            });
            video.addEventListener('seeking', function () {
                if (video.currentTime > maxWatched + 1) {
                    video.currentTime = maxWatched;
                }
            });
            video.addEventListener('play', function () {
                if (waiting) waiting.classList.add('is-hidden');
                playOverlay.classList.add('hidden');
                syncIcons();
            });
            video.addEventListener('pause', function () {
                // No pause experience once user has joined.
                if (liveStarted && !isSessionEnded) {
                    video.play().catch(() => {});
                    playOverlay.classList.add('hidden');
                }
                syncIcons();
            });
            video.addEventListener('volumechange', syncIcons);
            playBtn.addEventListener('click', function () {
                if (isSessionEnded) return;
                if (video.readyState >= 1) applySimulatedLiveOffset();
                if (waiting) waiting.classList.add('is-hidden');
                video.play().catch(() => {});
                playOverlay.classList.add('hidden');
            });
            muteBtn.addEventListener('click', function () {
                video.muted = !video.muted;
                syncIcons();
            });
            volRange.addEventListener('input', function () {
                const v = Number(volRange.value) / 100;
                video.volume = Math.max(0, Math.min(1, v));
                video.muted = video.volume === 0;
                syncIcons();
            });
            fullscreenBtn.addEventListener('click', function () {
                if (!document.fullscreenElement && videoContainer.requestFullscreen) {
                    videoContainer.requestFullscreen().catch(() => {});
                } else if (document.fullscreenElement && document.exitFullscreen) {
                    document.exitFullscreen().catch(() => {});
                }
            });
            videoContainer.addEventListener('keydown', function (e) {
                // Empêche les raccourcis seek du navigateur.
                if (['ArrowLeft', 'ArrowRight', 'j', 'l', 'J', 'L'].includes(e.key)) {
                    e.preventDefault();
                }
            });

            updateCtaStateByTime();
            updateDiagnosticGuideState();
            tick();
            disableNativeSeekAndFastForward();
            video.src = ACTIVE_VIDEO_SOURCE_URL;
            syncIcons();
            updatePlayOverlayLabel();
            video.addEventListener('loadedmetadata', function () {
                if (Number.isFinite(video.duration) && video.duration > 0) {
                    ACTIVE_VIDEO_DURATION_SECONDS = Math.ceil(video.duration);
                } else {
                    ACTIVE_VIDEO_DURATION_SECONDS = VIDEO_DURATION_FALLBACK_SECONDS;
                }
                applySimulatedLiveOffset();
                updateCtaStateByTime();
            });
            refreshPreLiveCountdown();
            launchInterval = setInterval(refreshPreLiveCountdown, 1000);
            presenceInterval = setInterval(function () {
                const now = getNowMs();
                const stage = now < liveStartMs ? 'waiting' : 'session';
                sendPresencePing(reg.token, stage, { currentSecond: video.currentTime, isPlaying: !video.paused });
            }, 20000);
            const beforeUnloadHandler = function () {
                if (launchInterval) clearInterval(launchInterval);
                if (offerInterval) clearInterval(offerInterval);
                if (presenceInterval) clearInterval(presenceInterval);
            };
            window.addEventListener('beforeunload', beforeUnloadHandler);

            const hearts = initHeartColumn(liveStartMs);
            const purchaseToasts = initPurchaseToasts(liveStartMs);

            return {
                recalcFromSimulatedTime: function () {
                    hasAppliedLiveOffset = false;
                    isSessionEnded = false;
                    hideOfferZone();
                    refreshPreLiveCountdown();
                    tick();
                    updateCtaStateByTime();
                    updateDiagnosticGuideState();
                    hearts.recalc();
                    purchaseToasts.recalc();
                },
                sessionStartMs,
                destroy: function () {
                    if (launchInterval) clearInterval(launchInterval);
                    if (offerInterval) clearInterval(offerInterval);
                    if (presenceInterval) clearInterval(presenceInterval);
                    hearts.destroy();
                    purchaseToasts.destroy();
                    window.removeEventListener('beforeunload', beforeUnloadHandler);
                },
            };
        }

        async function maybeMarkPresent(reg) {
            if (reg.statut !== 'inscrit') return;
            try {
                await fetch('/.netlify/functions/update-webinaire-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: reg.token, statut: 'present' }),
                });
            } catch {}
        }

        function toLocalDatetimeInputValue(ms) {
            const d = new Date(ms);
            const z = (n) => String(n).padStart(2, '0');
            return `${d.getFullYear()}-${z(d.getMonth() + 1)}-${z(d.getDate())}T${z(d.getHours())}:${z(d.getMinutes())}`;
        }

        /* ── Session date calc (mirrors webinaire-session-paris.mjs logic, client-side) ── */
        function devParisParts(date) {
            var fmt = new Intl.DateTimeFormat('fr-FR', {
                timeZone: 'Europe/Paris', numberingSystem: 'latn',
                year: 'numeric', month: 'numeric', day: 'numeric',
                weekday: 'short', hour: 'numeric', minute: 'numeric',
                hourCycle: 'h23',
            });
            var parts = fmt.formatToParts(date);
            var v = function(type) { return Number((parts.find(function(p) { return p.type === type; }) || {}).value || 0); };
            var wd = (parts.find(function(p) { return p.type === 'weekday'; }) || {}).value || '';
            return { year: v('year'), month: v('month'), day: v('day'), hour: v('hour'), minute: v('minute'), wd: wd.toLowerCase() };
        }
        function devParisWeekday(p) {
            var map = { lun: 1, mar: 2, mer: 3, jeu: 4, ven: 5, sam: 6, dim: 7 };
            for (var k in map) { if (p.wd.indexOf(k) === 0) return map[k]; }
            return 1;
        }
        function devAddDays(y, m, d, delta) {
            var dt = new Date(Date.UTC(y, m - 1, d + delta, 12, 0, 0));
            var p = devParisParts(dt);
            return { year: p.year, month: p.month, day: p.day };
        }
        function devFindParisInstant(py, pm, pd, ph) {
            var start = Date.UTC(py, pm - 1, pd, 0, 0, 0);
            var end = start + 48 * 3600 * 1000;
            for (var t = start; t < end; t += 60000) {
                var p = devParisParts(new Date(t));
                if (p.year === py && p.month === pm && p.day === pd && p.hour === ph) return new Date(t);
            }
            return null;
        }
        function devCalcSession(inscriptionDate) {
            var p = devParisParts(inscriptionDate);
            var dow = devParisWeekday(p);
            var mon = devAddDays(p.year, p.month, p.day, -(dow - 1));
            var thu = devAddDays(mon.year, mon.month, mon.day, 3);
            var thu19 = devFindParisInstant(thu.year, thu.month, thu.day, 19);
            var targetThu = thu;
            if (!thu19 || inscriptionDate.getTime() >= thu19.getTime()) {
                targetThu = devAddDays(thu.year, thu.month, thu.day, 7);
            }
            var sessionStart = devFindParisInstant(targetThu.year, targetThu.month, targetThu.day, 20);
            var sun = devAddDays(targetThu.year, targetThu.month, targetThu.day, 3);
            var offerExpiry = devFindParisInstant(sun.year, sun.month, sun.day, 23);
            return { sessionStart: sessionStart, offerExpiry: offerExpiry };
        }
        function devFormatParis(ms) {
            return new Date(ms).toLocaleString('fr-FR', { timeZone: 'Europe/Paris', weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit', hourCycle: 'h23' });
        }
        function devGetState(sessionMs, nowMs) {
            var elapsed = (nowMs - sessionMs) / 1000;
            if (elapsed < -900) return 'Attente';
            if (elapsed < 0)    return 'Pré-live';
            if (elapsed < CTA_APPEAR_SECONDS) return 'Live';
            if (elapsed < getVideoDurationSeconds()) return 'CTA visible';
            var endMs = sessionMs + getVideoDurationSeconds() * 1000;
            var sun23 = sessionMs + (3 * 24 + 3) * 3600 * 1000;
            if (nowMs < sun23) return 'Vidéo terminée / Replay';
            return 'Expiré';
        }

        function initDevBanner() {
            var banner = document.getElementById('dev-time-banner');
            if (!banner) return;
            banner.classList.add('is-visible');

            var inscInput = document.getElementById('dev-inscription-input');
            var nowInput  = document.getElementById('dev-time-input');
            var sumInsc   = document.getElementById('dev-sum-inscription');
            var sumSession = document.getElementById('dev-sum-session');
            var sumNow    = document.getElementById('dev-sum-now');
            var sumState  = document.getElementById('dev-sum-state');

            var inscBtns = Array.from(banner.querySelectorAll('[data-insc-preset]'));
            var nowBtns  = Array.from(banner.querySelectorAll('[data-now-preset]'));

            var currentSessionMs = 0;
            var currentOfferExpiryMs = 0;
            var currentMounted = null;

            function setActiveInsc(key) { inscBtns.forEach(function(b) { b.classList.toggle('is-active', b.getAttribute('data-insc-preset') === key); }); }
            function setActiveNow(key)  { nowBtns.forEach(function(b)  { b.classList.toggle('is-active', b.getAttribute('data-now-preset') === key); }); }

            function refreshSummary() {
                var nowMs = getNowMs();
                sumInsc.textContent = 'Inscrit le : ' + devFormatParis(new Date(inscInput.value).getTime());
                sumSession.textContent = 'Session : ' + devFormatParis(currentSessionMs);
                sumNow.textContent = 'Heure simulée : ' + devFormatParis(nowMs);
                sumState.innerHTML = 'État : <span class="dev-state-val">' + devGetState(currentSessionMs, nowMs) + '</span>';
            }

            function remountWithSession(sessionMs, offerMs) {
                if (currentMounted && typeof currentMounted.destroy === 'function') {
                    currentMounted.destroy();
                }
                currentSessionMs = sessionMs;
                currentOfferExpiryMs = offerMs;
                var reg = {
                    token: 'preview-session',
                    statut: 'present',
                    prenom: 'Preview',
                    sessionStartsAt: new Date(sessionMs).toISOString(),
                    offreExpiresAt: new Date(offerMs).toISOString(),
                };
                showScreen('screen-main');
                currentMounted = mountVideoAndOffer(reg);
            }

            function setSimNow(ms) {
                simulatedNowMs = ms;
                simulatedAnchorRealMs = Date.now();
                nowInput.value = toLocalDatetimeInputValue(ms);
                if (currentMounted) currentMounted.recalcFromSimulatedTime();
                refreshSummary();
            }

            function onInscriptionChange(inscMs) {
                inscInput.value = toLocalDatetimeInputValue(inscMs);
                var result = devCalcSession(new Date(inscMs));
                var sesMs = result.sessionStart ? result.sessionStart.getTime() : null;
                var offMs = result.offerExpiry ? result.offerExpiry.getTime() : null;
                if (!Number.isFinite(sesMs) || !Number.isFinite(offMs)) {
                    // Fallback robuste pour éviter tout blocage du mode preview
                    sesMs = new Date(inscMs + 24 * 60 * 60 * 1000).getTime();
                    offMs = sesMs + 3 * 24 * 60 * 60 * 1000;
                }
                remountWithSession(sesMs, offMs);
                setSimNow(getNowMs());
                refreshSummary();
            }

            // Inscription presets: relative to current real week
            function getInscPresetMs(key) {
                var now = new Date();
                var p = devParisParts(now);
                var dow = devParisWeekday(p);
                var mon = devAddDays(p.year, p.month, p.day, -(dow - 1));
                var map = {
                    'mon-10':   { dayOffset: 0, hour: 10, minute: 0 },
                    'wed-14':   { dayOffset: 2, hour: 14, minute: 0 },
                    'thu-18':   { dayOffset: 3, hour: 18, minute: 0 },
                    'thu-1930': { dayOffset: 3, hour: 19, minute: 30 },
                    'fri-10':   { dayOffset: 4, hour: 10, minute: 0 },
                    'sat-15':   { dayOffset: 5, hour: 15, minute: 0 },
                };
                var cfg = map[key];
                if (!cfg) return null;
                var d = devAddDays(mon.year, mon.month, mon.day, cfg.dayOffset);
                var instant = devFindParisInstant(d.year, d.month, d.day, cfg.hour);
                if (instant && cfg.minute) instant = new Date(instant.getTime() + cfg.minute * 60000);
                return instant ? instant.getTime() : null;
            }

            inscBtns.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var key = btn.getAttribute('data-insc-preset');
                    var ms = getInscPresetMs(key);
                    if (!ms) return;
                    setActiveInsc(key);
                    onInscriptionChange(ms);
                });
            });
            inscInput.addEventListener('change', function() {
                var ms = new Date(inscInput.value).getTime();
                if (!Number.isFinite(ms)) return;
                setActiveInsc(null);
                onInscriptionChange(ms);
            });

            // Now presets: relative to currentSessionMs
            var nowPresetOffsets = {
                'session-m60':  -60 * 60 * 1000,
                'session-m30':  -30 * 60 * 1000,
                'session-m15':  -15 * 60 * 1000,
                'session-p2':   2 * 60 * 1000,
                'session-p15':  15 * 60 * 1000,
                'session-p30':  30 * 60 * 1000,
                'session-p46':  46 * 60 * 1000,
            };
            function getNowPresetMs(key) {
                if (nowPresetOffsets[key] !== undefined) return currentSessionMs + nowPresetOffsets[key];
                if (key === 'expired') {
                    var p2 = devParisParts(new Date(currentSessionMs));
                    var sun = devAddDays(p2.year, p2.month, p2.day, 3);
                    var inst2 = devFindParisInstant(sun.year, sun.month, sun.day, 23);
                    return inst2 ? inst2.getTime() + 30 * 60 * 1000 : currentSessionMs + 76 * 3600 * 1000;
                }
                return null;
            }

            nowBtns.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var key = btn.getAttribute('data-now-preset');
                    var ms = getNowPresetMs(key);
                    if (!ms) return;
                    setActiveNow(key);
                    setSimNow(ms);
                });
            });
            nowInput.addEventListener('change', function() {
                var ms = new Date(nowInput.value).getTime();
                if (!Number.isFinite(ms)) return;
                setActiveNow(null);
                setSimNow(ms);
            });

            // Initialize: default inscription = now, session = next Thursday
            var initNow = new Date();
            simulatedNowMs = initNow.getTime();
            simulatedAnchorRealMs = Date.now();
            onInscriptionChange(initNow.getTime());
            setSimNow(initNow.getTime());

            setInterval(refreshSummary, 1000);
        }

        document.addEventListener('DOMContentLoaded', async function () {
            const params = new URLSearchParams(window.location.search);
            const preview = params.get('preview') === 'dev';

            if (preview) {
                initDevBanner();
                return;
            }

            await fetchActiveVideoSourceConfig();
            setupRecoveryForm();

            let token = (params.get('t') || '').trim();
            if (!token) token = getStoredTokenWithLegacy();
            if (!token) {
                showScreen('screen-recovery');
                return;
            }

            try {
                const res = await fetch('/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token));
                if (!res.ok) {
                    showScreen('screen-recovery');
                    return;
                }
                const data = await res.json();
                if (!data.valid || !data.sessionStartsAt || !data.offreExpiresAt) {
                    showScreen('screen-recovery');
                    return;
                }
                setTokenEverywhere(token);
                const reg = normalizeReg(data, token);

                const now = Date.now();
                const sessionMs = new Date(reg.sessionStartsAt).getTime();
                const offerMs = new Date(reg.offreExpiresAt).getTime();

                if (!Number.isFinite(sessionMs) || !Number.isFinite(offerMs)) {
                    showBlocked('Erreur', 'Dates de session invalides.');
                    return;
                }

                if (now >= offerMs) {
                    showBlocked("Cette masterclass n'est plus accessible.", '');
                    return;
                }
                const liveStartMs = sessionMs - LIVE_VIDEO_LEAD_MS;
                if (now >= liveStartMs + LATE_DIRECT_CUTOFF_MS) {
                    window.location.replace('/masterclass/replay?t=' + encodeURIComponent(token) + '&reason=late');
                    return;
                }
                showScreen('screen-main');
                if (now >= liveStartMs) await maybeMarkPresent(reg);
                mountVideoAndOffer(reg);
            } catch (e) {
                showBlocked('Erreur', 'Impossible de charger la session pour le moment.');
            }
        });
    </script>
    <script>document.documentElement.classList.add('ready');</script>
</body>
</html>
