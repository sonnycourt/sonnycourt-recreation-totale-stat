---
import GAConsentMode from '../../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Replay — Masterclass Esprit Subconscient 2.0</title>
  <meta name="description" content="Accède au replay de la masterclass Esprit Subconscient 2.0." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
  <GAConsentMode />
  <style>
    html { opacity: 0; }
    html.ready { opacity: 1; transition: opacity .15s ease; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      color: #fff;
      background:
        radial-gradient(ellipse at 20% 0%, rgba(59,130,246,.22) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 100%, rgba(37,99,235,.15) 0%, transparent 50%),
        linear-gradient(180deg, #0a1628 0%, #0a0a1a 50%, #06060f 100%);
      padding: 20px 14px 40px;
    }
    .wrap {
      max-width: 980px;
      margin: 0 auto;
      border: 1px solid rgba(59,130,246,.28);
      border-radius: 16px;
      background: rgba(255,255,255,.04);
      box-shadow: 0 18px 54px rgba(0,0,0,.42);
      padding: clamp(16px, 2.8vw, 26px);
    }
    .hidden { display: none !important; }
    .badge {
      display: inline-block;
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      font-weight: 700;
      color: #bfdbfe;
      border: 1px solid rgba(59,130,246,.4);
      background: rgba(59,130,246,.16);
      border-radius: 999px;
      padding: 6px 11px;
      margin-bottom: 10px;
    }
    h1 {
      margin: 0 0 8px;
      font-size: clamp(1.35rem, 3vw, 2rem);
      line-height: 1.2;
      font-weight: 800;
    }
    p { margin: 0; color: rgba(226,232,240,.84); line-height: 1.6; }
    .stack { margin-top: 14px; display: grid; gap: 10px; }
    input {
      width: 100%;
      border-radius: 10px;
      border: 1px solid rgba(59,130,246,.45);
      background: rgba(255,255,255,.07);
      color: #fff;
      padding: 12px 13px;
      font-size: 16px;
    }
    button, .btn {
      border: none;
      border-radius: 10px;
      padding: 12px 15px;
      font-size: .94rem;
      font-weight: 700;
      color: #fff;
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .btn.secondary { background: rgba(255,255,255,.1); border: 1px solid rgba(148,163,184,.32); }
    .btn-row { margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap; }
    .error { color: #fca5a5; margin-top: 10px; min-height: 1.2em; }
    .screen { display: none; }
    .screen.visible { display: block; }

    .expiry-banner {
      margin: 0 0 12px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid rgba(148,163,184,.28);
      background: rgba(15,23,42,.5);
      color: rgba(226,232,240,.9);
      font-size: .88rem;
      text-align: center;
    }
    .video-shell {
      margin-top: 16px;
      border: 1px solid rgba(59,130,246,.35);
      border-radius: 14px;
      background: rgba(2,6,23,.9);
      overflow: hidden;
    }
    .video-box {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      background: #000;
    }
    #replay-video { width: 100%; height: 100%; object-fit: cover; }
    .video-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, rgba(2,6,23,.25), rgba(2,6,23,.55));
      pointer-events: none;
      transition: opacity .2s ease;
    }
    .video-overlay.hidden { opacity: 0; }
    .video-overlay button {
      pointer-events: auto;
      border-radius: 999px;
      padding: 12px 20px;
      font-weight: 800;
    }
    .replay-pill {
      position: absolute;
      right: 10px;
      bottom: 10px;
      border-radius: 999px;
      border: 1px solid rgba(59,130,246,.45);
      background: rgba(30,64,175,.35);
      color: #bfdbfe;
      font-weight: 800;
      font-size: .75rem;
      padding: 6px 10px;
      user-select: none;
      pointer-events: none;
    }
    .fullscreen-floating {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 36px;
      height: 36px;
      border-radius: 9px;
      border: 1px solid rgba(148,163,184,.35);
      background: rgba(2,6,23,.75);
      color: #e2e8f0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .fullscreen-floating svg { width: 18px; height: 18px; }
    @media (max-width: 1024px) { .fullscreen-floating { display: none; } }

    .controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 10px 12px;
      border-top: 1px solid rgba(148,163,184,.2);
      background: rgba(15,23,42,.8);
    }
    .ctrl-group { display: flex; gap: 8px; align-items: center; }
    .ctrl-btn {
      border-radius: 8px;
      border: 1px solid rgba(148,163,184,.28);
      background: rgba(255,255,255,.06);
      color: #fff;
      min-height: 34px;
      padding: 0 11px;
      font-size: .82rem;
      font-weight: 700;
    }
    .ctrl-btn[disabled] { opacity: .55; cursor: not-allowed; }
    .volume-range { width: 120px; }

    .offer-zone {
      min-height: 132px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-top: 38px;
    }
    .offer-zone.hidden { display: none; }
    .diagnostic-guide-zone {
      display: none;
      margin-top: 22px;
      margin-bottom: 12px;
      text-align: center;
    }
    .diagnostic-guide-zone.visible {
      display: block;
      animation: ctaFadeIn 0.35s ease forwards;
    }
    .diagnostic-guide-btn {
      width: 100%;
      max-width: 520px;
      border-radius: 12px;
      border: 1px solid rgba(96,165,250,.45);
      background: rgba(59,130,246,.16);
      color: #dbeafe;
      text-decoration: none;
      font-weight: 700;
      font-size: .93rem;
      padding: 13px 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 24px rgba(2,6,23,.28);
    }
    .diagnostic-guide-btn:hover {
      background: rgba(59,130,246,.24);
      border-color: rgba(147,197,253,.65);
      color: #fff;
    }
    .diagnostic-guide-note {
      margin-top: 8px;
      font-size: .78rem;
      color: rgba(226,232,240,.68);
    }
    .dev-time-banner {
      margin-top: 12px;
      padding: 10px;
      border-radius: 10px;
      border: 1px dashed rgba(148,163,184,.45);
      background: rgba(15,23,42,.45);
      display: none;
    }
    .dev-time-banner.is-visible { display: block; }
    .dev-time-title {
      font-size: .76rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: rgba(191,219,254,.92);
      margin-bottom: 8px;
      font-weight: 700;
    }
    .dev-time-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .dev-time-btn {
      border-radius: 8px;
      border: 1px solid rgba(96,165,250,.35);
      background: rgba(30,64,175,.25);
      color: #e2e8f0;
      padding: 7px 10px;
      font-size: .78rem;
      font-weight: 700;
      cursor: pointer;
    }
    .dev-time-input {
      height: 32px;
      min-width: 100px;
      max-width: 120px;
      border-radius: 8px;
      border: 1px solid rgba(96,165,250,.35);
      background: rgba(255,255,255,.06);
      color: #fff;
      padding: 0 8px;
      font-size: .78rem;
    }
    .offer-zone.visible {
      display: flex;
      opacity: 1;
      transform: translateY(0);
      animation: ctaFadeIn 0.4s ease forwards;
    }
    @keyframes ctaFadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .offer-countdown-title {
      margin-top: 2px;
      margin-bottom: 16px;
      color: rgba(255, 255, 255, 0.96);
      font-size: 0.84rem;
      font-weight: 800;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      text-align: center;
      text-shadow: 0 2px 12px rgba(2, 6, 23, 0.35);
    }
    .countdown {
      display: grid;
      grid-template-columns: repeat(4,minmax(0,1fr));
      gap: 8px;
      margin-bottom: 14px;
    }
    .card {
      border-radius: 10px;
      border: 1px solid rgba(59,130,246,.28);
      background: rgba(15,23,42,.72);
      text-align: center;
      padding: 10px 6px;
    }
    .card .v { font-size: 1.2rem; font-weight: 800; line-height: 1; color: #fff; }
    .card .l { margin-top: 5px; font-size: .68rem; text-transform: uppercase; letter-spacing: .06em; color: rgba(191,219,254,.82); }
    .scarcity-card {
      width: 100%;
      max-width: 520px;
      margin: 20px 0 16px;
      padding: 14px 14px 12px;
      border-radius: 14px;
      border: 1px solid rgba(239, 68, 68, 0.55);
      background: radial-gradient(120% 130% at 0% 0%, rgba(220, 38, 38, 0.24) 0%, rgba(69, 10, 10, 0.30) 45%, rgba(15, 23, 42, 0.72) 100%);
      box-shadow: 0 14px 30px rgba(127, 29, 29, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      text-align: left;
    }
    .scarcity-kicker {
      margin: 0 0 8px;
      font-size: 0.70rem;
      text-transform: uppercase;
      letter-spacing: 0.10em;
      color: #fee2e2;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .scarcity-kicker::before {
      content: '';
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #ef4444;
      box-shadow: 0 0 10px rgba(239, 68, 68, 0.7);
    }
    .scarcity-main { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
    .scarcity-label { margin: 0; color: rgba(255, 255, 255, 0.96); font-size: 0.92rem; font-weight: 700; }
    .scarcity-value {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(220, 38, 38, 0.28);
      border: 1px solid rgba(252, 165, 165, 0.72);
    }
    .scarcity-number { font-size: 1.42rem; line-height: 1; font-weight: 900; color: #fff; }
    .scarcity-unit { font-size: 0.80rem; letter-spacing: 0.06em; color: #ffe4e6; font-weight: 700; }
    .scarcity-meter {
      margin-top: 10px;
      width: 100%;
      height: 7px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(252, 165, 165, 0.35);
    }
    .scarcity-meter__fill {
      height: 100%;
      width: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #ef4444, #dc2626);
      box-shadow: 0 0 14px rgba(239, 68, 68, 0.55);
    }
    .offer-cta {
      width: 100%;
      max-width: 520px;
      margin-top: 12px;
      border: none;
      border-radius: 14px;
      padding: 16px 20px;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      box-shadow: 0 14px 34px rgba(59, 130, 246, 0.38);
      transition: all 0.25s ease;
    }
    .offer-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 16px 40px rgba(59, 130, 246, 0.45);
    }

    .purchase-toast {
      position: fixed;
      left: 20px;
      bottom: 20px;
      z-index: 9999;
      opacity: 0;
      transform: translateY(20px);
      pointer-events: none;
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .purchase-toast.show { opacity: 1; transform: translateY(0); }
    .purchase-toast__content {
      display: flex;
      align-items: center;
      gap: 10px;
      max-width: 360px;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid rgba(59, 130, 246, 0.3);
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.95));
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(59, 130, 246, 0.2);
      backdrop-filter: blur(10px);
    }
    .purchase-toast__thumb-wrap { position: relative; width: 58px; height: 58px; flex-shrink: 0; }
    .purchase-toast__thumb {
      width: 58px;
      height: 58px;
      border-radius: 9px;
      object-fit: cover;
      display: block;
      border: 1px solid rgba(59, 130, 246, 0.4);
      box-shadow: 0 4px 16px rgba(2, 6, 23, 0.35);
    }
    .purchase-toast__thumb-flag {
      position: absolute;
      right: -4px;
      bottom: -4px;
      font-size: 14px;
      line-height: 1;
      filter: drop-shadow(0 2px 6px rgba(2, 6, 23, 0.5));
    }
    .purchase-toast__text { margin: 0; font-size: 14px; line-height: 1.35; color: #fff; }
    .purchase-toast__name { color: #60a5fa !important; font-weight: 900 !important; text-shadow: 0 0 10px rgba(96, 165, 250, 0.35); }
    .purchase-toast__action { color: rgba(255, 255, 255, 0.72); }
    .purchase-toast__course { display: block; margin-top: 2px; color: #ffffff !important; font-weight: 400 !important; }
    @media (max-width: 640px) {
      .offer-cta { width: 100%; }
      .purchase-toast { left: 10px; right: 10px; bottom: 10px; }
      .purchase-toast__content { max-width: 100%; }
      .countdown { grid-template-columns: repeat(2,minmax(0,1fr)); }
    }
  </style>
</head>
<body>
  <main class="wrap">
    <div id="dev-time-banner" class="dev-time-banner">
      <p class="dev-time-title">Simulation replay (preview uniquement)</p>
      <div class="dev-time-row">
        <button class="dev-time-btn" type="button" data-jump-seconds="0">Replay 00:00</button>
        <button class="dev-time-btn" type="button" data-jump-seconds="4910">CTA -10s</button>
        <button class="dev-time-btn" type="button" data-jump-seconds="4920">CTA exact</button>
        <button class="dev-time-btn" type="button" data-jump-seconds="4950">+30s après CTA</button>
        <button class="dev-time-btn" type="button" data-jump-seconds="5400">Replay 01:30:00</button>
        <button class="dev-time-btn" type="button" data-jump-seconds="-1">Fin vidéo</button>
        <input id="dev-time-input" class="dev-time-input" type="text" placeholder="hh:mm:ss" />
        <button id="dev-time-apply" class="dev-time-btn" type="button">Aller</button>
      </div>
    </div>

    <section id="screen-email" class="screen visible">
      <div class="badge">Accès replay</div>
      <h1>Retrouve ton accès au replay</h1>
      <p>Entre l'email utilisé lors de ton inscription à la masterclass.</p>
      <div class="stack">
        <input id="email-input" type="email" placeholder="Ton email" autocomplete="email" />
        <button id="email-submit" type="button">Vérifier mon accès</button>
      </div>
      <p id="email-error" class="error"></p>
    </section>

    <section id="screen-blocked" class="screen">
      <div class="badge">Replay indisponible</div>
      <h1 id="blocked-title">Replay indisponible</h1>
      <p id="blocked-copy">L'accès au replay n'est pas disponible.</p>
      <div class="btn-row">
        <a class="btn secondary" href="/masterclass">Retour masterclass</a>
      </div>
    </section>

    <section id="screen-replay" class="screen">
      <div class="badge">Replay privé</div>
      <h1>Masterclass Esprit Subconscient 2.0</h1>
      <p>Replay disponible jusqu'à dimanche 23h (Paris).</p>

      <p id="expiry-banner" class="expiry-banner">Cette session privée expire dimanche à 23h.</p>

      <div class="video-shell">
        <div class="video-box" id="video-box">
          <video id="replay-video" preload="metadata" playsinline controlslist="nodownload noremoteplayback nofullscreen" oncontextmenu="return false;"></video>
          <div id="video-overlay" class="video-overlay">
            <button id="play-overlay-btn" type="button">Lancer le replay</button>
          </div>
          <span class="replay-pill">Replay</span>
          <button class="fullscreen-floating" id="fullscreen-btn" type="button" aria-label="Plein écran">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 3 21 3 21 9"></polyline>
              <polyline points="9 21 3 21 3 15"></polyline>
              <line x1="21" y1="3" x2="14" y2="10"></line>
              <line x1="3" y1="21" x2="10" y2="14"></line>
            </svg>
          </button>
        </div>
        <div class="controls">
          <div class="ctrl-group">
            <button class="ctrl-btn" id="playpause-btn" type="button">Play</button>
            <button class="ctrl-btn" id="rewind-btn" type="button">-15s</button>
          </div>
          <div class="ctrl-group">
            <button class="ctrl-btn" id="mute-btn" type="button">Son</button>
            <input id="volume-range" class="volume-range" type="range" min="0" max="100" value="100" />
          </div>
          <div class="ctrl-group">
            <button class="ctrl-btn" type="button" disabled>Replay</button>
          </div>
        </div>
      </div>
      <div id="diagnostic-guide-zone" class="diagnostic-guide-zone" aria-live="polite">
        <a class="diagnostic-guide-btn" href="/media/pages/Guide-Diagnostic-ES2.pdf" target="_blank" rel="noopener">
          Télécharge ton guide diagnostique personnel
        </a>
        <p class="diagnostic-guide-note">Imprime ce PDF avant de suivre la session si possible.</p>
      </div>

      <section id="offer-zone" class="offer-zone hidden">
        <p class="offer-countdown-title">L'offre expire dans :</p>
        <div class="countdown">
          <div class="card"><span id="offer-days" class="v">00</span><div class="l">Jours</div></div>
          <div class="card"><span id="offer-hours" class="v">00</span><div class="l">Heures</div></div>
          <div class="card"><span id="offer-minutes" class="v">00</span><div class="l">Minutes</div></div>
          <div class="card"><span id="offer-seconds" class="v">00</span><div class="l">Secondes</div></div>
        </div>
        <div class="scarcity-card" id="scarcity-card" aria-live="polite">
          <p class="scarcity-kicker">Nombre de places limitées</p>
          <div class="scarcity-main">
            <p class="scarcity-label">Places restantes</p>
            <div class="scarcity-value">
              <span class="scarcity-number" id="scarcity-places">30</span>
              <span class="scarcity-unit">/ 30</span>
              <span class="scarcity-unit">places</span>
            </div>
          </div>
          <div class="scarcity-meter"><div class="scarcity-meter__fill" id="scarcity-meter-fill"></div></div>
        </div>
        <a id="offer-cta" class="offer-cta" href="#">Découvrir Esprit Subconscient 2.0</a>
      </section>
    </section>
  </main>

  <div id="purchase-toast" class="purchase-toast" aria-live="polite">
    <div class="purchase-toast__content">
      <div class="purchase-toast__thumb-wrap">
        <img class="purchase-toast__thumb" src="/media/pages/es2-square-sonny.webp" alt="" aria-hidden="true" />
        <span id="purchase-toast-flag" class="purchase-toast__thumb-flag">🇫🇷</span>
      </div>
      <p class="purchase-toast__text" id="purchase-toast-text"></p>
    </div>
  </div>

  <script>
    // @ts-nocheck
    import { startScarcityEngine } from '../../lib/scarcity-engine';

    const TOKEN_KEY = 'masterclass_es2_token';
    const LEGACY_TOKEN_KEY = 'webinaire_es2_token';
    const COOKIE_MAX = 365 * 24 * 60 * 60;
    const GUIDE_RELEASE_LEAD_MS = 60 * 60 * 1000;
    const LIVE_VIDEO_LEAD_MS = 15 * 60 * 1000;
    const CTA_TRIGGER_SECONDS = 82 * 60; // 1h22
    const VIDEO_TRACKING_CHECKPOINTS_MIN = [1, 15, 30, 45, 60, 82];
    const VIDEO_SOURCE_URL_PRIMARY = 'https://sonnycourt-videos-public.b-cdn.net/Webinaire%20-%20V1%20(Pour%20Partage%20Et%20Timing).mp4';

    function parseGmtOffsetMinutes(label) {
      const m = String(label || '').match(/GMT([+-])(\d{1,2})(?::?(\d{2}))?/i);
      if (!m) return 0;
      const sign = m[1] === '-' ? -1 : 1;
      const hh = Number(m[2] || 0);
      const mm = Number(m[3] || 0);
      return sign * (hh * 60 + mm);
    }
    function getTzOffsetMinutes(ms, timeZone) {
      const fmt = new Intl.DateTimeFormat('en-US', { timeZone, timeZoneName: 'shortOffset', hour: '2-digit', minute: '2-digit' });
      const parts = fmt.formatToParts(new Date(ms));
      const name = parts.find((p) => p.type === 'timeZoneName')?.value || 'GMT+0';
      return parseGmtOffsetMinutes(name);
    }
    function parisLocalToUtcMs(year, month, day, hour, minute, second) {
      const approxUtc = Date.UTC(year, month - 1, day, hour, minute, second);
      const offsetMin = getTzOffsetMinutes(approxUtc, 'Europe/Paris');
      return approxUtc - offsetMin * 60 * 1000;
    }
    function getParisYmd(nowMs) {
      const fmt = new Intl.DateTimeFormat('en-GB', { timeZone: 'Europe/Paris', year: 'numeric', month: '2-digit', day: '2-digit' });
      const parts = fmt.formatToParts(new Date(nowMs));
      return {
        year: Number(parts.find((p) => p.type === 'year')?.value || 0),
        month: Number(parts.find((p) => p.type === 'month')?.value || 0),
        day: Number(parts.find((p) => p.type === 'day')?.value || 0),
      };
    }
    function addYmdDays(year, month, day, deltaDays) {
      const d = new Date(Date.UTC(year, month - 1, day + deltaDays, 12, 0, 0));
      return { year: d.getUTCFullYear(), month: d.getUTCMonth() + 1, day: d.getUTCDate() };
    }
    function getParisWeekday(nowMs) {
      const key = new Intl.DateTimeFormat('en-US', { timeZone: 'Europe/Paris', weekday: 'short' }).format(new Date(nowMs));
      const map = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
      return map[key] ?? 0;
    }
    function getFriday8ToSunday23Window(nowMs) {
      const ymd = getParisYmd(nowMs);
      const weekday = getParisWeekday(nowMs);
      const daysFromThursday = (weekday - 4 + 7) % 7;
      const thu = addYmdDays(ymd.year, ymd.month, ymd.day, -daysFromThursday);
      const fri = addYmdDays(thu.year, thu.month, thu.day, 1);
      const sun = addYmdDays(thu.year, thu.month, thu.day, 3);
      const thisStartMs = parisLocalToUtcMs(fri.year, fri.month, fri.day, 8, 0, 0);
      const thisEndMs = parisLocalToUtcMs(sun.year, sun.month, sun.day, 23, 0, 0);
      if (nowMs <= thisEndMs) {
        return { startMs: thisStartMs, endMs: thisEndMs };
      }
      const nextFri = addYmdDays(fri.year, fri.month, fri.day, 7);
      const nextSun = addYmdDays(sun.year, sun.month, sun.day, 7);
      return {
        startMs: parisLocalToUtcMs(nextFri.year, nextFri.month, nextFri.day, 8, 0, 0),
        endMs: parisLocalToUtcMs(nextSun.year, nextSun.month, nextSun.day, 23, 0, 0),
      };
    }

    function getCookie(name) {
      const esc = name.replace(/[$()*+.?[\\\]^{|}]/g, '\\$&');
      const m = document.cookie.match(new RegExp('(?:^|; )' + esc + '=([^;]*)'));
      return m ? decodeURIComponent(m[1]) : '';
    }
    function setTokenEverywhere(token) {
      localStorage.setItem(TOKEN_KEY, token);
      document.cookie = `${TOKEN_KEY}=${encodeURIComponent(token)}; path=/; max-age=${COOKIE_MAX}; SameSite=Lax`;
      localStorage.removeItem(LEGACY_TOKEN_KEY);
      document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
    }
    function clearTokenEverywhere() {
      localStorage.removeItem(TOKEN_KEY);
      localStorage.removeItem(LEGACY_TOKEN_KEY);
      document.cookie = `${TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
      document.cookie = `${LEGACY_TOKEN_KEY}=; path=/; max-age=0; SameSite=Lax`;
    }
    function getStoredToken() {
      let t = (localStorage.getItem(TOKEN_KEY) || getCookie(TOKEN_KEY) || '').trim();
      if (t) return t;
      const legacy = (localStorage.getItem(LEGACY_TOKEN_KEY) || getCookie(LEGACY_TOKEN_KEY) || '').trim();
      if (legacy) {
        setTokenEverywhere(legacy);
        return legacy;
      }
      return '';
    }
    function show(screenId) {
      ['screen-email', 'screen-blocked', 'screen-replay'].forEach((id) => {
        document.getElementById(id).classList.toggle('visible', id === screenId);
      });
    }
    function showBlocked(title, copy) {
      document.getElementById('blocked-title').textContent = title;
      document.getElementById('blocked-copy').textContent = copy;
      show('screen-blocked');
    }
    function updateCountdown(targetMs) {
      const diff = Math.max(0, targetMs - Date.now());
      const total = Math.floor(diff / 1000);
      const d = Math.floor(total / 86400);
      const h = Math.floor((total % 86400) / 3600);
      const m = Math.floor((total % 3600) / 60);
      const s = total % 60;
      document.getElementById('offer-days').textContent = String(d).padStart(2, '0');
      document.getElementById('offer-hours').textContent = String(h).padStart(2, '0');
      document.getElementById('offer-minutes').textContent = String(m).padStart(2, '0');
      document.getElementById('offer-seconds').textContent = String(s).padStart(2, '0');
    }
    async function fetchVideoSource() {
      try {
        const res = await fetch('/.netlify/functions/webinaire-video-config', { cache: 'no-store' });
        if (!res.ok) return VIDEO_SOURCE_URL_PRIMARY;
        const data = await res.json();
        return data?.activeUrl ? String(data.activeUrl) : VIDEO_SOURCE_URL_PRIMARY;
      } catch {
        return VIDEO_SOURCE_URL_PRIMARY;
      }
    }
    async function sendPresencePing(token, stage) {
      if (!token) return;
      try {
        await fetch('/.netlify/functions/webinaire-presence', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, stage }),
        });
      } catch {}
    }
    function trackWebinaireEvent(token, eventName, value) {
      if (!token || !eventName) return;
      const payload = { token, event: eventName };
      if (value !== undefined && value !== null) payload.value = String(value);
      console.log('[ES2 TRACKING]', eventName, payload);
      fetch('/.netlify/functions/track-webinaire-event', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      }).catch(() => {});
    }

    function mountReplay(reg, token) {
      const video = document.getElementById('replay-video');
      const overlay = document.getElementById('video-overlay');
      const playOverlayBtn = document.getElementById('play-overlay-btn');
      const playPauseBtn = document.getElementById('playpause-btn');
      const rewindBtn = document.getElementById('rewind-btn');
      const muteBtn = document.getElementById('mute-btn');
      const volumeRange = document.getElementById('volume-range');
      const fullscreenBtn = document.getElementById('fullscreen-btn');
      const expiryBanner = document.getElementById('expiry-banner');
      const offerZone = document.getElementById('offer-zone');
      const offerCta = document.getElementById('offer-cta');
      const scarcityPlaces = document.getElementById('scarcity-places');
      const scarcityFill = document.getElementById('scarcity-meter-fill');
      const toast = document.getElementById('purchase-toast');
      const toastFlag = document.getElementById('purchase-toast-flag');
      const toastText = document.getElementById('purchase-toast-text');

      const sessionStartMs = new Date(reg.sessionStartsAt || reg.session_date || Date.now() + 2 * 60 * 60 * 1000).getTime();
      const offerExpiryMs = new Date(reg.offreExpiresAt).getTime();
      let maxWatched = 0;
      let ctaActivated = false;
      let allowProgrammaticSeek = false;
      let hideToastTimer = null;
      let countdownInterval = null;
      let presenceInterval = null;
      let scarcityEngine = null;
      let didTrackCtaReached = false;
      let didTrackReplayStarted = false;
      const emittedCheckpointMinutes = new Set();

      function setSeatsLeft(seatsLeft) {
        const seats = Math.max(0, Math.min(30, Number(seatsLeft) || 0));
        scarcityPlaces.textContent = String(seats);
        scarcityFill.style.width = `${(seats / 30) * 100}%`;
      }
      function showToast(purchase, mode, detail) {
        if (new URLSearchParams(window.location.search).get('scarcity_debug') === '1') {
          console.log('[replay scarcity toast]', mode, purchase?.name, detail || '');
        }
        toastFlag.textContent = purchase.flag;
        const actionText = mode === 'replay'
          ? `a rejoint il y a ${detail || 'quelques instants'}`
          : 'vient de rejoindre';
        toastText.innerHTML = `<span class="purchase-toast__name">${purchase.name}</span> <span class="purchase-toast__action">${actionText}</span><br /><span class="purchase-toast__course">Esprit Subconscient 2.0</span>`;
        toast.classList.add('show');
        if (hideToastTimer) clearTimeout(hideToastTimer);
        hideToastTimer = setTimeout(() => toast.classList.remove('show'), 4000);
      }
      function activateOfferAndScarcity() {
        if (ctaActivated) return;
        ctaActivated = true;
        if (!didTrackCtaReached) {
          didTrackCtaReached = true;
          trackWebinaireEvent(token, 'cta_reached');
        }
        offerZone.classList.remove('hidden');
        offerZone.classList.add('visible');
        expiryBanner.classList.add('hidden');
        scarcityEngine = startScarcityEngine({
          now: () => Date.now(),
          isActive: () => ctaActivated,
          enableReplay: true,
          debug: new URLSearchParams(window.location.search).get('scarcity_debug') === '1',
          onSeatsLeft: setSeatsLeft,
          onNotification: showToast,
        });
      }
      function hideOfferAndScarcity() {
        ctaActivated = false;
        offerZone.classList.add('hidden');
        offerZone.classList.remove('visible');
        expiryBanner.classList.remove('hidden');
        if (scarcityEngine) {
          scarcityEngine.stop();
          scarcityEngine = null;
        }
        toast.classList.remove('show');
      }
      function updateCtaStateByVideoTime() {
        if (video.currentTime >= CTA_TRIGGER_SECONDS) {
          activateOfferAndScarcity();
        } else {
          hideOfferAndScarcity();
        }
      }
      function jumpToSeconds(targetSec) {
        const duration = Number.isFinite(video.duration) && video.duration > 0 ? video.duration : null;
        let sec = Number(targetSec);
        if (!Number.isFinite(sec)) return;
        if (sec < 0 && duration) sec = Math.max(0, duration - 2);
        if (duration) sec = Math.max(0, Math.min(duration - 0.2, sec));
        allowProgrammaticSeek = true;
        video.currentTime = Math.max(0, sec);
        maxWatched = Math.max(maxWatched, video.currentTime);
        updateCtaStateByVideoTime();
        updateDiagnosticGuideState();
        if (video.paused) {
          overlay.classList.add('hidden');
          playPauseBtn.textContent = 'Pause';
          video.play().catch(() => {});
        }
      }
      function updateDiagnosticGuideState() {
        const zone = document.getElementById('diagnostic-guide-zone');
        if (!zone) return;
        const now = sessionStartMs - LIVE_VIDEO_LEAD_MS + Math.max(0, Math.floor((video.currentTime || 0) * 1000));
        const showAt = sessionStartMs - GUIDE_RELEASE_LEAD_MS;
        const hideAt = sessionStartMs + 15 * 60 * 1000;
        zone.classList.toggle('visible', now >= showAt && now <= hideAt);
      }

      playOverlayBtn.addEventListener('click', () => {
        if (!didTrackReplayStarted) {
          didTrackReplayStarted = true;
          trackWebinaireEvent(token, 'replay_started');
        }
        video.play().catch(() => {});
      });
      playPauseBtn.addEventListener('click', () => {
        if (video.paused) {
          if (!didTrackReplayStarted) {
            didTrackReplayStarted = true;
            trackWebinaireEvent(token, 'replay_started');
          }
          video.play().catch(() => {});
        }
        else video.pause();
      });
      rewindBtn.addEventListener('click', () => {
        video.currentTime = Math.max(0, (video.currentTime || 0) - 15);
      });
      muteBtn.addEventListener('click', () => {
        video.muted = !video.muted;
        muteBtn.textContent = video.muted ? 'Muet' : 'Son';
      });
      volumeRange.addEventListener('input', (e) => {
        const v = Math.max(0, Math.min(100, Number(e?.target?.value || 100)));
        video.volume = v / 100;
        if (video.volume > 0) video.muted = false;
        muteBtn.textContent = video.muted ? 'Muet' : 'Son';
      });
      fullscreenBtn.addEventListener('click', () => {
        const box = document.getElementById('video-box');
        if (!document.fullscreenElement) box.requestFullscreen?.().catch(() => {});
        else document.exitFullscreen?.().catch(() => {});
      });
      video.addEventListener('contextmenu', (e) => {
        e.preventDefault();
      });

      video.addEventListener('play', () => {
        overlay.classList.add('hidden');
        playPauseBtn.textContent = 'Pause';
      });
      video.addEventListener('pause', () => {
        if (!video.ended) overlay.classList.remove('hidden');
        playPauseBtn.textContent = 'Play';
      });
      video.addEventListener('timeupdate', () => {
        if (video.currentTime > maxWatched) maxWatched = video.currentTime;
        updateCtaStateByVideoTime();
        updateDiagnosticGuideState();
        const watchedMinutes = Math.floor((video.currentTime || 0) / 60);
        VIDEO_TRACKING_CHECKPOINTS_MIN.forEach((checkpointMin) => {
          if (watchedMinutes >= checkpointMin && !emittedCheckpointMinutes.has(checkpointMin)) {
            emittedCheckpointMinutes.add(checkpointMin);
            trackWebinaireEvent(token, 'video_checkpoint', checkpointMin);
          }
        });
      });
      video.addEventListener('seeking', () => {
        if (allowProgrammaticSeek) return;
        if (video.currentTime > maxWatched + 0.8) video.currentTime = maxWatched;
      });
      video.addEventListener('seeked', () => {
        if (allowProgrammaticSeek) allowProgrammaticSeek = false;
      });
      video.addEventListener('keydown', (e) => {
        if (['ArrowRight', 'l', 'L', 'j', 'J'].includes(e.key)) e.preventDefault();
      });
      if (new URLSearchParams(window.location.search).get('preview') === 'dev') {
        const devPanel = document.getElementById('dev-time-banner');
        const devTimeInput = document.getElementById('dev-time-input');
        const devTimeApply = document.getElementById('dev-time-apply');
        if (devPanel) devPanel.classList.add('is-visible');
        document.querySelectorAll('[data-jump-seconds]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const sec = Number(btn.getAttribute('data-jump-seconds'));
            jumpToSeconds(sec);
          });
        });
        if (devTimeApply && devTimeInput) {
          devTimeApply.addEventListener('click', () => {
            const parsed = parseTimecodeToSeconds(devTimeInput.value);
            if (parsed === null) return;
            jumpToSeconds(parsed);
          });
        }
      }

      countdownInterval = setInterval(() => {
        updateCountdown(offerExpiryMs);
        updateDiagnosticGuideState();
        if (Date.now() >= offerExpiryMs) showBlocked('Ce replay a expiré.', "L'accès au replay n'est plus disponible.");
      }, 1000);
      updateCountdown(offerExpiryMs);
      updateDiagnosticGuideState();
      offerCta.href = '/es2?t=' + encodeURIComponent(token);
      offerCta.addEventListener('click', () => {
        trackWebinaireEvent(token, 'cta_clicked');
      });

      presenceInterval = setInterval(() => {
        sendPresencePing(token, 'replay');
      }, 20000);
      sendPresencePing(token, 'replay');

      return {
        async initVideo() {
          video.src = await fetchVideoSource();
          video.load();
        },
        destroy() {
          if (countdownInterval) clearInterval(countdownInterval);
          if (presenceInterval) clearInterval(presenceInterval);
          if (scarcityEngine) scarcityEngine.stop();
          if (hideToastTimer) clearTimeout(hideToastTimer);
        },
      };
    }

    async function validateAccessWithToken(token) {
      const res = await fetch('/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token));
      if (!res.ok) return null;
      const data = await res.json();
      if (!data?.valid) return null;
      return data;
    }
    function isBuyer(payload) {
      const status = String(payload?.statut || payload?.status || '').toLowerCase();
      return status === 'acheteur' || status === 'paid' || status === 'purchased';
    }
    function createPreviewRegistration() {
      return {
        valid: true,
        statut: 'registered',
        sessionStartsAt: new Date(Date.now() + 2 * 60 * 60 * 1000).toISOString(),
        offreExpiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString(),
      };
    }
    function parseTimecodeToSeconds(raw) {
      const v = String(raw || '').trim();
      if (!v) return null;
      const parts = v.split(':').map((x) => Number(x));
      if (parts.some((x) => !Number.isFinite(x) || x < 0)) return null;
      if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
      if (parts.length === 2) return parts[0] * 60 + parts[1];
      if (parts.length === 1) return parts[0];
      return null;
    }

    document.addEventListener('DOMContentLoaded', async () => {
      const params = new URLSearchParams(window.location.search);
      const isPreviewDev = params.get('preview') === 'dev';
      let token = (params.get('t') || '').trim() || getStoredToken();
      let data = null;

      if (token) {
        data = await validateAccessWithToken(token);
        if (!data) {
          clearTokenEverywhere();
          token = '';
        }
      }

      if (!token && !isPreviewDev) {
        show('screen-email');
      } else {
        if (!token && isPreviewDev) {
          token = 'preview-dev-replay';
        }
        if (!data && isPreviewDev) {
          data = createPreviewRegistration();
        }
        const now = Date.now();
        const window = getFriday8ToSunday23Window(now);
        if (!isPreviewDev && isBuyer(data)) {
          showBlocked('Le replay est accessible sur Volt.', 'Ton accès élève est déjà actif sur Volt.');
          return;
        }
        if (!isPreviewDev && now < window.startMs) {
          showBlocked('Le replay sera disponible vendredi à 8h.', "Reviens dans la fenêtre de replay.");
          return;
        }
        if (!isPreviewDev && now >= window.endMs) {
          showBlocked('Ce replay a expiré.', "L'accès au replay est terminé.");
          return;
        }
        show('screen-replay');
        const mounted = mountReplay(data, token);
        await mounted.initVideo();
      }

      const btn = document.getElementById('email-submit');
      const input = document.getElementById('email-input');
      const err = document.getElementById('email-error');
      btn.addEventListener('click', async () => {
        err.textContent = '';
        const email = String(input.value || '').trim().toLowerCase();
        if (!email || !email.includes('@')) {
          err.textContent = 'Merci de saisir un email valide.';
          return;
        }
        btn.disabled = true;
        try {
          const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const body = await res.json().catch(() => ({}));
          if (!res.ok) {
            err.textContent = 'Vérification impossible. Réessaie dans un instant.';
            return;
          }
          if (body.eligible === false && body.reason === 'excluded') {
            err.textContent = "Tu n'es pas éligible pour suivre cette masterclass.";
            return;
          }
          if (body.eligible === false && body.reason === 'already_registered' && body.token) {
            const reg = await validateAccessWithToken(body.token);
            if (!reg) {
              err.textContent = 'Accès introuvable pour cet email.';
              return;
            }
            setTokenEverywhere(body.token);
            const now = Date.now();
            const window = getFriday8ToSunday23Window(now);
            if (isBuyer(reg)) {
              showBlocked('Le replay est accessible sur Volt.', 'Ton accès élève est déjà actif sur Volt.');
              return;
            }
            if (now < window.startMs) {
              showBlocked('Le replay sera disponible vendredi à 8h.', "Reviens dans la fenêtre de replay.");
              return;
            }
            if (now >= window.endMs) {
              showBlocked('Ce replay a expiré.', "L'accès au replay est terminé.");
              return;
            }
            show('screen-replay');
            const mounted = mountReplay(reg, body.token);
            await mounted.initVideo();
            return;
          }
          err.textContent = "Aucun accès replay trouvé avec cet email.";
        } catch {
          err.textContent = 'Vérification impossible. Réessaie dans un instant.';
        } finally {
          btn.disabled = false;
        }
      });
    });
  </script>
  <script>document.documentElement.classList.add('ready');</script>
</body>
</html>

