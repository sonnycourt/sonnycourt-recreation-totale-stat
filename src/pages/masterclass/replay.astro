  <script>
    // @ts-nocheck
    import { startScarcityEngine, getCurrentWindow, getSoldCount, getSeatsLeft, getPhase, SCARCITY_WINDOW_START_AFTER_SESSION_MS } from '../../lib/scarcity-engine';

    const TOKEN_KEY = 'masterclass_es2_token';
    const GUIDE_RELEASE_LEAD_MS = 60 * 60 * 1000;
    const LIVE_VIDEO_LEAD_MS = 15 * 60 * 1000;
    const CTA_TRIGGER_SECONDS = 81 * 60 + 6; // 1h21:06
    const VIDEO_TRACKING_CHECKPOINTS_MIN = [1, 15, 30, 45, 60, 82];
    const VIDEO_SOURCE_URL_PRIMARY = 'https://sonnycourt-videos-public.b-cdn.net/Webinaire%20-%20Final%20V3%20(22.04.2026).mp4';
    const DEV_CLOCK_KEY = 'es2_mc_dev_clock';

    function getMcWallClockMs() {
      try {
        const params = new URLSearchParams(window.location.search);
        if (params.get('preview') === 'dev') {
          const raw = sessionStorage.getItem(DEV_CLOCK_KEY);
          if (raw) {
            const c = JSON.parse(raw);
            if (Number.isFinite(c.simulatedNowMs) && Number.isFinite(c.simulatedAnchorRealMs)) {
              return c.simulatedNowMs + (Date.now() - c.simulatedAnchorRealMs);
            }
          }
        }
      } catch (e) {}
      return Date.now();
    }

    function parseGmtOffsetMinutes(label) {
      const m = String(label || '').match(/GMT([+-])(\d{1,2})(?::?(\d{2}))?/i);
      if (!m) return 0;
      const sign = m[1] === '-' ? -1 : 1;
      const hh = Number(m[2] || 0);
      const mm = Number(m[3] || 0);
      return sign * (hh * 60 + mm);
    }
    function getTzOffsetMinutes(ms, timeZone) {
      const fmt = new Intl.DateTimeFormat('en-US', { timeZone, timeZoneName: 'shortOffset', hour: '2-digit', minute: '2-digit' });
      const parts = fmt.formatToParts(new Date(ms));
      const name = parts.find((p) => p.type === 'timeZoneName')?.value || 'GMT+0';
      return parseGmtOffsetMinutes(name);
    }
    function parisLocalToUtcMs(year, month, day, hour, minute, second) {
      const approxUtc = Date.UTC(year, month - 1, day, hour, minute, second);
      const offsetMin = getTzOffsetMinutes(approxUtc, 'Europe/Paris');
      return approxUtc - offsetMin * 60 * 1000;
    }
    function getParisYmd(nowMs) {
      const fmt = new Intl.DateTimeFormat('en-GB', { timeZone: 'Europe/Paris', year: 'numeric', month: '2-digit', day: '2-digit' });
      const parts = fmt.formatToParts(new Date(nowMs));
      return {
        year: Number(parts.find((p) => p.type === 'year')?.value || 0),
        month: Number(parts.find((p) => p.type === 'month')?.value || 0),
        day: Number(parts.find((p) => p.type === 'day')?.value || 0),
      };
    }
    function addYmdDays(year, month, day, deltaDays) {
      const d = new Date(Date.UTC(year, month - 1, day + deltaDays, 12, 0, 0));
      return { year: d.getUTCFullYear(), month: d.getUTCMonth() + 1, day: d.getUTCDate() };
    }
    function getParisWeekday(nowMs) {
      const key = new Intl.DateTimeFormat('en-US', { timeZone: 'Europe/Paris', weekday: 'short' }).format(new Date(nowMs));
      const map = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
      return map[key] ?? 0;
    }
    function getFriday8ToSunday23Window(nowMs) {
      const ymd = getParisYmd(nowMs);
      const weekday = getParisWeekday(nowMs);
      const daysFromThursday = (weekday - 4 + 7) % 7;
      const thu = addYmdDays(ymd.year, ymd.month, ymd.day, -daysFromThursday);
      const fri = addYmdDays(thu.year, thu.month, thu.day, 1);
      const sun = addYmdDays(thu.year, thu.month, thu.day, 3);
      const thisStartMs = parisLocalToUtcMs(fri.year, fri.month, fri.day, 8, 0, 0);
      const thisEndMs = parisLocalToUtcMs(sun.year, sun.month, sun.day, 23, 0, 0);
      if (nowMs <= thisEndMs) {
        return { startMs: thisStartMs, endMs: thisEndMs };
      }
      const nextFri = addYmdDays(fri.year, fri.month, fri.day, 7);
      const nextSun = addYmdDays(sun.year, sun.month, sun.day, 7);
      return {
        startMs: parisLocalToUtcMs(nextFri.year, nextFri.month, nextFri.day, 8, 0, 0),
        endMs: parisLocalToUtcMs(nextSun.year, nextSun.month, nextSun.day, 23, 0, 0),
      };
    }

    function setTokenEverywhere(token) {
      localStorage.setItem(TOKEN_KEY, token);
    }
    function clearTokenEverywhere() {
      localStorage.removeItem(TOKEN_KEY);
    }
    function getStoredToken() {
      const t = (localStorage.getItem(TOKEN_KEY) || '').trim();
      return t;
    }
    function show(screenId) {
      ['screen-email', 'screen-blocked', 'screen-replay'].forEach((id) => {
        document.getElementById(id).classList.toggle('visible', id === screenId);
      });
    }
    function showBlocked(title, copy) {
      document.getElementById('blocked-title').textContent = title;
      document.getElementById('blocked-copy').textContent = copy;
      const voltLink = document.getElementById('blocked-volt-link');
      if (voltLink) voltLink.style.display = 'none';
      show('screen-blocked');
    }
    function showBuyerBlocked() {
      document.getElementById('blocked-title').textContent = 'Le replay est accessible sur Volt.';
      document.getElementById('blocked-copy').textContent = 'Ton accès élève est déjà actif sur Volt.';
      const voltLink = document.getElementById('blocked-volt-link');
      if (voltLink) voltLink.style.display = '';
      show('screen-blocked');
    }
    function updateCountdown(targetMs) {
      const diff = Math.max(0, targetMs - getMcWallClockMs());
      const total = Math.floor(diff / 1000);
      const d = Math.floor(total / 86400);
      const h = Math.floor((total % 86400) / 3600);
      const m = Math.floor((total % 3600) / 60);
      const s = total % 60;
      document.getElementById('offer-days').textContent = String(d).padStart(2, '0');
      document.getElementById('offer-hours').textContent = String(h).padStart(2, '0');
      document.getElementById('offer-minutes').textContent = String(m).padStart(2, '0');
      document.getElementById('offer-seconds').textContent = String(s).padStart(2, '0');
    }
    async function fetchVideoSource() {
      try {
        const res = await fetch('/.netlify/functions/webinaire-video-config', { cache: 'no-store' });
        if (!res.ok) return VIDEO_SOURCE_URL_PRIMARY;
        const data = await res.json();
        return data?.activeUrl ? String(data.activeUrl) : VIDEO_SOURCE_URL_PRIMARY;
      } catch {
        return VIDEO_SOURCE_URL_PRIMARY;
      }
    }
    async function sendPresencePing(token, stage) {
      if (!token) return;
      try {
        await fetch('/.netlify/functions/webinaire-presence', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, stage }),
        });
      } catch {}
    }
    function trackWebinaireEvent(token, eventName, value) {
      if (!token || !eventName) return;
      const payload = { token, event: eventName };
      if (value !== undefined && value !== null) payload.value = String(value);
      console.log('[ES2 TRACKING]', eventName, payload);
      fetch('/.netlify/functions/track-webinaire-event', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      }).catch(() => {});
    }

    function mountReplay(reg, token) {
      const video = document.getElementById('replay-video');
      const overlay = document.getElementById('video-overlay');
      const playOverlayBtn = document.getElementById('play-overlay-btn');
      const playPauseBtn = document.getElementById('playpause-btn');
      const rewindBtn = document.getElementById('rewind-btn');
      const muteBtn = document.getElementById('mute-btn');
      const volumeRange = document.getElementById('volume-range');
      const fullscreenBtn = document.getElementById('fullscreen-btn');
      const controlsBar = document.querySelector('.controls');
      const videoBox = document.getElementById('video-box');
      const expiryBanner = document.getElementById('expiry-banner');
      const offerZone = document.getElementById('offer-zone');
      const offerCta = document.getElementById('offer-cta');
      const offerCountdownTitle = document.querySelector('#offer-zone .offer-countdown-title');
      const offerCountdownGrid = document.querySelector('#offer-zone .countdown');
      const offerScarcityCard = document.getElementById('scarcity-card');
      const offerExpiredState = document.getElementById('offer-expired-state');
      const scarcityPlaces = document.getElementById('scarcity-places');
      const scarcityFill = document.getElementById('scarcity-meter-fill');
      const scarcityPhase1TotalEl = document.querySelector('#offer-zone .scarcity-phase1-total');
      const scarcityPhase2NoteEl = document.querySelector('#offer-zone .scarcity-phase2-note');
      const scarcityDenominatorEl = document.querySelector('#offer-zone .scarcity-denominator');
      const scarcityUnitEl = document.getElementById('scarcity-unit');
      const replayUnavailableOverlay = document.getElementById('replay-unavailable-overlay');
      const toast = document.getElementById('purchase-toast');
      const toastFlag = document.getElementById('purchase-toast-flag');
      const toastText = document.getElementById('purchase-toast-text');

      const sessionStartMs = new Date(reg.sessionStartsAt || reg.session_date || Date.now() + 2 * 60 * 60 * 1000).getTime();
      const offerExpiryMs = new Date(reg.offreExpiresAt).getTime();
      const scarcityWindowStartMs = sessionStartMs + SCARCITY_WINDOW_START_AFTER_SESSION_MS;
      const scarcityWindowEndMs = offerExpiryMs;
      const isPreviewDev = new URLSearchParams(window.location.search).get('preview') === 'dev';
      let maxWatched = 0;
      let ctaActivated = false;
      let allowProgrammaticSeek = false;
      let hideToastTimer = null;
      let toastQueueGapTimer = null;
      const toastQueue = [];
      let toastQueueBusy = false;
      let countdownInterval = null;
      let presenceInterval = null;
      let scarcityEngine = null;
      let previewOfferStateOverride = null;
      let didTrackCtaReached = false;
      let didTrackReplayStarted = false;
      const emittedCheckpointMinutes = new Set();
      let previewScarcityAnchorStartMs = null;
      let soldOutExpired = false;
      let mobileControlsHideTimer = null;
      const MOBILE_CONTROLS_HIDE_DELAY_MS = 5000;

      function isMobileLandscapeViewport() {
        return window.matchMedia('(max-width: 1023px) and (orientation: landscape)').matches;
      }
      function clearMobileControlsHideTimer() {
        if (mobileControlsHideTimer) {
          clearTimeout(mobileControlsHideTimer);
          mobileControlsHideTimer = null;
        }
      }
      function showMobileControlsNow() {
        if (!controlsBar) return;
        controlsBar.classList.remove('mobile-autohide-hidden');
      }
      function hideMobileControlsNow() {
        if (!controlsBar) return;
        controlsBar.classList.add('mobile-autohide-hidden');
      }
      function syncMobileControlsAutoHide() {
        if (!controlsBar) return;
        clearMobileControlsHideTimer();
        if (!isMobileLandscapeViewport()) {
          showMobileControlsNow();
          return;
        }
        if (video.paused || video.ended) {
          showMobileControlsNow();
          return;
        }
        showMobileControlsNow();
        mobileControlsHideTimer = setTimeout(() => {
          if (!video.paused && !video.ended && isMobileLandscapeViewport()) {
            hideMobileControlsNow();
          }
        }, MOBILE_CONTROLS_HIDE_DELAY_MS);
      }
      function onMobileControlsActivity() {
        if (!isMobileLandscapeViewport()) return;
        showMobileControlsNow();
        syncMobileControlsAutoHide();
      }

      function getPreviewScarcityAnchorStartMs() {
        if (Number.isFinite(previewScarcityAnchorStartMs)) return previewScarcityAnchorStartMs;
        if (Number.isFinite(scarcityWindowStartMs)) {
          previewScarcityAnchorStartMs = scarcityWindowStartMs;
          return previewScarcityAnchorStartMs;
        }
        const now = Date.now();
        const win = getCurrentWindow(now);
        if (win.phase === 'closed') {
          previewScarcityAnchorStartMs = win.startMs + (7 * 24 * 60 * 60 * 1000);
        } else {
          previewScarcityAnchorStartMs = win.startMs;
        }
        return previewScarcityAnchorStartMs;
      }

      function setPreviewWallClockFromReplaySeconds(replaySeconds) {
        if (!isPreviewDev) return;
        const sec = Number(replaySeconds);
        if (!Number.isFinite(sec)) return;
        const scarcityAnchorStartMs = getPreviewScarcityAnchorStartMs();
        const relativeToCtaMs = Math.floor((sec - CTA_TRIGGER_SECONDS) * 1000);
        const simulatedNowMs = scarcityAnchorStartMs + relativeToCtaMs;
        const payload = {
          simulatedNowMs,
          simulatedAnchorRealMs: Date.now(),
        };
        try {
          sessionStorage.setItem(DEV_CLOCK_KEY, JSON.stringify(payload));
        } catch {}
      }
      function setPreviewWallClockAbsolute(ms) {
        if (!isPreviewDev || !Number.isFinite(ms)) return;
        try {
          sessionStorage.setItem(DEV_CLOCK_KEY, JSON.stringify({
            simulatedNowMs: ms,
            simulatedAnchorRealMs: Date.now(),
          }));
        } catch {}
      }
      function getPreviewWallClockPresetMs(key) {
        const anchorStartMs = getPreviewScarcityAnchorStartMs();
        const thu = getParisYmd(anchorStartMs);
        const fri = addYmdDays(thu.year, thu.month, thu.day, 1);
        const sun = addYmdDays(thu.year, thu.month, thu.day, 3);
        if (key === 'thu-start') return anchorStartMs + 60 * 1000;
        if (key === 'fri-22') return parisLocalToUtcMs(fri.year, fri.month, fri.day, 22, 0, 0);
        if (key === 'sun-14') return parisLocalToUtcMs(sun.year, sun.month, sun.day, 14, 0, 0);
        if (key === 'sun-2250') return parisLocalToUtcMs(sun.year, sun.month, sun.day, 22, 50, 0);
        if (key === 'after-end') return parisLocalToUtcMs(sun.year, sun.month, sun.day, 23, 5, 0);
        return null;
      }
      function formatParisDateTime(ms) {
        try {
          return new Intl.DateTimeFormat('fr-FR', {
            timeZone: 'Europe/Paris',
            weekday: 'short',
            day: '2-digit',
            month: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
          }).format(new Date(ms));
        } catch {
          return '--';
        }
      }
      function formatDevScarcityLabel(phase, seatsLeft) {
        if (phase === 'sold_out') return '0 / 30 places (sold out)';
        const denominator = phase === 'phase2' ? 10 : 30;
        const seats = Math.max(0, Math.min(denominator, Number(seatsLeft) || 0));
        return `${seats} / ${denominator} places`;
      }
      function updateDevPreviewStatus() {
        if (!isPreviewDev) return;
        const nowEl = document.getElementById('dev-now-status');
        const scarcityEl = document.getElementById('dev-scarcity-status');
        const auditEl = document.getElementById('dev-scarcity-audit');
        const nowMs = getMcWallClockMs();
        if (nowEl) nowEl.textContent = `Horloge replay (Paris): ${formatParisDateTime(nowMs)}`;
        const bounds = Number.isFinite(scarcityWindowStartMs) && Number.isFinite(scarcityWindowEndMs) && scarcityWindowEndMs > scarcityWindowStartMs
          ? { startMs: scarcityWindowStartMs, endMs: scarcityWindowEndMs }
          : null;
        const phase = getPhase(nowMs, bounds);
        const soldCount = getSoldCount(nowMs, bounds);
        const seatsLeft = getSeatsLeft(nowMs, bounds);
        const scarcityLabel = formatDevScarcityLabel(phase, seatsLeft);
        if (scarcityEl) {
          scarcityEl.textContent = `Scarcity: ${phase} · ${scarcityLabel}`;
        }
        if (auditEl) {
          auditEl.textContent = [
            `sessionStartsAt : ${formatParisDateTime(sessionStartMs)}`,
            `windowStartMs : ${formatParisDateTime(scarcityWindowStartMs)}`,
            `offreExpiresAt : ${formatParisDateTime(scarcityWindowEndMs)}`,
            `Phase actuelle : ${phase}`,
            `soldCount : ${soldCount}`,
            `seatsLeft : ${scarcityLabel}`,
          ].join('\n');
        }
      }

      function renderScarcityVisual(seatsLeft, phase) {
        const isPhase2 = phase === 'phase2';
        const maxSeats = isPhase2 ? 10 : 30;
        const seats = Math.max(0, Math.min(maxSeats, Number(seatsLeft) || 0));
        if (scarcityPlaces) scarcityPlaces.textContent = String(seats);
        if (scarcityUnitEl) scarcityUnitEl.textContent = 'places';
        if (scarcityPhase1TotalEl) scarcityPhase1TotalEl.classList.toggle('is-visible', isPhase2);
        if (scarcityPhase2NoteEl) scarcityPhase2NoteEl.classList.toggle('is-visible', isPhase2);
        if (scarcityDenominatorEl) {
          scarcityDenominatorEl.classList.add('is-visible');
          scarcityDenominatorEl.textContent = `/ ${maxSeats}`;
        }
        const pct = (seats / maxSeats) * 100;
        if (scarcityFill) scarcityFill.style.width = `${pct}%`;
      }
      function setSeatsLeft(seatsLeft, _soldCount, phase) {
        const seats = Math.max(0, Number(seatsLeft) || 0);
        if (phase === 'sold_out' && seats <= 0) {
          soldOutExpired = true;
          syncReplayUnavailableLock();
          return;
        }
        soldOutExpired = false;
        renderScarcityVisual(seats, phase);
      }
      function isOfferExpiredNow() {
        if (previewOfferStateOverride === 'expired') return true;
        if (previewOfferStateOverride === 'active') return false;
        if (soldOutExpired) return true;
        return getMcWallClockMs() >= offerExpiryMs;
      }
      function syncReplayUnavailableLock() {
        const expired = isOfferExpiredNow();
        if (!replayUnavailableOverlay) return;
        replayUnavailableOverlay.classList.toggle('is-visible', expired);
        replayUnavailableOverlay.setAttribute('aria-hidden', expired ? 'false' : 'true');
        document.documentElement.classList.toggle('mc-page-lock', expired);
        if (expired && scarcityEngine) {
          scarcityEngine.stop();
          scarcityEngine = null;
        }
        if (expired) {
          const v = document.getElementById('replay-video');
          if (v) v.pause();
        }
      }
      function setOfferExpiredState(expired) {
        const isExpired = Boolean(expired);
        if (offerCountdownTitle) offerCountdownTitle.classList.toggle('hidden', isExpired);
        if (offerCountdownGrid) offerCountdownGrid.classList.toggle('hidden', isExpired);
        if (offerScarcityCard) offerScarcityCard.classList.toggle('hidden', isExpired);
        if (offerCta) offerCta.classList.toggle('hidden', isExpired);
        if (offerExpiredState) offerExpiredState.classList.toggle('hidden', !isExpired);
      }
      function showToast(purchase, mode, detail) {
        toastQueue.push({ purchase, mode, detail });
        if (!toastQueueBusy) flushToastQueue();
      }
      function flushToastQueue() {
        if (toastQueueBusy) return;
        const next = toastQueue.shift();
        if (!next) return;
        toastQueueBusy = true;
        const purchase = next.purchase;
        const mode = next.mode;
        const detail = next.detail;
        if (new URLSearchParams(window.location.search).get('scarcity_debug') === '1') {
          console.log('[replay scarcity toast]', mode, purchase?.name, detail || '');
        }
        toastFlag.textContent = purchase.flag;
        const actionText = mode === 'replay'
          ? `a rejoint il y a ${detail || 'quelques instants'}`
          : 'vient de rejoindre';
        toastText.innerHTML = `<span class="purchase-toast__name">${purchase.name}</span> <span class="purchase-toast__action">${actionText}</span><br /><span class="purchase-toast__course">Esprit Subconscient 2.0</span>`;
        toast.classList.add('show');
        if (hideToastTimer) clearTimeout(hideToastTimer);
        if (toastQueueGapTimer) clearTimeout(toastQueueGapTimer);
        hideToastTimer = setTimeout(() => {
          toast.classList.remove('show');
          toastQueueGapTimer = setTimeout(() => {
            toastQueueBusy = false;
            flushToastQueue();
          }, 1000);
        }, 4000);
      }
      function startScarcityEngineIfNeeded() {
        if (!ctaActivated || isOfferExpiredNow() || scarcityEngine) return;
        scarcityEngine = startScarcityEngine({
          now: () => getMcWallClockMs(),
          isActive: () => ctaActivated && !isOfferExpiredNow(),
          windowStartMs: scarcityWindowStartMs,
          windowEndMs: scarcityWindowEndMs,
          enableReplay: true,
          debug: new URLSearchParams(window.location.search).get('scarcity_debug') === '1',
          onSeatsLeft: setSeatsLeft,
          onNotification: showToast,
        });
      }
      function activateOfferAndScarcity() {
        if (ctaActivated) return;
        if (isOfferExpiredNow()) {
          syncReplayUnavailableLock();
          return;
        }
        ctaActivated = true;
        if (!didTrackCtaReached) {
          didTrackCtaReached = true;
          trackWebinaireEvent(token, 'cta_reached');
        }
        offerZone.classList.remove('hidden');
        offerZone.classList.add('visible');
        expiryBanner.classList.add('hidden');
        setOfferExpiredState(isOfferExpiredNow());
        startScarcityEngineIfNeeded();
      }
      function hideOfferAndScarcity() {
        ctaActivated = false;
        offerZone.classList.add('hidden');
        offerZone.classList.remove('visible');
        expiryBanner.classList.remove('hidden');
        if (scarcityEngine) {
          scarcityEngine.stop();
          scarcityEngine = null;
        }
        toast.classList.remove('show');
        if (hideToastTimer) clearTimeout(hideToastTimer);
        if (toastQueueGapTimer) clearTimeout(toastQueueGapTimer);
        hideToastTimer = null;
        toastQueueGapTimer = null;
        toastQueue.length = 0;
        toastQueueBusy = false;
      }
      function updateCtaStateByVideoTime() {
        if (video.currentTime >= CTA_TRIGGER_SECONDS) {
          activateOfferAndScarcity();
          setOfferExpiredState(isOfferExpiredNow());
        } else {
          hideOfferAndScarcity();
        }
      }
      function ensureOfferVisibleForPreview() {
        if (!isPreviewDev) return;
        if ((video.currentTime || 0) >= CTA_TRIGGER_SECONDS) return;
        allowProgrammaticSeek = true;
        video.currentTime = CTA_TRIGGER_SECONDS + 30;
        maxWatched = Math.max(maxWatched, video.currentTime);
      }
      function jumpToSeconds(targetSec) {
        const duration = Number.isFinite(video.duration) && video.duration > 0 ? video.duration : null;
        let sec = Number(targetSec);
        if (!Number.isFinite(sec)) return;
        if (sec < 0 && duration) sec = Math.max(0, duration - 2);
        if (duration) sec = Math.max(0, Math.min(duration - 0.2, sec));
        allowProgrammaticSeek = true;
        video.currentTime = Math.max(0, sec);
        maxWatched = Math.max(maxWatched, video.currentTime);
        setPreviewWallClockFromReplaySeconds(sec);
        updateCtaStateByVideoTime();
        updateDiagnosticGuideState();
        updateDevPreviewStatus();
        if (video.paused) {
          overlay.classList.add('hidden');
          playPauseBtn.textContent = 'Pause';
          video.play().catch(() => {});
        }
      }
      function updateDiagnosticGuideState() {
        const zone = document.getElementById('diagnostic-guide-zone');
        if (!zone) return;
        const now = sessionStartMs - LIVE_VIDEO_LEAD_MS + Math.max(0, Math.floor((video.currentTime || 0) * 1000));
        const showAt = sessionStartMs - GUIDE_RELEASE_LEAD_MS;
        const hideAt = sessionStartMs + 15 * 60 * 1000;
        zone.classList.toggle('visible', now >= showAt && now <= hideAt);
      }

      playOverlayBtn.addEventListener('click', () => {
        if (!didTrackReplayStarted) {
          didTrackReplayStarted = true;
          trackWebinaireEvent(token, 'replay_started');
        }
        video.play().catch(() => {});
      });
      playPauseBtn.addEventListener('click', () => {
        if (video.paused) {
          if (!didTrackReplayStarted) {
            didTrackReplayStarted = true;
            trackWebinaireEvent(token, 'replay_started');
          }
          video.play().catch(() => {});
        }
        else video.pause();
      });
      rewindBtn.addEventListener('click', () => {
        video.currentTime = Math.max(0, (video.currentTime || 0) - 15);
      });
      muteBtn.addEventListener('click', () => {
        video.muted = !video.muted;
        muteBtn.textContent = video.muted ? 'Muet' : 'Son';
      });
      volumeRange.addEventListener('input', (e) => {
        const v = Math.max(0, Math.min(100, Number(e?.target?.value || 100)));
        video.volume = v / 100;
        if (video.volume > 0) video.muted = false;
        muteBtn.textContent = video.muted ? 'Muet' : 'Son';
      });
      fullscreenBtn.addEventListener('click', () => {
        const box = document.getElementById('video-box');
        if (!document.fullscreenElement) box.requestFullscreen?.().catch(() => {});
        else document.exitFullscreen?.().catch(() => {});
        syncMobileControlsAutoHide();
      });
      video.addEventListener('contextmenu', (e) => {
        e.preventDefault();
      });

      video.addEventListener('play', () => {
        overlay.classList.add('hidden');
        playPauseBtn.textContent = 'Pause';
        syncMobileControlsAutoHide();
      });
      video.addEventListener('pause', () => {
        if (!video.ended) overlay.classList.remove('hidden');
        playPauseBtn.textContent = 'Play';
        syncMobileControlsAutoHide();
      });
      video.addEventListener('timeupdate', () => {
        if (video.currentTime > maxWatched) maxWatched = video.currentTime;
        updateCtaStateByVideoTime();
        updateDiagnosticGuideState();
        const watchedMinutes = Math.floor((video.currentTime || 0) / 60);
        VIDEO_TRACKING_CHECKPOINTS_MIN.forEach((checkpointMin) => {
          if (watchedMinutes >= checkpointMin && !emittedCheckpointMinutes.has(checkpointMin)) {
            emittedCheckpointMinutes.add(checkpointMin);
            trackWebinaireEvent(token, 'video_checkpoint', checkpointMin);
          }
        });
      });
      video.addEventListener('seeking', () => {
        if (allowProgrammaticSeek) return;
        if (video.currentTime > maxWatched + 0.8) video.currentTime = maxWatched;
      });
      video.addEventListener('seeked', () => {
        if (allowProgrammaticSeek) allowProgrammaticSeek = false;
      });
      video.addEventListener('keydown', (e) => {
        if (['ArrowRight', 'l', 'L', 'j', 'J'].includes(e.key)) e.preventDefault();
      });
      [videoBox, controlsBar].forEach((target) => {
        if (!target) return;
        ['touchstart', 'touchmove', 'pointermove'].forEach((evt) => {
          target.addEventListener(evt, onMobileControlsActivity, { passive: true });
        });
      });
      window.addEventListener('resize', syncMobileControlsAutoHide);
      if (isPreviewDev) {
        const devPanel = document.getElementById('dev-time-banner');
        const devTimeInput = document.getElementById('dev-time-input');
        const devTimeApply = document.getElementById('dev-time-apply');
        if (devPanel) devPanel.classList.add('is-visible');
        // If no shared preview clock exists yet, seed it from replay start.
        try {
          const rawClock = sessionStorage.getItem(DEV_CLOCK_KEY);
          if (!rawClock) setPreviewWallClockFromReplaySeconds(0);
        } catch {}
        document.querySelectorAll('[data-jump-seconds]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const sec = Number(btn.getAttribute('data-jump-seconds'));
            jumpToSeconds(sec);
          });
        });
        document.querySelectorAll('[data-wallclock-preset]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const key = String(btn.getAttribute('data-wallclock-preset') || '').trim();
            const targetMs = getPreviewWallClockPresetMs(key);
            if (!Number.isFinite(targetMs)) return;
            setPreviewWallClockAbsolute(targetMs);
            ensureOfferVisibleForPreview();
            updateCtaStateByVideoTime();
            startScarcityEngineIfNeeded();
            updateDevPreviewStatus();
          });
        });
        document.querySelectorAll('[data-offer-state]').forEach((btn) => {
          btn.addEventListener('click', () => {
            previewOfferStateOverride = btn.getAttribute('data-offer-state') || null;
            updateCtaStateByVideoTime();
            startScarcityEngineIfNeeded();
            updateDevPreviewStatus();
          });
        });
        if (devTimeApply && devTimeInput) {
          devTimeApply.addEventListener('click', () => {
            const parsed = parseTimecodeToSeconds(devTimeInput.value);
            if (parsed === null) return;
            jumpToSeconds(parsed);
          });
        }
        document.querySelectorAll('[data-scarcity-jump]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const raw = btn.getAttribute('data-scarcity-jump');
            if (raw === null || raw === '') {
              try { sessionStorage.removeItem(DEV_CLOCK_KEY); } catch {}
              previewScarcityAnchorStartMs = null;
              previewOfferStateOverride = null;
              soldOutExpired = false;
            } else {
              const offset = Number(raw);
              const base = Number.isFinite(scarcityWindowStartMs) ? scarcityWindowStartMs : getCurrentWindow(Date.now()).startMs;
              soldOutExpired = false;
              previewOfferStateOverride = null;
              setPreviewWallClockAbsolute(base + (Number.isFinite(offset) ? offset : 0));
            }
            syncReplayUnavailableLock();
            ensureOfferVisibleForPreview();
            updateCtaStateByVideoTime();
            startScarcityEngineIfNeeded();
            if (scarcityEngine && typeof scarcityEngine.debugSnapshot === 'function') {
              const snap = scarcityEngine.debugSnapshot();
              setSeatsLeft(snap.seatsLeft, snap.soldCount, snap.phase);
            } else {
              const nowMs = getMcWallClockMs();
              const bounds = Number.isFinite(scarcityWindowStartMs) && Number.isFinite(scarcityWindowEndMs) && scarcityWindowEndMs > scarcityWindowStartMs
                ? { startMs: scarcityWindowStartMs, endMs: scarcityWindowEndMs }
                : null;
              setSeatsLeft(getSeatsLeft(nowMs, bounds), getSoldCount(nowMs, bounds), getPhase(nowMs, bounds));
            }
            updateDevPreviewStatus();
          });
        });
        updateDevPreviewStatus();
      }

      countdownInterval = setInterval(() => {
        updateCountdown(offerExpiryMs);
        updateDiagnosticGuideState();
        syncReplayUnavailableLock();
        startScarcityEngineIfNeeded();
        updateDevPreviewStatus();
        if (ctaActivated && !isOfferExpiredNow()) {
          setOfferExpiredState(false);
        } else if (ctaActivated) {
          setOfferExpiredState(true);
        }
      }, 1000);
      updateCountdown(offerExpiryMs);
      updateDiagnosticGuideState();
      syncReplayUnavailableLock();
      syncMobileControlsAutoHide();
      offerCta.href = '/invitation?t=' + encodeURIComponent(token);
      offerCta.addEventListener('click', () => {
        trackWebinaireEvent(token, 'cta_clicked');
      });

      presenceInterval = setInterval(() => {
        sendPresencePing(token, 'replay');
      }, 60000);
      sendPresencePing(token, 'replay');

      return {
        async initVideo() {
          video.src = await fetchVideoSource();
          video.load();
        },
        destroy() {
          if (countdownInterval) clearInterval(countdownInterval);
          if (presenceInterval) clearInterval(presenceInterval);
          if (scarcityEngine) scarcityEngine.stop();
          if (hideToastTimer) clearTimeout(hideToastTimer);
          if (toastQueueGapTimer) clearTimeout(toastQueueGapTimer);
          document.documentElement.classList.remove('mc-page-lock');
        },
      };
    }

    async function validateAccessWithToken(token) {
      const res = await fetch('/.netlify/functions/get-webinaire-registration?t=' + encodeURIComponent(token));
      if (!res.ok) return null;
      const data = await res.json();
      if (!data?.valid) return null;
      return data;
    }
    function isBuyer(payload) {
      if (payload && payload.purchased === true) return true;
      const status = String(payload?.statut || payload?.status || '').toLowerCase();
      return status === 'acheteur' || status === 'paid' || status === 'purchased';
    }
    function createPreviewRegistration() {
      return {
        valid: true,
        statut: 'registered',
        sessionStartsAt: new Date(Date.now() + 2 * 60 * 60 * 1000).toISOString(),
        offreExpiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString(),
      };
    }
    function parseTimecodeToSeconds(raw) {
      const v = String(raw || '').trim();
      if (!v) return null;
      const parts = v.split(':').map((x) => Number(x));
      if (parts.some((x) => !Number.isFinite(x) || x < 0)) return null;
      if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
      if (parts.length === 2) return parts[0] * 60 + parts[1];
      if (parts.length === 1) return parts[0];
      return null;
    }

    document.addEventListener('DOMContentLoaded', async () => {
      const params = new URLSearchParams(window.location.search);
      const isPreviewDev = params.get('preview') === 'dev';
      let token = (params.get('t') || params.get('token') || '').trim() || getStoredToken();
      let data = null;

      if (token) {
        data = await validateAccessWithToken(token);
        if (!data) {
          clearTokenEverywhere();
          token = '';
        } else {
          setTokenEverywhere(token);
        }
      }

      if (!token && !isPreviewDev) {
        show('screen-email');
      } else {
        if (!token && isPreviewDev) {
          token = 'preview-dev-replay';
        }
        if (!data && isPreviewDev) {
          data = createPreviewRegistration();
        }
        if (!isPreviewDev && isBuyer(data)) {
          showBuyerBlocked();
          return;
        }
        show('screen-replay');
        const lateReplayBanner = document.getElementById('late-replay-banner');
        if (lateReplayBanner) lateReplayBanner.classList.toggle('hidden', params.get('reason') !== 'late');
        const mounted = mountReplay(data, token);
        await mounted.initVideo();
      }

      const btn = document.getElementById('email-submit');
      const input = document.getElementById('email-input');
      const err = document.getElementById('email-error');
      btn.addEventListener('click', async () => {
        err.textContent = '';
        const email = String(input.value || '').trim().toLowerCase();
        if (!email || !email.includes('@')) {
          err.textContent = 'Merci de saisir un email valide.';
          return;
        }
        btn.disabled = true;
        try {
          const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const body = await res.json().catch(() => ({}));
          if (!res.ok) {
            err.textContent = 'Vérification impossible. Réessaie dans un instant.';
            return;
          }
          if (body.eligible === false && body.reason === 'excluded') {
            err.textContent = "Tu n'es pas éligible pour suivre cette masterclass.";
            return;
          }
          if (body.eligible === false && body.reason === 'already_registered' && body.token) {
            const reg = await validateAccessWithToken(body.token);
            if (!reg) {
              err.textContent = 'Accès introuvable pour cet email.';
              return;
            }
            setTokenEverywhere(body.token);
            if (isBuyer(reg)) {
              showBuyerBlocked();
              return;
            }
            show('screen-replay');
            const mounted = mountReplay(reg, body.token);
            await mounted.initVideo();
            return;
          }
          err.textContent = "Aucun accès replay trouvé avec cet email.";
        } catch {
          err.textContent = 'Vérification impossible. Réessaie dans un instant.';
        } finally {
          btn.disabled = false;
        }
      });
    });
  </script>
  <script>document.documentElement.classList.add('ready');</script>
</body>
</html>

