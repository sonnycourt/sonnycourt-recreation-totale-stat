---
import GAConsentMode from '../../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Replay - Masterclass Esprit Subconscient 2.0</title>
  <meta name="description" content="Accède au replay de la masterclass Esprit Subconscient 2.0." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
  <GAConsentMode />
  <style>
    html { opacity: 0; }
    html.ready { opacity: 1; transition: opacity .15s ease; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      color: #fff;
      background:
        radial-gradient(ellipse at 20% 0%, rgba(59,130,246,.22) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 100%, rgba(37,99,235,.15) 0%, transparent 50%),
        linear-gradient(180deg, #0a1628 0%, #0a0a1a 50%, #06060f 100%);
      padding: 20px 14px 40px;
    }
    .wrap {
      max-width: 980px;
      margin: 0 auto;
      border: 1px solid rgba(59,130,246,.28);
      border-radius: 16px;
      background: rgba(255,255,255,.04);
      box-shadow: 0 18px 54px rgba(0,0,0,.42);
      padding: clamp(16px, 2.8vw, 26px);
    }
    .hidden { display: none !important; }
    .badge {
      display: inline-block;
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      font-weight: 700;
      color: #bfdbfe;
      border: 1px solid rgba(59,130,246,.4);
      background: rgba(59,130,246,.16);
      border-radius: 999px;
      padding: 6px 11px;
      margin-bottom: 10px;
    }
    h1 {
      margin: 0 0 8px;
      font-size: clamp(1.35rem, 3vw, 2rem);
      line-height: 1.2;
      font-weight: 800;
    }
    p { margin: 0; color: rgba(226,232,240,.84); line-height: 1.6; }
    .stack { margin-top: 14px; display: grid; gap: 10px; }
    input {
      width: 100%;
      border-radius: 10px;
      border: 1px solid rgba(59,130,246,.45);
      background: rgba(255,255,255,.07);
      color: #fff;
      padding: 12px 13px;
      font-size: 16px;
    }
    button, .btn {
      border: none;
      border-radius: 10px;
      padding: 12px 15px;
      font-size: .94rem;
      font-weight: 700;
      color: #fff;
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .btn.secondary { background: rgba(255,255,255,.1); border: 1px solid rgba(148,163,184,.32); }
    .btn-row { margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap; }
    .error { color: #fca5a5; margin-top: 10px; min-height: 1.2em; }
    .screen { display: none; }
    .screen.visible { display: block; }

    .expiry-banner {
      margin: 0 0 12px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid rgba(148,163,184,.28);
      background: rgba(15,23,42,.5);
      color: rgba(226,232,240,.9);
      font-size: .88rem;
      text-align: center;
    }
    .video-shell {
      margin-top: 16px;
      border: 1px solid rgba(59,130,246,.35);
      border-radius: 14px;
      background: rgba(2,6,23,.9);
      overflow: hidden;
    }
    .video-box {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      background: #000;
    }
    #replay-video { width: 100%; height: 100%; object-fit: cover; }
    .video-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, rgba(2,6,23,.25), rgba(2,6,23,.55));
      pointer-events: none;
      transition: opacity .2s ease;
    }
    .video-overlay.hidden { opacity: 0; }
    .video-overlay button {
      pointer-events: auto;
      border-radius: 999px;
      padding: 12px 20px;
      font-weight: 800;
    }
    .replay-pill {
      position: absolute;
      right: 10px;
      bottom: 10px;
      border-radius: 999px;
      border: 1px solid rgba(59,130,246,.45);
      background: rgba(30,64,175,.35);
      color: #bfdbfe;
      font-weight: 800;
      font-size: .75rem;
      padding: 6px 10px;
      user-select: none;
      pointer-events: none;
    }
    .fullscreen-floating {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 36px;
      height: 36px;
      border-radius: 9px;
      border: 1px solid rgba(148,163,184,.35);
      background: rgba(2,6,23,.75);
      color: #e2e8f0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .fullscreen-floating svg { width: 18px; height: 18px; }
    @media (max-width: 1024px) { .fullscreen-floating { display: none; } }

    .controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 10px 12px;
      border-top: 1px solid rgba(148,163,184,.2);
      background: rgba(15,23,42,.8);
      opacity: 1;
      max-height: 90px;
      overflow: hidden;
      transition: opacity .25s ease, max-height .25s ease, padding .25s ease, border-color .25s ease;
    }
    @media (max-width: 1023px) and (orientation: landscape) {
      .controls.mobile-autohide-hidden {
        opacity: 0;
        max-height: 0;
        padding-top: 0;
        padding-bottom: 0;
        border-top-color: transparent;
        pointer-events: none;
      }
    }
    .ctrl-group { display: flex; gap: 8px; align-items: center; }
    .ctrl-btn {
      border-radius: 8px;
      border: 1px solid rgba(148,163,184,.28);
      background: rgba(255,255,255,.06);
      color: #fff;
      min-height: 34px;
      padding: 0 11px;
      font-size: .82rem;
      font-weight: 700;
    }
    .ctrl-btn[disabled] { opacity: .55; cursor: not-allowed; }
    .volume-range { width: 120px; }

    .offer-zone {
      min-height: 132px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-top: 38px;
    }
    .offer-zone.hidden { display: none; }
    .diagnostic-guide-zone {
      display: none;
      margin-top: 22px;
      margin-bottom: 12px;
      text-align: center;
    }
    .diagnostic-guide-zone.visible {
      display: block;
      animation: ctaFadeIn 0.35s ease forwards;
    }
    .diagnostic-guide-btn {
      width: 100%;
      max-width: 520px;
      border-radius: 12px;
      border: 1px solid rgba(96,165,250,.45);
      background: rgba(59,130,246,.16);
      color: #dbeafe;
      text-decoration: none;
      font-weight: 700;
      font-size: .93rem;
      padding: 13px 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 24px rgba(2,6,23,.28);
    }
    .diagnostic-guide-btn:hover {
      background: rgba(59,130,246,.24);
      border-color: rgba(147,197,253,.65);
      color: #fff;
    }
    .diagnostic-guide-note {
      margin-top: 8px;
      font-size: .78rem;
      color: rgba(226,232,240,.68);
    }
    .dev-time-banner {
      padding: 10px;
      border-radius: 12px;
      border: 1px solid rgba(96,165,250,.45);
      background: rgba(15,23,42,.92);
      box-shadow: 0 12px 30px rgba(2,6,23,.45);
      display: none;
    }
    .dev-time-banner.is-visible {
      display: block;
      position: fixed;
      top: 10px;
      right: 10px;
      left: auto;
      z-index: 460000;
      width: min(340px, calc(100vw - 24px));
      max-height: min(420px, 70vh);
      overflow-x: hidden;
      overflow-y: auto;
      margin: 0;
      -webkit-overflow-scrolling: touch;
    }
    .dev-time-title {
      font-size: .76rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: rgba(191,219,254,.92);
      margin-bottom: 8px;
      font-weight: 700;
    }
    .dev-time-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    .dev-time-btn {
      border-radius: 8px;
      border: 1px solid rgba(96,165,250,.35);
      background: rgba(30,64,175,.25);
      color: #e2e8f0;
      padding: 7px 10px;
      font-size: .78rem;
      font-weight: 700;
      cursor: pointer;
    }
    .dev-time-input {
      height: 32px;
      min-width: 100px;
      max-width: 120px;
      border-radius: 8px;
      border: 1px solid rgba(96,165,250,.35);
      background: rgba(255,255,255,.06);
      color: #fff;
      padding: 0 8px;
      font-size: .78rem;
    }
    .dev-time-status {
      margin-top: 8px;
      font-size: .74rem;
      line-height: 1.4;
      color: rgba(191,219,254,.95);
    }
    .dev-scarcity-force {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }
    .dev-scarcity-force .dev-time-btn { padding: 5px 8px; font-size: .72rem; }
    .offer-zone.visible {
      display: flex;
      opacity: 1;
      transform: translateY(0);
      animation: ctaFadeIn 0.4s ease forwards;
    }
    @keyframes ctaFadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .offer-countdown-title {
      margin-top: 2px;
      margin-bottom: 16px;
      color: rgba(255, 255, 255, 0.96);
      font-size: 0.84rem;
      font-weight: 800;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      text-align: center;
      text-shadow: 0 2px 12px rgba(2, 6, 23, 0.35);
    }
    .countdown {
      display: grid;
      grid-template-columns: repeat(4,minmax(0,1fr));
      gap: 8px;
      margin-bottom: 14px;
    }
    .card {
      border-radius: 10px;
      border: 1px solid rgba(59,130,246,.28);
      background: rgba(15,23,42,.72);
      text-align: center;
      padding: 10px 6px;
    }
    .card .v { font-size: 1.2rem; font-weight: 800; line-height: 1; color: #fff; }
    .card .l { margin-top: 5px; font-size: .68rem; text-transform: uppercase; letter-spacing: .06em; color: rgba(191,219,254,.82); }
    .scarcity-card {
      width: 100%;
      max-width: 520px;
      margin: 20px 0 16px;
      padding: 14px 14px 12px;
      border-radius: 14px;
      border: 1px solid rgba(239, 68, 68, 0.55);
      background: radial-gradient(120% 130% at 0% 0%, rgba(220, 38, 38, 0.24) 0%, rgba(69, 10, 10, 0.30) 45%, rgba(15, 23, 42, 0.72) 100%);
      box-shadow: 0 14px 30px rgba(127, 29, 29, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      text-align: left;
    }
    .scarcity-kicker {
      margin: 0 0 8px;
      font-size: 0.70rem;
      text-transform: uppercase;
      letter-spacing: 0.10em;
      color: #fee2e2;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .scarcity-kicker::before {
      content: '';
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #ef4444;
      box-shadow: 0 0 10px rgba(239, 68, 68, 0.7);
    }
    .scarcity-main { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
    .scarcity-label { margin: 0; color: rgba(255, 255, 255, 0.96); font-size: 0.92rem; font-weight: 700; }
    .scarcity-value {
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(220, 38, 38, 0.28);
      border: 1px solid rgba(252, 165, 165, 0.72);
    }
    .scarcity-number { font-size: 1.42rem; line-height: 1; font-weight: 900; color: #fff; }
    .scarcity-unit { font-size: 0.80rem; letter-spacing: 0.06em; color: #ffe4e6; font-weight: 700; }
    .scarcity-denominator {
      display: none;
      font-size: 0.95rem;
      line-height: 1;
      font-weight: 800;
      color: rgba(255, 228, 230, 0.92);
    }
    .scarcity-denominator.is-visible { display: inline; }
    @media (max-width: 768px) {
      .scarcity-value {
        padding: 4px 10px;
        gap: 4px;
      }
      .scarcity-number { font-size: 1.16rem; }
      .scarcity-denominator { font-size: 0.78rem; }
      .scarcity-unit { font-size: 0.68rem; }
    }
    .scarcity-meter {
      margin-top: 10px;
      width: 100%;
      height: 7px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(252, 165, 165, 0.35);
    }
    .scarcity-meter__fill {
      height: 100%;
      width: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #ef4444, #dc2626);
      box-shadow: 0 0 14px rgba(239, 68, 68, 0.55);
    }
    .scarcity-phase1-total {
      display: none;
      margin: 10px 0 12px;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid rgba(248, 113, 113, 0.55);
      background: linear-gradient(135deg, rgba(127, 29, 29, 0.55), rgba(153, 27, 27, 0.28));
      box-shadow: inset 0 0 0 1px rgba(127, 29, 29, 0.35), 0 8px 22px rgba(127, 29, 29, 0.30);
    }
    .scarcity-soldout-stamp {
      flex: 0 0 auto;
      padding: 6px 10px;
      border-radius: 6px;
      background: #b91c1c;
      color: #fff;
      font-size: 0.66rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      border: 1px solid rgba(254, 202, 202, 0.55);
      text-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);
      transform: rotate(-3deg);
    }
    .scarcity-soldout-line {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      line-height: 1.2;
      min-width: 0;
    }
    .scarcity-soldout-count {
      font-size: 0.95rem;
      font-weight: 800;
      color: #fff;
      text-decoration: line-through;
      text-decoration-thickness: 2px;
      text-decoration-color: rgba(254, 202, 202, 0.9);
    }
    .scarcity-soldout-slash { opacity: 0.75; font-weight: 700; }
    .scarcity-soldout-text {
      font-size: 0.76rem;
      font-weight: 600;
      color: #fecaca;
      margin-top: 3px;
      letter-spacing: 0.01em;
    }
    .scarcity-phase2-note {
      display: none;
      margin: 0 0 12px;
      align-items: center;
      gap: 10px;
      padding: 7px 12px;
      border-radius: 999px;
      border: 1px solid rgba(110, 231, 183, 0.45);
      background: linear-gradient(135deg, rgba(6, 78, 59, 0.55), rgba(4, 120, 87, 0.20));
      font-size: 0.78rem;
      font-weight: 700;
      color: #d1fae5;
      box-shadow: 0 6px 16px rgba(6, 95, 70, 0.18);
    }
    .scarcity-phase2-pulse {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #34d399;
      box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.65);
      animation: scarcityPulse 1.6s ease-out infinite;
    }
    .scarcity-phase2-text strong { color: #fff; font-weight: 800; }
    .scarcity-phase1-total.is-visible { display: flex; }
    .scarcity-phase2-note.is-visible { display: inline-flex; }
    @keyframes scarcityPulse {
      0% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.65); }
      70% { box-shadow: 0 0 0 10px rgba(52, 211, 153, 0); }
      100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0); }
    }
    .mc-gate-overlay {
      position: fixed;
      inset: 0;
      z-index: 200000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 18px;
      background: rgba(2, 6, 23, 0.92);
      backdrop-filter: blur(10px);
    }
    .mc-gate-overlay.is-visible { display: flex; }
    html.mc-page-lock,
    html.mc-page-lock body {
      overflow: hidden;
      height: 100%;
    }
    .mc-gate-overlay__panel {
      width: min(560px, 100%);
      border-radius: 16px;
      border: 1px solid rgba(248, 113, 113, 0.45);
      background: linear-gradient(135deg, rgba(127, 29, 29, 0.55), rgba(15, 23, 42, 0.92));
      box-shadow: 0 24px 70px rgba(127, 29, 29, 0.35);
      padding: 22px 18px 18px;
      text-align: center;
    }
    .mc-gate-overlay__title {
      margin: 0;
      font-size: clamp(1.12rem, 2.6vw, 1.42rem);
      font-weight: 900;
      color: #fff1f2;
    }
    .mc-gate-overlay__copy {
      margin: 10px 0 14px;
      font-size: 0.95rem;
      line-height: 1.45;
      color: #fecdd3;
    }
    .mc-gate-overlay__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 16px;
      border-radius: 12px;
      border: 1px solid rgba(251, 113, 133, 0.55);
      background: rgba(225, 29, 72, 0.35);
      color: #fff;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 900;
    }
    .late-replay-banner {
      margin: 0 0 12px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid rgba(59, 130, 246, 0.45);
      background: rgba(30, 64, 175, 0.35);
      color: #dbeafe;
      font-size: 0.88rem;
      line-height: 1.45;
      text-align: center;
    }
    .late-replay-banner.hidden { display: none !important; }
    .offer-cta {
      width: 100%;
      max-width: 520px;
      margin-top: 12px;
      border: none;
      border-radius: 14px;
      padding: 16px 20px;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      box-shadow: 0 14px 34px rgba(59, 130, 246, 0.38);
      transition: all 0.25s ease;
    }
    .offer-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 16px 40px rgba(59, 130, 246, 0.45);
    }
    .offer-expired-state {
      width: 100%;
      max-width: 520px;
      margin-top: 12px;
      border-radius: 14px;
      border: 1px solid rgba(248, 113, 113, 0.45);
      background: linear-gradient(135deg, rgba(127, 29, 29, 0.38), rgba(69, 10, 10, 0.45));
      padding: 16px 16px 14px;
      text-align: center;
    }
    .offer-expired-title {
      margin: 0;
      color: #fff1f2;
      font-size: 1rem;
      font-weight: 800;
    }
    .offer-expired-copy {
      margin: 8px 0 12px;
      color: #fecdd3;
      font-size: 0.9rem;
      line-height: 1.4;
    }
    .offer-expired-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0 14px;
      border-radius: 10px;
      border: 1px solid rgba(251, 113, 133, 0.55);
      color: #fff;
      background: rgba(225, 29, 72, 0.32);
      text-decoration: none;
      font-size: .85rem;
      font-weight: 800;
    }

    .purchase-toast {
      position: fixed;
      left: 20px;
      bottom: 20px;
      z-index: 9999;
      opacity: 0;
      transform: translateY(20px);
      pointer-events: none;
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .purchase-toast.show { opacity: 1; transform: translateY(0); }
    .purchase-toast__content {
      display: flex;
      align-items: center;
      gap: 10px;
      max-width: 360px;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid rgba(59, 130, 246, 0.3);
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.95));
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(59, 130, 246, 0.2);
      backdrop-filter: blur(10px);
    }
    .purchase-toast__thumb-wrap { position: relative; width: 58px; height: 58px; flex-shrink: 0; }
    .purchase-toast__thumb {
      width: 58px;
      height: 58px;
      border-radius: 9px;
      object-fit: cover;
      display: block;
      border: 1px solid rgba(59, 130, 246, 0.4);
      box-shadow: 0 4px 16px rgba(2, 6, 23, 0.35);
    }
    .purchase-toast__thumb-flag {
      position: absolute;
      right: -4px;
      bottom: -4px;
      font-size: 14px;
      line-height: 1;
      filter: drop-shadow(0 2px 6px rgba(2, 6, 23, 0.5));
    }
    .purchase-toast__text { margin: 0; font-size: 14px; line-height: 1.35; color: #fff; }
    .purchase-toast__name { color: #60a5fa !important; font-weight: 900 !important; text-shadow: 0 0 10px rgba(96, 165, 250, 0.35); }
    .purchase-toast__action { color: rgba(255, 255, 255, 0.72); }
    .purchase-toast__course { display: block; margin-top: 2px; color: #ffffff !important; font-weight: 400 !important; }
    @media (max-width: 1023px) {
      .offer-cta { width: 100%; }
