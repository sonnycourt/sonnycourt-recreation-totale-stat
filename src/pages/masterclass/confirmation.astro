---
import GAConsentMode from '../../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmation — Webinaire Esprit Subconscient 2.0</title>
    <meta name="description" content="Ta place au webinaire Esprit Subconscient 2.0 est réservée. Ajoute la session à ton calendrier.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"></noscript>
    <GAConsentMode />
    <style>
        html { opacity: 0; }
        html.ready { opacity: 1; transition: opacity 0.15s ease; }
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --accent: #e2e8f0;
            --bg-dark: #0a0a1a;
            --text-muted: rgba(255, 255, 255, 0.72);
            --border: rgba(59, 130, 246, 0.35);
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .bg-gradient {
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 100%, rgba(37, 99, 235, 0.2) 0%, transparent 50%),
                linear-gradient(180deg, #0a0a1a 0%, #1a1a3a 50%, #0a0a1a 100%);
            z-index: -1;
        }

        .container {
            max-width: 640px;
            margin: 0 auto;
            padding: 28px 18px 48px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(34, 197, 94, 0.12);
            border: 1px solid rgba(34, 197, 94, 0.36);
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            color: #bbf7d0;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 16px;
        }

        h1 {
            font-size: clamp(1.75rem, 4vw, 2.4rem);
            line-height: 1.2;
            font-weight: 800;
            margin-bottom: 14px;
            background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            font-size: clamp(1rem, 2.2vw, 1.12rem);
            line-height: 1.55;
            color: var(--text-muted);
            margin-bottom: 22px;
        }

        .section {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 22px 18px;
            margin-bottom: 18px;
        }

        .section h2 {
            font-size: 1.1rem;
            color: #fff;
            margin-bottom: 14px;
            font-weight: 700;
        }

        .section-h2-icon {
            width: 18px;
            height: 18px;
            margin-left: 6px;
            vertical-align: -3px;
        }

        .countdown {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 8px;
            max-width: 100%;
        }

        .count-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 10px 6px;
            text-align: center;
        }

        .count-value {
            display: block;
            font-size: clamp(1.1rem, 3vw, 1.5rem);
            font-weight: 700;
        }

        .count-label {
            font-size: 0.68rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

        .calendar-grid {
            display: grid;
            gap: 10px;
        }

        .cal-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 14px 16px;
            border-radius: 12px;
            border: 2px solid var(--border);
            background: rgba(59, 130, 246, 0.15);
            color: #fff;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .cal-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(59, 130, 246, 0.35);
        }

        .video-player {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            aspect-ratio: 16 / 9;
            background: #000;
            box-shadow:
                0 0 0 1px rgba(96, 165, 250, 0.15),
                0 16px 48px rgba(0, 0, 0, 0.45),
                0 0 60px rgba(59, 130, 246, 0.08);
        }

        .video-player video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            cursor: pointer;
        }

        /* ── Initial overlay (before first play) ── */
        .video-overlay {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: linear-gradient(180deg, rgba(0,0,0,0.12) 0%, rgba(0,0,0,0.52) 100%);
            transition: opacity 0.4s ease;
            z-index: 3;
            cursor: pointer;
        }

        .video-overlay.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .play-btn {
            width: clamp(56px, 12vw, 72px);
            height: clamp(56px, 12vw, 72px);
            border-radius: 50%;
            border: 2px solid rgba(96, 165, 250, 0.7);
            background: rgba(59, 130, 246, 0.25);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
        }

        .play-btn svg {
            width: 24px;
            height: 24px;
            fill: #60a5fa;
            margin-left: 3px;
        }

        .video-player:hover .play-btn {
            transform: scale(1.08);
            background: rgba(59, 130, 246, 0.4);
            box-shadow: 0 0 32px rgba(59, 130, 246, 0.35);
        }

        .play-btn-ring {
            position: absolute;
            width: clamp(72px, 15vw, 92px);
            height: clamp(72px, 15vw, 92px);
            border-radius: 50%;
            border: 1.5px solid rgba(96, 165, 250, 0.25);
            animation: ringPulse 2.4s ease-in-out infinite;
        }

        @keyframes ringPulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.12); opacity: 0; }
        }

        /* ── Custom controls bar ── */
        .vp-controls {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            background: linear-gradient(0deg, rgba(0,0,0,0.72) 0%, transparent 100%);
            z-index: 4;
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }

        .video-player.playing .vp-controls,
        .video-player.paused .vp-controls {
            pointer-events: auto;
        }

        .video-player.playing:hover .vp-controls,
        .video-player.paused .vp-controls {
            opacity: 1;
        }

        .vp-btn {
            background: none;
            border: none;
            color: #fff;
            cursor: pointer;
            padding: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .vp-btn svg {
            width: 18px;
            height: 18px;
        }

        .vp-progress-wrap {
            flex: 1;
            height: 4px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            cursor: default;
            position: relative;
            overflow: hidden;
        }

        .vp-progress-wrap:hover {
            height: 6px;
        }

        .vp-progress-bar {
            height: 100%;
            width: 0%;
            background: #3b82f6;
            border-radius: 4px;
            transition: width 0.15s linear;
        }

        .vp-volume-wrap {
            display: flex;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
        }

        .vp-volume-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 52px;
            height: 4px;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.2);
            outline: none;
            cursor: pointer;
        }

        .vp-volume-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #fff;
            cursor: pointer;
        }

        .vp-volume-slider::-moz-range-thumb {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #fff;
            border: none;
            cursor: pointer;
        }

        @media (max-width: 480px) {
            .vp-volume-wrap { display: none; }
        }

        .video-caption {
            text-align: center;
            margin-top: 10px;
            font-size: 0.8rem;
            color: rgba(226, 232, 240, 0.5);
            font-weight: 500;
        }

        .steps-list {
            list-style: none;
            display: grid;
            gap: 12px;
        }

        .step-item {
            display: grid;
            grid-template-columns: 28px 1fr;
            gap: 12px;
            align-items: start;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .step-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .step-icon {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: rgba(59, 130, 246, 0.15);
            border: 1px solid rgba(59, 130, 246, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #93c5fd;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .step-icon svg {
            width: 15px;
            height: 15px;
        }

        .step-title {
            font-weight: 700;
            color: #fff;
            line-height: 1.35;
            margin-bottom: 4px;
            font-size: 0.95rem;
        }

        .step-text {
            color: var(--text-muted);
            line-height: 1.55;
            font-size: 0.9rem;
        }

        .step-btn {
            margin-top: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid rgba(37, 211, 102, 0.72);
            background: rgba(37, 211, 102, 0.05);
            color: #8ff0b6;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .step-btn:hover {
            transform: translateY(-1px);
            background: rgba(37, 211, 102, 0.12);
            box-shadow: 0 8px 20px rgba(37, 211, 102, 0.2);
        }

        /* Lien diffusion — volontairement plus discret que le CTA WhatsApp */
        .session-access-step .step-icon {
            background: rgba(148, 163, 184, 0.1);
            border-color: rgba(148, 163, 184, 0.28);
            color: #94a3b8;
        }

        .session-access-title {
            font-weight: 700;
            color: #e2e8f0;
            line-height: 1.35;
            margin-bottom: 6px;
            font-size: 0.92rem;
        }

        .session-access-sub {
            color: var(--text-muted);
            line-height: 1.5;
            font-size: 0.84rem;
            margin-bottom: 10px;
        }

        .session-access-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 14px;
            border-radius: 10px;
            border: 1px solid rgba(148, 163, 184, 0.45);
            background: transparent;
            color: #cbd5e1;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
            transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
        }

        .session-access-link:hover {
            border-color: rgba(96, 165, 250, 0.55);
            color: #e2e8f0;
            background: rgba(59, 130, 246, 0.08);
        }

        .session-access-note {
            margin-top: 10px;
            font-size: 0.72rem;
            line-height: 1.45;
            color: rgba(255, 255, 255, 0.45);
        }

        .session-access-step.is-hidden {
            display: none !important;
        }

        .social-proof {
            display: grid;
            gap: 6px;
            color: var(--text-muted);
            font-size: 0.92rem;
        }

        .social-proof strong {
            color: #fff;
            font-weight: 600;
        }

        #loading-state {
            text-align: center;
            padding: 80px 20px;
            color: var(--text-muted);
        }

        #main-content {
            display: none;
        }

        #main-content.visible {
            display: block;
        }

        .dev-preview-banner {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 10000;
            display: none;
            text-align: center;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.03em;
            color: rgba(251, 191, 36, 0.96);
            background: rgba(20, 20, 34, 0.94);
            border-bottom: 1px solid rgba(251, 191, 36, 0.32);
            padding: 8px 12px;
            backdrop-filter: blur(6px);
        }

        .dev-preview-banner.visible {
            display: block;
        }

        .confetti-canvas {
            position: fixed;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 9998;
        }
    </style>
</head>
<body>
    <div class="bg-gradient"></div>
    <canvas id="confetti-canvas" class="confetti-canvas" aria-hidden="true"></canvas>
    <div id="dev-preview-banner" class="dev-preview-banner">
        Mode aperçu actif (`?preview=dev`) — rendu visuel de préproduction
    </div>

    <div class="container">
        <div id="loading-state">Chargement de ta confirmation…</div>

        <div id="main-content">
            <div id="badge-label" class="badge">Inscription confirmée</div>
            <h1>Ta place est réservée !</h1>
            <p id="subtitle" class="subtitle"></p>

            <div class="section">
                <h2>
                    Un message de Sonny pour toi
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-h2-icon icon icon-tabler icons-tabler-outline icon-tabler-hand-finger-down" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M8 12v8.5a1.5 1.5 0 0 0 3 0v-7.5"></path><path d="M11 13.5v2a1.5 1.5 0 0 0 3 0v-2.5"></path><path d="M14 14.5a1.5 1.5 0 0 0 3 0v-1.5"></path><path d="M17 13.5a1.5 1.5 0 0 0 3 0v-4.5a6 6 0 0 0 -6 -6h-2h.208a6 6 0 0 0 -5.012 2.7l-.196 .3q -.468 .718 -3.286 5.728a1.5 1.5 0 0 0 .536 2.022c.734 .44 1.674 .325 2.28 -.28l1.47 -1.47"></path></svg>
                </h2>
                <div class="video-player" id="video-player">
                    <video id="confirmation-video" playsinline preload="metadata">
                        <source src="https://sonnycourt-videos-public.b-cdn.net/FE%CC%81LICITATIONS%20(inscription%20Webinaire%20V2).mp4" type="video/mp4" />
                    </video>
                    <div class="video-overlay" id="video-overlay">
                        <span class="play-btn-ring"></span>
                        <span class="play-btn">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polygon points="6,3 20,12 6,21"/></svg>
                        </span>
                    </div>
                    <div class="vp-controls" id="vp-controls">
                        <button class="vp-btn" id="vp-playpause" aria-label="Play/Pause">
                            <svg id="vp-icon-play" viewBox="0 0 24 24" fill="currentColor"><polygon points="6,3 20,12 6,21"/></svg>
                            <svg id="vp-icon-pause" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="5" y="3" width="4" height="18"/><rect x="15" y="3" width="4" height="18"/></svg>
                        </button>
                        <div class="vp-progress-wrap" id="vp-progress-wrap">
                            <div class="vp-progress-bar" id="vp-progress-bar"></div>
                        </div>
                        <div class="vp-volume-wrap">
                            <button class="vp-btn" id="vp-mute" aria-label="Mute">
                                <svg id="vp-icon-vol" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                                <svg id="vp-icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
                            </button>
                            <input type="range" class="vp-volume-slider" id="vp-volume" min="0" max="1" step="0.05" value="1" />
                        </div>
                    </div>
                </div>
                <p class="video-caption">1 min — un message personnel de Sonny</p>
            </div>

            <div class="section">
                <h2>Avant la session</h2>
                <div class="countdown" aria-live="polite">
                    <div class="count-card">
                        <span id="cd-days" class="count-value">00</span>
                        <span class="count-label">Jours</span>
                    </div>
                    <div class="count-card">
                        <span id="cd-hours" class="count-value">00</span>
                        <span class="count-label">Heures</span>
                    </div>
                    <div class="count-card">
                        <span id="cd-minutes" class="count-value">00</span>
                        <span class="count-label">Minutes</span>
                    </div>
                    <div class="count-card">
                        <span id="cd-seconds" class="count-value">00</span>
                        <span class="count-label">Secondes</span>
                    </div>
                </div>
            </div>

            <div class="section">
                <h2>Prochaines étapes</h2>
                <ul class="steps-list">
                    <li class="step-item" id="whatsapp-step">
                        <span class="step-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-whatsapp">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                                <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
                                <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
                            </svg>
                        </span>
                        <div>
                            <p class="step-title">Rejoins le groupe WhatsApp privé</p>
                            <p class="step-text">Lien d'accès, rappels, ressources exclusives — tout passe par là.</p>
                            <div id="whatsapp-groups-complete" style="display:none;margin:6px 0 8px;"></div>
                            <a id="link-whatsapp" class="step-btn" href="#" target="_blank" rel="noopener noreferrer">Rejoindre le Groupe</a>
                        </div>
                    </li>
                    <li class="step-item session-access-step is-hidden" id="session-access-step">
                        <span class="step-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                            </svg>
                        </span>
                        <div>
                            <p class="session-access-title">Ton lien d'accès à la masterclass</p>
                            <p class="session-access-sub">Sauvegarde ce lien — c'est ton accès le jour J</p>
                            <a id="link-masterclass-session" class="session-access-link" href="#" target="_blank" rel="noopener noreferrer">Ouvrir la page de diffusion</a>
                            <p class="session-access-note">Ce lien te sera aussi renvoyé par email avant la session.</p>
                        </div>
                    </li>
                    <li class="step-item">
                        <span class="step-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                                <path d="m3 7 9 6 9-6"></path>
                            </svg>
                        </span>
                        <div>
                            <p class="step-title">Vérifie ta boîte email</p>
                            <p class="step-text">Une confirmation arrive dans quelques minutes. Si elle est en spam, marque-la "non spam" et ajoute mon adresse à tes contacts pour ne rien manquer.</p>
                        </div>
                    </li>
                    <li class="step-item">
                        <span class="step-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="17" rx="2"></rect>
                                <path d="M8 2v4M16 2v4M3 10h18"></path>
                            </svg>
                        </span>
                        <div>
                            <p class="step-title">Bloque jeudi 20h dans ton agenda maintenant</p>
                            <p class="step-text">Prévois 1h30 de calme et de quoi écrire.</p>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="section">
                <h2>Ajouter au calendrier</h2>
                <div class="calendar-grid">
                    <a id="link-google" class="cal-btn" href="#" target="_blank" rel="noopener noreferrer">Google Calendar</a>
                    <a id="link-outlook" class="cal-btn" href="#" target="_blank" rel="noopener noreferrer">Outlook</a>
                    <button type="button" id="btn-apple" class="cal-btn">Apple Calendar</button>
                </div>
            </div>

        </div>
    </div>

    <script>
        // @ts-nocheck
        const EVENT_TITLE = 'Masterclass Esprit Subconscient 2.0 — Sonny Court';
        const EVENT_DESCRIPTION =
            "Ton lien d'accès personnel te sera envoyé par email et SMS avant la session.";
        const TOKEN_KEY = 'masterclass_es2_token';

        function pad(n) {
            return String(n).padStart(2, '0');
        }

        function toGCalUtc(iso) {
            return new Date(iso).toISOString().replace(/[-:]/g, '').replace(/\.\d{3}Z$/, 'Z');
        }

        function formatSubtitle(sessionStartsAt, creneau) {
            const d = new Date(sessionStartsAt);
            const dateOnly = new Intl.DateTimeFormat('fr-FR', {
                timeZone: 'Europe/Paris',
                weekday: 'long',
                day: 'numeric',
                month: 'long',
                year: 'numeric',
            }).format(d);
            const slotLabel = creneau === '20h' ? '20h' : '14h';
            const cap = dateOnly.charAt(0).toUpperCase() + dateOnly.slice(1);
            return `Rendez-vous le ${cap} à ${slotLabel} (heure de Paris)`;
        }

        function buildGoogleUrl(startIso, endIso) {
            const dates = `${toGCalUtc(startIso)}/${toGCalUtc(endIso)}`;
            const params = new URLSearchParams({
                action: 'TEMPLATE',
                text: EVENT_TITLE,
                dates,
                details: EVENT_DESCRIPTION,
                location: 'En ligne',
            });
            return `https://calendar.google.com/calendar/render?${params.toString()}`;
        }

        function buildOutlookUrl(startIso, endIso) {
            const params = new URLSearchParams({
                path: '/calendar/action/compose',
                rru: 'addevent',
                subject: EVENT_TITLE,
                startdt: new Date(startIso).toISOString(),
                enddt: new Date(endIso).toISOString(),
                body: EVENT_DESCRIPTION,
            });
            return `https://outlook.live.com/calendar/0/deeplink/compose?${params.toString()}`;
        }

        function escapeIcs(text) {
            return String(text)
                .replace(/\\/g, '\\\\')
                .replace(/;/g, '\\;')
                .replace(/,/g, '\\,')
                .replace(/\n/g, '\\n');
        }

        function buildIcsContent(uid, startIso, endIso) {
            const fmt = (iso) => new Date(iso).toISOString().replace(/[-:]/g, '').replace(/\.\d{3}Z$/, 'Z');
            const lines = [
                'BEGIN:VCALENDAR',
                'VERSION:2.0',
                'PRODID:-//Sonny Court//Webinaire ES2//FR',
                'CALSCALE:GREGORIAN',
                'METHOD:PUBLISH',
                'BEGIN:VEVENT',
                `UID:${uid}`,
                `DTSTAMP:${fmt(new Date().toISOString())}`,
                `DTSTART:${fmt(startIso)}`,
                `DTEND:${fmt(endIso)}`,
                `SUMMARY:${escapeIcs(EVENT_TITLE)}`,
                `DESCRIPTION:${escapeIcs(EVENT_DESCRIPTION)}`,
                'LOCATION:En ligne',
                'END:VEVENT',
                'END:VCALENDAR',
            ];
            return lines.join('\r\n');
        }

        function downloadAppleCalendar(uid, startIso, endIso) {
            const ics = buildIcsContent(uid, startIso, endIso);
            const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'webinaire-esprit-subconscient-2.ics';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        function updateCountdown(targetMs) {
            const now = Date.now();
            const diff = Math.max(0, targetMs - now);
            const totalSec = Math.floor(diff / 1000);
            document.getElementById('cd-days').textContent = pad(Math.floor(totalSec / 86400));
            document.getElementById('cd-hours').textContent = pad(Math.floor((totalSec % 86400) / 3600));
            document.getElementById('cd-minutes').textContent = pad(Math.floor((totalSec % 3600) / 60));
            document.getElementById('cd-seconds').textContent = pad(totalSec % 60);
        }

        let confettiPlayed = false;
        function launchConfetti() {
            if (confettiPlayed) return;
            confettiPlayed = true;
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

            const canvas = document.getElementById('confetti-canvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;

            const particles = [];
            const colors = ['#60a5fa', '#93c5fd', '#f8fafc', '#22c55e', '#f59e0b'];
            const durationMs = 4600;
            const gravity = 0.12;
            const drag = 0.992;
            const start = performance.now();

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();

            const burstCount = Math.min(120, Math.max(70, Math.floor(window.innerWidth / 12)));
            for (let i = 0; i < burstCount; i++) {
                const fromLeft = i % 2 === 0;
                particles.push({
                    x: fromLeft ? -20 - Math.random() * 80 : canvas.width + 20 + Math.random() * 80,
                    y: Math.random() * canvas.height * 0.45,
                    vx: fromLeft ? 2 + Math.random() * 4 : -2 - Math.random() * 4,
                    vy: -1.8 + Math.random() * 2.2,
                    size: 3 + Math.random() * 6,
                    rot: Math.random() * Math.PI,
                    vr: (Math.random() - 0.5) * 0.25,
                    color: colors[(Math.random() * colors.length) | 0],
                    life: 0.75 + Math.random() * 0.9,
                });
            }

            const topRainCount = Math.min(140, Math.max(80, Math.floor(window.innerWidth / 10)));
            for (let i = 0; i < topRainCount; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: -20 - Math.random() * 240,
                    vx: (Math.random() - 0.5) * 1.4,
                    vy: 1.6 + Math.random() * 2.3,
                    size: 2.8 + Math.random() * 5.2,
                    rot: Math.random() * Math.PI,
                    vr: (Math.random() - 0.5) * 0.22,
                    color: colors[(Math.random() * colors.length) | 0],
                    life: 0.95 + Math.random() * 1.05,
                });
            }

            function frame(now) {
                const elapsed = now - start;
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                for (let i = 0; i < particles.length; i++) {
                    const p = particles[i];
                    p.vx *= drag;
                    p.vy = p.vy * drag + gravity;
                    p.x += p.vx;
                    p.y += p.vy;
                    p.rot += p.vr;
                    p.life -= 0.0062;
                    if (p.life <= 0 || p.y > canvas.height + 30) continue;

                    ctx.save();
                    ctx.translate(p.x, p.y);
                    ctx.rotate(p.rot);
                    ctx.globalAlpha = Math.max(0, p.life);
                    ctx.fillStyle = p.color;
                    ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.64);
                    ctx.restore();
                }

                if (elapsed < durationMs) {
                    requestAnimationFrame(frame);
                } else {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    window.removeEventListener('resize', resize);
                }
            }

            window.addEventListener('resize', resize);
            requestAnimationFrame(frame);
        }

        function setTokenEverywhere(token) {
            localStorage.setItem(TOKEN_KEY, token);
        }

        async function requestTokenFromEmail() {
            const overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(2,6,23,.88);display:flex;align-items:center;justify-content:center;padding:16px;';
            overlay.innerHTML = `
                <div style="width:100%;max-width:420px;border:1px solid rgba(148,163,184,.25);background:#0f172a;border-radius:16px;padding:18px;color:#e2e8f0;">
                    <p style="margin:0 0 8px;font-size:20px;font-weight:700;">Retrouve ton accès</p>
                    <p style="margin:0 0 12px;font-size:14px;color:#94a3b8;">Entre l'email utilisé à l'inscription.</p>
                    <input id="conf-recovery-email" type="email" placeholder="Ton email" autocomplete="email" style="width:100%;height:44px;border-radius:10px;border:1px solid #334155;background:#020617;color:#e2e8f0;padding:0 12px;outline:none;" />
                    <button id="conf-recovery-submit" type="button" style="margin-top:10px;width:100%;height:44px;border:none;border-radius:10px;background:#38bdf8;color:#082f49;font-weight:800;cursor:pointer;">Vérifier mon accès</button>
                    <p id="conf-recovery-error" style="min-height:1.2em;margin:10px 0 0;color:#fca5a5;font-size:13px;"></p>
                </div>
            `;
            document.body.appendChild(overlay);

            const input = overlay.querySelector('#conf-recovery-email');
            const submit = overlay.querySelector('#conf-recovery-submit');
            const err = overlay.querySelector('#conf-recovery-error');

            async function submitEmail() {
                err.textContent = '';
                const email = String(input.value || '').trim().toLowerCase();
                if (!email || !email.includes('@')) {
                    err.textContent = 'Merci de saisir un email valide.';
                    return;
                }
                submit.disabled = true;
                try {
                    const res = await fetch('/.netlify/functions/check-webinaire-eligibility', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email }),
                    });
                    const body = await res.json().catch(() => ({}));
                    if (!res.ok) {
                        err.textContent = 'Vérification impossible. Réessaie dans un instant.';
                        return;
                    }
                    if (body.eligible === false && body.reason === 'already_registered' && body.token) {
                        overlay.remove();
                        window.__confirmationRecoveredToken = String(body.token);
                        return;
                    }
                    if (body.eligible === false && body.reason === 'excluded') {
                        err.textContent = "Tu n'es pas éligible pour cette session.";
                        return;
                    }
                    err.textContent = "Aucune inscription trouvée avec cet email.";
                } catch {
                    err.textContent = 'Vérification impossible. Réessaie dans un instant.';
                } finally {
                    submit.disabled = false;
                }
            }

            submit.addEventListener('click', submitEmail);
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') submitEmail();
            });

            return new Promise(function (resolve) {
                const t = setInterval(function () {
                    if (window.__confirmationRecoveredToken) {
                        const recovered = window.__confirmationRecoveredToken;
                        window.__confirmationRecoveredToken = '';
                        clearInterval(t);
                        resolve(recovered);
                    }
                }, 120);
            });
        }

        /** Aperçu design local : pas de token ni d’API Netlify */
        const PREVIEW_SUBTITLE =
            'Rendez-vous le jeudi 27 mars 2026 à 20h (heure de Paris)';
        const PREVIEW_SESSION_START_ISO = '2026-03-27T19:00:00.000Z';
        const PREVIEW_SESSION_END_ISO = '2026-03-27T19:45:00.000Z';
        /** Token factice pour afficher le bloc « lien session » en preview=dev (ou utiliser ?preview=dev&t=TON_TOKEN) */
        const PREVIEW_SESSION_ACCESS_TOKEN = '00000000-0000-4000-8000-000000000001';

        function mountConfirmation(data, options) {
            const tokenForApple = options && options.appleUid ? options.appleUid : 'preview@webinaire-es2.sonnycourt';
            const startMs = new Date(data.sessionStartsAt).getTime();
            const whatsappStep = document.getElementById('whatsapp-step');
            const whatsappLinkEl = document.getElementById('link-whatsapp');
            const whatsappGroupsCompleteEl = document.getElementById('whatsapp-groups-complete');
            const whatsappLink = data && data.whatsappLink ? String(data.whatsappLink).trim() : '';
            const whatsappGroupNumber = Number(data?.whatsappGroupNumber);

            if (whatsappStep && whatsappLinkEl) {
                if (whatsappLink) {
                    whatsappLinkEl.href = whatsappLink;
                    const baseGroup = Number.isFinite(whatsappGroupNumber) && whatsappGroupNumber > 0
                        ? Math.floor(whatsappGroupNumber)
                        : 0;
                    const visualGroup = baseGroup > 0 ? baseGroup + 1 : 1;
                    whatsappLinkEl.textContent = `Rejoindre le Groupe ${visualGroup}`;
                    if (whatsappGroupsCompleteEl) {
                        if (baseGroup > 0) {
                            whatsappGroupsCompleteEl.innerHTML = '';
                            for (let i = 1; i <= baseGroup; i += 1) {
                                const line = document.createElement('p');
                                line.className = 'step-text';
                                line.style.margin = '0 0 4px';
                                line.style.color = 'rgba(148,163,184,.95)';
                                line.style.fontWeight = '600';
                                line.textContent = `Groupe ${i} — Complet ✓`;
                                whatsappGroupsCompleteEl.appendChild(line);
                            }
                            whatsappGroupsCompleteEl.style.display = '';
                        } else {
                            whatsappGroupsCompleteEl.innerHTML = '';
                            whatsappGroupsCompleteEl.style.display = 'none';
                        }
                    }
                    whatsappLinkEl.onclick = function () {
                        const payload = {
                            session_date: String(data?.sessionStartsAt || '').slice(0, 10),
                            group_number:
                                Number.isFinite(whatsappGroupNumber) && whatsappGroupNumber > 0
                                    ? Math.floor(whatsappGroupNumber)
                                    : null,
                        };
                        if (payload.session_date && payload.group_number) {
                            fetch('/.netlify/functions/track-whatsapp-join', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(payload),
                                keepalive: true,
                            }).catch(function () {});
                        }
                    };
                    whatsappStep.style.display = '';
                } else {
                    if (whatsappGroupsCompleteEl) {
                        whatsappGroupsCompleteEl.innerHTML = '';
                        whatsappGroupsCompleteEl.style.display = 'none';
                    }
                    whatsappStep.style.display = 'none';
                }
            }

            const sessionAccessRow = document.getElementById('session-access-step');
            const sessionAccessLink = document.getElementById('link-masterclass-session');
            const accessToken = options && options.sessionAccessToken ? String(options.sessionAccessToken).trim() : '';
            if (sessionAccessRow && sessionAccessLink) {
                if (accessToken) {
                    sessionAccessLink.href = '/masterclass/session?t=' + encodeURIComponent(accessToken);
                    sessionAccessRow.classList.remove('is-hidden');
                    sessionAccessRow.style.display = 'grid';
                } else {
                    sessionAccessRow.classList.add('is-hidden');
                    sessionAccessRow.style.removeProperty('display');
                }
            }

            document.getElementById('subtitle').textContent = data.subtitleText || formatSubtitle(data.sessionStartsAt, data.creneau);
            document.getElementById('link-google').href = buildGoogleUrl(data.sessionStartsAt, data.sessionEndsAt);
            document.getElementById('link-outlook').href = buildOutlookUrl(data.sessionStartsAt, data.sessionEndsAt);
            document.getElementById('btn-apple').addEventListener('click', function () {
                downloadAppleCalendar(tokenForApple, data.sessionStartsAt, data.sessionEndsAt);
            });

            document.getElementById('loading-state').style.display = 'none';
            document.getElementById('main-content').classList.add('visible');
            launchConfetti();

            updateCountdown(startMs);
            setInterval(function () {
                updateCountdown(startMs);
            }, 1000);
        }

        /* ── Custom Video Player ── */
        (function initVideoPlayer() {
            var player = document.getElementById('video-player');
            var video = document.getElementById('confirmation-video');
            var overlay = document.getElementById('video-overlay');
            var controls = document.getElementById('vp-controls');
            var btnPlayPause = document.getElementById('vp-playpause');
            var iconPlay = document.getElementById('vp-icon-play');
            var iconPause = document.getElementById('vp-icon-pause');
            var progressWrap = document.getElementById('vp-progress-wrap');
            var progressBar = document.getElementById('vp-progress-bar');
            var btnMute = document.getElementById('vp-mute');
            var iconVol = document.getElementById('vp-icon-vol');
            var iconMuted = document.getElementById('vp-icon-muted');
            var volumeSlider = document.getElementById('vp-volume');
            if (!player || !video || !overlay) return;

            var hasStarted = false;
            var hideTimer = null;

            function fmtTime(s) {
                var m = Math.floor(s / 60);
                var sec = Math.floor(s % 60);
                return m + ':' + (sec < 10 ? '0' : '') + sec;
            }

            function syncIcons() {
                if (video.paused) {
                    iconPlay.style.display = '';
                    iconPause.style.display = 'none';
                    player.classList.remove('playing');
                    player.classList.add('paused');
                } else {
                    iconPlay.style.display = 'none';
                    iconPause.style.display = '';
                    player.classList.add('playing');
                    player.classList.remove('paused');
                }
            }

            function syncVolume() {
                if (video.muted || video.volume === 0) {
                    iconVol.style.display = 'none';
                    iconMuted.style.display = '';
                } else {
                    iconVol.style.display = '';
                    iconMuted.style.display = 'none';
                }
                volumeSlider.value = video.muted ? 0 : video.volume;
            }

            function startAutoHide() {
                clearTimeout(hideTimer);
                hideTimer = setTimeout(function () {
                    if (!video.paused) controls.style.opacity = '0';
                }, 2800);
            }

            function showControls() {
                controls.style.opacity = '1';
                startAutoHide();
            }

            /* First play from overlay */
            overlay.addEventListener('click', function (e) {
                e.stopPropagation();
                hasStarted = true;
                overlay.classList.add('hidden');
                video.play().catch(function () {});
            });

            /* Click on video to toggle play/pause */
            video.addEventListener('click', function (e) {
                e.stopPropagation();
                if (!hasStarted) {
                    hasStarted = true;
                    overlay.classList.add('hidden');
                    video.play().catch(function () {});
                    return;
                }
                if (video.paused) {
                    video.play().catch(function () {});
                } else {
                    video.pause();
                }
            });

            /* Controls play/pause button */
            btnPlayPause.addEventListener('click', function (e) {
                e.stopPropagation();
                if (video.paused) {
                    video.play().catch(function () {});
                } else {
                    video.pause();
                }
            });

            video.addEventListener('play', function () { syncIcons(); showControls(); });
            video.addEventListener('pause', function () { syncIcons(); clearTimeout(hideTimer); });

            /* Progress bar */
            video.addEventListener('timeupdate', function () {
                var pct = video.duration ? (video.currentTime / video.duration) * 100 : 0;
                progressBar.style.width = pct + '%';
            });

            /* Volume */
            btnMute.addEventListener('click', function (e) {
                e.stopPropagation();
                video.muted = !video.muted;
                syncVolume();
            });

            volumeSlider.addEventListener('input', function (e) {
                e.stopPropagation();
                video.volume = parseFloat(this.value);
                video.muted = video.volume === 0;
                syncVolume();
            });
            volumeSlider.addEventListener('click', function (e) { e.stopPropagation(); });

            /* Auto-hide controls on mouse leave/move */
            player.addEventListener('mousemove', function () { if (hasStarted) showControls(); });
            player.addEventListener('mouseleave', function () {
                if (!video.paused) { clearTimeout(hideTimer); controls.style.opacity = '0'; }
            });

            /* End of video — reset to overlay */
            video.addEventListener('ended', function () {
                hasStarted = false;
                video.currentTime = 0;
                player.classList.remove('playing', 'paused');
                overlay.classList.remove('hidden');
                controls.style.opacity = '0';
                progressBar.style.width = '0%';
                syncIcons();
            });
        })();

        (async function init() {
            const url = new URL(window.location.href);
            let token = (url.searchParams.get('t') || url.searchParams.get('token') || '').trim();
            const preview = url.searchParams.get('preview') === 'dev';

            if (preview) {
                document.getElementById('badge-label').textContent = '✓ INSCRIPTION CONFIRMÉE';
                const previewBanner = document.getElementById('dev-preview-banner');
                if (previewBanner) {
                    previewBanner.classList.add('visible');
                    document.body.style.paddingTop = `${previewBanner.offsetHeight}px`;
                }
                const sessionTokenPreview =
                    token && String(token).trim() ? String(token).trim() : PREVIEW_SESSION_ACCESS_TOKEN;
                mountConfirmation(
                    {
                        sessionStartsAt: PREVIEW_SESSION_START_ISO,
                        sessionEndsAt: PREVIEW_SESSION_END_ISO,
                        creneau: '20h',
                        subtitleText: PREVIEW_SUBTITLE,
                        whatsappLink: 'https://chat.whatsapp.com/PLACEHOLDER',
                        whatsappGroupNumber: 1,
                    },
                    { appleUid: 'preview-design@webinaire-es2.local', sessionAccessToken: sessionTokenPreview },
                );
                return;
            }

            if (!token) {
                token = (localStorage.getItem(TOKEN_KEY) || '').trim();
            }
            if (!token) {
                token = await requestTokenFromEmail();
            }
            if (!token || !token.trim()) {
                window.location.replace('/masterclass');
                return;
            }

            let res;
            try {
                res = await fetch(`/.netlify/functions/get-webinaire-registration?t=${encodeURIComponent(token.trim())}`);
            } catch (e) {
                window.location.replace('/masterclass');
                return;
            }

            if (!res.ok) {
                window.location.replace('/masterclass');
                return;
            }

            const data = await res.json();
            if (!data.valid || !data.sessionStartsAt || !data.sessionEndsAt) {
                window.location.replace('/masterclass');
                return;
            }

            const tk = token.trim();
            setTokenEverywhere(tk);

            async function pingWaiting() {
                try {
                    await fetch('/.netlify/functions/webinaire-presence', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ token: tk, stage: 'waiting' }),
                    });
                } catch {
                    /* ignore */
                }
            }
            pingWaiting();
            const waitingInterval = setInterval(pingWaiting, 20000);
            window.addEventListener('beforeunload', function () {
                clearInterval(waitingInterval);
            });

            mountConfirmation(
                {
                    sessionStartsAt: data.sessionStartsAt,
                    sessionEndsAt: data.sessionEndsAt,
                    creneau: data.creneau,
                    whatsappLink: data.whatsappLink || '',
                    whatsappGroupNumber: data.whatsappGroupNumber,
                },
                {
                    appleUid: `${token.trim()}@webinaire-es2.sonnycourt`,
                    sessionAccessToken: tk,
                },
            );
        })();
    </script>
    <script>document.documentElement.classList.add('ready');</script>
</body>
