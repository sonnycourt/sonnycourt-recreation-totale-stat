---
import GAConsentMode from '../../components/GAConsentMode.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Felicitation - Achat confirme</title>
    <meta name="description" content="Ton achat est confirme. Retrouve ici les prochaines etapes pour acceder a ton espace." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GAConsentMode />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #0a0a1a;
            --card: rgba(255, 255, 255, 0.05);
            --border: rgba(148, 163, 184, 0.2);
            --text: #f8fafc;
            --muted: rgba(226, 232, 240, 0.72);
            --accent: #60a5fa;
            --success: #22c55e;
        }

        body {
            font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: var(--text);
            background:
                radial-gradient(ellipse at 20% 0%, rgba(59, 130, 246, 0.22), transparent 50%),
                radial-gradient(ellipse at 80% 100%, rgba(34, 197, 94, 0.12), transparent 52%),
                linear-gradient(180deg, #0a0a1a 0%, #131833 45%, #0a0a1a 100%);
            min-height: 100vh;
        }

        .wrap {
            max-width: 760px;
            margin: 0 auto;
            padding: 36px 18px 54px;
            position: relative;
            z-index: 2;
        }

        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: clamp(24px, 4vw, 38px);
            backdrop-filter: blur(5px);
        }

        h1 {
            font-size: clamp(1.8rem, 4.8vw, 2.55rem);
            line-height: 1.16;
            font-weight: 800;
            margin-bottom: 16px;
            background: linear-gradient(135deg, #fff 0%, #cbd5e1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .lead {
            color: var(--muted);
            line-height: 1.65;
            margin-bottom: clamp(26px, 4vw, 34px);
            font-size: 1rem;
        }

        .steps-heading {
            font-size: 1.05rem;
            font-weight: 700;
            color: #fff;
            margin-top: clamp(8px, 2vw, 14px);
            margin-bottom: 16px;
        }

        .steps {
            list-style: none;
            display: grid;
            gap: 12px;
            margin-bottom: clamp(30px, 5vw, 42px);
        }

        .step-item {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            background: rgba(15, 23, 42, 0.46);
            border: 1px solid rgba(148, 163, 184, 0.1);
            border-radius: 14px;
            padding: 14px;
        }

        .step-num {
            flex-shrink: 0;
            width: 34px;
            height: 34px;
            border-radius: 999px;
            background: rgba(59, 130, 246, 0.12);
            border: 1px solid rgba(59, 130, 246, 0.28);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #60a5fa;
            margin-top: 1px;
        }

        .step-num svg {
            width: 16px;
            height: 16px;
        }

        .step-content {
            flex: 1;
            min-width: 0;
        }

        .step-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 3px;
            line-height: 1.3;
        }

        .step-text {
            font-size: 0.88rem;
            color: var(--muted);
            line-height: 1.55;
        }

        .video-placeholder {
            margin-bottom: 8px;
            border-radius: 14px;
            border: 1px solid rgba(148, 163, 184, 0.2);
            background: rgba(15, 23, 42, 0.55);
            aspect-ratio: 16 / 9;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: var(--muted);
            padding: 18px;
            line-height: 1.55;
        }

        .video-caption {
            text-align: center;
            font-size: 0.84rem;
            color: rgba(226, 232, 240, 0.72);
            margin-bottom: clamp(26px, 4vw, 36px);
        }

        .step-action {
            margin-top: 10px;
        }

        .btn-inline {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            border-radius: 10px;
            padding: 10px 14px;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 0.02em;
            text-transform: uppercase;
            color: #fff;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            box-shadow: 0 8px 22px rgba(59, 130, 246, 0.25);
        }

        .commitment {
            margin-bottom: clamp(30px, 5vw, 42px);
            border-radius: 14px;
            border: 1px solid rgba(96, 165, 250, 0.22);
            background: rgba(15, 23, 42, 0.62);
            padding: 18px;
        }

        .section-subtitle {
            font-size: 1rem;
            margin-top: clamp(6px, 2vw, 12px);
            margin-bottom: 14px;
            color: #fff;
            font-weight: 700;
        }

        .commitment p {
            color: var(--muted);
            line-height: 1.5;
            margin-bottom: 10px;
            font-style: italic;
        }

        .signature {
            color: #bfdbfe;
            font-weight: 600;
            margin-top: 8px;
        }

        .pioneers {
            margin-bottom: clamp(30px, 5vw, 40px);
            text-align: center;
        }

        .pioneers h3 {
            font-size: 1.08rem;
            color: #fff;
            margin-bottom: 8px;
        }

        .pioneers p {
            color: rgba(226, 232, 240, 0.82);
            line-height: 1.6;
        }

        .cta-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin-bottom: clamp(24px, 4vw, 34px);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            border-radius: 10px;
            padding: 12px 16px;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 0.02em;
            border: 1px solid transparent;
        }

        .btn-primary {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: #fff;
            box-shadow: 0 12px 28px rgba(59, 130, 246, 0.28);
        }

        .btn-secondary {
            background: rgba(59, 130, 246, 0.08);
            border-color: rgba(96, 165, 250, 0.35);
            color: #bfdbfe;
        }

        .support-note {
            text-align: center;
            font-size: 0.78rem;
            color: rgba(226, 232, 240, 0.6);
        }

        .confetti-canvas {
            position: fixed;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }
    </style>
</head>
<body>
    <canvas id="confetti-canvas" class="confetti-canvas" aria-hidden="true"></canvas>
    <main class="wrap">
        <section class="card">
            <h1>Bienvenue dans<br />Esprit Subconscient 2.0</h1>
            <p class="lead">
                Tu viens de prendre une décision importante. Cette décision est la preuve que tu crois en ton avenir et que tu as déjà en toi tout ce qu'il faut pour y arriver.<br />Sinon, tu ne te serais pas inscrit.
            </p>

            <div class="video-placeholder">
                Video de bienvenue (placeholder) — intègre ici le player Loom/Vimeo/YouTube.
            </div>
            <p class="video-caption">Un mot personnel avant que tu commences ↑</p>

            <p class="steps-heading">Pour bien commencer ta transformation</p>
            <ul class="steps">
                <li class="step-item">
                    <span class="step-num" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><path d="M7 11V8a5 5 0 0 1 10 0v3"></path></svg>
                    </span>
                    <div class="step-content">
                        <p class="step-title">Crée ton espace personnel sur Volt</p>
                        <p class="step-text">Inscription en moins d'une minute. Tu accèdes immédiatement à ta formation et à la communauté Volt. Ton nouvel environnement de transformation.</p>
                    </div>
                </li>
                <li class="step-item">
                    <span class="step-num" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M15 10l4.553 -2.276a1 1 0 0 1 1.447 .894v6.764a1 1 0 0 1 -1.447 .894l-4.553 -2.276v-4" /><path d="M3 8a2 2 0 0 1 2 -2h8a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-8a2 2 0 0 1 -2 -2l0 -8" /></svg>
                    </span>
                    <div class="step-content">
                        <p class="step-title">Regarde la vidéo de bienvenue sur Volt</p>
                        <p class="step-text">Une fois connecté, je t'explique comment naviguer dans la communauté Volt et comment tirer le meilleur de ta formation.</p>
                    </div>
                </li>
                <li class="step-item">
                    <span class="step-num" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"></rect><path d="M8 2v4M16 2v4M3 10h18"></path></svg>
                    </span>
                    <div class="step-content">
                        <p class="step-title">Connecte-toi chaque jour pendant 30 jours</p>
                        <p class="step-text">Une nouvelle leçon se débloque automatiquement tous les jours. Prends 15 minutes par jour. C'est cette régularité qui crée la vraie transformation.</p>
                    </div>
                </li>
                <li class="step-item">
                    <span class="step-num" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
                    </span>
                    <div class="step-content">
                        <p class="step-title">Vérifie ta boîte email</p>
                        <p class="step-text">Tu vas recevoir ta facture dans les prochaines minutes. Ajoute mon adresse à tes contacts pour ne rien manquer des prochains messages.</p>
                    </div>
                </li>
            </ul>

            <h3 class="section-subtitle">Mon engagement personnel envers toi</h3>
            <section class="commitment">
                <p>Pendant les 30 prochains jours, je te guide jour après jour via le contenu de la formation. Au jour 30, je viens vérifier personnellement où tu en es et te donner un feedback adapté à ta situation.</p>
                <p>On avance ensemble.</p>
                <p class="signature">Sonny</p>
            </section>

            <section class="pioneers">
                <h3>Tu viens de rejoindre un mouvement !</h3>
                <p>Mes accompagnements ont déjà transformé la vie de plus de 10 000 personnes.<br />Esprit Subconscient 2.0 est l'aboutissement de 10 ans de travail. Le système le plus complet et le plus puissant que j'aie jamais créé.</p>
            </section>

            <div class="cta-row">
                <a class="btn btn-primary" href="/masterclass/session">Créer mon compte</a>
            </div>
            <p class="support-note">Pour toute question, mon équipe est joignable à support@sonnycourt.com.</p>
        </section>
    </main>
    <script>
        (function () {
            if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

            const canvas = document.getElementById('confetti-canvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();

            const colors = ['#60a5fa', '#93c5fd', '#22c55e', '#f8fafc', '#f59e0b'];
            const pieces = [];
            const count = Math.min(200, Math.max(100, Math.floor(window.innerWidth / 8)));
            const gravity = 0.11;
            const drag = 0.992;
            const duration = 4200;
            const start = performance.now();

            for (let i = 0; i < count; i++) {
                const side = i % 2 === 0 ? -1 : 1;
                pieces.push({
                    x: side < 0 ? -20 - Math.random() * 60 : canvas.width + 20 + Math.random() * 60,
                    y: Math.random() * canvas.height * 0.45,
                    vx: side < 0 ? 2.2 + Math.random() * 4 : -2.2 - Math.random() * 4,
                    vy: -1.6 + Math.random() * 2.1,
                    size: 3 + Math.random() * 6,
                    rot: Math.random() * Math.PI,
                    vr: (Math.random() - 0.5) * 0.25,
                    life: 0.85 + Math.random() * 0.95,
                    color: colors[(Math.random() * colors.length) | 0],
                });
            }

            const topRain = Math.min(120, Math.max(70, Math.floor(window.innerWidth / 10)));
            for (let i = 0; i < topRain; i++) {
                pieces.push({
                    x: Math.random() * canvas.width,
                    y: -20 - Math.random() * 220,
                    vx: (Math.random() - 0.5) * 1.1,
                    vy: 1.7 + Math.random() * 2.4,
                    size: 3 + Math.random() * 5.5,
                    rot: Math.random() * Math.PI,
                    vr: (Math.random() - 0.5) * 0.22,
                    life: 0.95 + Math.random() * 1.1,
                    color: colors[(Math.random() * colors.length) | 0],
                });
            }

            function frame(now) {
                const elapsed = now - start;
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                for (let i = 0; i < pieces.length; i++) {
                    const p = pieces[i];
                    p.vx *= drag;
                    p.vy = p.vy * drag + gravity;
                    p.x += p.vx;
                    p.y += p.vy;
                    p.rot += p.vr;
                    p.life -= 0.0058;
                    if (p.life <= 0 || p.y > canvas.height + 40) continue;

                    ctx.save();
                    ctx.translate(p.x, p.y);
                    ctx.rotate(p.rot);
                    ctx.globalAlpha = Math.max(0, p.life);
                    ctx.fillStyle = p.color;
                    ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.64);
                    ctx.restore();
                }

                if (elapsed < duration) requestAnimationFrame(frame);
                else ctx.clearRect(0, 0, canvas.width, canvas.height);
            }

            window.addEventListener('resize', resize);
            requestAnimationFrame(frame);
        })();
    </script>
</body>
</html>
