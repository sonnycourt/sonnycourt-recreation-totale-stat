---
import '../../styles/admin-es2.css';

const tabs = [
  { id: 'overview', label: "Vue d'ensemble" },
  { id: 'funnel', label: 'Funnel' },
  { id: 'behavior', label: 'Comportement utilisateur' },
  { id: 'content', label: 'Contenu' },
  { id: 'ops', label: 'Ops / Debug' },
  { id: 'health', label: 'Santé client' },
];
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Dashboard admin — ES2</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <div id="gate" class="min-h-screen flex items-center justify-center text-slate-400 text-sm">Vérification…</div>

    <div id="app" class="hidden min-h-screen flex flex-col md:flex-row">
      <aside class="w-full md:w-56 shrink-0 border-b md:border-b-0 md:border-r border-slate-800 bg-slate-900/80 p-4 md:min-h-screen">
        <div class="mb-6 flex items-center justify-between md:block">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Admin</span>
        </div>
        <nav class="flex flex-row flex-wrap gap-1 md:flex-col md:gap-0.5" id="nav" aria-label="Sections">
          {tabs.map((t, i) => (
            <button
              type="button"
              class:list={[
                'tab-btn rounded-md px-3 py-2 text-left text-sm font-medium transition md:w-full',
                i === 0 ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200',
              ]}
              data-tab={t.id}
            >
              {t.label}
            </button>
          ))}
        </nav>
      </aside>

      <div class="flex min-h-0 flex-1 flex-col">
        <header class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-800 bg-slate-950/90 px-4 py-3 md:px-6">
          <h1 class="text-sm font-semibold text-slate-300 md:text-base" id="panel-title">{tabs[0].label}</h1>
          <div class="flex items-center gap-2">
            <button
              type="button"
              id="pwd-btn"
              class="rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-300 transition hover:border-slate-500 hover:text-white"
            >
              Mot de passe
            </button>
            <button
              type="button"
              id="logout-btn"
              class="rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-300 transition hover:border-slate-500 hover:text-white"
            >
              Se déconnecter
            </button>
          </div>
        </header>

        <main class="flex-1 p-4 md:p-8">
          {tabs.map((t, i) => (
            <section
              class:list={['tab-panel', i === 0 ? '' : 'hidden']}
              data-panel={t.id}
              role="tabpanel"
            >
              {t.id === 'overview' ? (
                <div class="space-y-4" id="overview-kpis">
                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                      <div>
                        <p class="text-xs uppercase tracking-wider text-slate-500">Vue d'ensemble</p>
                        <h3 class="text-sm font-semibold text-white">KPIs Funnel ES 2.0</h3>
                      </div>
                      <div class="flex items-center gap-2">
                        <label for="overview-session-select" class="text-xs text-slate-400">Session</label>
                        <select
                          id="overview-session-select"
                          class="rounded-md border border-slate-700 bg-slate-950 px-2 py-1 text-xs text-slate-200 focus:border-blue-500 focus:outline-none"
                        >
                          <option value="">Toutes sessions</option>
                        </select>
                        <button id="overview-refresh" type="button" class="rounded-md border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-200 hover:border-slate-500">
                          Actualiser
                        </button>
                        <span id="overview-updated" class="text-xs text-slate-500">—</span>
                      </div>
                    </div>
                  </div>

                  <div id="overview-hero" class="sticky top-0 z-20 -mx-4 px-4 md:-mx-8 md:px-8 py-3 backdrop-blur bg-slate-950/85 border-b border-slate-800">
                    <div class="flex flex-wrap items-baseline justify-between gap-3 gap-y-2">
                      <div class="flex flex-wrap items-baseline gap-3">
                        <p id="hero-title" class="text-sm font-semibold text-white">Toutes sessions</p>
                        <p id="hero-comparison" class="text-[11px] text-slate-500">—</p>
                      </div>
                      <div class="flex flex-wrap items-baseline gap-x-5 gap-y-1 text-xs">
                        <div class="flex items-baseline gap-1.5">
                          <span class="text-slate-500">Inscrits</span>
                          <span id="hero-inscrits" class="font-semibold text-white">0</span>
                          <span id="hero-inscrits-delta" class="text-slate-500"></span>
                        </div>
                        <div class="flex items-baseline gap-1.5">
                          <span class="text-slate-500">Présents</span>
                          <span id="hero-presents" class="font-semibold text-white">0</span>
                          <span id="hero-presents-delta" class="text-slate-500"></span>
                        </div>
                        <div class="flex items-baseline gap-1.5">
                          <span class="text-slate-500">Conv</span>
                          <span id="hero-conv" class="font-semibold text-white">0%</span>
                          <span id="hero-conv-delta" class="text-slate-500"></span>
                        </div>
                        <div class="flex items-baseline gap-1.5">
                          <span class="text-slate-500">Revenus</span>
                          <span id="hero-revenue" class="font-semibold text-white">0 €</span>
                          <span id="hero-revenue-delta" class="text-slate-500"></span>
                        </div>
                        <div class="flex items-baseline gap-1.5">
                          <span class="text-slate-500">€/lead</span>
                          <span id="hero-vpl" class="font-semibold text-white">0 €</span>
                          <span id="hero-vpl-delta" class="text-slate-500"></span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div id="overview-spiffy-warning" class="hidden rounded-xl border border-amber-500/40 bg-amber-500/10 p-3 text-xs text-amber-200">
                    ⏳ Sync Spiffy en cours pour cette session. Le webhook peut prendre 5-30 min — les acheteurs apparaîtront dès la prochaine synchro. Vérifiez Spiffy directement si urgent.
                  </div>

                  <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Inscrits</p>
                      <p id="kpi-inscrits" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Présents (live)</p>
                      <p id="kpi-presents" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Présents (replay)</p>
                      <p id="kpi-presents-replay" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Taux de présence (live)</p>
                      <p id="kpi-presence-rate" class="mt-1 text-2xl font-semibold text-white">0%</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Ont vu l'offre</p>
                      <p id="kpi-saw-offer" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Ont cliqué CTA</p>
                      <p id="kpi-clicked-cta" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Taux conversion CTA</p>
                      <p id="kpi-cta-rate" class="mt-1 text-2xl font-semibold text-white">0%</p>
                    </div>
                  </div>

                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <p class="text-xs uppercase tracking-wider text-slate-500">Funnel visuel</p>
                    <p class="mt-1 text-xs text-slate-500">Taux inter-étapes (vs étape précédente). Couleur : <span class="text-emerald-400">vert</span> au-dessus du benchmark, <span class="text-amber-400">jaune</span> dans la norme, <span class="text-red-400">rouge</span> en dessous.</p>
                    <div id="overview-funnel" class="mt-3 space-y-1"></div>
                  </div>

                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <p class="text-xs uppercase tracking-wider text-slate-500">Performance financière</p>
                    <p class="mt-1 text-xs text-slate-500">
                      Prix de référence : <span id="kpi-offer-price" class="text-slate-300">1 997 €</span> par acheteur. Comparaison global vs pays riches (France, Belgique, Suisse, Canada, Luxembourg, Monaco, Allemagne).
                    </p>
                    <div class="mt-3 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                      <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                        <p class="text-xs text-slate-500">Taux conversion global</p>
                        <p id="kpi-conv-global" class="mt-1 text-2xl font-semibold text-white">0%</p>
                        <p id="kpi-conv-global-detail" class="mt-1 text-xs text-slate-500">— / —</p>
                      </div>
                      <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                        <p class="text-xs text-slate-500">Taux conversion pays riches</p>
                        <p id="kpi-conv-rich" class="mt-1 text-2xl font-semibold text-white">0%</p>
                        <p id="kpi-conv-rich-detail" class="mt-1 text-xs text-slate-500">— / —</p>
                      </div>
                      <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                        <p class="text-xs text-slate-500">Valeur / lead global</p>
                        <p id="kpi-vpl-global" class="mt-1 text-2xl font-semibold text-white">0 €</p>
                        <p id="kpi-vpl-global-detail" class="mt-1 text-xs text-slate-500">— € / —</p>
                      </div>
                      <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                        <p class="text-xs text-slate-500">Valeur / lead pays riches</p>
                        <p id="kpi-vpl-rich" class="mt-1 text-2xl font-semibold text-white">0 €</p>
                        <p id="kpi-vpl-rich-detail" class="mt-1 text-xs text-slate-500">— € / —</p>
                      </div>
                    </div>
                  </div>

                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <p class="text-xs uppercase tracking-wider text-slate-500">Rétention vidéo</p>
                    <p class="mt-1 text-xs text-slate-500">Nombre de personnes ayant atteint chaque minute (cumulatif). Bleu = pays riches · gris = autres. <span class="text-red-400">●</span> Apparition CTA.</p>
                    <div id="overview-retention" class="mt-3 space-y-2"></div>
                  </div>

                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <p class="text-xs uppercase tracking-wider text-slate-500">Segmentation pays</p>
                    <p class="mt-1 text-xs text-slate-500">
                      Pays « riches » : France, Belgique, Suisse, Canada, Luxembourg, Monaco, Allemagne. Métriques détaillées (vu offre, CTA, PdV) → voir le funnel.
                    </p>
                    <div class="mt-3 overflow-x-auto">
                      <table class="w-full min-w-[480px] border-collapse text-left text-xs text-slate-300">
                        <thead>
                          <tr class="border-b border-slate-700 text-slate-500">
                            <th class="py-2 pr-4 font-medium">Segment</th>
                            <th class="py-2 pr-4 font-medium">Inscrits</th>
                            <th class="py-2 pr-4 font-medium">Engagés</th>
                            <th class="py-2 pr-4 font-medium">Acheteurs</th>
                            <th class="py-2 pr-4 font-medium">€ / lead</th>
                          </tr>
                        </thead>
                        <tbody id="overview-country-segments"></tbody>
                      </table>
                    </div>
                  </div>

                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <p class="text-xs uppercase tracking-wider text-slate-500">Live vs Replay</p>
                    <div class="mt-3 overflow-x-auto">
                      <table class="w-full min-w-[480px] border-collapse text-left text-xs text-slate-300">
                        <thead>
                          <tr class="border-b border-slate-700 text-slate-500">
                            <th class="py-2 pr-4 font-medium">Segment</th>
                            <th class="py-2 pr-4 font-medium">Live only</th>
                            <th class="py-2 pr-4 font-medium">Replay only</th>
                            <th class="py-2 pr-4 font-medium">Live + Replay</th>
                            <th class="py-2 pr-4 font-medium">Total engagés</th>
                          </tr>
                        </thead>
                        <tbody id="overview-livereplay"></tbody>
                      </table>
                    </div>
                  </div>

                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <p class="text-xs uppercase tracking-wider text-slate-500">Détail acheteurs</p>
                    <p class="mt-1 text-xs text-slate-500">Triés par dernier événement (plus récent en haut).</p>
                    <div class="mt-3 overflow-x-auto">
                      <table class="w-full min-w-[760px] border-collapse text-left text-xs text-slate-300">
                        <thead>
                          <tr class="border-b border-slate-700 text-slate-500">
                            <th class="py-2 pr-4 font-medium">Prénom</th>
                            <th class="py-2 pr-4 font-medium">Pays</th>
                            <th class="py-2 pr-4 font-medium">Mode</th>
                            <th class="py-2 pr-4 font-medium">Min vue</th>
                            <th class="py-2 pr-4 font-medium">CTA</th>
                            <th class="py-2 pr-4 font-medium">PdV</th>
                            <th class="py-2 pr-4 font-medium">Dernier event</th>
                          </tr>
                        </thead>
                        <tbody id="overview-buyer-details"></tbody>
                      </table>
                    </div>
                  </div>

                  <p id="overview-error" class="hidden text-xs text-red-400"></p>
                </div>
              ) : t.id === 'ops' ? (
                <div class="space-y-4" id="ops-cockpit">
                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                      <div>
                        <p class="text-xs uppercase tracking-wider text-slate-500">Cockpit live</p>
                        <h3 class="text-sm font-semibold text-white">Surveillance diffusion ES2</h3>
                      </div>
                      <div class="flex items-center gap-2">
                        <button id="ops-refresh" type="button" class="rounded-md border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-200 hover:border-slate-500">Actualiser</button>
                        <span id="ops-updated" class="text-xs text-slate-500">—</span>
                      </div>
                    </div>
                  </div>

                  <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">En attente (live)</p>
                      <p id="ops-waiting" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">En session (live)</p>
                      <p id="ops-session" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">En replay (live)</p>
                      <p id="ops-replay" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                      <p class="text-xs text-slate-500">Actifs totaux</p>
                      <p id="ops-total" class="mt-1 text-2xl font-semibold text-white">0</p>
                    </div>
                  </div>

                  <div class="grid gap-3 xl:grid-cols-2">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-3">
                      <p class="text-xs uppercase tracking-wider text-slate-500">Santé vidéo</p>
                      <p class="text-xs text-slate-400">Source active: <span id="ops-source" class="font-semibold text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400 break-all">URL active: <span id="ops-url" class="text-slate-300">—</span></p>
                      <div class="space-y-1 text-xs text-slate-400">
                        <p>Check active: <span id="ops-check-active">—</span></p>
                        <p>Check primary: <span id="ops-check-primary">—</span></p>
                        <p>Check backup: <span id="ops-check-backup">—</span></p>
                      </div>
                      <div class="flex flex-wrap gap-2 pt-1">
                        <button id="ops-switch-primary" type="button" class="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-500">Passer en Primary</button>
                        <button id="ops-switch-backup" type="button" class="rounded-md border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-200 hover:border-slate-500">Passer en Backup</button>
                        <button id="ops-clear-override" type="button" class="rounded-md border border-slate-700 px-3 py-1.5 text-xs font-medium text-slate-300 hover:border-slate-500">Reset</button>
                        <button id="ops-seek-live-offset" type="button" class="rounded-md border border-amber-500/60 bg-amber-500/10 px-3 py-1.5 text-xs font-semibold text-amber-200 hover:border-amber-400">
                          Seek live offset
                        </button>
                      </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-2">
                      <p class="text-xs uppercase tracking-wider text-slate-500">Session courante</p>
                      <p class="text-xs text-slate-400">Heure UTC: <span id="ops-now-utc" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Heure Paris: <span id="ops-now-paris" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Session: <span id="ops-session-date" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Expire: <span id="ops-expire-date" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Fenêtre live: <span id="ops-live-window" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">
                        Diffusion détectée:
                        <span id="ops-stream-state-badge" class="ml-1 inline-flex items-center gap-1 rounded-full border border-slate-700 px-2 py-0.5 text-[11px] text-slate-300">
                          <span id="ops-stream-dot" class="h-2 w-2 rounded-full bg-slate-500"></span>
                          <span id="ops-stream-state" class="text-slate-200">—</span>
                        </span>
                      </p>
                      <div class="rounded-lg border border-slate-800 bg-slate-950/70 p-2">
                        <video
                          id="ops-stream-thumb"
                          class="w-full max-w-[220px] rounded border border-slate-700 bg-black"
                          muted
                          playsinline
                          preload="metadata"
                        ></video>
                        <p class="mt-1 text-xs text-slate-400">Timing vidéo: <span id="ops-stream-second" class="text-slate-200">—</span></p>
                      </div>
                      <p class="text-xs text-slate-400">Lecteurs en play: <span id="ops-stream-playing" class="text-slate-200">0</span></p>
                      <div class="pt-2 text-xs text-slate-400">
                        <p>Inscrits: <span id="ops-pop-inscrit" class="text-slate-200">0</span></p>
                        <p>Présents: <span id="ops-pop-present" class="text-slate-200">0</span></p>
                        <p>Acheteurs: <span id="ops-pop-acheteur" class="text-slate-200">0</span></p>
                        <p>Non-acheteurs: <span id="ops-pop-nonacheteur" class="text-slate-200">0</span></p>
                      </div>
                    </div>
                  </div>

                  <div class="grid gap-3 xl:grid-cols-2">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-2">
                      <div class="flex items-center justify-between gap-2">
                        <p class="text-xs uppercase tracking-wider text-slate-500">Prochaine session</p>
                        <span id="ops-next-session-state" class="inline-flex items-center rounded-full border border-slate-700 px-2 py-0.5 text-[10px] uppercase tracking-wide text-slate-400">—</span>
                      </div>
                      <p class="text-xs text-slate-400">Session: <span id="ops-next-session-date" class="text-slate-200">—</span></p>
                      <p class="text-xs text-slate-400">Expire: <span id="ops-next-expire-date" class="text-slate-200">—</span></p>
                      <div class="pt-1 text-xs text-slate-400">
                        <p>Inscrits: <span id="ops-next-inscrit" class="text-slate-200">0</span></p>
                        <p>Présents: <span id="ops-next-present" class="text-slate-200">0</span></p>
                        <p>Acheteurs: <span id="ops-next-acheteur" class="text-slate-200">0</span></p>
                        <p>Non-acheteurs: <span id="ops-next-nonacheteur" class="text-slate-200">0</span></p>
                        <p>No-show: <span id="ops-next-noshow" class="text-slate-200">0</span></p>
                      </div>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-2">
                      <div class="flex flex-wrap items-center justify-between gap-2">
                        <p class="text-xs uppercase tracking-wider text-slate-500">Historique sessions</p>
                        <div class="flex flex-wrap gap-1">
                          <button type="button" class="ops-history-filter rounded border border-slate-700 px-2 py-0.5 text-[10px] text-slate-300" data-filter="all">Toutes</button>
                          <button type="button" class="ops-history-filter rounded border border-slate-700 px-2 py-0.5 text-[10px] text-slate-300" data-filter="upcoming">À venir</button>
                          <button type="button" class="ops-history-filter rounded border border-slate-700 px-2 py-0.5 text-[10px] text-slate-300" data-filter="live">En cours</button>
                          <button type="button" class="ops-history-filter rounded border border-slate-700 px-2 py-0.5 text-[10px] text-slate-300" data-filter="closed">Clôturées</button>
                        </div>
                      </div>
                      <input
                        id="ops-history-search"
                        type="search"
                        placeholder="Rechercher une date (ex: 17/04 ou 2026)"
                        class="w-full rounded border border-slate-700 bg-slate-950 px-2 py-1 text-xs text-slate-200 placeholder:text-slate-500 focus:border-blue-500 focus:outline-none"
                      />
                      <div id="ops-past-sessions" class="space-y-2 text-xs text-slate-300">
                        <p class="text-slate-500">Aucune session passée.</p>
                      </div>
                    </div>
                  </div>

                  <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 space-y-3">
                    <div>
                      <p class="text-xs uppercase tracking-wider text-slate-500">Action admin</p>
                      <h3 class="text-sm font-semibold text-white">Prolonger une offre</h3>
                    </div>
                    <form id="extend-offer-form" class="grid gap-3 md:grid-cols-[minmax(220px,1fr)_140px_auto] md:items-end">
                      <label class="block">
                        <span class="mb-1 block text-xs text-slate-400">Email du prospect</span>
                        <input
                          id="extend-offer-email"
                          type="email"
                          required
                          placeholder="prenom@email.com"
                          class="w-full rounded border border-slate-700 bg-slate-950 px-3 py-2 text-xs text-slate-100 placeholder:text-slate-500 focus:border-blue-500 focus:outline-none"
                        />
                      </label>
                      <label class="block">
                        <span class="mb-1 block text-xs text-slate-400">Heures à ajouter</span>
                        <input
                          id="extend-offer-hours"
                          type="number"
                          min="1"
                          step="1"
                          value="24"
                          required
                          class="w-full rounded border border-slate-700 bg-slate-950 px-3 py-2 text-xs text-slate-100 placeholder:text-slate-500 focus:border-blue-500 focus:outline-none"
                        />
                      </label>
                      <button
                        id="extend-offer-submit"
                        type="submit"
                        class="h-9 rounded-md bg-blue-600 px-3 text-xs font-semibold text-white transition hover:bg-blue-500 disabled:cursor-not-allowed disabled:opacity-60"
                      >
                        Prolonger
                      </button>
                    </form>
                    <p id="extend-offer-feedback" class="hidden text-xs"></p>
                  </div>

                  <p id="ops-error" class="hidden text-xs text-red-400"></p>
                </div>
              ) : (
                <p class="text-slate-500 text-sm">À venir</p>
              )}
            </section>
          ))}
        </main>
      </div>
    </div>

    <div
      id="pwd-modal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 px-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="pwd-modal-title"
    >
      <div class="w-full max-w-md rounded-xl border border-slate-700 bg-slate-900 p-6 shadow-xl">
        <h2 id="pwd-modal-title" class="text-base font-semibold text-white mb-1">Changer le mot de passe</h2>
        <p class="text-xs text-slate-500 mb-4">Minimum 12 caractères.</p>
        <form id="pwd-form" class="space-y-3">
          <input
            type="password"
            id="pwd-current"
            autocomplete="current-password"
            required
            class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
            placeholder="Mot de passe actuel"
          />
          <input
            type="password"
            id="pwd-new"
            autocomplete="new-password"
            required
            minlength="12"
            class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
            placeholder="Nouveau mot de passe"
          />
          <input
            type="password"
            id="pwd-confirm"
            autocomplete="new-password"
            required
            minlength="12"
            class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
            placeholder="Confirmer le nouveau"
          />
          <p id="pwd-modal-err" class="hidden text-sm text-red-400"></p>
          <p id="pwd-modal-ok" class="hidden text-sm text-emerald-400"></p>
          <div class="flex gap-2 justify-end pt-2">
            <button type="button" id="pwd-cancel" class="rounded-lg border border-slate-600 px-3 py-2 text-xs font-medium text-slate-300 hover:bg-slate-800">
              Annuler
            </button>
            <button type="submit" id="pwd-save" class="rounded-lg bg-blue-600 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-500">
              Enregistrer
            </button>
          </div>
        </form>
      </div>
    </div>

    <script define:vars={{ tabIds: tabs.map((t) => t.id), tabLabels: tabs.map((t) => t.label) }}>
      const gate = document.getElementById('gate');
      const app = document.getElementById('app');
      const titleEl = document.getElementById('panel-title');

      async function requireAuth() {
        try {
          const r = await fetch('/.netlify/functions/admin-es2-session', { credentials: 'same-origin' });
          if (!r.ok) throw new Error('unauth');
          const d = await r.json();
          if (!d.authenticated) throw new Error('unauth');
          gate.classList.add('hidden');
          app.classList.remove('hidden');
        } catch {
          window.location.replace('/es-cockpit/');
        }
      }

      const pwdModal = document.getElementById('pwd-modal');
      document.getElementById('pwd-btn').addEventListener('click', function () {
        pwdModal.classList.remove('hidden');
      });
      document.getElementById('pwd-cancel').addEventListener('click', function () {
        pwdModal.classList.add('hidden');
        document.getElementById('pwd-modal-err').classList.add('hidden');
      });
      pwdModal.addEventListener('click', function (e) {
        if (e.target === pwdModal) pwdModal.classList.add('hidden');
      });

      document.getElementById('pwd-form').addEventListener('submit', async function (e) {
        e.preventDefault();
        const errEl = document.getElementById('pwd-modal-err');
        const btn = document.getElementById('pwd-save');
        errEl.classList.add('hidden');
        errEl.textContent = '';
        btn.disabled = true;
        try {
          const r = await fetch('/.netlify/functions/admin-es2-change-password', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              currentPassword: document.getElementById('pwd-current').value,
              newPassword: document.getElementById('pwd-new').value,
              confirm: document.getElementById('pwd-confirm').value,
            }),
          });
          const d = await r.json().catch(function () { return {}; });
          if (r.ok) {
            document.getElementById('pwd-current').value = '';
            document.getElementById('pwd-new').value = '';
            document.getElementById('pwd-confirm').value = '';
            errEl.classList.add('hidden');
            const okEl = document.getElementById('pwd-modal-ok');
            okEl.textContent = 'Mot de passe mis à jour.';
            okEl.classList.remove('hidden');
            setTimeout(function () {
              okEl.classList.add('hidden');
              pwdModal.classList.add('hidden');
            }, 1200);
            return;
          }
          errEl.textContent = d.error || 'Erreur.';
          if (r.status === 429) errEl.textContent = 'Trop de tentatives. Réessaie plus tard.';
          if (r.status === 401) errEl.textContent = d.error || 'Session expirée. Reconnecte-toi.';
          errEl.classList.remove('hidden');
        } catch {
          errEl.textContent = 'Erreur réseau.';
          errEl.classList.remove('hidden');
        } finally {
          btn.disabled = false;
        }
      });

      document.getElementById('logout-btn').addEventListener('click', async function () {
        try {
          await fetch('/.netlify/functions/admin-es2-logout', { method: 'POST', credentials: 'same-origin' });
        } catch {
          /* ignore */
        }
        window.location.replace('/es-cockpit/');
      });

      document.querySelectorAll('.tab-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const id = btn.getAttribute('data-tab');
          document.querySelectorAll('.tab-btn').forEach(function (b) {
            b.classList.remove('bg-slate-800', 'text-white');
            b.classList.add('text-slate-400');
          });
          btn.classList.add('bg-slate-800', 'text-white');
          btn.classList.remove('text-slate-400');
          document.querySelectorAll('.tab-panel').forEach(function (p) {
            p.classList.toggle('hidden', p.getAttribute('data-panel') !== id);
          });
          const idx = tabIds.indexOf(id);
          if (idx >= 0) titleEl.textContent = tabLabels[idx];
          if (id === 'overview') refreshOverviewKpis();
          if (id === 'ops') startOpsPolling();
        });
      });

      let opsPollingTimer = null;
      let opsBusy = false;
      let overviewBusy = false;
      let overviewSessionsHydrated = false;
      let streamCounterTimer = null;
      let streamCounterBaseSecond = null;
      let streamCounterBaseAtMs = null;
      let streamCounterIsRunning = false;
      let streamThumbLoadedUrl = '';
      let opsHistoryFilter = 'all';
      let opsHistorySearch = '';
      let opsHistoryItems = [];

      function formatPct(value) {
        const n = Number(value);
        if (!Number.isFinite(n)) return '0%';
        if (n === 0) return '0%';
        if (n < 10) return `${(Math.round(n * 10) / 10).toFixed(1)}%`;
        return `${Math.round(n)}%`;
      }
      function formatEur(value) {
        const n = Number(value);
        if (!Number.isFinite(n)) return '0 €';
        return `${Math.round(n).toLocaleString('fr-FR')} €`;
      }

      function funnelGradient(index) {
        const palette = [
          'from-emerald-400 to-emerald-500',
          'from-emerald-400 to-lime-500',
          'from-lime-400 to-yellow-500',
          'from-yellow-400 to-amber-500',
          'from-amber-400 to-orange-500',
          'from-orange-400 to-red-500',
          'from-orange-500 to-red-600',
        ];
        return palette[index] || 'from-slate-400 to-slate-500';
      }

      function renderOverviewCountrySegments(segments, offerPriceEur) {
        const tbody = document.getElementById('overview-country-segments');
        if (!tbody) return;
        tbody.innerHTML = '';
        const list = Array.isArray(segments) ? segments : [];
        if (!list.length) {
          const tr = document.createElement('tr');
          tr.className = 'border-t border-slate-800';
          const td = document.createElement('td');
          td.colSpan = 5;
          td.className = 'py-3 text-slate-500';
          td.textContent = 'Aucune donnée.';
          tr.appendChild(td);
          tbody.appendChild(tr);
          return;
        }
        const price = Number(offerPriceEur || 0);
        for (const row of list) {
          const tr = document.createElement('tr');
          tr.className = 'border-t border-slate-800';
          const inscrits = Number(row?.inscrits || 0);
          const presents = Number(row?.presents || 0);
          const replay = Number(row?.watchedReplay || 0);
          // engagés = total ayant attended_live OU watched_replay (pas de dedup ici, donc max(presents+replay, presents))
          const engaged = Math.max(presents, replay);
          const acheteurs = Number(row?.acheteurs || 0);
          const vpl = inscrits > 0 ? (acheteurs * price) / inscrits : 0;
          const cells = [
            String(row?.segment || '—'),
            String(inscrits),
            String(engaged),
            String(acheteurs),
            formatEur(vpl),
          ];
          cells.forEach(function (text, i) {
            const td = document.createElement('td');
            td.className =
              i === 0 ? 'py-2.5 pr-4 font-medium text-slate-200' : 'py-2.5 pr-4 text-slate-300';
            td.textContent = text;
            tr.appendChild(td);
          });
          tbody.appendChild(tr);
        }
      }

      // Delta helpers ----------------------------------------------------
      function deltaCount(curr, prev) {
        const c = Number(curr); const p = Number(prev);
        if (!Number.isFinite(c) || !Number.isFinite(p) || p === 0) return null;
        return ((c - p) / p) * 100;
      }
      function deltaPctPoints(curr, prev) {
        const c = Number(curr); const p = Number(prev);
        if (!Number.isFinite(c) || !Number.isFinite(p)) return null;
        return c - p;
      }
      function deltaSpan(value, opts) {
        const o = opts || {};
        const suffix = o.suffix || '';
        if (value == null) return '<span class="text-slate-600 text-[11px]">—</span>';
        const v = Number(value);
        if (!Number.isFinite(v)) return '<span class="text-slate-600 text-[11px]">—</span>';
        const arrow = v > 0.05 ? '▲' : v < -0.05 ? '▼' : '·';
        const cls = v > 0.05 ? 'text-emerald-400' : v < -0.05 ? 'text-red-400' : 'text-slate-500';
        const formatted = Math.abs(v) < 10 ? v.toFixed(1) : Math.round(v).toString();
        const sign = v > 0 ? '+' : '';
        return `<span class="${cls} text-[11px] font-medium">${arrow} ${sign}${formatted}${suffix}</span>`;
      }

      function renderHeroStrip(d) {
        const cards = d?.cards || {};
        const prev = d?.previousSession?.cards || null;
        const filterDate = d?.filter?.session_date || '';
        const titleEl = document.getElementById('hero-title');
        const compareEl = document.getElementById('hero-comparison');
        if (titleEl) {
          titleEl.textContent = filterDate
            ? `Session ${new Date(filterDate + 'T00:00:00').toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' })}`
            : 'Toutes sessions';
        }
        if (compareEl) {
          if (!filterDate) {
            compareEl.textContent = 'Agrégat de toutes les sessions (deltas indisponibles)';
          } else if (d?.previousReason === 'session_test') {
            compareEl.textContent = 'Session de test (avant lancement) · pas de comparaison';
          } else if (d?.previousReason === 'first_real_session') {
            compareEl.textContent = 'Première session ES2 · pas de N-1 disponible';
          } else if (prev) {
            const prevDate = d?.previousSession?.sessionDate || '';
            const prevLabel = prevDate
              ? new Date(prevDate + 'T00:00:00').toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' })
              : '—';
            compareEl.textContent = `vs session du ${prevLabel}`;
          } else {
            compareEl.textContent = '—';
          }
        }

        const inscrits = Number(cards.inscrits || 0);
        const presentsTotal = Math.max(Number(cards.presents || 0), Number(cards.presentsReplay || 0));
        const conv = Number(cards.conversionGlobalRate || 0);
        const acheteurs = Number(cards.acheteurs || 0);
        const offerPrice = Number(cards.offerPriceEur || 0);
        const revenue = acheteurs * offerPrice;
        const vpl = Number(cards.valuePerLeadGlobal || 0);

        const setVal = function (id, txt) { const el = document.getElementById(id); if (el) el.textContent = txt; };
        const setHtml = function (id, html) { const el = document.getElementById(id); if (el) el.innerHTML = html; };

        setVal('hero-inscrits', inscrits.toLocaleString('fr-FR'));
        setVal('hero-presents', presentsTotal.toLocaleString('fr-FR'));
        setVal('hero-conv', formatPct(conv));
        setVal('hero-revenue', formatEur(revenue));
        setVal('hero-vpl', formatEur(vpl));

        const showDeltas = Boolean(prev);
        if (!showDeltas) {
          setHtml('hero-inscrits-delta', '');
          setHtml('hero-presents-delta', '');
          setHtml('hero-conv-delta', '');
          setHtml('hero-revenue-delta', '');
          setHtml('hero-vpl-delta', '');
          return;
        }
        const prevPresentsTotal = Math.max(Number(prev.presents || 0), Number(prev.presentsReplay || 0));
        const prevRevenue = Number(prev.acheteurs || 0) * Number(prev.offerPriceEur || offerPrice);
        setHtml('hero-inscrits-delta', deltaSpan(deltaCount(inscrits, prev.inscrits), { suffix: '%' }));
        setHtml('hero-presents-delta', deltaSpan(deltaCount(presentsTotal, prevPresentsTotal), { suffix: '%' }));
        setHtml('hero-conv-delta', deltaSpan(deltaPctPoints(conv, prev.conversionGlobalRate), { suffix: 'pts' }));
        setHtml('hero-revenue-delta', deltaSpan(deltaCount(revenue, prevRevenue), { suffix: '%' }));
        setHtml('hero-vpl-delta', deltaSpan(deltaCount(vpl, prev.valuePerLeadGlobal), { suffix: '%' }));
      }

      function benchmarkClass(stepRate, benchmark) {
        if (!Number.isFinite(stepRate) || !benchmark) return 'text-slate-300';
        const warn = Number(benchmark.warn);
        const good = Number(benchmark.good);
        if (!Number.isFinite(warn) || !Number.isFinite(good)) return 'text-slate-300';
        if (stepRate >= good) return 'text-emerald-400';
        if (stepRate >= warn) return 'text-amber-400';
        return 'text-red-400';
      }

      function buildFunnelBarHtml(label, count, percentVsInscrits, gradientClass) {
        const pct = Math.max(0, Math.min(100, Number(percentVsInscrits || 0)));
        return `
          <div class="grid grid-cols-[120px_1fr_auto] items-center gap-3 text-xs">
            <p class="text-slate-300">${label}</p>
            <div class="h-3 w-full overflow-hidden rounded-full bg-slate-800">
              <div class="h-3 rounded-full bg-gradient-to-r ${gradientClass}" style="width:${pct}%"></div>
            </div>
            <p class="text-slate-300">${Math.round(pct)}% <span class="text-slate-500">(${Number(count || 0)})</span></p>
          </div>`;
      }

      function renderOverviewFunnel(items, totalInscrits) {
        const root = document.getElementById('overview-funnel');
        if (!root) return;
        root.innerHTML = '';
        const list = Array.isArray(items) ? items : [];
        if (!list.length) {
          const empty = document.createElement('p');
          empty.className = 'text-xs text-slate-500';
          empty.textContent = 'Aucune donnée disponible.';
          root.appendChild(empty);
          return;
        }
        const inscrits = Number(totalInscrits || 0);
        list.forEach(function (item, idx) {
          if (idx > 0) {
            const arrow = document.createElement('div');
            const stepRate = Number.isFinite(Number(item?.stepRate)) ? Number(item.stepRate) : null;
            const cls = benchmarkClass(stepRate, item?.benchmark);
            const benchHint = item?.benchmark
              ? ` <span class="text-slate-600">[norme ${item.benchmark.warn}-${item.benchmark.good}%]</span>`
              : '';
            arrow.className = 'grid grid-cols-[120px_1fr_auto] items-center gap-3 text-[11px]';
            arrow.innerHTML = `
              <p class="text-slate-600 text-right pr-2">↓</p>
              <p class="${cls} font-medium">${stepRate == null ? '—' : `${stepRate.toFixed(1)}%`}${benchHint}</p>
              <p class="text-slate-600"></p>
            `;
            root.appendChild(arrow);
          }
          if (item?.split) {
            const livePct = inscrits > 0 ? (Number(item.split.live || 0) / inscrits) * 100 : 0;
            const replayPct = inscrits > 0 ? (Number(item.split.replay || 0) / inscrits) * 100 : 0;
            const wrap = document.createElement('div');
            wrap.className = 'space-y-1';
            wrap.innerHTML =
              buildFunnelBarHtml(`${item.label} (live)`, item.split.live, livePct, 'from-blue-400 to-blue-500') +
              buildFunnelBarHtml(`${item.label} (replay)`, item.split.replay, replayPct, 'from-slate-400 to-slate-500');
            root.appendChild(wrap);
          } else {
            const row = document.createElement('div');
            row.innerHTML = buildFunnelBarHtml(item?.label || '—', item?.count, item?.percent, funnelGradient(idx));
            root.appendChild(row.firstElementChild);
          }
        });
      }

      function renderRetention(items, ctaAppearMinute) {
        const root = document.getElementById('overview-retention');
        if (!root) return;
        root.innerHTML = '';
        const list = Array.isArray(items) ? items : [];
        if (!list.length || list.every(function (it) { return Number(it?.total || 0) === 0; })) {
          const empty = document.createElement('p');
          empty.className = 'text-xs text-slate-500';
          empty.textContent = 'En attente des premières données vidéo (les checkpoints se remplissent en cours de session).';
          root.appendChild(empty);
          return;
        }
        const maxTotal = list.reduce(function (acc, item) {
          return Math.max(acc, Number(item?.total || 0));
        }, 0) || 1;
        const ctaMin = Number(ctaAppearMinute);
        const ctaMarkerInserted = { done: false };
        list.forEach(function (item, idx) {
          // Insert CTA marker just before the first checkpoint >= CTA appear minute
          const minute = Number(item?.minute || 0);
          if (Number.isFinite(ctaMin) && !ctaMarkerInserted.done && minute >= ctaMin) {
            const prev = list[idx - 1];
            let dropLabel = '';
            if (prev) {
              const richDrop = prev.richBase > 0
                ? Math.round(((Number(prev.rich || 0) - Number(item.rich || 0)) / prev.richBase) * 100)
                : null;
              const otherDrop = prev.otherBase > 0
                ? Math.round(((Number(prev.other || 0) - Number(item.other || 0)) / prev.otherBase) * 100)
                : null;
              if (richDrop != null || otherDrop != null) {
                dropLabel = ` · drop ${richDrop ?? '—'}% riches / ${otherDrop ?? '—'}% autres`;
              }
            }
            const marker = document.createElement('div');
            marker.className = 'grid grid-cols-[64px_1fr_auto] items-center gap-3 text-[11px] py-1 border-y border-red-500/30 bg-red-500/5';
            marker.innerHTML = `
              <p class="text-red-400 tabular-nums font-semibold">${ctaMin} min</p>
              <p class="text-red-300 font-medium">→ Apparition CTA${dropLabel}</p>
              <p class="text-slate-500"></p>
            `;
            root.appendChild(marker);
            ctaMarkerInserted.done = true;
          }
          const rich = Math.max(0, Number(item?.rich || 0));
          const other = Math.max(0, Number(item?.other || 0));
          const total = rich + other;
          const richBase = Math.max(0, Number(item?.richBase || 0));
          const otherBase = Math.max(0, Number(item?.otherBase || 0));
          const richPctOfBase = richBase > 0 ? Math.round((rich / richBase) * 100) : 0;
          const otherPctOfBase = otherBase > 0 ? Math.round((other / otherBase) * 100) : 0;
          const richWidth = (rich / maxTotal) * 100;
          const otherWidth = (other / maxTotal) * 100;
          const row = document.createElement('div');
          row.className = 'grid grid-cols-[64px_1fr_auto] items-center gap-3 text-xs';
          row.innerHTML = `
            <p class="text-slate-300 tabular-nums">${item.minute} min</p>
            <div class="h-3 w-full overflow-hidden rounded-full bg-slate-800 flex">
              <div class="h-3 bg-blue-500" style="width:${richWidth}%" title="Pays riches: ${rich} (${richPctOfBase}% de ${richBase})"></div>
              <div class="h-3 bg-slate-500" style="width:${otherWidth}%" title="Autres: ${other} (${otherPctOfBase}% de ${otherBase})"></div>
            </div>
            <p class="text-slate-300 tabular-nums">${total} <span class="text-slate-500">(${richPctOfBase}%/${otherPctOfBase}%)</span></p>
          `;
          root.appendChild(row);
        });
      }

      function renderLiveReplay(liveReplay) {
        const tbody = document.getElementById('overview-livereplay');
        if (!tbody) return;
        tbody.innerHTML = '';
        const rows = [
          { segment: 'Pays riches', d: liveReplay?.rich },
          { segment: 'Autres', d: liveReplay?.other },
          { segment: 'Total', d: liveReplay?.total },
        ];
        rows.forEach(function (row) {
          const tr = document.createElement('tr');
          tr.className = 'border-t border-slate-800';
          const d = row.d || {};
          const cells = [
            row.segment,
            String(d.liveOnly || 0),
            String(d.replayOnly || 0),
            String(d.liveAndReplay || 0),
            String(d.engaged || 0),
          ];
          cells.forEach(function (text, i) {
            const td = document.createElement('td');
            td.className =
              i === 0 ? 'py-2.5 pr-4 font-medium text-slate-200' : 'py-2.5 pr-4 text-slate-300';
            td.textContent = text;
            tr.appendChild(td);
          });
          tbody.appendChild(tr);
        });
      }

      function renderBuyerDetails(items, opts) {
        const tbody = document.getElementById('overview-buyer-details');
        if (!tbody) return;
        tbody.innerHTML = '';
        const list = Array.isArray(items) ? items : [];
        if (!list.length) {
          const tr = document.createElement('tr');
          tr.className = 'border-t border-slate-800';
          const td = document.createElement('td');
          td.colSpan = 7;
          td.className = 'py-3 text-slate-500';
          td.textContent = opts && opts.spiffyPending
            ? '⏳ Sync Spiffy en cours — les acheteurs s\'afficheront dès la prochaine synchro (5-30 min).'
            : 'Aucun acheteur pour cette session.';
          tr.appendChild(td);
          tbody.appendChild(tr);
          return;
        }
        list.forEach(function (b) {
          const tr = document.createElement('tr');
          tr.className = 'border-t border-slate-800';
          const mode =
            b.attendedLive && b.watchedReplay
              ? 'Live + Replay'
              : b.attendedLive
                ? 'Live'
                : b.watchedReplay
                  ? 'Replay'
                  : '—';
          const cells = [
            b.prenom || '—',
            (b.pays || '—') + (b.isRich ? ' ★' : ''),
            mode,
            String(b.watchMaxMinutes || 0),
            b.clickedCta ? 'oui' : 'non',
            b.visitedSales ? 'oui' : 'non',
            b.lastEventAt ? new Date(b.lastEventAt).toLocaleString('fr-FR', { timeZone: 'Europe/Paris' }) : '—',
          ];
          cells.forEach(function (text, i) {
            const td = document.createElement('td');
            td.className =
              i === 0 ? 'py-2.5 pr-4 font-medium text-slate-200' : 'py-2.5 pr-4 text-slate-300';
            td.textContent = text;
            tr.appendChild(td);
          });
          tbody.appendChild(tr);
        });
      }

      function renderSpiffyWarning(d) {
        const banner = document.getElementById('overview-spiffy-warning');
        if (!banner) return;
        const acheteurs = Number(d?.cards?.acheteurs || 0);
        const filterDate = d?.filter?.session_date || '';
        let show = false;
        if (acheteurs === 0 && filterDate) {
          const sessionMs = Date.parse(`${filterDate}T20:00:00+02:00`);
          if (Number.isFinite(sessionMs) && Date.now() - sessionMs > 30 * 60 * 1000) {
            show = true;
          }
        }
        banner.classList.toggle('hidden', !show);
      }

      function colorByConvBenchmark(el, rate) {
        if (!el) return;
        el.classList.remove('text-emerald-400', 'text-amber-400', 'text-red-400', 'text-white');
        if (!Number.isFinite(rate) || rate === 0) {
          el.classList.add('text-white');
          return;
        }
        if (rate >= 5) el.classList.add('text-emerald-400');
        else if (rate >= 2) el.classList.add('text-amber-400');
        else el.classList.add('text-red-400');
      }

      function renderFinancialKpis(d) {
        const cards = d?.cards || {};
        const segments = Array.isArray(d?.countrySegments) ? d.countrySegments : [];
        const richSegment = segments.find(function (s) { return s?.segment === 'Pays riches'; });
        const inscritsTotal = Number(cards.inscrits || 0);
        const acheteursTotal = Number(cards.acheteurs || 0);
        const richInscrits = Number(richSegment?.inscrits || 0);
        const richBuyers = Number(richSegment?.acheteurs || 0);
        const convGlobal = Number(cards.conversionGlobalRate || 0);
        const convRich = Number(cards.conversionRichRate || 0);
        const vplGlobal = Number(cards.valuePerLeadGlobal || 0);
        const vplRich = Number(cards.valuePerLeadRich || 0);
        const offerPrice = Number(cards.offerPriceEur || 0);

        const priceEl = document.getElementById('kpi-offer-price');
        if (priceEl) priceEl.textContent = formatEur(offerPrice);

        const gEl = document.getElementById('kpi-conv-global');
        if (gEl) { gEl.textContent = formatPct(convGlobal); colorByConvBenchmark(gEl, convGlobal); }
        const gDetail = document.getElementById('kpi-conv-global-detail');
        if (gDetail) gDetail.textContent = `${acheteursTotal} / ${inscritsTotal}`;

        const rEl = document.getElementById('kpi-conv-rich');
        if (rEl) { rEl.textContent = formatPct(convRich); colorByConvBenchmark(rEl, convRich); }
        const rDetail = document.getElementById('kpi-conv-rich-detail');
        if (rDetail) rDetail.textContent = `${richBuyers} / ${richInscrits}`;

        const vgEl = document.getElementById('kpi-vpl-global');
        if (vgEl) vgEl.textContent = formatEur(vplGlobal);
        const vgDetail = document.getElementById('kpi-vpl-global-detail');
        if (vgDetail) vgDetail.textContent = `${formatEur(acheteursTotal * offerPrice)} / ${inscritsTotal} inscrits`;

        const vrEl = document.getElementById('kpi-vpl-rich');
        if (vrEl) vrEl.textContent = formatEur(vplRich);
        const vrDetail = document.getElementById('kpi-vpl-rich-detail');
        if (vrDetail) vrDetail.textContent = `${formatEur(richBuyers * offerPrice)} / ${richInscrits} inscrits`;
      }

      function hydrateSessionDropdown(sessionDates, selectedValue) {
        const select = document.getElementById('overview-session-select');
        if (!select) return;
        if (!overviewSessionsHydrated) {
          select.innerHTML = '<option value="">Toutes sessions</option>';
          (Array.isArray(sessionDates) ? sessionDates : []).forEach(function (day) {
            const opt = document.createElement('option');
            opt.value = day;
            opt.textContent = day;
            select.appendChild(opt);
          });
          overviewSessionsHydrated = true;
        }
        select.value = selectedValue || '';
      }

      function setOverviewRefreshLoading(isLoading) {
        const btn = document.getElementById('overview-refresh');
        const stamp = document.getElementById('overview-updated');
        if (btn) {
          if (!btn.dataset.idleLabel) btn.dataset.idleLabel = btn.textContent || 'Actualiser';
          btn.disabled = isLoading;
          btn.innerHTML = isLoading
            ? '<span class="inline-flex items-center gap-2"><span class="h-3 w-3 animate-spin rounded-full border border-slate-300 border-t-transparent"></span><span>Chargement...</span></span>'
            : (btn.dataset.idleLabel || 'Actualiser');
          btn.classList.toggle('opacity-60', isLoading);
          btn.classList.toggle('cursor-not-allowed', isLoading);
        }
        if (isLoading && stamp) {
          stamp.textContent = 'Mise à jour en cours...';
        }
      }

      async function refreshOverviewKpis(options = {}) {
        const manual = options?.manual === true;
        if (overviewBusy) return;
        const root = document.getElementById('overview-kpis');
        if (!root || root.closest('.hidden')) return;
        if (manual) setOverviewRefreshLoading(true);
        overviewBusy = true;
        const errEl = document.getElementById('overview-error');
        if (errEl) {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
        try {
          const select = document.getElementById('overview-session-select');
          const selected = select ? String(select.value || '').trim() : '';
          const qs = selected ? `?session_date=${encodeURIComponent(selected)}` : '';
          const r = await fetch(`/.netlify/functions/admin-es2-dashboard-kpis${qs}`, {
            credentials: 'same-origin',
          });
          const d = await r.json().catch(function () { return {}; });
          if (!r.ok) throw new Error(d.error || 'Erreur KPIs');

          hydrateSessionDropdown(d?.sessions, d?.filter?.session_date || '');

          renderHeroStrip(d);

          document.getElementById('kpi-inscrits').textContent = String(d?.cards?.inscrits || 0);
          document.getElementById('kpi-presents').textContent = String(d?.cards?.presents || 0);
          const presReplayEl = document.getElementById('kpi-presents-replay');
          if (presReplayEl) presReplayEl.textContent = String(d?.cards?.presentsReplay || 0);
          document.getElementById('kpi-presence-rate').textContent = formatPct(d?.cards?.presenceRate);
          document.getElementById('kpi-saw-offer').textContent = String(d?.cards?.sawOffer || 0);
          document.getElementById('kpi-clicked-cta').textContent = String(d?.cards?.clickedCta || 0);
          document.getElementById('kpi-cta-rate').textContent = formatPct(d?.cards?.ctaConversionRate);

          renderOverviewFunnel(d?.funnel, d?.cards?.inscrits);
          renderRetention(d?.retention, d?.ctaAppearMinute);
          renderOverviewCountrySegments(d?.countrySegments, d?.cards?.offerPriceEur);
          renderFinancialKpis(d);
          renderLiveReplay(d?.liveReplay);
          renderSpiffyWarning(d);
          // Empty state buyers : si la session est passée depuis >30min sans acheteurs, on parle de sync en cours
          const filterDate = d?.filter?.session_date || '';
          const sessionMs = filterDate ? Date.parse(`${filterDate}T20:00:00+02:00`) : 0;
          const spiffyPending = (Number(d?.cards?.acheteurs || 0) === 0)
            && filterDate
            && Number.isFinite(sessionMs)
            && (Date.now() - sessionMs > 30 * 60 * 1000);
          renderBuyerDetails(d?.buyerDetails, { spiffyPending });
          const stamp = document.getElementById('overview-updated');
          if (stamp) stamp.textContent = `MAJ ${new Date().toLocaleString('fr-FR')}`;
        } catch (e) {
          if (errEl) {
            errEl.textContent = e?.message || 'Erreur KPIs';
            errEl.classList.remove('hidden');
          }
        } finally {
          overviewBusy = false;
          if (manual) setOverviewRefreshLoading(false);
        }
      }

      function statusText(check) {
        if (!check) return '—';
        if (check.ok) return `OK (${check.status || '200'})`;
        if (check.status) return `KO (${check.status})`;
        return `KO (${check.error || 'error'})`;
      }

      function formatSecond(second) {
        if (!Number.isFinite(Number(second))) return '—';
        const total = Math.max(0, Math.floor(Number(second)));
        const h = Math.floor(total / 3600);
        const m = Math.floor((total % 3600) / 60);
        const s = total % 60;
        return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')} (${total}s)`;
      }

      function formatShortIso(value) {
        if (!value) return '—';
        const dt = new Date(value);
        if (!Number.isFinite(dt.getTime())) return '—';
        return dt.toLocaleString('fr-FR', { timeZone: 'Europe/Paris' });
      }

      function formatHistoryLabel(value) {
        if (!value) return '—';
        const dt = new Date(value);
        if (!Number.isFinite(dt.getTime())) return '—';
        return dt.toLocaleString('fr-FR', {
          timeZone: 'Europe/Paris',
          weekday: 'long',
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
      }

      function buildHistoryItems(d) {
        const out = [];
        if (d?.nextSession?.sessionDateIso) {
          out.push({
            state: 'upcoming',
            sessionDateIso: d.nextSession.sessionDateIso,
            offerExpiresIso: d.nextSession.offerExpiresIso,
            population: d.nextSession.population || {},
          });
        }
        if (d?.currentSession?.sessionDateIso) {
          out.push({
            state: d?.currentSession?.isLiveWindow ? 'live' : 'closed',
            sessionDateIso: d.currentSession.sessionDateIso,
            offerExpiresIso: d.currentSession.offerExpiresIso,
            population: d.sessionPopulation || {},
          });
        }
        const closed = Array.isArray(d?.pastSessions) ? d.pastSessions : [];
        for (const item of closed) {
          out.push({
            state: 'closed',
            sessionDateIso: item?.sessionDateIso,
            offerExpiresIso: item?.offerExpiresIso,
            population: item?.population || {},
          });
        }
        const dedup = new Map();
        for (const item of out) {
          if (!item.sessionDateIso) continue;
          if (!dedup.has(item.sessionDateIso)) dedup.set(item.sessionDateIso, item);
        }
        return Array.from(dedup.values()).sort(function (a, b) {
          return new Date(b.sessionDateIso).getTime() - new Date(a.sessionDateIso).getTime();
        });
      }

      function normalizeText(value) {
        return String(value || '')
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '');
      }

      function renderPastSessions(items) {
        const root = document.getElementById('ops-past-sessions');
        if (!root) return;
        root.innerHTML = '';
        const list = (Array.isArray(items) ? items : []).filter(function (item) {
          if (opsHistoryFilter !== 'all' && item.state !== opsHistoryFilter) return false;
          if (!opsHistorySearch) return true;
          const dateText = normalizeText(formatShortIso(item.sessionDateIso));
          const expireText = normalizeText(formatShortIso(item.offerExpiresIso));
          return dateText.includes(opsHistorySearch) || expireText.includes(opsHistorySearch);
        });
        if (!list.length) {
          const empty = document.createElement('p');
          empty.className = 'text-slate-500';
          empty.textContent = 'Aucune session pour ce filtre.';
          root.appendChild(empty);
          return;
        }
        for (const item of list) {
          const row = document.createElement('div');
          row.className = 'rounded-lg border border-slate-800 bg-slate-950/70 p-2';
          const p = item.population || {};
          const inscrits = Math.max(0, Number(p.inscrit || 0));
          const presents = Math.max(0, Number(p.present || 0));
          const ratio = inscrits > 0 ? Math.min(100, Math.round((presents / inscrits) * 100)) : 0;
          const stateLabel = item.state === 'live' ? 'En cours' : item.state === 'upcoming' ? 'À venir' : 'Clôturée';
          const stateClass =
            item.state === 'live'
              ? 'border-emerald-500/50 bg-emerald-500/10 text-emerald-200'
              : item.state === 'upcoming'
                ? 'border-blue-500/50 bg-blue-500/10 text-blue-200'
                : 'border-slate-700 bg-slate-900 text-slate-300';
          row.innerHTML = `
            <div class="flex items-center justify-between gap-2">
              <p class="text-slate-200">${formatHistoryLabel(item.sessionDateIso)}</p>
              <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] uppercase tracking-wide ${stateClass}">${stateLabel}</span>
            </div>
            <p class="text-[11px] text-slate-500">Expire: ${formatShortIso(item.offerExpiresIso)}</p>
            <p class="text-[11px] text-slate-400">Inscrits ${inscrits} · Présents ${presents} · Acheteurs ${p.acheteur || 0} · Non-acheteurs ${p.non_acheteur || 0} · No-show ${p.no_show || 0}</p>
            <div class="mt-1">
              <div class="h-1.5 w-full overflow-hidden rounded-full bg-slate-800">
                <div class="h-1.5 rounded-full bg-emerald-400" style="width:${ratio}%"></div>
              </div>
              <p class="mt-1 text-[10px] text-slate-500">Présence: ${ratio}% (${presents}/${inscrits || 0})</p>
            </div>
          `;
          root.appendChild(row);
        }
      }

      function setCurrentSessionBadge(isLiveWindow) {
        const el = document.getElementById('ops-live-window');
        if (!el) return;
        if (isLiveWindow) {
          el.textContent = 'En cours';
          el.classList.remove('text-slate-200');
          el.classList.add('text-emerald-300');
          return;
        }
        el.textContent = 'Hors live';
        el.classList.remove('text-emerald-300');
        el.classList.add('text-slate-200');
      }

      function setNextSessionBadge(nextSession) {
        const label = document.getElementById('ops-next-session-state');
        if (!label) return;
        if (!nextSession) {
          label.textContent = 'Aucune';
          label.className = 'inline-flex items-center rounded-full border border-slate-700 px-2 py-0.5 text-[10px] uppercase tracking-wide text-slate-400';
          return;
        }
        label.textContent = 'À venir';
        label.className = 'inline-flex items-center rounded-full border border-blue-500/50 bg-blue-500/10 px-2 py-0.5 text-[10px] uppercase tracking-wide text-blue-200';
      }

      function setStreamBadgeState(isRunning, mode) {
        const badge = document.getElementById('ops-stream-state-badge');
        const dot = document.getElementById('ops-stream-dot');
        const stateText = document.getElementById('ops-stream-state');
        if (!badge || !dot || !stateText) return;
        const streamMode = String(mode || 'none');
        if (isRunning) {
          badge.classList.remove('border-slate-700', 'text-slate-300', 'border-red-500/50', 'text-red-200', 'border-amber-500/50', 'text-amber-200', 'border-sky-500/50', 'text-sky-200');
          dot.classList.remove('bg-slate-500', 'bg-red-500', 'bg-amber-400', 'bg-sky-400');
          dot.classList.add('animate-pulse');
          if (streamMode === 'test') {
            badge.classList.add('border-amber-500/50', 'text-amber-200');
            dot.classList.add('bg-amber-400');
            stateText.textContent = 'Oui (test)';
          } else if (streamMode === 'mixed') {
            badge.classList.add('border-sky-500/50', 'text-sky-200');
            dot.classList.add('bg-sky-400');
            stateText.textContent = 'Oui (mixte)';
          } else {
            badge.classList.add('border-emerald-500/50', 'text-emerald-200');
            dot.classList.add('bg-emerald-400');
            stateText.textContent = 'Oui (réelle)';
          }
        } else {
          badge.classList.remove('border-emerald-500/50', 'text-emerald-200', 'border-amber-500/50', 'text-amber-200', 'border-sky-500/50', 'text-sky-200');
          badge.classList.add('border-red-500/50', 'text-red-200');
          dot.classList.remove('bg-slate-500', 'bg-emerald-400', 'bg-amber-400', 'bg-sky-400', 'animate-pulse');
          dot.classList.add('bg-red-500');
          stateText.textContent = 'Non';
        }
      }

      function startStreamCounter(baseSecond, isRunning) {
        streamCounterBaseSecond = Number.isFinite(Number(baseSecond)) ? Math.max(0, Math.floor(Number(baseSecond))) : null;
        streamCounterBaseAtMs = Date.now();
        streamCounterIsRunning = Boolean(isRunning && Number.isFinite(streamCounterBaseSecond));
        if (streamCounterTimer) clearInterval(streamCounterTimer);
        const el = document.getElementById('ops-stream-second');
        if (!el) return;
        if (!streamCounterIsRunning) {
          el.textContent = formatSecond(streamCounterBaseSecond);
          return;
        }
        streamCounterTimer = setInterval(function () {
          const elapsed = Math.floor((Date.now() - streamCounterBaseAtMs) / 1000);
          el.textContent = formatSecond((streamCounterBaseSecond || 0) + Math.max(0, elapsed));
        }, 1000);
      }

      function syncStreamThumbnail(url, second, hasStream) {
        const thumb = document.getElementById('ops-stream-thumb');
        if (!thumb) return;
        if (!url) {
          thumb.pause();
          streamThumbLoadedUrl = '';
          return;
        }
        if (streamThumbLoadedUrl !== url) {
          streamThumbLoadedUrl = url;
          thumb.src = url;
          thumb.load();
        }
        const targetSec = Number.isFinite(Number(second)) ? Math.max(0, Math.floor(Number(second))) : null;
        if (targetSec != null) {
          const seekTo = function () {
            try {
              thumb.currentTime = targetSec;
            } catch {
              /* ignore */
            }
          };
          if (thumb.readyState >= 1) seekTo();
          else thumb.addEventListener('loadedmetadata', seekTo, { once: true });
        }
        if (hasStream) thumb.play().catch(function () {});
        else thumb.pause();
      }

      function setOpsRefreshLoading(isLoading) {
        const btn = document.getElementById('ops-refresh');
        const stamp = document.getElementById('ops-updated');
        if (btn) {
          if (!btn.dataset.idleLabel) btn.dataset.idleLabel = btn.textContent || 'Actualiser';
          btn.disabled = isLoading;
          btn.innerHTML = isLoading
            ? '<span class="inline-flex items-center gap-2"><span class="h-3 w-3 animate-spin rounded-full border border-slate-300 border-t-transparent"></span><span>Chargement...</span></span>'
            : (btn.dataset.idleLabel || 'Actualiser');
          btn.classList.toggle('opacity-60', isLoading);
          btn.classList.toggle('cursor-not-allowed', isLoading);
        }
        if (isLoading && stamp) {
          stamp.textContent = 'Mise à jour en cours...';
        }
      }

      async function refreshOpsStatus(options = {}) {
        const manual = options?.manual === true;
        if (opsBusy) return;
        const root = document.getElementById('ops-cockpit');
        if (!root) return;
        if (root.closest('.hidden')) return;
        if (manual) setOpsRefreshLoading(true);
        opsBusy = true;
        const errEl = document.getElementById('ops-error');
        if (errEl) {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
        try {
          const r = await fetch('/.netlify/functions/admin-es2-cockpit-status', { credentials: 'same-origin' });
          const d = await r.json().catch(function () { return {}; });
          if (!r.ok) throw new Error(d.error || 'Erreur cockpit');

          document.getElementById('ops-waiting').textContent = String(d?.presence?.waiting || 0);
          document.getElementById('ops-session').textContent = String(d?.presence?.session || 0);
          document.getElementById('ops-replay').textContent = String(d?.presence?.replay || 0);
          document.getElementById('ops-total').textContent = String(d?.presence?.activeTotal || 0);

          document.getElementById('ops-source').textContent = d?.video?.activeSource || '—';
          document.getElementById('ops-url').textContent = d?.video?.activeUrl || '—';
          document.getElementById('ops-check-active').textContent = statusText(d?.video?.checks?.active);
          document.getElementById('ops-check-primary').textContent = statusText(d?.video?.checks?.primary);
          document.getElementById('ops-check-backup').textContent = statusText(d?.video?.checks?.backup);

          document.getElementById('ops-now-utc').textContent = d?.now?.utcIso || '—';
          document.getElementById('ops-now-paris').textContent = d?.now?.parisIso || '—';
          document.getElementById('ops-session-date').textContent = d?.currentSession?.sessionDateIso || '—';
          document.getElementById('ops-expire-date').textContent = d?.currentSession?.offerExpiresIso || '—';
          setCurrentSessionBadge(Boolean(d?.currentSession?.isLiveWindow));
          const hasStream = Boolean(d?.presence?.stream?.hasStream);
          setStreamBadgeState(hasStream, d?.presence?.stream?.mode);
          startStreamCounter(d?.presence?.stream?.medianSecond, hasStream);
          syncStreamThumbnail(d?.video?.activeUrl || '', d?.presence?.stream?.medianSecond, hasStream);
          document.getElementById('ops-stream-playing').textContent = String(d?.presence?.stream?.sessionPlaying || 0);

          document.getElementById('ops-pop-inscrit').textContent = String(d?.sessionPopulation?.inscrit || 0);
          document.getElementById('ops-pop-present').textContent = String(d?.sessionPopulation?.present || 0);
          document.getElementById('ops-pop-acheteur').textContent = String(d?.sessionPopulation?.acheteur || 0);
          document.getElementById('ops-pop-nonacheteur').textContent = String(d?.sessionPopulation?.non_acheteur || 0);

          document.getElementById('ops-next-session-date').textContent = formatShortIso(d?.nextSession?.sessionDateIso);
          document.getElementById('ops-next-expire-date').textContent = formatShortIso(d?.nextSession?.offerExpiresIso);
          setNextSessionBadge(d?.nextSession || null);
          document.getElementById('ops-next-inscrit').textContent = String(d?.nextSession?.population?.inscrit || 0);
          document.getElementById('ops-next-present').textContent = String(d?.nextSession?.population?.present || 0);
          document.getElementById('ops-next-acheteur').textContent = String(d?.nextSession?.population?.acheteur || 0);
          document.getElementById('ops-next-nonacheteur').textContent = String(d?.nextSession?.population?.non_acheteur || 0);
          document.getElementById('ops-next-noshow').textContent = String(d?.nextSession?.population?.no_show || 0);
          opsHistoryItems = buildHistoryItems(d);
          renderPastSessions(opsHistoryItems);

          document.getElementById('ops-updated').textContent = `MAJ ${new Date().toLocaleString('fr-FR')}`;
        } catch (e) {
          if (errEl) {
            errEl.textContent = e?.message || 'Erreur cockpit';
            errEl.classList.remove('hidden');
          }
        } finally {
          opsBusy = false;
          if (manual) setOpsRefreshLoading(false);
        }
      }

      function startOpsPolling() {
        if (opsPollingTimer) return;
        refreshOpsStatus();
        opsPollingTimer = setInterval(refreshOpsStatus, 7000);
      }

      async function sendOpsControl(action) {
        const errEl = document.getElementById('ops-error');
        if (errEl) {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
        try {
          const r = await fetch('/.netlify/functions/admin-es2-cockpit-control', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action }),
          });
          const d = await r.json().catch(function () { return {}; });
          if (!r.ok) throw new Error(d.error || 'Action impossible');
          await refreshOpsStatus();
        } catch (e) {
          if (errEl) {
            errEl.textContent = e?.message || 'Erreur action';
            errEl.classList.remove('hidden');
          }
        }
      }

      const opsRefreshBtn = document.getElementById('ops-refresh');
      if (opsRefreshBtn) {
        opsRefreshBtn.addEventListener('click', function () {
          refreshOpsStatus({ manual: true });
        });
      }
      const opsPrimaryBtn = document.getElementById('ops-switch-primary');
      if (opsPrimaryBtn) opsPrimaryBtn.addEventListener('click', function () { sendOpsControl('switch_primary'); });
      const opsBackupBtn = document.getElementById('ops-switch-backup');
      if (opsBackupBtn) opsBackupBtn.addEventListener('click', function () { sendOpsControl('switch_backup'); });
      const opsResetBtn = document.getElementById('ops-clear-override');
      if (opsResetBtn) opsResetBtn.addEventListener('click', function () { sendOpsControl('clear_override'); });
      const opsSeekBtn = document.getElementById('ops-seek-live-offset');
      if (opsSeekBtn) opsSeekBtn.addEventListener('click', function () { sendOpsControl('seek_live_offset'); });
      const extendOfferForm = document.getElementById('extend-offer-form');
      if (extendOfferForm) {
        extendOfferForm.addEventListener('submit', async function (event) {
          event.preventDefault();
          const emailInput = document.getElementById('extend-offer-email');
          const hoursInput = document.getElementById('extend-offer-hours');
          const submitBtn = document.getElementById('extend-offer-submit');
          const feedbackEl = document.getElementById('extend-offer-feedback');
          const email = String(emailInput?.value || '').trim().toLowerCase();
          const hours = Number(hoursInput?.value);

          if (feedbackEl) {
            feedbackEl.classList.add('hidden');
            feedbackEl.classList.remove('text-red-400', 'text-emerald-300');
            feedbackEl.textContent = '';
          }
          if (!email || !Number.isFinite(hours) || hours <= 0) {
            if (feedbackEl) {
              feedbackEl.textContent = 'Renseigne un email valide et un nombre d\'heures supérieur à 0.';
              feedbackEl.classList.remove('hidden');
              feedbackEl.classList.add('text-red-400');
            }
            return;
          }

          if (submitBtn) submitBtn.disabled = true;
          try {
            const response = await fetch('/.netlify/functions/extend-webinaire-offer', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email, hoursToAdd: hours }),
            });
            const payload = await response.json().catch(function () { return {}; });
            if (!response.ok) throw new Error(payload?.error || 'Impossible de prolonger cette offre.');

            const firstName = payload?.firstName ? `${payload.firstName} ` : '';
            const nextExpiry = payload?.offreExpiresAt
              ? new Date(payload.offreExpiresAt).toLocaleString('fr-FR', { timeZone: 'Europe/Paris' })
              : 'date invalide';
            if (feedbackEl) {
              feedbackEl.textContent = `Offre prolongée pour ${firstName}${payload?.email || email} - Nouvelle expiration: ${nextExpiry} (Paris).`;
              feedbackEl.classList.remove('hidden');
              feedbackEl.classList.add('text-emerald-300');
            }
          } catch (error) {
            if (feedbackEl) {
              feedbackEl.textContent = error?.message || 'Erreur réseau.';
              feedbackEl.classList.remove('hidden');
              feedbackEl.classList.add('text-red-400');
            }
          } finally {
            if (submitBtn) submitBtn.disabled = false;
          }
        });
      }
      const opsSearch = document.getElementById('ops-history-search');
      if (opsSearch) {
        opsSearch.addEventListener('input', function (e) {
          opsHistorySearch = normalizeText(e?.target?.value || '');
          renderPastSessions(opsHistoryItems);
        });
      }
      document.querySelectorAll('.ops-history-filter').forEach(function (btn) {
        btn.addEventListener('click', function () {
          opsHistoryFilter = btn.getAttribute('data-filter') || 'all';
          document.querySelectorAll('.ops-history-filter').forEach(function (b) {
            b.classList.remove('border-blue-500', 'text-blue-200', 'bg-blue-500/10');
          });
          btn.classList.add('border-blue-500', 'text-blue-200', 'bg-blue-500/10');
          renderPastSessions(opsHistoryItems);
        });
      });
      const defaultFilterBtn = document.querySelector('.ops-history-filter[data-filter="all"]');
      if (defaultFilterBtn) defaultFilterBtn.classList.add('border-blue-500', 'text-blue-200', 'bg-blue-500/10');

      const overviewRefreshBtn = document.getElementById('overview-refresh');
      if (overviewRefreshBtn) {
        overviewRefreshBtn.addEventListener('click', function () {
          refreshOverviewKpis({ manual: true });
        });
      }
      const overviewSessionSelect = document.getElementById('overview-session-select');
      if (overviewSessionSelect) overviewSessionSelect.addEventListener('change', refreshOverviewKpis);

      requireAuth();
      refreshOverviewKpis();
    </script>
  </body>
</html>
