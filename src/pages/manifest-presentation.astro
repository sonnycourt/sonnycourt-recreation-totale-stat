        }

        /* Guarantee Section */
        .guarantee-section {
            padding: 140px 0;
            background:
                radial-gradient(circle at 30% 20%, rgba(139, 92, 246, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(255, 215, 0, 0.04) 0%, transparent 50%),
