    <!-- Deadline personnelle 24h : basée sur le token ES2 (?t=...), ancrée serveur à la 1ère ouverture -->
    <script is:inline>
    (function() {
        var bar = document.getElementById('presentation-deadline-bar');
        var barLabel = document.getElementById('pdb-label');
        var barTimer = document.getElementById('pdb-timer');
        var STORAGE_KEY = 'manifest_presentation_token';

        var params = new URLSearchParams(window.location.search);

        function showBar() {
            if (!bar) return;
            bar.style.display = 'block';
        }

        function disableCheckout() {
            var ctas = document.querySelectorAll('a[href*="spiffy.co"], .cta-button-final');
            ctas.forEach(function(el) {
                el.classList.add('pdb-cta-disabled');
                el.setAttribute('aria-disabled', 'true');
                el.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    return false;
                }, true);
            });
        }

        function setExpired() {
            if (bar) bar.classList.add('pdb-expired');
            if (barLabel) barLabel.textContent = "⛔ Ton offre a expiré — contacte-nous si tu as une question";
            disableCheckout();
            showBar();
        }

        function startTicker(expiresAtMs, serverNowMs) {
            var clockOffset = Date.now() - serverNowMs; // corrige l'horloge du visiteur
            var itv = null;
            function tick() {
                var remaining = expiresAtMs - (Date.now() - clockOffset);
                if (remaining <= 0) {
                    if (itv) clearInterval(itv);
                    setExpired();
                    return;
                }
                var h = Math.floor(remaining / 3600000);
                var m = Math.floor((remaining % 3600000) / 60000);
                var s = Math.floor((remaining % 60000) / 1000);
                if (barTimer) barTimer.textContent =
                    String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
            }
            tick();
            itv = setInterval(tick, 1000);
            showBar();
        }

        var gate = document.getElementById('pdb-email-gate');
        var gateForm = document.getElementById('pdb-gate-form');
        var gateInput = document.getElementById('pdb-gate-input');
        var gateBtn = document.getElementById('pdb-gate-btn');
        var gateError = document.getElementById('pdb-gate-error');

        function hideGate() {
            if (gate) gate.style.display = 'none';
            document.body.style.overflow = '';
        }

        function showGate() {
            if (!gate) return;
            gate.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        // Applique la réponse serveur : mémorise le token, ferme l'overlay, lance le timer
        function handleAccessData(data) {
            if (!data || !data.ok) return false;
            if (data.token) { try { localStorage.setItem(STORAGE_KEY, data.token); } catch (e) {} }
            hideGate();
            if (data.expired) { setExpired(); } else { startTicker(data.expiresAt, data.serverNow); }
            return true;
        }

        // Modes preview pour tester sans token : ?preview=expired / ?preview=timer
        var previewMode = params.get('preview');
        if (previewMode === 'expired') { setExpired(); return; }
        if (previewMode === 'timer') { startTicker(Date.now() + 24 * 3600 * 1000, Date.now()); return; }

        var token = params.get('t') || params.get('token') || localStorage.getItem(STORAGE_KEY);

        if (token) {
            try { localStorage.setItem(STORAGE_KEY, token); } catch (e) {}
            fetch('/.netlify/functions/manifest-presentation-access?t=' + encodeURIComponent(token))
                .then(function(r) { return r.json(); })
                .then(function(data) { handleAccessData(data); }) // ok:false → fail-open, pas de barre
                .catch(function() {}); // fail-open : jamais bloquer une vente sur un pépin serveur
            return;
        }

        // Pas de token : on demande l'email d'inscription à la masterclass pour le retrouver
        showGate();
        if (gateForm) gateForm.addEventListener('submit', function(e) {
            e.preventDefault();
            var email = (gateInput && gateInput.value || '').trim();
            if (!email) return;
            if (gateError) gateError.style.display = 'none';
            if (gateBtn) { gateBtn.disabled = true; gateBtn.textContent = 'Vérification...'; }

            fetch('/.netlify/functions/manifest-presentation-access?email=' + encodeURIComponent(email))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (handleAccessData(data)) return;
                    if (gateBtn) { gateBtn.disabled = false; gateBtn.textContent = 'Accéder à la présentation'; }
                    if (gateError) gateError.style.display = 'block';
                })
                .catch(function() {
                    hideGate(); // fail-open : problème serveur → page consultable sans deadline
                });
        });
    })();
    </script>
