        /* FAQ Section */
        .faq-section {
            padding: 120px 0;
            background: var(--card-bg);
            position: relative;
            z-index: 2;
        }

        .faq-container {
            max-width: 800px;
            margin: 0 auto;
        }


        .faq-item {
            background: linear-gradient(135deg, var(--darker-bg) 0%, rgba(20, 20, 20, 0.95) 100%);
            border: 1px solid rgba(139, 92, 246, 0.15);
            border-radius: 16px;
            margin-bottom: 20px;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);
        }

        .faq-item:hover {
            border-color: rgba(139, 92, 246, 0.3);
            box-shadow: 0 8px 25px rgba(139, 92, 246, 0.08);
            transform: translateY(-1px);
        }

        .faq-item.active {
            border-color: rgba(139, 92, 246, 0.4);
            box-shadow: 0 6px 20px rgba(139, 92, 246, 0.1);
        }

        .faq-question {
            padding: 30px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
            position: relative;
        }

        .faq-question:hover {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(139, 92, 246, 0.02));
        }

        .faq-question span {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .faq-toggle {
            color: var(--primary-purple);
            font-size: 1.5rem;
            font-weight: 700;
            transition: all 0.3s ease;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(139, 92, 246, 0.1);
            border-radius: 8px;
            border: 1px solid rgba(139, 92, 246, 0.2);
