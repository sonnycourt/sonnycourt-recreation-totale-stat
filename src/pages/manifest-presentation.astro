        /* Modules Section */
        .modules-section {
            padding: 120px 0;
            background: linear-gradient(180deg, var(--darker-bg) 0%, var(--dark-bg) 50%, var(--darker-bg) 100%);
            position: relative;
            z-index: 2;
        }

        .modules-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 60px;
            max-width: 900px;
            margin: 0 auto;
        }

        .module-card {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(20, 20, 20, 0.8) 100%);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: 20px;
            padding: 50px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
            transition: all 0.4s ease;
            box-shadow:
                0 20px 40px rgba(0, 0, 0, 0.3),
                0 0 60px rgba(139, 92, 246, 0.1);
        }

        .module-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-purple), rgba(139, 92, 246, 0.8), var(--primary-purple));
            border-radius: 20px 20px 0 0;
        }

        .module-card:hover {
            transform: translateY(-8px);
            box-shadow:
                0 30px 60px rgba(0, 0, 0, 0.4),
                0 0 80px rgba(139, 92, 246, 0.2);
            border-color: rgba(139, 92, 246, 0.5);
        }

        .module-header {
            display: flex;
            align-items: center;
            gap: 25px;
            margin-bottom: 30px;
        }

        .module-number {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--primary-purple), #A78BFA);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            font-weight: 700;
            flex-shrink: 0;
            box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);
        }

        .module-title {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary-purple), #A78BFA);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0;
        }

        .module-content {
            line-height: 1.8;
        }

        .module-description {
            color: var(--text-secondary);
            font-size: 1.1rem;
            margin-bottom: 20px;
        }

        .module-highlight {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(139, 92, 246, 0.05));
            border-left: 4px solid var(--primary-purple);
            padding: 25px;
            margin: 25px 0;
            border-radius: 0 12px 12px 0;
