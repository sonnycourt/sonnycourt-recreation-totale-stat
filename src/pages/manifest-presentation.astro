        .descriptive-image {
            width: 100%;
            max-width: 600px;
            height: auto;
            border-radius: 24px;
            transition: all 0.4s ease;
        }

        .descriptive-image-frame:hover .descriptive-image {
            transform: scale(1.02);
        }

        .descriptive-image-glow {
            position: absolute;
            top: -10px;
            left: -10px;
            right: -10px;
            bottom: -10px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(139, 92, 246, 0.1));
            border-radius: 28px;
            z-index: -1;
            opacity: 0.7;
