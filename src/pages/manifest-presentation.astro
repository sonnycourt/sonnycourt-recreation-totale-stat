        .trust-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 25px;
        }

        .trust-text {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.7;
            margin-bottom: 20px;
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
        }

        .trust-text:last-child {
            margin-bottom: 0;
        }

        @keyframes shieldPulse {
            0%, 100% {
                transform: scale(1);
                filter:
                    drop-shadow(0 0 20px rgba(139, 92, 246, 0.6))
                    drop-shadow(0 0 40px rgba(139, 92, 246, 0.4));
            }
            50% {
                transform: scale(1.05);
                filter:
                    drop-shadow(0 0 25px rgba(139, 92, 246, 0.8))
                    drop-shadow(0 0 50px rgba(139, 92, 246, 0.6));
            }
        }

        @keyframes shieldGlowPulse {
            0%, 100% {
                opacity: 0.3;
                transform: scale(1);
            }
            50% {
                opacity: 0.6;
                transform: scale(1.1);
            }
        }

        @keyframes trustPulse {
            0%, 100% {
                transform: scale(1);
                filter:
                    drop-shadow(0 0 15px rgba(139, 92, 246, 0.5))
                    drop-shadow(0 0 30px rgba(139, 92, 246, 0.3));
            }
            50% {
                transform: scale(1.02);
                filter:
                    drop-shadow(0 0 20px rgba(139, 92, 246, 0.7))
                    drop-shadow(0 0 40px rgba(139, 92, 246, 0.5));
            }
        }

        @keyframes trustGlowPulse {
            0%, 100% {
                opacity: 0.3;
                transform: scale(1);
            }
            50% {
                opacity: 0.5;
                transform: scale(1.05);
            }
        }

        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
                opacity: 1;
            }
            50% {
                transform: scale(1.05);
                opacity: 0.9;
            }
        }

        @media (max-width: 768px) {
            .guarantee-highlight {
                flex-direction: column;
                text-align: center;
                gap: 20px;
                padding: 30px;
            }

            .guarantee-steps {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .guarantee-conditions {
