---
import { promo } from '../config/promo';

interface Props {
  forceShow?: boolean;
}
const { forceShow = false } = Astro.props;
const url = Astro.url;
const isPromo = promo.active && (forceShow || url.searchParams.get('preview') === 'promo');

const themes = {
  red: {
    bg: "linear-gradient(105deg, #8b0e3a 0%, #b31950 40%, #c6284a 100%)",
    accent: "linear-gradient(100deg, #ffffff 0%, #ffd5e0 70%)",
    btn: "#ffd166",
    btnText: "#7c0a2a",
  },
  purple: {
    bg: "linear-gradient(105deg, #2d1b69 0%, #5b2d8e 40%, #7c3aed 100%)",
    accent: "linear-gradient(100deg, #ffffff 0%, #d8b4fe 70%)",
    btn: "#a78bfa",
    btnText: "#1e1042",
  },
  gold: {
    bg: "linear-gradient(105deg, #1a1a1a 0%, #2d2306 40%, #44370a 100%)",
    accent: "linear-gradient(100deg, #ffd700 0%, #ffec80 70%)",
    btn: "#ffd700",
    btnText: "#1a1a1a",
  },
  green: {
    bg: "linear-gradient(105deg, #064e3b 0%, #047857 40%, #059669 100%)",
    accent: "linear-gradient(100deg, #ffffff 0%, #a7f3d0 70%)",
    btn: "#34d399",
    btnText: "#064e3b",
  },
};

const t = themes[promo.theme] || themes.red;
---

{isPromo && (
<div id="promo-banner" data-deadline={promo.deadline} style={`position: fixed; top: 0; left: 0; right: 0; width: 100%; background: ${t.bg}; border-bottom: 1px solid rgba(255, 255, 255, 0.08); min-height: 64px; z-index: 99999; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;`}>
  <div style="max-width: 1400px; margin: 0 auto; padding: 12px 24px; display: flex; align-items: center; gap: 24px; flex-wrap: wrap; justify-content: center;">
    <div style="display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 0; align-items: flex-start; text-align: left;">
      <span style="font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255, 255, 255, 0.85); font-weight: 700;">{promo.emoji} {promo.name}</span>
      <div style="display: flex; flex-wrap: wrap; align-items: baseline; gap: 12px; color: #fff;">
        <span style={`font-size: 36px; font-weight: 900; line-height: 1; color: transparent; background: ${t.accent}; -webkit-background-clip: text; background-clip: text;`}>-{promo.discount}%</span>
        <span style="font-size: 28px; font-weight: 900; line-height: 1.05; color: rgba(255, 255, 255, 0.95);">{promo.bannerMessage}</span>
      </div>
    </div>
    <div id="promo-countdown" style="display: flex; align-items: center; gap: 12px; background: rgba(0, 0, 0, 0.15); border-radius: 999px; padding: 6px 16px; color: #fff;">
      <span style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.8px; color: rgba(255, 255, 255, 0.7);">Expire dans</span>
      <div style="display: flex; align-items: center; gap: 12px;">
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span data-unit="days" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">jours</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span data-unit="hours" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">heures</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span data-unit="minutes" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">min</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span data-unit="seconds" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">sec</span>
        </div>
      </div>
    </div>
    <div style="display: flex; align-items: center; gap: 12px;">
      <a href="/pack-complet-promo/" style={`background: ${t.btn}; color: ${t.btnText}; padding: 10px 20px; border-radius: 6px; font-weight: 700; font-size: 14px; text-decoration: none; white-space: nowrap;`}>Offre Pack Complet</a>
    </div>
  </div>
</div>
)}

<style is:global>
@media (max-width: 768px) {
  #promo-banner,
  #promo-banner-dynamic {
    min-height: auto !important;
  }
  #promo-banner > div,
  #promo-banner-dynamic > div {
    flex-direction: column !important;
    gap: 10px !important;
    padding: 10px 16px !important;
    align-items: center !important;
  }
  #promo-banner > div > div:first-child,
  #promo-banner-dynamic > div > div:first-child {
    flex: none !important;
    align-items: center !important;
    text-align: center !important;
  }
  #promo-banner > div > div:first-child > span:first-child,
  #promo-banner-dynamic > div > div:first-child > span:first-child {
    font-size: 11px !important;
    letter-spacing: 1px !important;
  }
  #promo-banner > div > div:first-child > div,
  #promo-banner-dynamic > div > div:first-child > div {
    justify-content: center !important;
    gap: 8px !important;
  }
  #promo-banner > div > div:first-child > div > span:first-child,
  #promo-banner-dynamic > div > div:first-child > div > span:first-child,
  #promo-banner-discount {
    font-size: 22px !important;
  }
  #promo-banner > div > div:first-child > div > span:last-child,
  #promo-banner-dynamic > div > div:first-child > div > span:last-child {
    font-size: 16px !important;
  }
  #promo-countdown,
  #promo-banner-countdown {
    gap: 8px !important;
    padding: 5px 12px !important;
  }
  #promo-countdown > div:last-child,
  #promo-banner-countdown > div:last-child {
    gap: 8px !important;
  }
  #promo-countdown > div:last-child > div,
  #promo-banner-countdown > div:last-child > div {
    min-width: 32px !important;
  }
  #promo-countdown [data-unit],
  #promo-banner-countdown [data-unit] {
    font-size: 14px !important;
  }
}
</style>

<script is:inline>
  (function() {
    var banner = document.getElementById('promo-banner');
    if (!banner) return;

    // Padding-top pour compenser le banner fixed
    var h = banner.offsetHeight;
    document.body.style.paddingTop = h + 'px';
    window.addEventListener('resize', function() {
      document.body.style.paddingTop = banner.offsetHeight + 'px';
    });

    // Countdown + redirection deadline
    var deadlineStr = banner.getAttribute('data-deadline');
    var deadline = new Date(deadlineStr).getTime();
    var countdown = document.getElementById('promo-countdown');

    function update() {
      var now = Date.now();
      var d = deadline - now;
      function set(unit, val) {
        if (!countdown) return;
        var el = countdown.querySelector('[data-unit="' + unit + '"]');
        if (el) el.textContent = val.toString().padStart(2, '0');
      }
      if (d <= 0) {
        ['days','hours','minutes','seconds'].forEach(function(u){ set(u, 0); });
        window.location.href = '/fin-promo/';
        return;
      }
      set('days', Math.floor(d / 86400000));
      set('hours', Math.floor((d % 86400000) / 3600000));
      set('minutes', Math.floor((d % 3600000) / 60000));
      set('seconds', Math.floor((d % 60000) / 1000));
    }
    update();
    setInterval(update, 1000);
  })();
</script>
