<section class="space-y-4" id="funnel-stats-root">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex items-center gap-2">
      <h2 class="text-sm font-semibold text-slate-300">Performance du funnel</h2>
      <span id="fs-dev-badge" class="hidden rounded-md border border-amber-500/50 bg-amber-500/10 px-2 py-0.5 text-[11px] font-semibold tracking-wide text-amber-200">DEV BYPASS ACTIF</span>
    </div>
    <div class="flex flex-wrap items-center gap-2" role="group" aria-label="Période">
      <button type="button" class="fs-period-btn rounded-md border border-slate-700 px-3 py-1.5 text-xs text-slate-300 hover:border-slate-500" data-preset="today">Aujourd'hui</button>
      <button type="button" class="fs-period-btn rounded-md border border-slate-700 px-3 py-1.5 text-xs text-slate-300 hover:border-slate-500" data-preset="7d">7 derniers jours</button>
      <button type="button" class="fs-period-btn rounded-md border border-slate-700 px-3 py-1.5 text-xs text-slate-300 hover:border-slate-500" data-preset="30d">30 derniers jours</button>
      <button type="button" class="fs-period-btn rounded-md border border-slate-700 px-3 py-1.5 text-xs text-slate-300 hover:border-slate-500" data-preset="custom">Personnalisé</button>
      <div id="fs-custom-wrap" class="hidden flex items-center gap-1">
        <input id="fs-custom-start" type="date" class="rounded-md border border-slate-700 bg-slate-900 px-2 py-1 text-xs text-slate-200" />
        <span class="text-xs text-slate-500">→</span>
        <input id="fs-custom-end" type="date" class="rounded-md border border-slate-700 bg-slate-900 px-2 py-1 text-xs text-slate-200" />
        <button id="fs-custom-apply" type="button" class="rounded-md bg-blue-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-blue-500">Appliquer</button>
      </div>
    </div>
  </div>

  <p id="fs-loading" class="text-sm text-slate-400">Chargement des métriques Umami…</p>
  <p id="fs-error" class="hidden rounded-lg border border-red-900/60 bg-red-950/30 px-3 py-2 text-sm text-red-300"></p>

  <div id="fs-cards" class="hidden grid grid-cols-1 xl:grid-cols-2 gap-4"></div>

  <div id="fs-funnel" class="hidden rounded-xl border border-slate-800 bg-slate-900/40 p-4">
    <h3 class="text-sm font-semibold text-slate-200 mb-3">Visualisation funnel (visiteurs uniques)</h3>
    <div id="fs-funnel-lines" class="space-y-2"></div>
  </div>
</section>

<script>
  (function initFunnelStats() {
    const API_URL = '/api/umami-funnel-stats';
    const root = document.getElementById('funnel-stats-root');
    if (!root) return;

    const loadingEl = document.getElementById('fs-loading');
    const errorEl = document.getElementById('fs-error');
    const cardsEl = document.getElementById('fs-cards');
    const funnelEl = document.getElementById('fs-funnel');
    const funnelLinesEl = document.getElementById('fs-funnel-lines');
    const devBadgeEl = document.getElementById('fs-dev-badge');
    const customWrap = document.getElementById('fs-custom-wrap');
    const customStart = document.getElementById('fs-custom-start');
    const customEnd = document.getElementById('fs-custom-end');
    const customApply = document.getElementById('fs-custom-apply');
    const periodBtns = Array.from(document.querySelectorAll('.fs-period-btn'));

    let currentPreset = '7d';

    function fmtNumber(n) {
      return new Intl.NumberFormat('fr-FR').format(Number(n || 0));
    }

    function fmtPct(n) {
      return `${Number(n || 0).toFixed(1)}%`;
    }

    function fmtDuration(sec) {
      const s = Math.max(0, Math.floor(Number(sec || 0)));
      const m = Math.floor(s / 60);
      const rs = s % 60;
      return `${m}m ${String(rs).padStart(2, '0')}s`;
    }

    function dayBounds(ts) {
      const d = new Date(ts);
      const start = new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
      const end = start + 24 * 60 * 60 * 1000 - 1;
      return { startAt: start, endAt: end };
    }

    function rangeFromPreset(preset) {
      const now = Date.now();
      if (preset === 'today') return dayBounds(now);
      if (preset === '30d') return { startAt: now - 30 * 24 * 60 * 60 * 1000, endAt: now };
      return { startAt: now - 7 * 24 * 60 * 60 * 1000, endAt: now };
    }

    function setActivePreset(preset) {
      currentPreset = preset;
      periodBtns.forEach((btn) => {
        const active = btn.dataset.preset === preset;
        btn.classList.toggle('bg-slate-800', active);
        btn.classList.toggle('text-white', active);
      });
      customWrap.classList.toggle('hidden', preset !== 'custom');
    }

    function mapTopList(list) {
      if (!Array.isArray(list) || !list.length) return '<span class="text-slate-500">—</span>';
      return list
        .slice(0, 3)
        .map((x) => `<span class="rounded-md border border-slate-700 px-2 py-1 text-xs text-slate-300">${x.name} · ${fmtNumber(x.value)}</span>`)
        .join(' ');
    }

    function renderCards(pages) {
      cardsEl.innerHTML = pages
        .map((p) => {
          const devices = p.devices || { mobile: 0, desktop: 0, tablet: 0 };
          return `
            <article class="rounded-xl border border-slate-800 bg-slate-900/40 p-4">
              <div class="mb-3">
                <h3 class="text-sm font-semibold text-slate-100">${p.name}</h3>
                <p class="text-xs text-slate-500">${p.path}</p>
              </div>
              <div class="grid grid-cols-2 gap-2 text-xs mb-3">
                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-2"><p class="text-slate-500">Pageviews</p><p class="text-slate-200 font-semibold">${fmtNumber(p.pageviews)}</p></div>
                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-2"><p class="text-slate-500">Visiteurs</p><p class="text-slate-200 font-semibold">${fmtNumber(p.visitors)}</p></div>
                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-2"><p class="text-slate-500">Temps moyen</p><p class="text-slate-200 font-semibold">${fmtDuration(p.avgTime)}</p></div>
                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-2"><p class="text-slate-500">Bounce rate</p><p class="text-slate-200 font-semibold">${fmtPct(p.bounceRate)}</p></div>
              </div>
              <div class="space-y-2 text-xs">
                <div><p class="text-slate-500 mb-1">Top sources</p><div class="flex flex-wrap gap-1">${mapTopList(p.topSources)}</div></div>
                <div><p class="text-slate-500 mb-1">Top pays</p><div class="flex flex-wrap gap-1">${mapTopList(p.topCountries)}</div></div>
                <div><p class="text-slate-500 mb-1">Devices</p><p class="text-slate-300">Mobile ${fmtPct(devices.mobile)} · Desktop ${fmtPct(devices.desktop)} · Tablet ${fmtPct(devices.tablet)}</p></div>
              </div>
            </article>
          `;
        })
        .join('');
    }

    function renderFunnel(pages) {
      const baseline = Math.max(1, Number(pages?.[0]?.visitors || 0));
      funnelLinesEl.innerHTML = pages
        .map((p, idx) => {
          const visitors = Number(p.visitors || 0);
          const rate = idx === 0 ? 100 : Number(((visitors / baseline) * 100).toFixed(1));
          return `
            <div>
              <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-slate-300">${p.name}</span>
                <span class="text-slate-400">${fmtNumber(visitors)} · ${fmtPct(rate)}</span>
              </div>
              <div class="h-2 rounded-full bg-slate-800 overflow-hidden">
                <div class="h-full bg-blue-500" style="width:${Math.max(0, Math.min(100, rate))}%"></div>
              </div>
            </div>
          `;
        })
        .join('');
    }

    async function load(startAt, endAt) {
      loadingEl.classList.remove('hidden');
      errorEl.classList.add('hidden');
      cardsEl.classList.add('hidden');
      funnelEl.classList.add('hidden');
      try {
        const r = await fetch(`${API_URL}?startAt=${encodeURIComponent(startAt)}&endAt=${encodeURIComponent(endAt)}`, {
          credentials: 'same-origin',
        });
        const data = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(data.error || `HTTP ${r.status}`);
        const pages = Array.isArray(data.pages) ? data.pages : [];
        devBadgeEl?.classList.toggle('hidden', !data.mock);
        renderCards(pages);
        renderFunnel(pages);
        cardsEl.classList.remove('hidden');
        funnelEl.classList.remove('hidden');
      } catch (e) {
        errorEl.textContent = `Impossible de charger Umami : ${e.message || e}`;
        errorEl.classList.remove('hidden');
      } finally {
        loadingEl.classList.add('hidden');
      }
    }

    periodBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const preset = btn.dataset.preset;
        setActivePreset(preset);
        if (preset !== 'custom') {
          const r = rangeFromPreset(preset);
          load(r.startAt, r.endAt);
        }
      });
    });

    customApply.addEventListener('click', () => {
      const s = customStart.value ? new Date(`${customStart.value}T00:00:00`).getTime() : 0;
      const e = customEnd.value ? new Date(`${customEnd.value}T23:59:59`).getTime() : 0;
      if (!s || !e || s >= e) {
        errorEl.textContent = 'Période personnalisée invalide.';
        errorEl.classList.remove('hidden');
        return;
      }
      load(s, e);
    });

    setActivePreset('7d');
    const initial = rangeFromPreset('7d');
    load(initial.startAt, initial.endAt);
  })();
</script>

