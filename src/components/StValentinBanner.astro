---
// Banner St-Valentin avec countdown jusqu'au 15 février 2026 23h59
// S'affiche uniquement si ?preview=stvalentin est dans l'URL (ou si forceShow=true)
interface Props {
  forceShow?: boolean;
}
const { forceShow = false } = Astro.props;
const url = Astro.url;
const isStvalentin = forceShow || url.searchParams.get('preview') === 'stvalentin';
---

{isStvalentin && (
<div class="stvalentin-banner" id="stvalentin-banner" style="position: fixed; top: 0; left: 0; right: 0; width: 100%; background: linear-gradient(105deg, #8b0e3a 0%, #b31950 40%, #c6284a 100%); border-bottom: 1px solid rgba(255, 255, 255, 0.08); min-height: 64px; z-index: 99999; overflow: hidden;">
  <div class="stvalentin-banner-content" style="max-width: 1400px; margin: 0 auto; padding: 12px 24px; display: flex; align-items: center; gap: 24px;">
    <div class="stvalentin-banner-info" style="display: flex; flex-direction: column; gap: 12px; flex: 1; min-width: 0; align-items: flex-start; text-align: left;">
      <span style="font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255, 255, 255, 0.85); font-weight: 700;">❤️ St-Valentin</span>
      <div style="display: flex; flex-wrap: wrap; align-items: baseline; gap: 12px; color: #fff;">
        <span style="font-size: 36px; font-weight: 900; line-height: 1; color: transparent; background: linear-gradient(100deg, #ffffff 0%, #ffd5e0 70%); -webkit-background-clip: text; background-clip: text;">-50%</span>
        <span style="font-size: 32px; font-weight: 900; line-height: 1.05; color: rgba(255, 255, 255, 0.95);">sur toutes les formations</span>
      </div>
    </div>
    <div class="stvalentin-countdown" id="stvalentin-countdown" style="display: flex; align-items: center; gap: 12px; background: rgba(0, 0, 0, 0.15); border-radius: 999px; padding: 6px 16px; color: #fff;">
      <span style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.8px; color: rgba(255, 255, 255, 0.7);">Expire dans</span>
      <div style="display: flex; align-items: center; gap: 12px;">
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span class="stvalentin-count-value" data-unit="days" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">jours</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span class="stvalentin-count-value" data-unit="hours" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">heures</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span class="stvalentin-count-value" data-unit="minutes" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">min</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; min-width: 40px;">
          <span class="stvalentin-count-value" data-unit="seconds" style="font-weight: 700; font-size: 16px; color: #fff;">00</span>
          <span style="font-size: 10px; text-transform: uppercase; color: rgba(255, 255, 255, 0.6);">sec</span>
        </div>
      </div>
    </div>
    <div style="display: flex; align-items: center; gap: 12px;">
      <a href="/pack-complet-stvalentin/" style="background: #ffd166; color: #7c0a2a; padding: 10px 20px; border-radius: 6px; font-weight: 700; font-size: 14px; text-decoration: none; transition: all 0.2s ease; white-space: nowrap;">Offre Pack Complet</a>
    </div>
  </div>
</div>
)}

<script is:inline>
  (function() {
    // Ajouter padding-top au body pour compenser le banner fixed
    var banner = document.getElementById('stvalentin-banner');
    if (banner) {
      var h = banner.offsetHeight;
      document.body.style.paddingTop = h + 'px';
      window.addEventListener('resize', function() {
        document.body.style.paddingTop = banner.offsetHeight + 'px';
      });
    }
    
    var countdown = document.getElementById('stvalentin-countdown');
    if (!countdown) return;
    var deadline = new Date('2026-02-15T23:59:00').getTime();
    function update() {
      var now = Date.now();
      var d = deadline - now;
      function set(unit, val) {
        var el = countdown.querySelector('[data-unit="' + unit + '"]');
        if (el) el.textContent = val.toString().padStart(2, '0');
      }
      if (d <= 0) {
        ['days','hours','minutes','seconds'].forEach(function(u){ set(u, 0); });
        return;
      }
      set('days', Math.floor(d / 86400000));
      set('hours', Math.floor((d % 86400000) / 3600000));
      set('minutes', Math.floor((d % 3600000) / 60000));
      set('seconds', Math.floor((d % 60000) / 1000));
    }
    update();
    setInterval(update, 1000);
  })();
</script>
